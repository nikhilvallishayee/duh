+from __future__ import annotations
+
+from abc import ABC, abstractmethod
+from dataclasses import dataclass
+from typing import Protocol
+
+
+@dataclass(frozen=True)
+class Decision:
+    allowed: bool
+    retry_after_ms: int
+    remaining: int
+    reset_ts: int
+
+
+class Backend(Protocol):
+    def token_bucket_enforce(
+        self,
+        key: str,
+        *,
+        capacity: int,
+        refill_rate: float,
+        cost: int,
+    ) -> Decision:
+        ...
+
+    def sliding_window_enforce(
+        self,
+        key: str,
+        *,
+        limit: int,
+        period_ms: int,
+        cost: int,
+    ) -> Decision:
+        ...
+
+
+class RateLimiter(ABC):
+    @abstractmethod
+    def enforce(self, key: str, cost: int = 1) -> Decision:
+        ...
