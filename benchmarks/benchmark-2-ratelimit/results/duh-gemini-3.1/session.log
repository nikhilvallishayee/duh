  [33m> Write[0m(content="import time\nimport threading\nfrom typing import Dict, Tuple\nfrom ..types import Decision\nfrom .base import Backend\n\nclass InMemoryBackend(Backend):\n    def __init__(self):\n        self._lock = threading.Lock()\n        # Token bucket: key -> (tokens, last_refill_ts_ms)\n        self._tb_state: Dict[str, Tuple[float, int]] = {}\n        # Sliding window: key -> (current_window_start_ms, current_count, previous_count)\n        self._sw_state: Dict[str, Tuple[int, int, int]] = {}\n\n    def token_bucket(self, key: str, capacity: int, refill_rate: float, cost: int) -> Decision:\n        now_ms = int(time.time() * 1000)\n        \n        with self._lock:\n            tokens, last_refill_ts_ms = self._tb_state.get(key, (float(capacity), now_ms))\n            \n            # Refill tokens based on elapsed time\n            elapsed_ms = now_ms - last_refill_ts_ms\n            new_tokens = min(capacity, tokens + (elapsed_ms / 1000.0) * refill_rate)\n            \n            if new_tokens >= cost:\n                new_tokens -= cost\n                self._tb_state[key] = (new_tokens, now_ms)\n                allowed = True\n            else:\n                self._tb_state[key] = (new_tokens, now_ms)\n                allowed = False\n                \n            remaining = int(new_tokens)\n            # Calculate when we will have enough tokens for 'cost'\n            if not allowed:\n                tokens_needed = cost - new_tokens\n                retry_after_ms = int((tokens_needed / refill_rate) * 1000)\n            else:\n                retry_after_ms = 0\n                \n            # Time to full capacity\n            time_to_full_ms = int(((capacity - new_tokens) / refill_rate) * 1000) if refill_rate > 0 else 0\n            reset_ts = now_ms + time_to_full_ms\n\n            return Decision(\n                allowed=allowed,\n                retry_after_ms=retry_after_ms,\n                remaining=remaining,\n                reset_ts=reset_ts\n            )\n\n    def sliding_window(self, key: str, capacity: int, window_size_ms: int, cost: int) -> Decision:\n        now_ms = int(time.time() * 1000)\n        current_window_start_ms = (now_ms // window_size_ms) * window_size_ms\n        \n        with self._lock:\n            state = self._sw_state.get(key)\n            if state is None:\n                curr_start, curr_count, prev_count = current_window_start_ms, 0, 0\n            else:\n                curr_start, curr_count, prev_count = state\n                \n                # Roll windows\n                windows_passed = (current_window_start_ms - curr_start) // window_size_ms\n                if windows_passed == 1:\n                    prev_count = curr_count\n                    curr_count = 0\n                elif windows_passed > 1:\n                    prev_count = 0\n                    curr_count = 0\n                curr_start = current_window_start_ms\n            \n            # Calculate estimated count\n            elapsed_in_window_ms = now_ms - curr_start\n            overlap_weight = 1.0 - (elapsed_in_window_ms / window_size_ms)\n            estimated_count = int(prev_count * overlap_weight) + curr_count\n            \n            allowed = (estimated_count + cost) <= capacity\n            \n            if allowed:\n                curr_count += cost\n                self._sw_state[key] = (curr_start, curr_count, prev_count)\n            else:\n                # Do not increment if not allowed\n                self._sw_state[key] = (curr_start, curr_count, prev_count)\n                \n            remaining = max(0, capacity - estimated_count) if not allowed else max(0, capacity - (estimated_count + cost))\n            \n            if not allowed:\n                # We can retry when enough of the previous window drops off, \n                # or when the next window starts if prev_count is 0.\n                # To simplify, we can set retry_after_ms to the start of the next window.\n                # Actually, a more precise retry_after_ms could be calculated, but next window is safe.\n                retry_after_ms = window_size_ms - elapsed_in_window_ms\n            else:\n                retry_after_ms = 0\n                \n            reset_ts = curr_start + window_size_ms\n\n            return Decision(\n                allowed=allowed,\n                retry_after_ms=retry_after_ms,\n                remaining=remaining,\n                reset_ts=reset_ts\n            )\n", file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-gemini-3.1/ratelimit/backends/memory.py')
  [33m> Write[0m(content='import time\nimport math\nfrom typing import Any\nfrom ..types import Decision\nfrom .base import Backend\nimport redis\n\nTOKEN_BUCKET_LUA = """\nredis.replicate_commands()\nlocal key = KEYS[1]\nlocal capacity = tonumber(ARGV[1])\nlocal refill_rate = tonumber(ARGV[2])\nlocal cost = tonumber(ARGV[3])\n\nlocal time_arr = redis.call(\'TIME\')\nlocal now_ms = tonumber(time_arr[1]) * 1000 + math.floor(tonumber(time_arr[2]) / 1000)\n\nlocal state = redis.call(\'HGETALL\', key)\nlocal tokens = capacity\nlocal last_refill_ts = now_ms\n\nif #state > 0 then\n    for i = 1, #state, 2 do\n        if state[i] == \'tokens\' then\n            tokens = tonumber(state[i+1])\n        elseif state[i] == \'last_refill_ts\' then\n            last_refill_ts = tonumber(state[i+1])\n        end\n    end\nend\n\nlocal elapsed_ms = math.max(0, now_ms - last_refill_ts)\ntokens = math.min(capacity, tokens + (elapsed_ms / 1000.0) * refill_rate)\n\nlocal allowed = 0\nif tokens >= cost then\n    tokens = tokens - cost\n    allowed = 1\nend\n\nredis.call(\'HSET\', key, \'tokens\', tostring(tokens), \'last_refill_ts\', tostring(now_ms))\nlocal ttl = 1\nif refill_rate > 0 then\n    ttl = math.ceil((capacity / refill_rate))\nend\nredis.call(\'EXPIRE\', key, ttl)\n\nreturn {allowed, tostring(tokens), now_ms}\n"""\n\nSLIDING_WINDOW_LUA = """\nredis.replicate_commands()\nlocal key = KEYS[1]\nlocal capacity = tonumber(ARGV[1])\nlocal window_size_ms = tonumber(ARGV[2])\nlocal cost = tonumber(ARGV[3])\n\nlocal time_arr = redis.call(\'TIME\')\nlocal now_ms = tonumber(time_arr[1]) * 1000 + math.floor(tonumber(time_arr[2]) / 1000)\n\nlocal curr_start = math.floor(now_ms / window_size_ms) * window_size_ms\nlocal prev_count = 0\nlocal curr_count = 0\n\nlocal state = redis.call(\'HGETALL\', key)\nlocal stored_start = curr_start\n\nif #state > 0 then\n    for i = 1, #state, 2 do\n        if state[i] == \'curr_start\' then stored_start = tonumber(state[i+1])\n        elseif state[i] == \'curr_count\' then curr_count = tonumber(state[i+1])\n        elseif state[i] == \'prev_count\' then prev_count = tonumber(state[i+1])\n        end\n    end\n    \n    local windows_passed = math.floor((curr_start - stored_start) / window_size_ms)\n    if windows_passed == 1 then\n        prev_count = curr_count\n        curr_count = 0\n    elseif windows_passed > 1 then\n        prev_count = 0\n        curr_count = 0\n    end\nend\n\nlocal elapsed_in_window_ms = math.max(0, now_ms - curr_start)\nlocal overlap_weight = math.max(0, 1.0 - (elapsed_in_window_ms / window_size_ms))\nlocal estimated_count = math.floor(prev_count * overlap_weight) + curr_count\n\nlocal allowed = 0\nif estimated_count + cost <= capacity then\n    curr_count = curr_count + cost\n    allowed = 1\nend\n\nredis.call(\'HSET\', key, \'curr_start\', tostring(curr_start), \'curr_count\', tostring(curr_count), \'prev_count\', tostring(prev_count))\nredis.call(\'PEXPIRE\', key, window_size_ms * 2)\n\nreturn {allowed, estimated_count, curr_start, now_ms}\n"""\n\nclass RedisBackend(Backend):\n    def __init__(self, redis_client: redis.Redis):\n        self.redis = redis_client\n        self._tb_script = self.redis.register_script(TOKEN_BUCKET_LUA)\n        self._sw_script = self.redis.register_script(SLIDING_WINDOW_LUA)\n\n    def token_bucket(self, key: str, capacity: int, refill_rate: float, cost: int) -> Decision:\n        result = self._tb_script(keys=[key], args=[capacity, refill_rate, cost])\n        allowed_int, tokens_str, now_ms = result\n        allowed = bool(allowed_int)\n        tokens = float(tokens_str)\n        \n        if not allowed:\n            tokens_needed = cost - tokens\n            retry_after_ms = int((tokens_needed / refill_rate) * 1000) if refill_rate > 0 else 0\n        else:\n            retry_after_ms = 0\n            \n        remaining = int(tokens)\n        time_to_full_ms = int(((capacity - tokens) / refill_rate) * 1000) if refill_rate > 0 else 0\n        reset_ts = now_ms + time_to_full_ms\n\n        return Decision(\n            allowed=allowed,\n            retry_after_ms=retry_after_ms,\n            remaining=remaining,\n            reset_ts=reset_ts\n        )\n\n    def sliding_window(self, key: str, capacity: int, window_size_ms: int, cost: int) -> Decision:\n        result = self._sw_script(keys=[key], args=[capacity, window_size_ms, cost])\n        allowed_int, estimated_count, curr_start, now_ms = result\n        allowed = bool(allowed_int)\n        \n        remaining = max(0, capacity - estimated_count) if not allowed else max(0, capacity - (estimated_count + cost))\n        \n        if not allowed:\n            elapsed_in_window_ms = now_ms - curr_start\n            retry_after_ms = window_size_ms - elapsed_in_window_ms\n        else:\n            retry_after_ms = 0\n            \n        reset_ts = curr_start + window_size_ms\n\n        return Decision(\n            allowed=allowed,\n            retry_after_ms=retry_after_ms,\n            remaining=remaining,\n            reset_ts=reset_ts\n        )\n', file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-gemini-3.1/ratelimit/backends/redis.py')
