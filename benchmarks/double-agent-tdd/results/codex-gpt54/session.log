+
+
+class TestTddMain:
+    def test_tdd_routes_to_runner(self):
+        with patch("duh.cli.tdd.run_tdd", new_callable=AsyncMock, return_value=0) as mock_run:
+            with patch("duh.cli.main.asyncio") as mock_asyncio:
+                mock_asyncio.run = MagicMock(return_value=0)
+                code = main(
