@@ -0,0 +1,366 @@
+from __future__ import annotations
+
+import math
+import threading
+import time
+from collections import defaultdict, deque
+from dataclasses import dataclass
+from typing import Deque, Protocol
+
+import redis
+
+from ratelimit.models import Decision
+
+
+class Backend(Protocol):
+    def now_ms(self) -> int:
+        ...
+
+    def enforce_token_bucket(
+        self,
+        namespace: str,
+        key: str,
+        capacity: int,
+        refill_rate: float,
+        cost: int,
+    ) -> Decision:
+        ...
+
+    def enforce_sliding_window(
+        self,
+        namespace: str,
+        key: str,
+        capacity: int,
+        period_ms: int,
+        cost: int,
+    ) -> Decision:
+        ...
+
+
+@dataclass
+class _TokenBucketState:
+    tokens: float
+    last_refill_ms: int
+
+
+@dataclass
+class _LogEntry:
+    timestamp_ms: int
+    cost: int
+
+
+@dataclass
+class _SlidingWindowState:
+    entries: Deque[_LogEntry]
+    total_cost: int = 0
+
+
+class InMemoryBackend:
+    def __init__(self) -> None:
+        self._token_buckets: dict[tuple[str, str], _TokenBucketState] = {}
+        self._sliding_windows: dict[tuple[str, str], _SlidingWindowState] = {}
+        self._locks: defaultdict[tuple[str, str], threading.Lock] = defaultdict(threading.Lock)
+
+    def now_ms(self) -> int:
+        return int(time.time() * 1000)
+
+    def enforce_token_bucket(
+        self,
+        namespace: str,
+        key: str,
+        capacity: int,
+        refill_rate: float,
+        cost: int,
+    ) -> Decision:
+        cache_key = (namespace, key)
+        with self._locks[cache_key]:
+            now_ms = self.now_ms()
+            state = self._token_buckets.get(cache_key)
+            if state is None:
+                state = _TokenBucketState(tokens=float(capacity), last_refill_ms=now_ms)
+                self._token_buckets[cache_key] = state
+
+            elapsed_ms = max(0, now_ms - state.last_refill_ms)
+            refilled = state.tokens + (elapsed_ms / 1000.0) * refill_rate
+            available = min(float(capacity), refilled)
+
+            if cost <= capacity and available >= cost:
+                remaining_tokens = available - cost
+                state.tokens = remaining_tokens
+                state.last_refill_ms = now_ms
+                remaining = max(0, math.floor(remaining_tokens))
+                reset_ts = now_ms + _token_bucket_full_reset_ms(capacity, remaining_tokens, refill_rate)
+                return Decision(True, 0, remaining, reset_ts)
+
+            state.tokens = available
+            state.last_refill_ms = now_ms
+            remaining = max(0, math.floor(available))
+            retry_after_ms = _token_bucket_retry_after_ms(capacity, available, refill_rate, cost)
+            reset_ts = now_ms + _token_bucket_full_reset_ms(capacity, available, refill_rate)
+            return Decision(False, retry_after_ms, remaining, reset_ts)
+
+    def enforce_sliding_window(
+        self,
+        namespace: str,
+        key: str,
+        capacity: int,
+        period_ms: int,
+        cost: int,
+    ) -> Decision:
+        cache_key = (namespace, key)
+        with self._locks[cache_key]:
+            now_ms = self.now_ms()
+            state = self._sliding_windows.get(cache_key)
+            if state is None:
+                state = _SlidingWindowState(entries=deque())
+                self._sliding_windows[cache_key] = state
+
+            _prune_window(state, now_ms, period_ms)
+            if cost <= capacity and state.total_cost + cost <= capacity:
+                state.entries.append(_LogEntry(timestamp_ms=now_ms, cost=cost))
+                state.total_cost += cost
+                remaining = capacity - state.total_cost
+                return Decision(True, 0, remaining, now_ms + period_ms)
+
+            retry_after_ms = _sliding_window_retry_after_ms(state, now_ms, period_ms, cost, capacity)
+            remaining = max(0, capacity - state.total_cost)
+            reset_ts = _sliding_window_reset_ts(state, now_ms, period_ms)
+            return Decision(False, retry_after_ms, remaining, reset_ts)
+
+
+def _token_bucket_retry_after_ms(
+    capacity: int,
+    available: float,
+    refill_rate: float,
+    cost: int,
+) -> int:
+    if cost > capacity:
+        return 0
+    if available >= cost:
+        return 0
+    missing = cost - available
+    return max(0, math.ceil((missing / refill_rate) * 1000))
+
+
+def _token_bucket_full_reset_ms(capacity: int, available: float, refill_rate: float) -> int:
+    if available >= capacity:
+        return 0
+    missing = capacity - available
+    return max(0, math.ceil((missing / refill_rate) * 1000))
+
+
+def _prune_window(state: _SlidingWindowState, now_ms: int, period_ms: int) -> None:
+    cutoff = now_ms - period_ms
+    while state.entries and state.entries[0].timestamp_ms <= cutoff:
+        entry = state.entries.popleft()
+        state.total_cost -= entry.cost
+
+
+def _sliding_window_retry_after_ms(
+    state: _SlidingWindowState,
+    now_ms: int,
+    period_ms: int,
+    cost: int,
+    capacity: int,
+) -> int:
+    if cost > capacity:
+        return 0
+    excess = state.total_cost + cost - capacity
+    if excess <= 0:
+        return 0
+
+    released = 0
+    for entry in state.entries:
+        released += entry.cost
+        if released >= excess:
+            return max(0, entry.timestamp_ms + period_ms - now_ms)
+    return 0
+
+
+def _sliding_window_reset_ts(state: _SlidingWindowState, now_ms: int, period_ms: int) -> int:
+    if not state.entries:
+        return now_ms
+    newest = state.entries[-1].timestamp_ms
+    return newest + period_ms
+
+
+_TOKEN_BUCKET_SCRIPT = """
+local state_key = KEYS[1]
+local capacity = tonumber(ARGV[1])
+local refill_rate = tonumber(ARGV[2])
+local cost = tonumber(ARGV[3])
+local ttl_ms = tonumber(ARGV[4])
+
+local server_time = redis.call('TIME')
+local now_ms = tonumber(server_time[1]) * 1000 + math.floor(tonumber(server_time[2]) / 1000)
+
+local tokens = tonumber(redis.call('HGET', state_key, 'tokens'))
+local last_refill_ms = tonumber(redis.call('HGET', state_key, 'last_refill_ms'))
+
+if not tokens or not last_refill_ms then
+  tokens = capacity
+  last_refill_ms = now_ms
+end
+
+local elapsed_ms = now_ms - last_refill_ms
+if elapsed_ms < 0 then
+  elapsed_ms = 0
+end
+
+local available = tokens + (elapsed_ms / 1000.0) * refill_rate
+if available > capacity then
+  available = capacity
+end
+
+local allowed = 0
+local retry_after_ms = 0
+if cost <= capacity and available >= cost then
+  allowed = 1
+  available = available - cost
+elseif cost <= capacity then
+  retry_after_ms = math.ceil(((cost - available) / refill_rate) * 1000)
+end
+
+redis.call('HSET', state_key, 'tokens', available, 'last_refill_ms', now_ms)
+redis.call('PEXPIRE', state_key, ttl_ms)
+
+local remaining = math.floor(available)
+if remaining < 0 then
+  remaining = 0
+end
+
+local reset_after_ms = 0
+if available < capacity then
+  reset_after_ms = math.ceil(((capacity - available) / refill_rate) * 1000)
+end
+
+return {allowed, retry_after_ms, remaining, now_ms + reset_after_ms}
+"""
+
+
+_SLIDING_WINDOW_SCRIPT = """
+local window_key = KEYS[1]
+local seq_key = KEYS[2]
+local capacity = tonumber(ARGV[1])
+local period_ms = tonumber(ARGV[2])
+local cost = tonumber(ARGV[3])
+local ttl_ms = tonumber(ARGV[4])
+
+local server_time = redis.call('TIME')
+local now_ms = tonumber(server_time[1]) * 1000 + math.floor(tonumber(server_time[2]) / 1000)
+
+local cutoff = now_ms - period_ms
+redis.call('ZREMRANGEBYSCORE', window_key, '-inf', cutoff)
+local current_count = redis.call('ZCARD', window_key)
+
+local allowed = 0
+local retry_after_ms = 0
+local remaining = capacity - current_count
+if remaining < 0 then
+  remaining = 0
+end
+local reset_ts = now_ms
+local newest = redis.call('ZREVRANGE', window_key, 0, 0, 'WITHSCORES')
+if #newest >= 2 then
+  reset_ts = tonumber(newest[2]) + period_ms
+end
+
+if cost <= capacity and current_count + cost <= capacity then
+  allowed = 1
+  local seq = redis.call('INCR', seq_key)
+  local members = {}
+  for i = 1, cost do
+    members[(i - 1) * 2 + 1] = now_ms
+    members[(i - 1) * 2 + 2] = tostring(now_ms) .. ':' .. tostring(seq) .. ':' .. tostring(i)
+  end
+  if #members > 0 then
+    redis.call('ZADD', window_key, unpack(members))
+  end
+  redis.call('PEXPIRE', window_key, ttl_ms)
+  redis.call('PEXPIRE', seq_key, ttl_ms)
+  remaining = capacity - current_count - cost
+  reset_ts = now_ms + period_ms
+else
+  if cost <= capacity then
+    local needed = current_count + cost - capacity
+    local oldest = redis.call('ZRANGE', window_key, 0, needed - 1, 'WITHSCORES')
+    if #oldest >= 2 then
+      retry_after_ms = tonumber(oldest[#oldest]) + period_ms - now_ms
+      if retry_after_ms < 0 then
+        retry_after_ms = 0
+      end
+    end
+  end
+  redis.call('PEXPIRE', window_key, ttl_ms)
+  redis.call('PEXPIRE', seq_key, ttl_ms)
+end
+
+return {allowed, retry_after_ms, remaining, reset_ts}
+"""
+
+
+class RedisBackend:
+    def __init__(self, client: redis.Redis, prefix: str = "ratelimit") -> None:
+        self._client = client
+        self._prefix = prefix
+        self._token_bucket_script = client.register_script(_TOKEN_BUCKET_SCRIPT)
+        self._sliding_window_script = client.register_script(_SLIDING_WINDOW_SCRIPT)
+
+    def now_ms(self) -> int:
+        seconds, micros = self._client.time()
+        return int(seconds) * 1000 + int(micros) // 1000
+
+    def enforce_token_bucket(
+        self,
+        namespace: str,
+        key: str,
+        capacity: int,
+        refill_rate: float,
+        cost: int,
+    ) -> Decision:
+        ttl_ms = max(1000, _token_bucket_ttl_ms(capacity, refill_rate))
+        result = self._token_bucket_script(
+            keys=[self._token_bucket_key(namespace, key)],
+            args=[capacity, refill_rate, cost, ttl_ms],
+        )
+        return _coerce_decision(result)
+
+    def enforce_sliding_window(
+        self,
+        namespace: str,
+        key: str,
+        capacity: int,
+        period_ms: int,
+        cost: int,
+    ) -> Decision:
+        ttl_ms = max(1000, period_ms * 2)
+        result = self._sliding_window_script(
+            keys=[
+                self._sliding_window_key(namespace, key),
+                self._sliding_window_seq_key(namespace, key),
+            ],
+            args=[capacity, period_ms, cost, ttl_ms],
+        )
+        return _coerce_decision(result)
+
+    def _token_bucket_key(self, namespace: str, key: str) -> str:
+        return f"{self._prefix}:tb:{namespace}:{key}"
+
+    def _sliding_window_key(self, namespace: str, key: str) -> str:
+        return f"{self._prefix}:sw:{namespace}:{key}"
+
+    def _sliding_window_seq_key(self, namespace: str, key: str) -> str:
+        return f"{self._prefix}:swseq:{namespace}:{key}"
+
+
+def _token_bucket_ttl_ms(capacity: int, refill_rate: float) -> int:
+    return math.ceil((capacity / refill_rate) * 1000) * 2
+
+
+def _coerce_decision(result: object) -> Decision:
+    if isinstance(result, tuple):
+        values = list(result)
+    else:
+        values = list(result)
+    allowed, retry_after_ms, remaining, reset_ts = (int(v) for v in values)
+    return Decision(bool(allowed), retry_after_ms, remaining, reset_ts)
