I have the pattern. Let me write the tdd CLI subcommand:  [33m> Write[0m(file_path='/Users/nomind/Code/Tengu/tengu-cockpit/benchmarks/double-agent-tdd/worktrees/duh-opus/duh/cli/tdd.py', content='"""``duh tdd`` subcommand — one-shot double-agent TDD run (ADR-076).\n\nBuilds a Driver engine and a Navigator engine from the current provider\n+ tool set, then drives them through the six-phase red-green-refactor\nflow defined in :mod:`duh.kernel.tdd_mode`.  Designed for CI use: no\ninteractive approval, prints a concise phase-by-phase log to stdout,\nexits non-zero if any gate fails.\n\nFor the interactive REPL flow, see the ``/tdd`` slash command in\n``duh.cli.slash_commands``.\n"""\n\nfrom __future__ import annotations\n\nimport argparse\nimport logging\nimport os\nimport shlex\nimport sys\nfrom typing import Any\n\nfrom duh.adapters.approvers import AutoApprover\nfrom duh.adapters.file_store import FileStore\nfrom duh.adapters.native_executor import NativeExecutor\nfrom duh.adapters.simple_compactor import SimpleCompactor\nfrom duh.agents import AgentDef\nfrom duh.cli import exit_codes\nfrom duh.kernel.deps import Deps\nfrom duh.kernel.engine import Engine, EngineConfig\nfrom duh.kernel.tdd_mode import DEFAULT_TEST_COMMAND, TddMode, TddState\nfrom duh.providers.registry import build_model_backend, resolve_provider_name\nfrom duh.tools.registry import get_all_tools\n\nlogger = logging.getLogger("duh")\n\n\ndef _resolve_provider_and_model(args: argparse.Namespace) -> tuple[str, str, Any]:\n    """Shared provider-resolution plumbing for the tdd subcommand.\n\n    Returns ``(provider_name, model, call_model)`` on success.  Writes an\n    error to stderr and raises :class:`SystemExit` on failure.\n    """\n\n    def _check_ollama() -> bool:\n        try:\n            import httpx\n            r = httpx.get("http://localhost:11434/api/tags", timeout=2)\n            return r.status_code == 200\n        except Exception:\n            return False\n\n    provider_name = resolve_provider_name(\n        explicit_provider=getattr(args, "provider", None),\n        model=getattr(args, "model", None),\n        check_ollama=_check_ollama,\n    )\n    if not provider_name:\n        sys.stderr.write(\n            "Error: No provider available for `duh tdd`.\\n"\n            "  Set ANTHROPIC_API_KEY, OPENAI_API_KEY, or DUH_STUB_PROVIDER=1.\\n"\n        )\n        raise SystemExit(exit_codes.PROVIDER_ERROR)\n\n    backend = build_model_backend(provider_name, getattr(args, "model", None))\n    if not backend.ok:\n        sys.stderr.write(f"Error: {backend.error}\\n")\n        raise SystemExit(exit_codes.PROVIDER_ERROR)\n    return provider_name, backend.model, backend.call_model\n\n\ndef _build_engine(\n    *,\n    agent_type: str,\n    model: str,\n    call_model: Any,\n    tools: list[Any],\n    cwd: str,\n    max_turns: int,\n) -> Engine:\n    """Build a single Engine with the given agent overlay, sharing the\n    caller\'s tool set + approver.  Driver and Navigator differ only in\n    the system prompt (``agent_type``) and — optionally — the model.\n    """\n    agent_def = AgentDef.from_type(agent_type)\n    executor = NativeExecutor(tools=tools, cwd=cwd)\n    compactor = SimpleCompactor()\n    store = FileStore(cwd=cwd)\n    approver = AutoApprover()  # non-interactive — see ADR-076\n\n    deps = Deps(\n        call_model=call_model,\n        run_tool=executor.run,\n        approve=approver.check,\n        compact=compactor.compact,\n    )\n    config = EngineConfig(\n        model=model,\n        system_prompt=agent_def.system_prompt,\n        tools=tools,\n        max_turns=max_turns,\n        cwd=cwd,\n    )\n    # Same lambda as batch.py — let tools ask which model is running.\n    executor.get_current_model = lambda: config.model\n    return Engine(deps=deps, config=config, session_store=store)\n\n\ndef _format_gate(event: dict[str, Any]) -> str:\n    """Render a ``tdd_gate`` event as a single readable line."""\n    phase = event.get("phase", "?")\n    passed = event.get("passed", False)\n    exit_code = event.get("exit_code", "?")\n    marker = "✓" if passed else "✗"\n    return f"  [{phase} gate {marker}] exit={exit_code} gate_passed={passed}"\n\n\nasync def run_tdd(args: argparse.Namespace) -> int:\n    """Drive the full six-phase double-agent TDD flow end-to-end.\n\n    Returns 0 on success (``TddState.DONE``), non-zero on any gate\n    failure or phase that didn\'t advance.\n    """\n    debug = getattr(args, "debug", False)\n    if debug:\n        logging.basicConfig(\n            level=logging.DEBUG, stream=sys.stderr,\n            format="[%(levelname)s] %(name)s: %(message)s",\n        )\n\n    provider_name, model, call_model = _resolve_provider_and_model(args)\n    driver_model = getattr(args, "driver_model", None) or model\n    navigator_model = getattr(args, "navigator_model", None) or model\n\n    cwd = os.getcwd()\n    tools = list(get_all_tools())\n    max_turns = getattr(args, "max_turns", 50) or 50\n\n    # Two Engines, same provider, distinct system prompts (ADR-076).\n    driver = _build_engine(\n        agent_type="coder",\n        model=driver_model,\n        call_model=call_model,\n        tools=tools,\n        cwd=cwd,\n        max_turns=max_turns,\n    )\n    navigator = _build_engine(\n        agent_type="reviewer",\n        model=navigator_model,\n        call_model=call_model,\n        tools=tools,\n        cwd=cwd,\n        max_turns=max_turns,\n    )\n\n    # Parse --test\n    test_cmd_str = getattr(args, "test", None)\n    if test_cmd_str:\n        test_command = shlex.split(test_cmd_str)\n    else:\n        test_command = list(DEFAULT_TEST_COMMAND)\n\n    tdd = TddMode(\n        driver=driver,\n        navigator=navigator,\n        test_command=test_command,\n        cwd=cwd,\n    )\n\n    sys.stdout.write(\n        f"duh tdd — provider={provider_name} "\n        f"driver={driver_model} navigator={navigator_model}\\n"\n        f"  test command: {\' \'.join(test_command)}\\n"\n        f"  feature     : {args.feature}\\n\\n"\n    )\n    sys.stdout.flush()\n\n    async for event in tdd.run_all(args.feature):\n        etype = event.get("type", "")\n        if etype == "tdd_phase":\n            phase = event.get("phase", "?")\n            actor = event.get("actor", "?")\n            sys.stdout.write(f"== {phase} ({actor}) ==\\n")\n            sys.stdout.flush()\n        elif etype == "tdd_gate":\n            sys.stdout.write(_format_gate(event) + "\\n")\n            if not event.get("passed", False):\n                # Surface stdout/stderr so the user can see why.\n                err_tail = (event.get("stdout", "") + event.get("stderr", ""))[-500:]\n                if err_tail:\n                    sys.stdout.write("    " + err_tail.replace("\\n", "\\n    ") + "\\n")\n            sys.stdout.flush()\n        elif etype == "text_delta" and debug:\n            sys.stderr.write(event.get("text", ""))\n            sys.stderr.flush()\n        elif etype == "error":\n            sys.stderr.write(f"  ! error: {event.get(\'error\', \'unknown\')}\\n")\n\n    sys.stdout.write("\\n" + tdd.format_status() + "\\n")\n\n    if tdd.state == TddState.DONE:\n        return exit_codes.SUCCESS\n    # Spec revised but never re-approved, or a gate failed — signal\n    # non-zero but preserve the session state for the user to inspect.\n    sys.stderr.write(\n        f"\\nTDD run did not reach DONE (final state: {tdd.state.name}, "\n        f"spec revisions: {tdd.spec_revisions})\\n"\n    )\n    return exit_codes.ERROR\n')
