+
+
+class TestRefactorAppliedBeforeValidate:
+    async def test_apply_refactor_requires_nonempty_suggestion(self):
+        agents, tests = _happy_path_scripts()
+        # Empty refactor suggestion → apply_refactor should raise.
+        agents[3] = ("reviewer", "   \n   ")
+        flow, _, _ = _make_flow(agent_script=agents, test_script=tests)
+
+        await flow.draft_spec()
+        await flow.write_failing_test()
+        await flow.write_implementation()
+        await flow.propose_refactor()
+
+        assert flow.refactor_suggestion == ""
+        with pytest.raises(TDDError) as exc_info:
+            await flow.apply_refactor()
+        assert exc_info.value.reason == "no_refactor_suggested"
+
+    async def test_suggestion_is_threaded_into_apply_prompt(self):
+        """The Driver's refactor-apply prompt must contain the suggestion.
+
+        This guarantees the suggestion cannot be silently dropped between
+        phase 4 and phase 5.
+        """
+        agents, tests = _happy_path_scripts()
+        flow, agent_spy, _ = _make_flow(agent_script=agents, test_script=tests)
+
+        await flow.draft_spec()
+        await flow.write_failing_test()
+        await flow.write_implementation()
+        await flow.propose_refactor()
+        await flow.apply_refactor()
+
+        apply_call = agent_spy.calls[4]  # 0=spec, 1=red, 2=green, 3=suggest, 4=apply
+        assert apply_call["agent_type"] == "coder"
+        assert "inline helper variable" in apply_call["prompt"]
+
+    async def test_validate_passes_suggestion_into_navigator_prompt(self):
+        agents, tests = _happy_path_scripts()
+        flow, agent_spy, _ = _make_flow(agent_script=agents, test_script=tests)
+
+        await flow.draft_spec()
+        await flow.write_failing_test()
+        await flow.write_implementation()
+        await flow.propose_refactor()
+        await flow.apply_refactor()
+        await flow.validate()
+
+        validate_call = agent_spy.calls[5]
+        assert validate_call["agent_type"] == "reviewer"
+        assert "inline helper variable" in validate_call["prompt"]
+
+    async def test_validate_regression_raises(self):
+        agents, tests = _happy_path_scripts()
+        # Flip the post-refactor test run to fail.
+        tests[2] = TestRunResult(
+            passed=False, exit_code=1,
+            output="E   assert False\nFAILED tests/test_widget.py::test_sum",
+            assertion_failure="assert False",
+        )
+        flow, _, _ = _make_flow(agent_script=agents, test_script=tests)
+        await flow.draft_spec()
+        await flow.write_failing_test()
+        await flow.write_implementation()
+        await flow.propose_refactor()
+        await flow.apply_refactor()
+        with pytest.raises(TDDError) as exc_info:
+            await flow.validate()
+        assert exc_info.value.reason == "validate_regressed"
