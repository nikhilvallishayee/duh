+from hypothesis import given, strategies as st
+from ratelimit import InMemoryBackend, SlidingWindowLimiter
+import time
+from unittest.mock import patch
+
+@given(st.lists(st.floats(min_value=0.0, max_value=5.0), max_size=50))
+def test_sliding_window_invariant(delays):
+    backend = InMemoryBackend()
+    capacity = 10
+    window_size_ms = 1000
+    limiter = SlidingWindowLimiter(backend, capacity=capacity, window_size_ms=window_size_ms)
+    
+    key = "hyp_sw"
+    current_time = 1000000.0 
+    
+    granted_times = []
+    
+    for delay in delays:
+        current_time += delay
+        
+        with patch('time.time', return_value=current_time):
+            decision = limiter.enforce(key)
+            if decision.allowed:
+                granted_times.append(current_time)
+                
+    # Check invariant: no more than `capacity` requests granted in any window of length period.
+    period_s = window_size_ms / 1000.0
+    for i in range(len(granted_times)):
+        for j in range(i+1, len(granted_times)):
+            t1 = granted_times[i]
+            t2 = granted_times[j]
+            if (t2 - t1) <= period_s:
+                count = j - i + 1
+                assert count <= capacity
+
+@given(st.lists(st.floats(min_value=0.0, max_value=10.0), max_size=100))
+def test_token_bucket_invariant(delays):
+    backend = InMemoryBackend()
+    capacity = 5
+    refill_rate = 1.0 # 1 token per second
+    limiter = InMemoryBackend()
+    
+    key = "hyp_tb"
+    current_time = 1000000.0
+    
+    granted_times = []
+    
+    for delay in delays:
+        current_time += delay
+        with patch('time.time', return_value=current_time):
+            decision = backend.token_bucket(key, capacity, refill_rate, 1)
+            if decision.allowed:
+                granted_times.append(current_time)
+                
+    # Invariant: For any time interval of length T, granted <= capacity + T * refill_rate
+    for i in range(len(granted_times)):
+        for j in range(i+1, len(granted_times)):
+            t1 = granted_times[i]
+            t2 = granted_times[j]
+            T = t2 - t1
+            count = j - i + 1
+            max_allowed = capacity + int(T * refill_rate) + 1 # +1 for margin due to discrete increments
+            assert count <= max_allowed + 1
