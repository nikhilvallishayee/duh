import ast, inspect, importlib, dataclasses
from pathlib import Path

MODULES=[*(f'duh.kernel.{p.stem}' for p in sorted(Path('duh/kernel').glob('*.py'))),*(f'duh.ports.{p.stem}' for p in sorted(Path('duh/ports').glob('*.py')))]
MODULES=[m for m in MODULES if not m.endswith('.__init__')]

def short(text:str)->str:
    if not text:
        return 'No docstring.'
    line=text.strip().splitlines()[0].strip().rstrip('.')
    return line + '.'

def fmt_args(args: ast.arguments) -> str:
    parts=[]; posonly=args.posonlyargs; regular=args.args; defaults=args.defaults
    total=len(posonly)+len(regular); default_start=total-len(defaults); all_args=posonly+regular
    for i,a in enumerate(all_args):
        s=a.arg
        if a.annotation: s += ': ' + ast.unparse(a.annotation)
        if i >= default_start: s += ' = ' + ast.unparse(defaults[i-default_start])
        parts.append(s)
        if posonly and i==len(posonly)-1: parts.append('/')
    if args.vararg:
        s='*'+args.vararg.arg
        if args.vararg.annotation: s += ': ' + ast.unparse(args.vararg.annotation)
        parts.append(s)
    elif args.kwonlyargs:
        parts.append('*')
    for a,d in zip(args.kwonlyargs,args.kw_defaults):
        s=a.arg
        if a.annotation: s += ': ' + ast.unparse(a.annotation)
        if d is not None: s += ' = ' + ast.unparse(d)
        parts.append(s)
    if args.kwarg:
        s='**'+args.kwarg.arg
        if args.kwarg.annotation: s += ': ' + ast.unparse(args.kwarg.annotation)
        parts.append(s)
    return ', '.join(parts)

