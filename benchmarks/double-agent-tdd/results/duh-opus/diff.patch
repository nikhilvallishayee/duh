+    async def test_gate_result_gate_passed_inversion(self):
+        """Unit test for the RED-is-inverted property on GateResult."""
+        red_fail = GateResult(phase="RED", exit_code=1, stdout="", stderr="")
+        red_pass = GateResult(phase="RED", exit_code=0, stdout="", stderr="")
+        green_fail = GateResult(phase="GREEN", exit_code=1, stdout="", stderr="")
+        green_pass = GateResult(phase="GREEN", exit_code=0, stdout="", stderr="")
+
+        # RED: failing test is gate-pass; passing test is gate-fail
+        assert red_fail.gate_passed is True
+        assert red_pass.gate_passed is False
+        # GREEN / VALIDATE: passing test is gate-pass
+        assert green_fail.gate_passed is False
+        assert green_pass.gate_passed is True
