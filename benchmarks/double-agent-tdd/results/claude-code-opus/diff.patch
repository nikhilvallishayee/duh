+"""Tests for the double-agent TDD flow (ADR-076).
+
+Covers the six-phase contract:
+
+* phase order is enforced (each phase must follow its predecessor),
+* RED surfaces the assertion failure distinctly from GREEN,
+* Navigator's refactor suggestion is applied before validation,
+* end-to-end flow completes against a stub provider,
+* spec-revision retry loop fires when the RED test passes,
+* GREEN failure and VALIDATE regression raise TDDError.
+"""
+
+from __future__ import annotations
+
+import json
+from dataclasses import dataclass, field
+from typing import Any
+
+import pytest
+
+from duh.agents import AgentResult
+from duh.kernel.double_agent_tdd import (
+    AgentRunnerFn,
+    Role,
+    TDDArtifact,
+    TDDConfig,
+    TDDError,
+    TDDFlow,
+    TDDPhase,
+    TestRunResult,
+    _extract_assertion_failure,
+    format_event,
+    run_flow,
+)
+
+
+# ---------------------------------------------------------------------------
+# Stub infrastructure — a scripted agent + scripted test runner
+# ---------------------------------------------------------------------------
+
+
+class _ScriptedAgent:
+    """Replay-based fake for ``run_agent``.
+
+    The flow calls agents six times (plus possibly revise + retry). We
+    feed it a list of ``(expected_agent_type, output)`` tuples so tests
+    can both stub outputs and assert the right role was invoked in the
+    right order.
+    """
+
+    def __init__(self, script: list[tuple[str, str]]):
+        self._script = list(script)
+        self.calls: list[dict[str, Any]] = []
+
+    async def __call__(
+        self,
+        *,
+        prompt: str,
+        agent_type: str,
+        model: str,
+        parent_model: str,
+        deps: Any,
+        tools: list[Any] | None,
+        cwd: str,
+        max_turns: int,
+    ) -> AgentResult:
+        if not self._script:
+            raise AssertionError(
+                f"scripted agent exhausted; unexpected call agent_type={agent_type}"
+            )
+        expected_type, output = self._script.pop(0)
+        self.calls.append(
+            {"agent_type": agent_type, "prompt": prompt, "model": model}
+        )
+        if expected_type and agent_type != expected_type:
+            raise AssertionError(
+                f"expected agent_type={expected_type} but got {agent_type}"
+            )
+        return AgentResult(agent_type=agent_type, result_text=output, turns_used=1)
+
+
+class _ScriptedRunner:
+    """Replay-based fake for the test runner."""
+
+    def __init__(self, script: list[TestRunResult]):
+        self._script = list(script)
+        self.calls: list[str] = []
+
+    async def __call__(self, cmd: str, cwd: str, timeout: float) -> TestRunResult:
+        self.calls.append(cmd)
+        if not self._script:
+            raise AssertionError(
+                f"scripted test runner exhausted (cmd={cmd})"
+            )
+        return self._script.pop(0)
+
+
+def _make_flow(
+    *,
+    agent_script: list[tuple[str, str]],
+    test_script: list[TestRunResult],
+    feature: str = "widget sum endpoint",
+    config: TDDConfig | None = None,
+) -> tuple[TDDFlow, _ScriptedAgent, _ScriptedRunner]:
+    agent = _ScriptedAgent(agent_script)
+    runner = _ScriptedRunner(test_script)
+    flow = TDDFlow(
+        feature=feature,
+        deps=object(),  # opaque — not used by stubs
+        tools=[],
+        parent_model="stub-model",
+        config=config or TDDConfig(cwd=".", test_cmd="echo fake-tests"),
+        test_runner=runner,
+        agent_runner=agent,
+    )
+    return flow, agent, runner
+
+
+def _happy_path_scripts() -> tuple[list[tuple[str, str]], list[TestRunResult]]:
+    """Canonical six-phase script: Navigator/Driver/.../Navigator."""
+    agent_script = [
+        ("reviewer", "1. endpoint returns 200\n2. body = {'sum': 6}"),         # SPEC
+        ("coder",    "wrote tests/test_widget.py with failing test"),           # RED
+        ("coder",    "wrote duh/widgets.py::sum_widgets"),                      # GREEN
+        ("reviewer", "File: duh/widgets.py\nChange: inline helper variable\n"
+                     "Why: no call sites touch it"),                            # REFACTOR-SUGGEST
+        ("coder",    "applied: removed temp variable `total`"),                 # REFACTOR-APPLY
+        ("reviewer", "PASS — tests green, refactor landed cleanly."),           # VALIDATE
+    ]
+    test_script = [
+        TestRunResult(
+            passed=False, exit_code=1,
+            output="E   assert 0 == 6\nFAILED tests/test_widget.py::test_sum",
+            assertion_failure="",  # will be extracted
+        ),
+        TestRunResult(passed=True, exit_code=0, output="2 passed in 0.01s"),     # GREEN
+        TestRunResult(passed=True, exit_code=0, output="2 passed in 0.01s"),     # VALIDATE
+    ]
+    # Pre-populate assertion_failure so has_assertion_failure is True.
+    test_script[0].assertion_failure = "assert 0 == 6"
+    return agent_script, test_script
+
+
+# ---------------------------------------------------------------------------
+# Phase transitions happen in order
+# ---------------------------------------------------------------------------
+
+
+class TestPhaseOrder:
+    async def test_initial_phase_is_idle(self):
+        flow, _, _ = _make_flow(agent_script=[], test_script=[])
+        assert flow.phase is TDDPhase.IDLE
+
+    async def test_cannot_skip_spec(self):
+        """Calling any phase out of order raises TDDError(out_of_order)."""
+        flow, _, _ = _make_flow(agent_script=[], test_script=[])
+        with pytest.raises(TDDError) as exc_info:
+            await flow.write_failing_test()
+        assert exc_info.value.reason == "out_of_order"
+
+    async def test_cannot_green_before_red(self):
+        agents = [("reviewer", "1. step")]
+        flow, _, _ = _make_flow(agent_script=agents, test_script=[])
+        await flow.draft_spec()
+        with pytest.raises(TDDError) as exc_info:
+            await flow.write_implementation()
+        assert exc_info.value.reason == "out_of_order"
+
+    async def test_cannot_refactor_before_green(self):
+        agents, tests = _happy_path_scripts()
+        # trim scripts to cover SPEC + RED only
+        flow, _, _ = _make_flow(agent_script=agents[:2], test_script=tests[:1])
+        await flow.draft_spec()
+        await flow.write_failing_test()
+        with pytest.raises(TDDError) as exc_info:
+            await flow.propose_refactor()
+        assert exc_info.value.reason == "out_of_order"
+
+    async def test_all_phases_complete_in_order(self):
+        agents, tests = _happy_path_scripts()
+        flow, _, _ = _make_flow(agent_script=agents, test_script=tests)
+
+        await flow.draft_spec()
+        assert flow.phase is TDDPhase.NAVIGATOR_SPEC
+
+        await flow.write_failing_test()
+        assert flow.phase is TDDPhase.DRIVER_RED
+
+        await flow.write_implementation()
+        assert flow.phase is TDDPhase.DRIVER_GREEN
+
+        await flow.propose_refactor()
+        assert flow.phase is TDDPhase.NAVIGATOR_REFACTOR
+
+        await flow.apply_refactor()
+        assert flow.phase is TDDPhase.DRIVER_REFACTOR
+
+        await flow.validate()
+        assert flow.phase is TDDPhase.DONE
+
+    async def test_history_records_phases_in_order(self):
+        agents, tests = _happy_path_scripts()
+        flow, _, _ = _make_flow(agent_script=agents, test_script=tests)
+
+        for step in (
+            flow.draft_spec,
+            flow.write_failing_test,
+            flow.write_implementation,
+            flow.propose_refactor,
+            flow.apply_refactor,
+            flow.validate,
+        ):
+            await step()
+
+        role_phases = [
+            (a.role, a.phase) for a in flow.history if a.role is not None
+        ]
+        assert role_phases == [
+            (Role.NAVIGATOR, TDDPhase.NAVIGATOR_SPEC),
+            (Role.DRIVER,    TDDPhase.DRIVER_RED),
+            (Role.DRIVER,    TDDPhase.DRIVER_GREEN),
+            (Role.NAVIGATOR, TDDPhase.NAVIGATOR_REFACTOR),
+            (Role.DRIVER,    TDDPhase.DRIVER_REFACTOR),
+            (Role.NAVIGATOR, TDDPhase.NAVIGATOR_VALIDATE),
+        ]
+
+
+# ---------------------------------------------------------------------------
+# RED surfaces assertion failure distinctly from GREEN
+# ---------------------------------------------------------------------------
+
+
+class TestRedVsGreen:
+    async def test_red_records_assertion_failure_and_failed_run(self):
+        agents, tests = _happy_path_scripts()
+        flow, _, _ = _make_flow(agent_script=agents, test_script=tests)
+
+        await flow.draft_spec()
+        await flow.write_failing_test()
+
+        red = flow.red_result
+        assert red is not None
+        assert red.passed is False
+        assert red.has_assertion_failure is True
+        assert "assert 0 == 6" in red.assertion_failure
+
+    async def test_green_records_passing_run_without_assertion_fail(self):
+        agents, tests = _happy_path_scripts()
+        flow, _, _ = _make_flow(agent_script=agents, test_script=tests)
+
+        await flow.draft_spec()
+        await flow.write_failing_test()
+        await flow.write_implementation()
+
+        green = flow.green_result
+        assert green is not None
+        assert green.passed is True
+        assert green.has_assertion_failure is False
+
+    async def test_red_raises_red_passed_when_test_didnt_fail(self):
+        """Key invariant: RED passing = spec wasn't tight enough."""
+        agents = [
+            ("reviewer", "1. trivial spec"),
+            ("coder",    "wrote a vacuous test"),
+        ]
+        tests = [
+            TestRunResult(passed=True, exit_code=0, output="1 passed"),
+        ]
+        flow, _, _ = _make_flow(
+            agent_script=agents, test_script=tests,
+            config=TDDConfig(max_spec_revisions=0),
+        )
+        await flow.draft_spec()
+        with pytest.raises(TDDError) as exc_info:
+            await flow.write_failing_test()
+        assert exc_info.value.reason == "red_passed"
+        assert exc_info.value.phase is TDDPhase.DRIVER_RED
+
+    async def test_green_raises_when_implementation_does_not_fix_test(self):
+        agents, tests = _happy_path_scripts()
+        # Flip GREEN test result to still-failing to simulate bad impl.
+        tests[1] = TestRunResult(
+            passed=False, exit_code=1,
+            output="E   assert 0 == 6",
+            assertion_failure="assert 0 == 6",
+        )
+        flow, _, _ = _make_flow(agent_script=agents, test_script=tests)
+        await flow.draft_spec()
+        await flow.write_failing_test()
+        with pytest.raises(TDDError) as exc_info:
+            await flow.write_implementation()
+        assert exc_info.value.reason == "green_still_failing"
+
+    def test_assertion_extractor_matches_pytest_output(self):
+        sample = (
+            "============================= FAILURES ==============================\n"
+            "_________________________ test_sum _________________________________\n"
+            "    def test_sum():\n"
+            ">       assert 1 + 1 == 3\n"
+            "E       assert 2 == 3\n"
+        )
+        assert _extract_assertion_failure(sample) == "assert 2 == 3"
+
+    def test_assertion_extractor_empty_on_clean_output(self):
+        assert _extract_assertion_failure("2 passed in 0.01s") == ""
