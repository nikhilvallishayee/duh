+"""Backend protocol for rate-limiter state.
+
+A Backend is the atomic primitive. Given an algorithm name, a key, and
+parameters, it returns the decision computed under mutual exclusion
+for that key. Algorithm-specific logic (what the bucket state means,
+how to compute retry times) lives in the limiter; the backend only
+has to execute those updates atomically.
+"""
+
+from __future__ import annotations
+
+from typing import Protocol, runtime_checkable
+
+from ratelimit.types import Decision
+
+
+@runtime_checkable
+class Backend(Protocol):
+    """Atomic state store for rate limiters.
+
+    Implementations must guarantee that ``token_bucket`` and
+    ``sliding_window`` calls for the same key are serialized globally
+    across all processes sharing the backend.
+    """
+
+    def token_bucket(
+        self,
+        key: str,
+        capacity: int,
+        refill_rate: float,
+        cost: int,
+        now_ms: int | None = None,
+    ) -> Decision:
+        """Apply token-bucket admission to ``key``.
+
+        ``now_ms`` is optional; when ``None`` the backend uses its own
+        authoritative clock (Redis server time for RedisBackend). Tests
+        may pass an explicit ``now_ms`` for determinism.
+        """
+        ...
+
+    def sliding_window(
+        self,
+        key: str,
+        capacity: int,
+        period_ms: int,
+        cost: int,
+        now_ms: int | None = None,
+    ) -> Decision:
+        """Apply sliding-window-log admission to ``key``."""
+        ...
+
+    def reset(self, key: str) -> None:
+        """Clear state for ``key`` (test utility)."""
+        ...
