+from hypothesis import given, settings
+from hypothesis.strategies import lists, integers, data
+import fakeredis
+
+from ratelimit.backends import RedisBackend
+from ratelimit.limiters import SlidingWindowLimiter
+
+@settings(max_examples=50)
+@given(
+    requests=lists(integers(min_value=0, max_value=2000), min_size=1, max_size=100),
+)
+def test_sliding_window_invariant(requests):
+    """
+    Test that across any simulated time sequence, the SlidingWindowLimiter
+    never allows more than `capacity` requests in any `window_ms` sliding window.
+    """
+    client = fakeredis.FakeStrictRedis()
+    backend = RedisBackend(client)
+    
+    capacity = 10
+    window_ms = 500
+    limiter = SlidingWindowLimiter(backend, capacity=capacity, window_ms=window_ms)
+    key = "hypo_key"
+    
+    # Sort the list to simulate monotonic time (though we might have identical timestamps)
+    requests.sort()
+    
+    allowed_times = []
+    
+    for req_time in requests:
+        # We need to inject time, so we bypass limiter.enforce which uses time.time()
+        # and directly call the backend to control time precisely.
+        dec = backend.eval_sliding_window(key, capacity, window_ms, 1, req_time)
+        if dec.allowed:
+            allowed_times.append(req_time)
+            
+    # Now assert invariant: for any request, count allowed_times in [req_time - window_ms, req_time]
+    # actually window is (req_time - window_ms, req_time] because cutoff is now - window_ms
+    for i in range(len(allowed_times)):
+        t = allowed_times[i]
+        cutoff = t - window_ms
+        # count how many elements in allowed_times are > cutoff and <= t
+        count = sum(1 for x in allowed_times if cutoff < x <= t)
+        assert count <= capacity, f"Invariant violated: {count} allowed in window ending at {t}"
