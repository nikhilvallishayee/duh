+++ b/ratelimit/backends/redis_backend.py
@@ -0,0 +1,291 @@
+"""Redis backend using atomic Lua scripts.
+
+Both algorithms are implemented as Lua scripts that run atomically
+server-side. See ADR-001 for why we chose Lua over WATCH/MULTI/EXEC.
+
+The Redis server's own clock is authoritative: every script calls
+``redis.call('TIME')`` so the Python client's clock skew is irrelevant.
+Tests may pass ``now_ms`` to override this for determinism.
+"""
+
+from __future__ import annotations
+
+import logging
+from typing import Any
+
+from ratelimit.backends.base import Backend
+from ratelimit.types import Decision, OnError
+
+log = logging.getLogger(__name__)
+
+
+# -----------------------------------------------------------------
+# Lua: token bucket
+# -----------------------------------------------------------------
+#
+# KEYS[1]  bucket key  ({tokens, last_refill_ms} as hash)
+# ARGV[1]  capacity
+# ARGV[2]  refill_rate  (tokens per second, float)
+# ARGV[3]  cost
+# ARGV[4]  now_ms_override ("" if use server time)
+#
+# returns {allowed(0|1), remaining, retry_after_ms, reset_ms}
+_TOKEN_BUCKET_LUA = r"""
+local key         = KEYS[1]
+local capacity    = tonumber(ARGV[1])
+local refill_rate = tonumber(ARGV[2])
+local cost        = tonumber(ARGV[3])
+
+local now_ms
+if ARGV[4] ~= "" then
+    now_ms = tonumber(ARGV[4])
+else
+    local t = redis.call('TIME')
+    now_ms = tonumber(t[1]) * 1000 + math.floor(tonumber(t[2]) / 1000)
+end
+
+local data = redis.call('HMGET', key, 'tokens', 'last_refill_ms')
+local tokens = tonumber(data[1])
+local last_refill_ms = tonumber(data[2])
+
+if tokens == nil or last_refill_ms == nil then
+    tokens = capacity
+    last_refill_ms = now_ms
+else
+    local elapsed_ms = now_ms - last_refill_ms
+    if elapsed_ms < 0 then elapsed_ms = 0 end
+    tokens = math.min(capacity, tokens + (elapsed_ms / 1000.0) * refill_rate)
+    last_refill_ms = now_ms
+end
+
+local allowed = 0
+local retry_after_ms = 0
+
+if tokens >= cost then
+    tokens = tokens - cost
+    allowed = 1
+else
+    local needed = cost - tokens
+    retry_after_ms = math.ceil(needed / refill_rate * 1000)
+    if retry_after_ms < 1 then retry_after_ms = 1 end
+end
+
+-- Persist. TTL = time to fully refill plus a small margin.
+redis.call('HSET', key, 'tokens', tostring(tokens),
+           'last_refill_ms', tostring(last_refill_ms))
+local full_refill_ms = math.ceil(capacity / refill_rate * 1000) + 1000
+redis.call('PEXPIRE', key, full_refill_ms)
+
+local deficit = capacity - tokens
+local reset_ms = now_ms + math.ceil(deficit / refill_rate * 1000)
+
+return {allowed, math.floor(tokens), retry_after_ms, reset_ms}
+"""
+
+
+# -----------------------------------------------------------------
+# Lua: sliding window log
+# -----------------------------------------------------------------
+#
+# Key stores admitted timestamps as a ZSET where:
+#   member = "<now_ms>:<seq>"      (seq makes it unique)
+#   score  = now_ms
+#
+# KEYS[1]  window key
+# ARGV[1]  capacity
+# ARGV[2]  period_ms
+# ARGV[3]  cost
+# ARGV[4]  now_ms_override ("" = server time)
+# ARGV[5]  seq_counter_key  (shared INCR used to break ties)
+#
+# returns {allowed(0|1), remaining, retry_after_ms, reset_ms}
+_SLIDING_WINDOW_LUA = r"""
+local key       = KEYS[1]
+local seqkey    = ARGV[5]
+local capacity  = tonumber(ARGV[1])
+local period_ms = tonumber(ARGV[2])
+local cost      = tonumber(ARGV[3])
+
+local now_ms
+if ARGV[4] ~= "" then
+    now_ms = tonumber(ARGV[4])
+else
+    local t = redis.call('TIME')
+    now_ms = tonumber(t[1]) * 1000 + math.floor(tonumber(t[2]) / 1000)
+end
+
+local cutoff = now_ms - period_ms
+redis.call('ZREMRANGEBYSCORE', key, '-inf', '(' .. tostring(cutoff))
+
+local used = redis.call('ZCARD', key)
+
+if used + cost <= capacity then
+    for i = 1, cost do
+        local seq = redis.call('INCR', seqkey)
+        redis.call('ZADD', key, now_ms, tostring(now_ms) .. ':' .. tostring(seq))
+    end
+    redis.call('PEXPIRE', key, period_ms + 1000)
+    redis.call('PEXPIRE', seqkey, period_ms + 1000)
+
+    local oldest = redis.call('ZRANGE', key, 0, 0, 'WITHSCORES')
+    local reset_ms = now_ms + period_ms
+    if #oldest >= 2 then
+        reset_ms = tonumber(oldest[2]) + period_ms
+    end
+    return {1, capacity - (used + cost), 0, reset_ms}
+end
+
+-- Denied.
+if cost > capacity then
+    return {0, math.max(0, capacity - used), period_ms, now_ms + period_ms}
+end
+local need_to_expire = (used + cost) - capacity
+-- kth oldest (0-indexed index = need_to_expire - 1)
+local kth = redis.call('ZRANGE', key, need_to_expire - 1, need_to_expire - 1, 'WITHSCORES')
+local kth_ms = tonumber(kth[2])
+local retry_after_ms = (kth_ms + period_ms) - now_ms
+if retry_after_ms < 1 then retry_after_ms = 1 end
+local oldest = redis.call('ZRANGE', key, 0, 0, 'WITHSCORES')
+local reset_ms = now_ms + period_ms
+if #oldest >= 2 then
+    reset_ms = tonumber(oldest[2]) + period_ms
+end
+return {0, math.max(0, capacity - used), retry_after_ms, reset_ms}
+"""
+
+
+class RedisBackend(Backend):
+    """Redis-backed atomic backend.
+
+    Parameters
+    ----------
+    client:
+        A redis-py compatible client (real redis or fakeredis).
+    namespace:
+        Prefix prepended to every key, for multi-tenant isolation.
+    on_error:
+        ``"fail_open"`` (default) permits requests on backend failure;
+        ``"fail_closed"`` denies them. See ADR-001 §6.
+    fail_closed_cooldown_ms:
+        When denying on error, the ``retry_after_ms`` to report.
+    """
+
+    def __init__(
+        self,
+        client: Any,
+        *,
+        namespace: str = "rl",
+        on_error: OnError = "fail_open",
+        fail_closed_cooldown_ms: int = 1000,
+    ) -> None:
+        self._redis = client
+        self._namespace = namespace
+        self._on_error: OnError = on_error
+        self._cooldown_ms = int(fail_closed_cooldown_ms)
+        # register_script returns a Script object that auto-loads and
+        # EVALSHA's on subsequent calls.
+        self._tb_script = client.register_script(_TOKEN_BUCKET_LUA)
+        self._sw_script = client.register_script(_SLIDING_WINDOW_LUA)
+
+    # ------------------------------------------------------------------
+
+    def _ns(self, key: str) -> str:
+        return f"{self._namespace}:{key}"
+
+    def _degrade(self, capacity: int) -> Decision:
+        if self._on_error == "fail_open":
+            return Decision(
+                allowed=True,
+                retry_after_ms=0,
+                remaining=capacity,
+                reset_ts=0,
+            )
+        return Decision(
+            allowed=False,
+            retry_after_ms=self._cooldown_ms,
+            remaining=0,
+            reset_ts=0,
+        )
+
+    # ------------------------------------------------------------------
+
+    def token_bucket(
+        self,
+        key: str,
+        capacity: int,
+        refill_rate: float,
+        cost: int,
+        now_ms: int | None = None,
+    ) -> Decision:
+        if capacity < 1:
+            raise ValueError("capacity must be >= 1")
+        if cost < 1:
+            raise ValueError("cost must be >= 1")
+        if refill_rate <= 0:
+            raise ValueError("refill_rate must be > 0")
+
+        args = [
+            str(capacity),
+            repr(float(refill_rate)),
+            str(cost),
+            "" if now_ms is None else str(int(now_ms)),
+        ]
+
+        try:
+            raw = self._tb_script(keys=[self._ns(key)], args=args)
+        except Exception:  # noqa: BLE001 - broad by design
+            log.exception("RedisBackend.token_bucket failed; degrading")
+            return self._degrade(capacity)
+
+        allowed, remaining, retry_after_ms, reset_ms = (int(x) for x in raw)
+        return Decision(
+            allowed=bool(allowed),
+            retry_after_ms=retry_after_ms,
+            remaining=remaining,
+            reset_ts=reset_ms,
+        )
+
+    # ------------------------------------------------------------------
+
+    def sliding_window(
+        self,
+        key: str,
+        capacity: int,
+        period_ms: int,
+        cost: int,
+        now_ms: int | None = None,
+    ) -> Decision:
+        if capacity < 1:
+            raise ValueError("capacity must be >= 1")
+        if cost < 1:
+            raise ValueError("cost must be >= 1")
+        if period_ms <= 0:
+            raise ValueError("period_ms must be > 0")
+
+        args = [
+            str(capacity),
+            str(int(period_ms)),
+            str(cost),
+            "" if now_ms is None else str(int(now_ms)),
+            self._ns(f"__seq:{key}"),
+        ]
+
+        try:
+            raw = self._sw_script(keys=[self._ns(key)], args=args)
+        except Exception:  # noqa: BLE001
+            log.exception("RedisBackend.sliding_window failed; degrading")
+            return self._degrade(capacity)
+
+        allowed, remaining, retry_after_ms, reset_ms = (int(x) for x in raw)
+        return Decision(
+            allowed=bool(allowed),
+            retry_after_ms=retry_after_ms,
+            remaining=remaining,
+            reset_ts=reset_ms,
+        )
+
+    def reset(self, key: str) -> None:
+        try:
+            self._redis.delete(self._ns(key), self._ns(f"__seq:{key}"))
+        except Exception:  # noqa: BLE001
+            log.exception("RedisBackend.reset failed; ignoring")
diff --git a/ratelimit/decorator.py b/ratelimit/decorator.py
new file mode 100644
index 0000000..1ccff94
--- /dev/null
+++ b/ratelimit/decorator.py
@@ -0,0 +1,70 @@
+"""Function-level rate limiting via decorator."""
+
+from __future__ import annotations
+
+import asyncio
+import functools
+from typing import Any, Callable
+
+from ratelimit.limiters import RateLimiter
+from ratelimit.types import Decision
+
+
+class RateLimitExceeded(Exception):
+    """Raised from the decorator when ``enforce`` returns ``allowed=False``."""
+
+    def __init__(self, decision: Decision, key: str):
+        self.decision = decision
+        self.key = key
+        super().__init__(
+            f"rate limit exceeded for key={key!r}: "
+            f"retry_after_ms={decision.retry_after_ms}, remaining={decision.remaining}"
+        )
+
+
+def rate_limit(
+    limiter: RateLimiter,
+    key_fn: Callable[..., str],
+    *,
+    cost: int | Callable[..., int] = 1,
+) -> Callable[[Callable[..., Any]], Callable[..., Any]]:
+    """Wrap a callable with a rate-limit enforcement step.
+
+    ``key_fn`` receives the same ``*args, **kwargs`` as the wrapped
+    function and returns the key string. ``cost`` may be an int or a
+    callable with the same signature.
+
+    Raises :class:`RateLimitExceeded` when the limiter rejects. Works
+    for both sync and async callables.
+    """
+
+    def decorate(fn: Callable[..., Any]) -> Callable[..., Any]:
+        resolve_cost: Callable[..., int] = (
+            cost if callable(cost) else (lambda *a, **k: int(cost))
+        )
+
+        if asyncio.iscoroutinefunction(fn):
+
+            @functools.wraps(fn)
+            async def async_wrapper(*args: Any, **kwargs: Any) -> Any:
+                k = key_fn(*args, **kwargs)
+                c = int(resolve_cost(*args, **kwargs))
+                decision = limiter.enforce(k, cost=c)
+                if not decision.allowed:
+                    raise RateLimitExceeded(decision, k)
+                return await fn(*args, **kwargs)
+
+            return async_wrapper
+
+        @functools.wraps(fn)
+        def sync_wrapper(*args: Any, **kwargs: Any) -> Any:
+            k = key_fn(*args, **kwargs)
+            c = int(resolve_cost(*args, **kwargs))
+            decision = limiter.enforce(k, cost=c)
+            if not decision.allowed:
+                raise RateLimitExceeded(decision, k)
+            return fn(*args, **kwargs)
+
+        return sync_wrapper
+
+    return decorate
diff --git a/ratelimit/limiters.py b/ratelimit/limiters.py
new file mode 100644
index 0000000..63559ff
--- /dev/null
+++ b/ratelimit/limiters.py
@@ -0,0 +1,140 @@
+"""Abstract ``RateLimiter`` base and the two concrete algorithms."""
+
+from __future__ import annotations
+
+import abc
+
+from ratelimit.backends.base import Backend
+from ratelimit.backends.memory import InMemoryBackend
+from ratelimit.types import Decision
+
+
+class RateLimiter(abc.ABC):
+    """Algorithm-facing interface for a rate limiter.
+
+    A limiter is bound to a ``Backend`` and exposes a single
+    ``enforce(key, cost=1) -> Decision`` call.
+    """
+
+    backend: Backend
+
+    def __init__(self, backend: Backend | None = None) -> None:
+        self.backend = backend if backend is not None else InMemoryBackend()
+
+    @abc.abstractmethod
+    def enforce(self, key: str, cost: int = 1, *, now_ms: int | None = None) -> Decision:
+        """Atomically admit or reject one request for ``key``."""
+
+    @property
+    @abc.abstractmethod
+    def capacity(self) -> int:
+        """Maximum allowed requests/tokens per window/bucket."""
+
+
+class TokenBucketLimiter(RateLimiter):
+    """Classic token bucket.
+
+    Parameters
+    ----------
+    capacity:
+        Maximum tokens the bucket can hold (burst size).
+    refill_rate:
+        Tokens added per second (float).
+    backend:
+        State store. Defaults to a fresh in-memory backend.
+    """
+
+    def __init__(
+        self,
+        capacity: int,
+        refill_rate: float,
+        *,
+        backend: Backend | None = None,
+    ) -> None:
+        if capacity < 1:
+            raise ValueError("capacity must be >= 1")
+        if refill_rate <= 0:
+            raise ValueError("refill_rate must be > 0")
+        super().__init__(backend)
+        self._capacity = int(capacity)
+        self._refill_rate = float(refill_rate)
+
+    @property
+    def capacity(self) -> int:
+        return self._capacity
+
+    @property
+    def refill_rate(self) -> float:
+        return self._refill_rate
+
+    def enforce(self, key: str, cost: int = 1, *, now_ms: int | None = None) -> Decision:
+        if cost < 1:
+            raise ValueError("cost must be >= 1")
+        if cost > self._capacity:
+            # A cost that exceeds capacity can never be admitted; return a
+            # deterministic denial rather than waiting forever.
+            from ratelimit.types import Decision
+
+            return Decision(
+                allowed=False,
+                retry_after_ms=int(self._capacity / self._refill_rate * 1000),
+                remaining=0,
+                reset_ts=0,
+            )
+        return self.backend.token_bucket(
+            key=key,
+            capacity=self._capacity,
+            refill_rate=self._refill_rate,
+            cost=cost,
+            now_ms=now_ms,
+        )
+
+
+class SlidingWindowLimiter(RateLimiter):
+    """Sliding-window-log rate limiter.
+
+    Parameters
+    ----------
+    capacity:
+        Maximum requests admitted in any window of length ``period_seconds``.
+    period_seconds:
+        Window length (may be fractional).
+    backend:
+        State store. Defaults to a fresh in-memory backend.
+    """
+
+    def __init__(
+        self,
+        capacity: int,
+        period_seconds: float,
+        *,
+        backend: Backend | None = None,
+    ) -> None:
+        if capacity < 1:
+            raise ValueError("capacity must be >= 1")
+        if period_seconds <= 0:
+            raise ValueError("period_seconds must be > 0")
+        super().__init__(backend)
+        self._capacity = int(capacity)
+        self._period_ms = int(round(period_seconds * 1000))
+        if self._period_ms <= 0:
+            raise ValueError("period_seconds too small; period_ms rounded to 0")
+
+    @property
+    def capacity(self) -> int:
+        return self._capacity
+
+    @property
+    def period_ms(self) -> int:
+        return self._period_ms
+
+    def enforce(self, key: str, cost: int = 1, *, now_ms: int | None = None) -> Decision:
+        if cost < 1:
+            raise ValueError("cost must be >= 1")
+        return self.backend.sliding_window(
+            key=key,
+            capacity=self._capacity,
+            period_ms=self._period_ms,
+            cost=cost,
+            now_ms=now_ms,
+        )
