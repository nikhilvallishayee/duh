+from __future__ import annotations
+
+import abc
+import uuid
+from typing import Optional
+
+from ratelimit.backends import Backend, InMemoryBackend
+from ratelimit.models import Decision
+
+
+class RateLimiter(abc.ABC):
+    def __init__(self, backend: Optional[Backend] = None, namespace: Optional[str] = None) -> None:
+        self.backend = backend or InMemoryBackend()
+        self.namespace = namespace or uuid.uuid4().hex
+
+    @property
+    @abc.abstractmethod
+    def limit(self) -> int:
+        ...
+
+    @abc.abstractmethod
+    def enforce(self, key: str, cost: int = 1) -> Decision:
+        ...
+
+    @staticmethod
+    def _validate_cost(cost: int) -> None:
+        if cost <= 0:
+            raise ValueError("cost must be positive")
+
+
+class TokenBucketLimiter(RateLimiter):
+    def __init__(
+        self,
+        capacity: int,
+        refill_rate: float,
+        backend: Optional[Backend] = None,
+        namespace: Optional[str] = None,
+    ) -> None:
+        if capacity <= 0:
+            raise ValueError("capacity must be positive")
+        if refill_rate <= 0:
+            raise ValueError("refill_rate must be positive")
+        super().__init__(backend=backend, namespace=namespace)
+        self.capacity = capacity
+        self.refill_rate = refill_rate
+
+    @property
+    def limit(self) -> int:
+        return self.capacity
+
+    def enforce(self, key: str, cost: int = 1) -> Decision:
+        self._validate_cost(cost)
+        return self.backend.enforce_token_bucket(
+            namespace=self.namespace,
+            key=key,
+            capacity=self.capacity,
+            refill_rate=self.refill_rate,
+            cost=cost,
+        )
+
+
+class SlidingWindowLimiter(RateLimiter):
+    def __init__(
+        self,
+        capacity: int,
+        period_ms: int,
+        backend: Optional[Backend] = None,
+        namespace: Optional[str] = None,
+    ) -> None:
+        if capacity <= 0:
+            raise ValueError("capacity must be positive")
+        if period_ms <= 0:
+            raise ValueError("period_ms must be positive")
+        super().__init__(backend=backend, namespace=namespace)
+        self.capacity = capacity
+        self.period_ms = period_ms
+
+    @property
+    def limit(self) -> int:
+        return self.capacity
+
+    def enforce(self, key: str, cost: int = 1) -> Decision:
+        self._validate_cost(cost)
+        return self.backend.enforce_sliding_window(
+            namespace=self.namespace,
+            key=key,
+            capacity=self.capacity,
+            period_ms=self.period_ms,
+            cost=cost,
+        )
