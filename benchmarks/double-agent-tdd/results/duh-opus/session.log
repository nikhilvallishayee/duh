Good. Now, let me write the implementation:  [33m> Write[0m(file_path='/Users/nomind/Code/Tengu/tengu-cockpit/benchmarks/double-agent-tdd/worktrees/duh-opus/duh/kernel/tdd_mode.py', content='"""Double-Agent TDD mode — Driver / Navigator pair-programming harness.\n\nImplements the red-green-refactor flow specified in ADR-076 on top of the\nexisting ``Engine`` / ``Deps`` / agent-overlay abstractions.  Two\n``Engine`` instances — the **Driver** (``coder`` overlay) and the\n**Navigator** (``reviewer`` overlay) — are sequenced through six strict\nphases, with a real subprocess test-run acting as the gate between\nphases.\n\nThe shape mirrors :class:`duh.kernel.plan_mode.PlanMode`:\n\n    driver = Engine(...)        # coder system prompt\n    navigator = Engine(...)     # reviewer system prompt\n    tdd = TddMode(driver=driver, navigator=navigator)\n\n    # Phase 1 — Navigator drafts the test spec\n    async for event in tdd.spec("cache LRU eviction drops oldest entry"):\n        handle(event)\n\n    # Phase 2 — Driver writes the failing test, runs it, RED-gate fires\n    async for event in tdd.red():\n        handle(event)\n\n    # Phase 3 — Driver writes minimum code, GREEN-gate fires\n    async for event in tdd.green():\n        handle(event)\n\n    # Phases 4–6 — Navigator proposes refactor, Driver applies, Navigator validates\n    async for event in tdd.refactor():\n        handle(event)\n\nA convenience ``run_all()`` coroutine drives every phase end-to-end for\nCLI / CI use.  See ADR-076 for the rationale.\n"""\n\nfrom __future__ import annotations\n\nimport os\nimport subprocess\nfrom dataclasses import dataclass, field\nfrom enum import Enum, auto\nfrom typing import Any, AsyncGenerator, Callable\n\nfrom duh.kernel.engine import Engine\nfrom duh.kernel.messages import Message\n\n\n# ---------------------------------------------------------------------------\n# State machine\n# ---------------------------------------------------------------------------\n\n\nclass TddState(Enum):\n    """Current state of a double-agent TDD session."""\n\n    EMPTY = auto()               # No spec yet\n    SPEC = auto()                # Navigator drafted spec, awaiting approval\n    RED = auto()                 # Driver wrote test, it failed — ready for GREEN\n    GREEN = auto()               # Driver wrote code, test passes — ready for REFACTOR\n    REFACTOR_PLAN = auto()       # Navigator proposed refactor — ready for APPLY\n    REFACTOR_APPLY = auto()      # Driver applied refactor — ready for VALIDATE\n    DONE = auto()                # Navigator validated — full cycle complete\n\n\n# Ordered list of phases for history / renderer consumption.\nPHASE_ORDER = [\n    TddState.SPEC,\n    TddState.RED,\n    TddState.GREEN,\n    TddState.REFACTOR_PLAN,\n    TddState.REFACTOR_APPLY,\n    TddState.DONE,\n]\n\n\n# ---------------------------------------------------------------------------\n# Prompt templates (single source of truth — referenced in unit tests)\n# ---------------------------------------------------------------------------\n\nSPEC_PROMPT = (\n    "You are the NAVIGATOR in a TDD pair. Draft a tight, minimal test "\n    "specification for the feature below. Output ONLY:\\n"\n    "  - one sentence describing the behaviour under test\\n"\n    "  - a bullet list of the concrete assertions the test must make\\n"\n    "  - the file path where the test should live\\n"\n    "Do NOT write any code or call any tools yet.\\n\\n"\n    "Feature: "\n)\n\nRED_PROMPT = (\n    "You are the DRIVER in a TDD pair. The Navigator has approved this "\n    "test specification:\\n\\n"\n    "---\\n{spec}\\n---\\n\\n"\n    "Write the FAILING test now. Use the Write / Edit tool to create the "\n    "test file. Do NOT write any production code — the test MUST fail "\n    "because the behaviour is not yet implemented. A test that passes on "\n    "the first run means the spec was too loose and we will start over."\n)\n\nGREEN_PROMPT = (\n    "You are the DRIVER. The test you just wrote is failing as expected "\n    "(the RED phase passed). Now write the MINIMUM production code "\n    "needed to make the test pass. Constraints:\\n"\n    "  - Do NOT refactor existing code — that is the next phase\\n"\n    "  - Do NOT add features the test does not exercise\\n"\n    "  - Do NOT rename, reorganise, or re-style code outside the diff\\n"\n    "When you think the test will pass, stop. The harness re-runs the "\n    "test automatically."\n)\n\nREFACTOR_PROPOSE_PROMPT = (\n    "You are the NAVIGATOR. The Driver\'s test is now GREEN. Read the "\n    "code the Driver just wrote and propose ONE concrete refactor that "\n    "improves clarity or removes duplication without changing behaviour. "\n    "Output ONLY:\\n"\n    "  - the file(s) to modify\\n"\n    "  - a bullet list of the exact changes\\n"\n    "  - a one-line justification\\n"\n    "Do NOT apply the refactor — the Driver will do that in the next phase."\n)\n\nREFACTOR_APPLY_PROMPT = (\n    "You are the DRIVER. Apply the Navigator\'s refactor VERBATIM — no "\n    "scope creep, no additional \'while I\'m here\' edits. Here is the "\n    "Navigator\'s refactor plan:\\n\\n"\n    "---\\n{refactor_plan}\\n---\\n\\n"\n    "Apply every bullet. Do not skip items. When done, stop — the "\n    "harness re-runs the test suite."\n)\n\nVALIDATE_PROMPT = (\n    "You are the NAVIGATOR. The Driver has applied the refactor and the "\n    "test suite passed. Your job is to VALIDATE: confirm that each "\n    "bullet in your refactor plan was applied, and that nothing extra "\n    "was changed. Output a short structured summary:\\n"\n    "  - plan item → \'applied\' | \'missing\' | \'partially applied\'\\n"\n    "  - any unexpected changes you spotted\\n"\n    "  - final verdict: APPROVED or NEEDS REWORK"\n)\n\n\n# Default test command — overridable via TddMode(test_command=...).\nDEFAULT_TEST_COMMAND: list[str] = ["pytest", "-x", "--no-header"]\n\n\n# ---------------------------------------------------------------------------\n# History entries + gate result\n# ---------------------------------------------------------------------------\n\n\n@dataclass\nclass GateResult:\n    """Outcome of running the test command at a RED/GREEN/VALIDATE gate."""\n\n    phase: str                   # "RED" | "GREEN" | "VALIDATE"\n    exit_code: int\n    stdout: str\n    stderr: str\n\n    @property\n    def test_passed(self) -> bool:\n        """True if the test command exited with code 0."""\n        return self.exit_code == 0\n\n    @property\n    def gate_passed(self) -> bool:\n        """True if the gate\'s expected outcome held.\n\n        RED expects the test to FAIL (non-zero exit).\n        GREEN and VALIDATE expect the test to PASS (zero exit).\n        """\n        if self.phase == "RED":\n            return not self.test_passed\n        return self.test_passed\n\n\n@dataclass\nclass PhaseResult:\n    """One entry per phase transition, in ``TddMode.history`` order."""\n\n    phase: str                   # e.g. "SPEC", "RED", "GREEN", ...\n    actor: str                   # "navigator" | "driver"\n    text: str                    # the agent\'s final assistant text\n    gate: GateResult | None = None\n\n\n# ---------------------------------------------------------------------------\n# Test runner — pluggable for tests\n# ---------------------------------------------------------------------------\n\n\nTestRunnerFn = Callable[[list[str], str], GateResult]\n\n\ndef _default_test_runner(cmd: list[str], cwd: str) -> GateResult:\n    """Run ``cmd`` in ``cwd`` and capture stdout/stderr/exit code.\n\n    Returns a :class:`GateResult` with ``phase`` left blank — the caller\n    fills it in with the current phase name.\n    """\n    proc = subprocess.run(\n        cmd,\n        cwd=cwd,\n        capture_output=True,\n        text=True,\n        check=False,\n    )\n    return GateResult(\n        phase="",\n        exit_code=proc.returncode,\n        stdout=proc.stdout,\n        stderr=proc.stderr,\n    )\n\n\n# ---------------------------------------------------------------------------\n# TddMode — the orchestrator\n# ---------------------------------------------------------------------------\n\n\nclass TddMode:\n    """Double-agent driver/navigator TDD state machine.\n\n    Owns nothing the two Engines already own (messages, tools, model\n    choice).  Owns only the TDD-specific state: which phase we are in,\n    the Navigator\'s spec, the refactor plan, and the per-phase history.\n\n    Raises ``ValueError`` on every out-of-order transition.  The tests in\n    ``tests/unit/test_tdd_mode.py`` cover each guard explicitly.\n    """\n\n    def __init__(\n        self,\n        *,\n        driver: Engine,\n        navigator: Engine,\n        test_command: list[str] | None = None,\n        test_runner: TestRunnerFn | None = None,\n        cwd: str | None = None,\n    ) -> None:\n        self._driver = driver\n        self._navigator = navigator\n        self._test_command = list(test_command) if test_command else list(DEFAULT_TEST_COMMAND)\n        self._test_runner: TestRunnerFn = test_runner or _default_test_runner\n        self._cwd = cwd or os.getcwd()\n\n        self._state: TddState = TddState.EMPTY\n        self._description: str = ""\n        self._spec: str = ""\n        self._refactor_plan: str = ""\n        self._history: list[PhaseResult] = []\n        self._spec_revisions: int = 0\n\n    # -------------------------------------------------------- read-only props\n\n    @property\n    def state(self) -> TddState:\n        return self._state\n\n    @property\n    def description(self) -> str:\n        return self._description\n\n    @property\n    def spec(self) -> str:\n        return self._spec\n\n    @property\n    def refactor_plan(self) -> str:\n        return self._refactor_plan\n\n    @property\n    def history(self) -> list[PhaseResult]:\n        return list(self._history)\n\n    @property\n    def test_command(self) -> list[str]:\n        return list(self._test_command)\n\n    @property\n    def spec_revisions(self) -> int:\n        """Number of times the Navigator re-drafted the spec because RED\n        unexpectedly passed.  Observable for tests / UX.\n        """\n        return self._spec_revisions\n\n    def clear(self) -> None:\n        """Reset to the initial empty state."""\n        self._state = TddState.EMPTY\n        self._description = ""\n        self._spec = ""\n        self._refactor_plan = ""\n        self._history = []\n        self._spec_revisions = 0\n\n    # --------------------------------------------------------------- helpers\n\n    @staticmethod\n    def _extract_assistant_text(event: dict[str, Any]) -> str:\n        """Pull clean text off an ``assistant`` event, tolerating the\n        several Message-shape variants the kernel emits.\n        """\n        msg = event.get("message")\n        if msg is None:\n            return ""\n        text_attr = getattr(msg, "text", None)\n        if isinstance(text_attr, str):\n            return text_attr\n        content = getattr(msg, "content", None)\n        if isinstance(content, str):\n            return content\n        if isinstance(content, list):\n            parts: list[str] = []\n            for block in content:\n                if isinstance(block, dict) and block.get("type") == "text":\n                    parts.append(block.get("text", "") or "")\n                else:\n                    btext = getattr(block, "text", None)\n                    if isinstance(btext, str):\n                        parts.append(btext)\n            return "".join(parts)\n        return ""\n\n    async def _run_engine(\n        self,\n        engine: Engine,\n        prompt: str,\n        *,\n        tool_choice: str | None,\n    ) -> AsyncGenerator[dict[str, Any], None]:\n        """Run a single phase on the given engine, yielding its events\n        plus capturing the final assistant text into ``self._last_text``.\n\n        ``tool_choice`` is restored on the engine\'s config even if the\n        caller breaks out early.\n        """\n        config = engine._config  # intentional — same seam PlanMode uses\n        original = config.tool_choice\n        config.tool_choice = tool_choice\n\n        delta_text: list[str] = []\n        assistant_text = ""\n\n        try:\n            async for event in engine.run(prompt):\n                etype = event.get("type", "")\n                if etype == "text_delta":\n                    delta_text.append(event.get("text", ""))\n                elif etype == "assistant":\n                    extracted = self._extract_assistant_text(event)\n                    if extracted:\n                        assistant_text = extracted\n                yield event\n        finally:\n            config.tool_choice = original\n\n        self._last_text = assistant_text or "".join(delta_text)\n\n    def _run_gate(self, phase_name: str) -> GateResult:\n        """Execute the test command and return a :class:`GateResult`\n        tagged with ``phase_name``.\n        """\n        result = self._test_runner(list(self._test_command), self._cwd)\n        return GateResult(\n            phase=phase_name,\n            exit_code=result.exit_code,\n            stdout=result.stdout,\n            stderr=result.stderr,\n        )\n\n    # ----------------------------------------------------------------- phases\n\n    async def spec(\n        self,\n        description: str,\n    ) -> AsyncGenerator[dict[str, Any], None]:\n        """**Phase 1** — Navigator drafts the test spec.\n\n        Runs the Navigator engine with ``tool_choice="none"`` (no writes),\n        captures the assistant text as ``self.spec``, and advances to\n        :attr:`TddState.SPEC`.  Callable only from ``EMPTY``.\n        """\n        if self._state not in (TddState.EMPTY,):\n            raise ValueError(\n                f"Cannot draft spec: state is {self._state.name}, expected EMPTY"\n            )\n        self._description = description\n\n        yield {"type": "tdd_phase", "phase": "SPEC", "actor": "navigator"}\n\n        async for event in self._run_engine(\n            self._navigator,\n            SPEC_PROMPT + description,\n            tool_choice="none",\n        ):\n            yield event\n\n        self._spec = self._last_text.strip()\n        self._history.append(\n            PhaseResult(phase="SPEC", actor="navigator", text=self._spec)\n        )\n        self._state = TddState.SPEC\n\n    async def red(self) -> AsyncGenerator[dict[str, Any], None]:\n        """**Phase 2** — Driver writes the failing test, we run it.\n\n        Must be called from :attr:`TddState.SPEC`.  Runs the test command\n        as a hard gate: if the test unexpectedly passes, the Navigator\n        is invited to revise the spec (``state`` reverts to ``EMPTY`` so\n        the caller can call :meth:`spec` again) and ``spec_revisions``\n        is incremented.  Otherwise advances to :attr:`TddState.RED`.\n        """\n        if self._state != TddState.SPEC:\n            raise ValueError(\n                f"Cannot run RED: state is {self._state.name}, expected SPEC"\n            )\n\n        yield {"type": "tdd_phase", "phase": "RED", "actor": "driver"}\n\n        prompt = RED_PROMPT.format(spec=self._spec)\n        async for event in self._run_engine(\n            self._driver,\n            prompt,\n            tool_choice=None,\n        ):\n            yield event\n        driver_text = self._last_text\n\n        gate = self._run_gate("RED")\n        yield {\n            "type": "tdd_gate",\n            "phase": "RED",\n            "passed": gate.gate_passed,\n            "test_passed": gate.test_passed,\n            "exit_code": gate.exit_code,\n            "stdout": gate.stdout,\n            "stderr": gate.stderr,\n        }\n        self._history.append(\n            PhaseResult(phase="RED", actor="driver", text=driver_text, gate=gate)\n        )\n\n        if gate.gate_passed:\n            self._state = TddState.RED\n        else:\n            # Test passed at RED — spec was too loose. Send the Navigator\n            # back to re-draft. State reverts so the caller can call\n            # .spec() again with a tightened description.\n            self._spec_revisions += 1\n            self._state = TddState.EMPTY\n            self._spec = ""\n\n    async def green(self) -> AsyncGenerator[dict[str, Any], None]:\n        """**Phase 3** — Driver writes the minimum code; we re-run.\n\n        Must be called from :attr:`TddState.RED`.\n        """\n        if self._state != TddState.RED:\n            raise ValueError(\n                f"Cannot run GREEN: state is {self._state.name}, expected RED"\n            )\n\n        yield {"type": "tdd_phase", "phase": "GREEN", "actor": "driver"}\n\n        async for event in self._run_engine(\n            self._driver,\n            GREEN_PROMPT,\n            tool_choice=None,\n        ):\n            yield event\n        driver_text = self._last_text\n\n        gate = self._run_gate("GREEN")\n        yield {\n            "type": "tdd_gate",\n            "phase": "GREEN",\n            "passed": gate.gate_passed,\n            "test_passed": gate.test_passed,\n            "exit_code": gate.exit_code,\n            "stdout": gate.stdout,\n            "stderr": gate.stderr,\n        }\n        self._history.append(\n            PhaseResult(phase="GREEN", actor="driver", text=driver_text, gate=gate)\n        )\n\n        if gate.gate_passed:\n            self._state = TddState.GREEN\n        # On failure we stay in RED — caller can retry green() after\n        # investigating. We do NOT silently advance.\n\n    async def refactor_plan(self) -> AsyncGenerator[dict[str, Any], None]:\n        """**Phase 4** — Navigator proposes a refactor (read-only).\n\n        Must be called from :attr:`TddState.GREEN`.\n        """\n        if self._state != TddState.GREEN:\n            raise ValueError(\n                f"Cannot propose refactor: state is {self._state.name}, expected GREEN"\n            )\n\n        yield {"type": "tdd_phase", "phase": "REFACTOR_PLAN", "actor": "navigator"}\n\n        async for event in self._run_engine(\n            self._navigator,\n            REFACTOR_PROPOSE_PROMPT,\n            tool_choice="none",\n        ):\n            yield event\n\n        self._refactor_plan = self._last_text.strip()\n        self._history.append(\n            PhaseResult(\n                phase="REFACTOR_PLAN",\n                actor="navigator",\n                text=self._refactor_plan,\n            )\n        )\n        self._state = TddState.REFACTOR_PLAN\n\n    async def refactor_apply(self) -> AsyncGenerator[dict[str, Any], None]:\n        """**Phase 5** — Driver applies the Navigator\'s refactor.\n\n        Must be called from :attr:`TddState.REFACTOR_PLAN`.  The prompt\n        literally includes :attr:`refactor_plan`, and we assert that it\n        is non-empty — a Driver cannot apply a refactor that was never\n        proposed.\n        """\n        if self._state != TddState.REFACTOR_PLAN:\n            raise ValueError(\n                f"Cannot apply refactor: state is {self._state.name}, "\n                f"expected REFACTOR_PLAN"\n            )\n        if not self._refactor_plan:\n            raise ValueError(\n                "Cannot apply refactor: Navigator\'s refactor_plan is empty"\n            )\n\n        yield {"type": "tdd_phase", "phase": "REFACTOR_APPLY", "actor": "driver"}\n\n        prompt = REFACTOR_APPLY_PROMPT.format(refactor_plan=self._refactor_plan)\n        async for event in self._run_engine(\n            self._driver,\n            prompt,\n            tool_choice=None,\n        ):\n            yield event\n        driver_text = self._last_text\n\n        self._history.append(\n            PhaseResult(\n                phase="REFACTOR_APPLY",\n                actor="driver",\n                text=driver_text,\n            )\n        )\n        self._state = TddState.REFACTOR_APPLY\n\n    async def validate(self) -> AsyncGenerator[dict[str, Any], None]:\n        """**Phase 6** — Navigator validates refactor landed + tests pass.\n\n        Must be called from :attr:`TddState.REFACTOR_APPLY`.  Re-runs\n        the test command; only on a passing test does state advance to\n        :attr:`TddState.DONE`.\n        """\n        if self._state != TddState.REFACTOR_APPLY:\n            raise ValueError(\n                f"Cannot validate: state is {self._state.name}, "\n                f"expected REFACTOR_APPLY"\n            )\n\n        yield {"type": "tdd_phase", "phase": "VALIDATE", "actor": "navigator"}\n\n        async for event in self._run_engine(\n            self._navigator,\n            VALIDATE_PROMPT,\n            tool_choice=None,\n        ):\n            yield event\n        navigator_text = self._last_text\n\n        gate = self._run_gate("VALIDATE")\n        yield {\n            "type": "tdd_gate",\n            "phase": "VALIDATE",\n            "passed": gate.gate_passed,\n            "test_passed": gate.test_passed,\n            "exit_code": gate.exit_code,\n            "stdout": gate.stdout,\n            "stderr": gate.stderr,\n        }\n        self._history.append(\n            PhaseResult(\n                phase="VALIDATE",\n                actor="navigator",\n                text=navigator_text,\n                gate=gate,\n            )\n        )\n\n        if gate.gate_passed:\n            self._state = TddState.DONE\n        # If the refactor broke the tests we stay at REFACTOR_APPLY so\n        # the caller can fix it. Again: no silent advancement.\n\n    # --------------------------------------------------------------- refactor\n\n    async def refactor(self) -> AsyncGenerator[dict[str, Any], None]:\n        """Convenience: run phases 4 → 5 → 6 in sequence from GREEN."""\n        async for event in self.refactor_plan():\n            yield event\n        if self._state != TddState.REFACTOR_PLAN:\n            return\n        async for event in self.refactor_apply():\n            yield event\n        if self._state != TddState.REFACTOR_APPLY:\n            return\n        async for event in self.validate():\n            yield event\n\n    async def run_all(\n        self,\n        description: str,\n    ) -> AsyncGenerator[dict[str, Any], None]:\n        """Drive every phase end-to-end for CLI / CI use.\n\n        Equivalent to ``spec() → red() → green() → refactor()`` but short-\n        circuits on any gate failure (state stops advancing).\n        """\n        async for event in self.spec(description):\n            yield event\n        if self._state != TddState.SPEC:\n            return\n        async for event in self.red():\n            yield event\n        if self._state != TddState.RED:\n            # RED gate failed (test passed) — caller may loop back to spec.\n            return\n        async for event in self.green():\n            yield event\n        if self._state != TddState.GREEN:\n            return\n        async for event in self.refactor():\n            yield event\n\n    # --------------------------------------------------------- pretty-printer\n\n    def format_status(self) -> str:\n        """Human-readable one-screen summary of the session."""\n        lines = [f"TDD state: {self._state.name}"]\n        if self._description:\n            lines.append(f"  feature: {self._description}")\n        if self._spec:\n            lines.append("  spec:")\n            for ln in self._spec.splitlines():\n                lines.append(f"    {ln}")\n        if self._spec_revisions:\n            lines.append(f"  spec revisions: {self._spec_revisions}")\n        if self._refactor_plan:\n            lines.append("  refactor plan:")\n            for ln in self._refactor_plan.splitlines():\n                lines.append(f"    {ln}")\n        if self._history:\n            lines.append("  history:")\n            for entry in self._history:\n                suffix = ""\n                if entry.gate is not None:\n                    suffix = (\n                        f"  [gate: exit={entry.gate.exit_code} "\n                        f"{\'PASSED\' if entry.gate.gate_passed else \'FAILED\'}]"\n                    )\n                lines.append(f"    - {entry.phase} ({entry.actor}){suffix}")\n        return "\\n".join(lines)\n')
Now let me write the unit tests against this module to make sure the implementation is correct before wiring the CLI:  [33m> Write[0m(file_path='/Users/nomind/Code/Tengu/tengu-cockpit/benchmarks/double-agent-tdd/worktrees/duh-opus/tests/unit/test_tdd_mode.py', content='"""Tests for :mod:`duh.kernel.tdd_mode` — the double-agent TDD flow.\n\nCovers the six-phase contract defined in ADR-076:\n\n  1. Phase transitions happen in order; out-of-order calls raise.\n  2. The RED-phase gate surfaces the assertion failure distinctly from\n     GREEN (different event ``phase`` tag, different pass condition).\n  3. The Navigator\'s refactor suggestion is actually reproduced verbatim\n     in the prompt the Driver receives for REFACTOR_APPLY, and the apply\n     phase refuses to run if no refactor has been proposed.\n  4. A full end-to-end run completes against the deterministic stub\n     provider and advances to :attr:`TddState.DONE`.\n"""\n\nfrom __future__ import annotations\n\nimport os\nfrom typing import Any, AsyncGenerator\nfrom unittest.mock import patch\n\nimport pytest\n\nfrom duh.kernel.deps import Deps\nfrom duh.kernel.engine import Engine, EngineConfig\nfrom duh.kernel.messages import Message\nfrom duh.kernel.tdd_mode import (\n    DEFAULT_TEST_COMMAND,\n    GateResult,\n    REFACTOR_APPLY_PROMPT,\n    RED_PROMPT,\n    SPEC_PROMPT,\n    TddMode,\n    TddState,\n)\n\n\n# ---------------------------------------------------------------------------\n# Test doubles\n# ---------------------------------------------------------------------------\n\n\ndef _scripted_model(responses: list[str]):\n    """Factory: build an async call_model that replies with the next\n    scripted response on each call.  Allows each Engine to produce a\n    different answer per phase.\n    """\n    iterator = iter(responses)\n\n    async def call_model(**kwargs) -> AsyncGenerator[dict[str, Any], None]:\n        try:\n            text = next(iterator)\n        except StopIteration:\n            text = ""\n        msg = Message(\n            role="assistant",\n            content=[{"type": "text", "text": text}],\n        )\n        yield {"type": "text_delta", "text": text}\n        yield {"type": "assistant", "message": msg}\n        yield {"type": "done", "stop_reason": "end_turn", "turns": 1}\n\n    return call_model\n\n\ndef _make_engine(responses: list[str]) -> Engine:\n    """Build a minimal Engine backed by a scripted call_model.  Tools\n    are empty — the Driver/Navigator cannot actually touch the disk in\n    unit tests, which is exactly what we want.\n    """\n    deps = Deps(call_model=_scripted_model(responses))\n    return Engine(deps=deps, config=EngineConfig(model="test-model"))\n\n\nclass FakeRunner:\n    """Pluggable test runner that returns scripted :class:`GateResult`\n    outcomes in order.  Every call also records the command + cwd it was\n    given so the tests can assert against them.\n    """\n\n    def __init__(self, results: list[GateResult]) -> None:\n        self._queue = list(results)\n        self.calls: list[tuple[list[str], str]] = []\n\n    def __call__(self, cmd: list[str], cwd: str) -> GateResult:\n        self.calls.append((list(cmd), cwd))\n        if not self._queue:\n            # Default to a passing test if the test forgot to queue one.\n            return GateResult(phase="", exit_code=0, stdout="", stderr="")\n        return self._queue.pop(0)\n\n\ndef _collect(gen):\n    """Drain an async generator into a list."""\n\n    async def _run():\n        out: list[dict[str, Any]] = []\n        async for event in gen:\n            out.append(event)\n        return out\n\n    return _run()\n\n\n# ---------------------------------------------------------------------------\n# 1. Phase transitions in strict order\n# ---------------------------------------------------------------------------\n\n\nclass TestPhaseOrdering:\n    """Each phase must be entered only from the immediately prior state."""\n\n    def test_initial_state_is_empty(self):\n        tdd = TddMode(\n            driver=_make_engine([""]),\n            navigator=_make_engine([""]),\n            test_runner=FakeRunner([]),\n        )\n        assert tdd.state == TddState.EMPTY\n        assert tdd.spec == ""\n        assert tdd.history == []\n\n    async def test_spec_advances_empty_to_spec(self):\n        tdd = TddMode(\n            driver=_make_engine([""]),\n            navigator=_make_engine(["spec: write a failing test for X"]),\n            test_runner=FakeRunner([]),\n        )\n        await _collect(tdd.spec("feature X"))\n        assert tdd.state == TddState.SPEC\n        assert "failing test" in tdd.spec\n        assert tdd.description == "feature X"\n        assert len(tdd.history) == 1\n        assert tdd.history[0].phase == "SPEC"\n        assert tdd.history[0].actor == "navigator"\n\n    async def test_cannot_run_red_from_empty(self):\n        tdd = TddMode(\n            driver=_make_engine([""]),\n            navigator=_make_engine([""]),\n            test_runner=FakeRunner([]),\n        )\n        with pytest.raises(ValueError, match="expected SPEC"):\n            await _collect(tdd.red())\n\n    async def test_cannot_run_green_from_spec(self):\n        """GREEN requires the RED gate to have fired (failing test)."""\n        tdd = TddMode(\n            driver=_make_engine([""]),\n            navigator=_make_engine(["spec"]),\n            test_runner=FakeRunner([]),\n        )\n        await _collect(tdd.spec("feature"))\n        with pytest.raises(ValueError, match="expected RED"):\n            await _collect(tdd.green())\n\n    async def test_cannot_propose_refactor_before_green(self):\n        tdd = TddMode(\n            driver=_make_engine(["wrote test"]),\n            navigator=_make_engine(["spec"]),\n            test_runner=FakeRunner(\n                [GateResult(phase="", exit_code=1, stdout="AssertionError", stderr="")],\n            ),\n        )\n        await _collect(tdd.spec("feature"))\n        await _collect(tdd.red())\n        with pytest.raises(ValueError, match="expected GREEN"):\n            await _collect(tdd.refactor_plan())\n\n    async def test_cannot_apply_refactor_before_plan(self):\n        tdd = TddMode(\n            driver=_make_engine(["wrote test", "wrote code"]),\n            navigator=_make_engine(["spec"]),\n            test_runner=FakeRunner(\n                [\n                    GateResult(phase="", exit_code=1, stdout="AssertionError", stderr=""),\n                    GateResult(phase="", exit_code=0, stdout="1 passed", stderr=""),\n                ],\n            ),\n        )\n        await _collect(tdd.spec("feature"))\n        await _collect(tdd.red())\n        await _collect(tdd.green())\n        with pytest.raises(ValueError, match="expected REFACTOR_PLAN"):\n            await _collect(tdd.refactor_apply())\n\n    async def test_apply_refuses_when_plan_is_empty(self):\n        """Edge case: if the Navigator returned an empty refactor, apply\n        must not proceed — we never send a Driver to "apply nothing.""" ""\n        tdd = TddMode(\n            driver=_make_engine(["wrote test", "wrote code"]),\n            navigator=_make_engine(["spec", "   "]),  # whitespace-only refactor\n            test_runner=FakeRunner(\n                [\n                    GateResult(phase="", exit_code=1, stdout="fail", stderr=""),\n                    GateResult(phase="", exit_code=0, stdout="pass", stderr=""),\n                ],\n            ),\n        )\n        await _collect(tdd.spec("feature"))\n        await _collect(tdd.red())\n        await _collect(tdd.green())\n        await _collect(tdd.refactor_plan())\n        assert tdd.refactor_plan == ""  # whitespace stripped\n        with pytest.raises(ValueError, match="refactor_plan is empty"):\n            await _collect(tdd.refactor_apply())\n\n    async def test_phase_events_fire_in_order(self):\n        """Every phase emits a ``tdd_phase`` event before yielding model\n        events — renderers depend on this ordering.\n        """\n        runner = FakeRunner(\n            [\n                GateResult(phase="", exit_code=1, stdout="fail", stderr=""),  # RED\n                GateResult(phase="", exit_code=0, stdout="pass", stderr=""),  # GREEN\n                GateResult(phase="", exit_code=0, stdout="pass", stderr=""),  # VALIDATE\n            ],\n        )\n        tdd = TddMode(\n            driver=_make_engine(["wrote test", "wrote code", "applied refactor"]),\n            navigator=_make_engine(["spec body", "refactor: rename foo→bar", "approved"]),\n            test_runner=runner,\n        )\n\n        phase_events: list[tuple[str, str]] = []\n        async for event in tdd.run_all("feature"):\n            if event.get("type") == "tdd_phase":\n                phase_events.append((event["phase"], event["actor"]))\n\n        assert phase_events == [\n            ("SPEC", "navigator"),\n            ("RED", "driver"),\n            ("GREEN", "driver"),\n            ("REFACTOR_PLAN", "navigator"),\n            ("REFACTOR_APPLY", "driver"),\n            ("VALIDATE", "navigator"),\n        ]\n        assert tdd.state == TddState.DONE\n\n\n# ---------------------------------------------------------------------------\n# 2. RED phase gate — assertion failure tagged distinctly\n# ---------------------------------------------------------------------------\n\n\nclass TestRedGreenGateTagging:\n    """The RED and GREEN gates are inverse: at RED, a failing test is\n    success; at GREEN, a passing test is success.  Consumers rely on\n    the ``phase`` tag on ``tdd_gate`` events to disambiguate.\n    """\n\n    async def test_red_gate_tags_event_with_red_phase(self):\n        tdd = TddMode(\n            driver=_make_engine(["wrote test"]),\n            navigator=_make_engine(["spec"]),\n            test_runner=FakeRunner(\n                [GateResult(phase="", exit_code=1, stdout="AssertionError: x != y", stderr="")],\n            ),\n        )\n        await _collect(tdd.spec("feature"))\n\n        events = []\n        async for event in tdd.red():\n            events.append(event)\n\n        gate_events = [e for e in events if e.get("type") == "tdd_gate"]\n        assert len(gate_events) == 1\n        gate = gate_events[0]\n        assert gate["phase"] == "RED"\n        assert gate["passed"] is True        # RED-gate passes on failure\n        assert gate["test_passed"] is False  # but the test itself failed\n        assert gate["exit_code"] == 1\n        assert "AssertionError" in gate["stdout"]\n\n    async def test_green_gate_tags_event_with_green_phase(self):\n        runner = FakeRunner(\n            [\n                GateResult(phase="", exit_code=1, stdout="fail", stderr=""),\n                GateResult(phase="", exit_code=0, stdout="1 passed", stderr=""),\n            ],\n        )\n        tdd = TddMode(\n            driver=_make_engine(["wrote test", "wrote code"]),\n            navigator=_make_engine(["spec"]),\n            test_runner=runner,\n        )\n        await _collect(tdd.spec("feature"))\n        await _collect(tdd.red())\n\n        events = []\n        async for event in tdd.green():\n            events.append(event)\n\n        gate_events = [e for e in events if e.get("type") == "tdd_gate"]\n        assert len(gate_events) == 1\n        assert gate_events[0]["phase"] == "GREEN"\n        assert gate_events[0]["passed"] is True\n        assert gate_events[0]["test_passed"] is True\n        assert gate_events[0]["exit_code"] == 0\n\n    async def test_red_passing_test_reverts_to_empty_and_counts_revision(self):\n        """If the RED test passes, the spec was too loose — revert to\n        EMPTY so the Navigator can re-draft a tighter spec.\n        """\n        tdd = TddMode(\n            driver=_make_engine(["wrote vacuous test"]),\n            navigator=_make_engine(["loose spec"]),\n            test_runner=FakeRunner(\n                [GateResult(phase="", exit_code=0, stdout="1 passed", stderr="")],\n            ),\n        )\n        await _collect(tdd.spec("feature"))\n        assert tdd.state == TddState.SPEC\n\n        events = []\n        async for event in tdd.red():\n            events.append(event)\n\n        # Gate event present and indicates failure\n        gate_events = [e for e in events if e.get("type") == "tdd_gate"]\n        assert gate_events[0]["phase"] == "RED"\n        assert gate_events[0]["passed"] is False\n        # State reverted so the caller can call .spec() again\n        assert tdd.state == TddState.EMPTY\n        assert tdd.spec_revisions == 1\n        assert tdd.spec == ""\n\n    async def test_green_failing_test_stays_in_red_state(self):\n        """If GREEN\'s test still fails, we do NOT silently advance."""\n        runner = FakeRunner(\n            [\n                GateResult(phase="", exit_code=1, stdout="fail", stderr=""),  # RED\n                GateResult(phase="", exit_code=1, stdout="still failing", stderr=""),  # GREEN\n            ],\n        )\n        tdd = TddMode(\n            driver=_make_engine(["wrote test", "wrote wrong code"]),\n            navigator=_make_engine(["spec"]),\n            test_runner=runner,\n        )\n        await _collect(tdd.spec("feature"))\n        await _collect(tdd.red())\n        assert tdd.state == TddState.RED\n        await _collect(tdd.green())\n        # GREEN gate failed, so we remain in RED.\n        assert tdd.state == TddState.RED\n\n\n# ---------------------------------------------------------------------------\n# 3. Refactor prompt must contain the Navigator\'s proposal verbatim\n# ---------------------------------------------------------------------------\n\n\nclass TestRefactorContract:\n    """The Navigator\'s refactor suggestion is actually applied before\n    validation — i.e. the prompt the Driver sees for REFACTOR_APPLY must\n    literally include the Navigator\'s words.\n    """\n\n    async def test_refactor_plan_text_flows_into_apply_prompt(self):\n        """Record every prompt the Driver engine sees and assert that\n        the REFACTOR_APPLY prompt contains the Navigator\'s refactor text.\n        """\n        driver_prompts: list[str] = []\n\n        async def capturing_driver_model(**kwargs) -> AsyncGenerator[dict[str, Any], None]:\n            # The user message is the last one with role="user" in the list.\n            messages = kwargs.get("messages", [])\n            for m in reversed(messages):\n                content = getattr(m, "content", m.get("content") if isinstance(m, dict) else None)\n                if isinstance(content, str):\n                    driver_prompts.append(content)\n                    break\n                if isinstance(content, list):\n                    for block in content:\n                        if isinstance(block, dict) and block.get("type") == "text":\n                            driver_prompts.append(block.get("text", ""))\n                            break\n                    else:\n                        continue\n                    break\n            text = "ok"\n            msg = Message(role="assistant", content=[{"type": "text", "text": text}])\n            yield {"type": "text_delta", "text": text}\n            yield {"type": "assistant", "message": msg}\n            yield {"type": "done", "stop_reason": "end_turn", "turns": 1}\n\n        driver = Engine(\n            deps=Deps(call_model=capturing_driver_model),\n            config=EngineConfig(model="test-model"),\n        )\n        navigator = _make_engine(\n            [\n                "spec body",\n                "Refactor: extract compute_total() helper from the if-ladder in cache.py",\n            ],\n        )\n\n        runner = FakeRunner(\n            [\n                GateResult(phase="", exit_code=1, stdout="fail", stderr=""),  # RED\n                GateResult(phase="", exit_code=0, stdout="pass", stderr=""),  # GREEN\n            ],\n        )\n        tdd = TddMode(driver=driver, navigator=navigator, test_runner=runner)\n\n        await _collect(tdd.spec("feature"))\n        await _collect(tdd.red())\n        await _collect(tdd.green())\n        await _collect(tdd.refactor_plan())\n        await _collect(tdd.refactor_apply())\n\n        assert tdd.state == TddState.REFACTOR_APPLY\n        # The Driver received THREE prompts: RED, GREEN, REFACTOR_APPLY.\n        assert len(driver_prompts) == 3\n        apply_prompt = driver_prompts[2]\n        # The Navigator\'s literal refactor text is spliced in.\n        assert "compute_total()" in apply_prompt\n        assert "cache.py" in apply_prompt\n        # And the APPLY template\'s leading sentence is present.\n        assert "Apply the Navigator\'s refactor VERBATIM" in apply_prompt\n\n    async def test_refactor_plan_stored_on_mode(self):\n        """``tdd.refactor_plan`` exposes the Navigator\'s text so the\n        REPL / renderer can display it."""\n        runner = FakeRunner(\n            [\n                GateResult(phase="", exit_code=1, stdout="fail", stderr=""),\n                GateResult(phase="", exit_code=0, stdout="pass", stderr=""),\n            ],\n        )\n        tdd = TddMode(\n            driver=_make_engine(["wrote test", "wrote code"]),\n            navigator=_make_engine(["spec body", "rename foo to bar"]),\n            test_runner=runner,\n        )\n        await _collect(tdd.spec("feature"))\n        await _collect(tdd.red())\n        await _collect(tdd.green())\n        await _collect(tdd.refactor_plan())\n\n        assert tdd.refactor_plan == "rename foo to bar"\n        assert tdd.state == TddState.REFACTOR_PLAN\n        # History entry for REFACTOR_PLAN captured the same text\n        plan_entries = [h for h in tdd.history if h.phase == "REFACTOR_PLAN"]\n        assert len(plan_entries) == 1\n        assert plan_entries[0].text == "rename foo to bar"\n        assert plan_entries[0].actor == "navigator"\n\n\n# ---------------------------------------------------------------------------\n# 4. Full end-to-end run against the stub provider\n# ---------------------------------------------------------------------------\n\n\nclass TestEndToEndStubProvider:\n    """Exercise every phase against the real :class:`StubProvider` — the\n    same deterministic provider the CI smoke tests use.  This proves the\n    wiring (Engine + Deps + phase sequencing + gate) all compose.\n    """\n\n    async def test_full_run_completes_against_stub(self, monkeypatch):\n        from duh.adapters.stub_provider import StubProvider\n\n        # Build two engines, each with its own StubProvider.  The stub\n        # always replies with "stub-ok" — we don\'t care about the text,\n        # we care that the phases run and the state advances.\n        stub = StubProvider(model="stub-model")\n        driver = Engine(\n            deps=Deps(call_model=stub.stream),\n            config=EngineConfig(model="stub-model"),\n        )\n        navigator = Engine(\n            deps=Deps(call_model=stub.stream),\n            config=EngineConfig(model="stub-model"),\n        )\n\n        # Scripted test runner: RED fails, GREEN passes, VALIDATE passes.\n        runner = FakeRunner(\n            [\n                GateResult(phase="", exit_code=1, stdout="E  AssertionError", stderr=""),\n                GateResult(phase="", exit_code=0, stdout="1 passed", stderr=""),\n                GateResult(phase="", exit_code=0, stdout="1 passed", stderr=""),\n            ],\n        )\n        tdd = TddMode(\n            driver=driver,\n            navigator=navigator,\n            test_runner=runner,\n            test_command=["pytest", "-x"],\n        )\n\n        events = []\n        async for event in tdd.run_all("LRU cache drops oldest entry"):\n            events.append(event)\n\n        # Final state reached\n        assert tdd.state == TddState.DONE\n        # All six phases ran\n        phase_names = [e["phase"] for e in events if e.get("type") == "tdd_phase"]\n        assert phase_names == [\n            "SPEC",\n            "RED",\n            "GREEN",\n            "REFACTOR_PLAN",\n            "REFACTOR_APPLY",\n            "VALIDATE",\n        ]\n        # Three gate events: RED (passed=True because test failed),\n        # GREEN (passed=True because test passed), VALIDATE (same).\n        gate_events = [e for e in events if e.get("type") == "tdd_gate"]\n        assert [g["phase"] for g in gate_events] == ["RED", "GREEN", "VALIDATE"]\n        assert all(g["passed"] for g in gate_events)\n        # History has one entry per phase (6 total).\n        assert [h.phase for h in tdd.history] == [\n            "SPEC",\n            "RED",\n            "GREEN",\n            "REFACTOR_PLAN",\n            "REFACTOR_APPLY",\n            "VALIDATE",\n        ]\n        # Spec + refactor_plan populated from the stub\'s canned response.\n        assert tdd.spec != ""\n        assert tdd.refactor_plan != ""\n        # The runner was called three times (once per gate), each time\n        # with the custom test command we passed in.\n        assert len(runner.calls) == 3\n        for cmd, _cwd in runner.calls:\n            assert cmd == ["pytest", "-x"]\n\n\n# ---------------------------------------------------------------------------\n# 5. Misc — defaults, clear(), format_status()\n# ---------------------------------------------------------------------------\n\n\nclass TestMisc:\n    def test_default_test_command_is_pytest(self):\n        tdd = TddMode(\n            driver=_make_engine([""]),\n            navigator=_make_engine([""]),\n        )\n        assert tdd.test_command[0] == "pytest"\n        assert tdd.test_command == DEFAULT_TEST_COMMAND\n\n    async def test_clear_resets_state(self):\n        tdd = TddMode(\n            driver=_make_engine([""]),\n            navigator=_make_engine(["spec body"]),\n            test_runner=FakeRunner([]),\n        )\n        await _collect(tdd.spec("feature"))\n        assert tdd.state == TddState.SPEC\n        tdd.clear()\n        assert tdd.state == TddState.EMPTY\n        assert tdd.spec == ""\n        assert tdd.description == ""\n        assert tdd.history == []\n\n    def test_prompt_templates_contain_role_markers(self):\n        """Loose safety-net: if someone rewrites a template and drops the\n        role marker, the other agent might try to play both parts."""\n        assert "NAVIGATOR" in SPEC_PROMPT\n        assert "DRIVER" in RED_PROMPT\n        assert "{spec}" in RED_PROMPT\n        assert "{refactor_plan}" in REFACTOR_APPLY_PROMPT\n\n    async def test_gate_result_gate_passed_inversion(self):\n        """Unit test for the RED-is-inverted property on GateResult."""\n        red_fail = GateResult(phase="RED", exit_code=1, stdout="", stderr="")\n        red_pass = GateResult(phase="RED", exit_code=0, stdout="", stderr="")\n        green_fail = GateResult(phase="GREEN", exit_code=1, stdout="", stderr="")\n        green_pass = GateResult(phase="GREEN", exit_code=0, stdout="", stderr="")\n\n        # RED: failing test is gate-pass; passing test is gate-fail\n        assert red_fail.gate_passed is True\n        assert red_pass.gate_passed is False\n        # GREEN / VALIDATE: passing test is gate-pass\n        assert green_fail.gate_passed is False\n        assert green_pass.gate_passed is True\n')
