@@ -0,0 +1,168 @@
+"""TDD Double-Agent Flow.
+
+Implements a 6-phase red-green-refactor cycle using a Navigator and Driver.
+"""
+
+from __future__ import annotations
+
+import argparse
+import logging
+import os
+import sys
+
+from duh.cli import exit_codes
+from duh.cli.session_builder import (
+    ProviderResolutionError,
+    SessionBuilder,
+    SessionBuilderOptions,
+    _BuilderPatchTargets,
+)
+from duh.kernel.deps import Deps
+from duh.kernel.engine import Engine, EngineConfig
+from duh.constitution import build_system_prompt, ConstitutionConfig
+
+logger = logging.getLogger(__name__)
+
+async def run_tdd(args: argparse.Namespace) -> int:
+    """Execute the double-agent TDD flow."""
+    opts = SessionBuilderOptions(
+        include_skills_in_tools=True,
+        include_deferred_tools=True,
+        include_memory_prompt=False,
+        include_env_block=True,
+        include_templates_hint=False,
+        honour_tool_filters=True,
+        approver_mode="auto", # Full automation
+        wire_audit_logger_in_deps=True,
+        allow_session_id_override=False,
+    )
+    
+    # We use a planner constitution for Navigator and coder for Driver
+    nav_base_prompt = build_system_prompt(ConstitutionConfig(agent_type="planner"))
+    driver_base_prompt = build_system_prompt(ConstitutionConfig(agent_type="coder"))
+
+    # Build shared session context
+    builder = SessionBuilder(args, opts, cwd=os.getcwd())
+    try:
+        build = await builder.build()
+    except ProviderResolutionError as exc:
+        if exc.provider_name is None:
+            from duh.cli.runner import _no_provider_message
+            sys.stderr.write(_no_provider_message())
+        else:
+            sys.stderr.write(f"Error: {exc.message}\n")
+        return exit_codes.PROVIDER_ERROR
+
+    # Build system prompts with env/git context from SessionBuilder
+    nav_sys_prompt, _ = builder._build_system_prompt(build.loaded_skills, [])
+    nav_sys_prompt = nav_base_prompt + "\n\n" + nav_sys_prompt
+    
+    driver_sys_prompt, _ = builder._build_system_prompt(build.loaded_skills, [])
+    driver_sys_prompt = driver_base_prompt + "\n\n" + driver_sys_prompt
+
+    # Create the two agents
+    nav_config = EngineConfig(
+        model=build.model,
+        fallback_model=getattr(args, "fallback_model", None),
+        system_prompt=nav_sys_prompt,
+        tools=build.tools,
+        max_turns=getattr(args, "max_turns", 100),
+        cwd=builder.cwd,
+    )
+    navigator = Engine(deps=build.deps, config=nav_config, session_store=build.store)
+
+    driver_config = EngineConfig(
+        model=build.model,
+        fallback_model=getattr(args, "fallback_model", None),
+        system_prompt=driver_sys_prompt,
+        tools=build.tools,
+        max_turns=getattr(args, "max_turns", 100),
+        cwd=builder.cwd,
+    )
+    driver = Engine(deps=build.deps, config=driver_config, session_store=build.store)
+
+    async def _run_agent_phase(engine: Engine, phase_name: str, prompt: str) -> tuple[int, str]:
+        print(f"\n\033[1;34m=== {phase_name} ===\033[0m\n")
+        sys.stdout.write(f"\033[36mPrompt:\033[0m {prompt}\n\n")
+        result = ""
+        exit_code = 0
+        try:
+            async for event in engine.run(prompt):
+                event_type = event.get("type", "")
+                if event_type == "text_delta":
+                    text = event.get("text", "")
+                    result += text
+                    sys.stdout.write(text)
+                    sys.stdout.flush()
+                elif event_type == "tool_use":
+                    name = event.get("name", "?")
+                    inp = event.get("input", {})
+                    summary = ", ".join(f"{k}={v!r}" for k, v in list(inp.items())[:2])
+                    sys.stderr.write(f"\n  \033[33m> {name}\033[0m({summary})\n")
+                    sys.stderr.flush()
+                elif event_type == "tool_result":
+                    if event.get("is_error"):
+                        out = str(event.get("output", ""))[:200]
+                        sys.stderr.write(f"  \033[31m! {out}\033[0m\n")
+                elif event_type == "error":
+                    sys.stderr.write(f"\n\033[31mError: {event.get('error')}\033[0m\n")
+                    exit_code = 1
+        except KeyboardInterrupt:
+            sys.stderr.write("\n\033[31mInterrupted by user.\033[0m\n")
+            raise
+        print("\n")
+        return exit_code, result
+
+    try:
+        # Phase 1
+        code, spec = await _run_agent_phase(
+            navigator,
+            "Phase 1/6: Navigator drafts test spec",
+            f"Draft a detailed TDD test spec for the following feature request. Focus only on the test spec.\n\nFeature: {args.prompt}"
+        )
+        if code != 0: return code
+
+        # Phase 2
+        code, _ = await _run_agent_phase(
+            driver,
+            "Phase 2/6: Driver writes RED tests",
+            f"Implement the test described in this spec. Ensure the test fails (RED phase). Run the test using your shell tool to prove it fails.\n\nSpec:\n{spec}"
+        )
+        if code != 0: return code
+
+        # Phase 3
+        code, _ = await _run_agent_phase(
+            driver,
+            "Phase 3/6: Driver writes GREEN code",
+            "The tests should now be failing. Write the minimum code to make the tests pass (GREEN phase). Run the tests again to prove they pass."
+        )
+        if code != 0: return code
+
+        # Phase 4
+        code, refactor_proposal = await _run_agent_phase(
+            navigator,
+            "Phase 4/6: Navigator proposes refactor",
+            "The Driver has implemented the tests and made them pass. Review the new code and tests. Suggest a refactoring to improve design, readability, or performance without changing behavior."
+        )
+        if code != 0: return code
+
+        # Phase 5
+        code, _ = await _run_agent_phase(
+            driver,
+            "Phase 5/6: Driver applies refactor",
+            f"Apply the following refactoring proposal. Make sure the tests still pass.\n\nProposal:\n{refactor_proposal}"
+        )
+        if code != 0: return code
+
+        # Phase 6
+        code, _ = await _run_agent_phase(
+            navigator,
+            "Phase 6/6: Navigator validates",
+            "The Driver has applied the refactoring. Validate that the refactoring was applied cleanly and all tests are passing. Run the tests yourself using the shell tool to verify."
+        )
+        if code != 0: return code
+
+        return 0
+    finally:
+        build.close_structured_logger()
+        await build.teardown_mcp()
