+"""Tests for the TDD Double-Agent Flow."""
+
+from __future__ import annotations
+
+import argparse
+from unittest.mock import AsyncMock, patch
+
+import pytest
+
+from duh.cli import exit_codes
+from duh.cli.tdd import run_tdd
+
+def _make_tdd_args(**overrides):
+    defaults = dict(
+        prompt="Add a simple calculator class",
+        provider="stub", # use stub to avoid network
+        debug=False,
+        max_turns=10,
+        mcp_config=None,
+        command="tdd",
+    )
+    defaults.update(overrides)
+    return argparse.Namespace(**defaults)
+
+class TestRunTDD:
+
+    @pytest.mark.asyncio
+    @patch("duh.cli.tdd.Engine.run")
+    async def test_tdd_flow_success(self, mock_engine_run):
+        """Test that the 6-phase flow executes correctly and finishes with SUCCESS."""
+        args = _make_tdd_args()
+
+        # We will track which phase we're in by counting calls to Engine.run.
+        # run_tdd creates two engines, but they both call the mocked Engine.run.
+        # We can just return different text for each phase.
+        
+        call_count = 0
+        
+        async def fake_run(*a, **kw):
+            nonlocal call_count
+            call_count += 1
+            yield {"type": "text_delta", "text": f"Phase {call_count} response"}
+            yield {"type": "done", "turns": 1}
+
+        mock_engine_run.side_effect = fake_run
+
+        # Execute the flow
+        code = await run_tdd(args)
+
+        assert code == 0
+        assert call_count == 6
+
+    @pytest.mark.asyncio
+    @patch("duh.cli.tdd.Engine.run")
+    async def test_tdd_flow_error(self, mock_engine_run):
+        """Test that the flow aborts and returns an error code on failure."""
+        args = _make_tdd_args()
+        
+        async def fake_run(*a, **kw):
+            yield {"type": "error", "error": "Something went wrong in the model"}
+            yield {"type": "done", "turns": 1}
+
+        mock_engine_run.side_effect = fake_run
+
+        code = await run_tdd(args)
+        
+        assert code == 1
