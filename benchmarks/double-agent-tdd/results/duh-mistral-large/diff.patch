+        # Should go back to SPEC_DRAFT after test passes unexpectedly
+        assert tdd.current_phase == TDDPhase.SPEC_DRAFT
+        assert any(step.phase == TDDPhase.SPEC_DRAFT and step.done for step in tdd.steps)
+        
+        # Should have two SPEC_DRAFT steps (original + revision)
+        spec_draft_steps = [s for s in tdd.steps if s.phase == TDDPhase.SPEC_DRAFT]
+        assert len(spec_draft_steps) == 2
+
+    @pytest.mark.asyncio
+    async def test_refactor_validation_fails(self):
+        """Test handling when refactor validation fails."""
+        engine = _make_engine()
+        tdd = TDDPlanMode(engine)
+        
+        # Mock the test run to fail after refactor
+        with patch.object(tdd, '_run_test') as mock_run_test:
