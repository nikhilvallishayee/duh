+"""Integration tests against fakeredis."""
+
+import fakeredis
+import pytest
+
+from ratelimit import (
+    RedisBackend,
+    SlidingWindowLimiter,
+    TokenBucketLimiter,
+)
+
+
+def test_token_bucket_basic(fake_redis):
+    backend = RedisBackend(fake_redis, fail_open=False)
+    lim = TokenBucketLimiter(capacity=3, refill_per_sec=1, backend=backend)
+    for _ in range(3):
+        assert lim.enforce("a").allowed
+    d = lim.enforce("a")
+    assert not d.allowed
+    assert d.retry_after_ms > 0
+
+
+def test_sliding_window_basic(fake_redis):
+    backend = RedisBackend(fake_redis, fail_open=False)
+    lim = SlidingWindowLimiter(capacity=3, period_ms=60_000, backend=backend)
+    for _ in range(3):
+        assert lim.enforce("a").allowed
+    assert not lim.enforce("a").allowed
+
+
+def test_redis_key_structure(fake_redis):
+    backend = RedisBackend(fake_redis, fail_open=False, key_prefix="rl:")
+    lim = TokenBucketLimiter(capacity=3, refill_per_sec=1, backend=backend)
+    lim.enforce("tenant:42")
+    assert fake_redis.exists(b"rl:tb:tenant:42")
+    sw = SlidingWindowLimiter(capacity=3, period_ms=1000, backend=backend)
+    sw.enforce("tenant:42")
+    assert fake_redis.exists(b"rl:sw:tenant:42")
+
+
+def test_ttl_is_set(fake_redis):
+    backend = RedisBackend(fake_redis, fail_open=False)
+    lim = TokenBucketLimiter(capacity=3, refill_per_sec=1, backend=backend)
+    lim.enforce("k")
+    ttl = fake_redis.pttl(b"rl:tb:k")
+    assert ttl > 0
+
+
+def test_fail_open_on_connection_error():
+    """Kill the client so every call raises."""
+
+    class DeadClient:
+        def register_script(self, src):
+            class _S:
+                def __call__(self, *, keys, args):
+                    raise ConnectionError("boom")
+
+            return _S()
+
+    backend = RedisBackend(DeadClient(), fail_open=True)
+    lim = TokenBucketLimiter(capacity=3, refill_per_sec=1, backend=backend)
+    d = lim.enforce("k")
+    assert d.allowed
+    assert d.remaining == -1
+
+
+def test_fail_closed_on_connection_error():
+    class DeadClient:
+        def register_script(self, src):
+            class _S:
+                def __call__(self, *, keys, args):
+                    raise ConnectionError("boom")
+
+            return _S()
+
+    backend = RedisBackend(DeadClient(), fail_open=False)
+    lim = TokenBucketLimiter(capacity=3, refill_per_sec=1, backend=backend)
+    d = lim.enforce("k")
+    assert not d.allowed
+    assert d.retry_after_ms == 1000
+
+
+def test_redis_atomicity_no_lost_update(fake_redis):
+    """A thin but pointed test: two processes sharing one Redis should
+    collectively consume exactly `capacity` tokens.
+
+    Emulated by two `RedisBackend` objects sharing one fakeredis — any
+    lost-update bug would show up as allowed > capacity.
+    """
+    import threading
+
+    backend_a = RedisBackend(fake_redis, fail_open=False)
+    backend_b = RedisBackend(fake_redis, fail_open=False)
+    lim_a = TokenBucketLimiter(capacity=20, refill_per_sec=0.0001, backend=backend_a)
+    lim_b = TokenBucketLimiter(capacity=20, refill_per_sec=0.0001, backend=backend_b)
+
+    hits = [0]
+    lock = threading.Lock()
+    start = threading.Event()
+
+    def worker(lim):
+        start.wait()
+        if lim.enforce("shared").allowed:
+            with lock:
+                hits[0] += 1
+
+    threads = []
+    for _ in range(60):
+        threads.append(threading.Thread(target=worker, args=(lim_a,)))
+        threads.append(threading.Thread(target=worker, args=(lim_b,)))
+    for t in threads:
+        t.start()
+    start.set()
+    for t in threads:
+        t.join()
+
+    assert hits[0] == 20
