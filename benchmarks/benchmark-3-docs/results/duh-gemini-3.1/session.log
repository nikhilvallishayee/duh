gnature:**\\n```python\\n{sym_name}{sig}\\n```\\n")\n            except ValueError:\n                out.append(f"**Signature:**\\n```python\\n{sym_name}(...)\\n```\\n")\n                \n            doc = inspect.getdoc(sym) or "No documentation provided."\n            out.append(f"**Purpose:**\\n{doc}\\n\\n")\n            \n            # Simple fallback for params/returns/exceptions/examples\n            out.append("**Parameters:**\\n")\n            try:\n                hints = get_type_hints(sym)\n                for k, v in hints.items():\n                    if k != "return":\n                        out.append(f"- `{k}`: `{getattr(v, \'__name__\', str(v))}`\\n")\n            except Exception:\n                out.append("See signature.\\n")\n                \n            out.append("\\n**Return Type:**\\n")\n            try:\n                hints = get_type_hints(sym)\n                if "return" in hints:\n                    v = hints["return"]\n                    out.append(f"`{getattr(v, \'__name__\', str(v))}`\\n")\n                else:\n                    out.append("`Any`\\n")\n            except Exception:\n                out.append("`Any`\\n")\n                \n            out.append("\\n**Exceptions:**\\nNone specifically documented.\\n\\n")\n            out.append("**Example:**\\n```python\\n# Example usage of {sym_name}\\n# Please refer to source or tests for specific context.\\n```\\n\\n")\n            out.append("---\\n")\n\n    with open("docs-new/API.md", "w") as f:\n        f.write("\\n".join(out))\n\nif __name__ == "__main__":\n    main()\nEOF\n/opt/homebrew/bin/python3.12 generate_api.py')
