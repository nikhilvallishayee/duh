ents = AgentSequence([\n        _ok("spec"),\n        _ok("red"),\n        _ok("green"),\n        _ok("refactor suggestion"),\n        _ok("refactor applied"),\n        _ok("validated"),\n    ])\n    tests = TestSequence([\n        (1, "AssertionError: expected 2 == 3"),\n        (0, "1 passed in 0.02s"),\n        (0, "1 passed in 0.02s"),\n    ])\n    session = DoubleAgentTDDSession(\n        task="fix bug",\n        test_command="pytest tests/unit/test_bug.py -q",\n        agent_runner=agents,\n        test_runner=tests,\n    )\n\n    outcome = await session.run()\n\n    red_record = outcome.phases[1]\n    green_record = outcome.phases[2]\n    assert red_record.phase is TDDPhase.DRIVER_RED\n    assert red_record.test_exit_code == 1\n    assert "AssertionError" in red_record.test_output\n    assert green_record.phase is TDDPhase.DRIVER_GREEN\n    assert green_record.test_exit_code == 0\n    assert "passed" in green_record.test_output\n\n\n@pytest.mark.asyncio\nasync def test_navigator_refactor_suggestion_is_applied_before_validation():\n    agents = AgentSequence([\n        _ok("spec"),\n        _ok("red"),\n        _ok("green"),\n        _ok("Extract helper named normalize_user_id"),\n        _ok("Applied normalize_user_id helper refactor"),\n        _ok("Validation: normalize_user_id refactor is present and tests pass"),\n    ])\n    tests = TestSequence([\n        (1, "AssertionError"),\n        (0, "1 passed"),\n        (0, "1 passed"),\n    ])\n    session = DoubleAgentTDDSession(\n        task="normalize ids",\n        test_command="pytest -q",\n        agent_runner=agents,\n        test_runner=tests,\n    )\n\n    outcome = await session.run()\n\n    validate_prompt = agents.calls[-1]["prompt"]\n    assert "Extract helper named normalize_user_id" in validate_prompt\n    assert "Applied normalize_user_id helper refactor" in validate_prompt\n    assert outcome.phases[4].phase is TDDPhase.DRIVER_REFACTOR\n    assert outcome.phases[5].phase is TDDPhase.NAVIGATOR_VALIDATE\n\n\n@pytest.mark.asyncio\nasync def test_red_not_failing_triggers_navigator_revision():\n    agents = AgentSequence([\n        _ok("spec"),\n        _ok("red"),\n        _ok("revised spec"),\n    ])\n    tests = TestSequence([\n        (0, "1 passed unexpectedly"),\n    ])\n    session = DoubleAgentTDDSession(\n        task="tighten spec",\n        test_command="pytest -q",\n        agent_runner=agents,\n        test_runner=tests,\n    )\n\n    outcome = await session.run()\n\n    assert outcome.success is False\n    assert outcome.status == "red_not_failing"\n    assert [record.phase for record in outcome.phases] == [\n        TDDPhase.NAVIGATOR_SPEC,\n        TDDPhase.DRIVER_RED,\n        TDDPhase.NAVIGATOR_SPEC,\n    ]\n\n\n@pytest.mark.asyncio\nasync def test_full_flow_completes_end_to_end_against_stub_provider():\n    calls = []\n\n    async def fake_agent_runner(**kwargs):\n        calls.append(kwargs)\n        prompt = kwargs["prompt"]\n        if "Draft a tight TDD test spec" in prompt:\n            return _ok("Spec: add a focused failing test")\n        if "Write the failing test" in prompt:\n            return _ok("Driver wrote failing test")\n        if "Make the RED test pass" in prompt:\n            return _ok("Driver made minimal code change")\n        if "Propose one behavior-preserving refactor" in prompt:\n            return _ok("Refactor: extract small helper")\n        if "Apply the Navigator\'s refactor" in prompt:\n            return _ok("Driver applied helper extraction")\n        return _ok("Navigator validated final state")\n\n    tests = TestSequence([\n        (1, "AssertionError: failing test"),\n        (0, "1 passed"),\n        (0, "1 passed"),\n    ])\n    session = DoubleAgentTDDSession(\n        task="implement helper",\n        test_command="pytest tests/unit/test_helper.py -q",\n        parent_model="stub-model",\n        agent_runner=fake_agent_runner,\n        test_runner=tests,\n    )\n\n    outcome = await session.run()\n\n    assert outcome.success is True\n    assert outcome.status == "completed"\n    assert len(calls) == 6\n    assert all(call["parent_model"] == "stub-model" for call in calls)\n    assert tests.calls == [\n        ("pytest tests/unit/test_helper.py -q", "."),\n        ("pytest tests/unit/test_helper.py -q", "."),\n        ("pytest tests/unit/test_helper.py -q", "."),\n    ]\n\n\ndef test_format_tdd_outcome_includes_phase_status():\n    from duh.tdd import PhaseRecord, TDDOutcome\n\n    outcome = TDDOutcome(\n        success=True,\n        status="completed",\n        phases=[PhaseRecord(phase=TDDPhase.NAVIGATOR_SPEC, actor="navigator", summary="spec")],\n    )\n\n    text = format_tdd_outcome(outcome)\n\n    assert "Double-agent TDD: completed" in text\n    assert "navigator_spec" in text\n\n\n@pytest.mark.asyncio\nasync def test_run_tdd_command_returns_zero_on_success(monkeypatch, capsys):\n    class FakeSession:\n        def __init__(self, **kwargs):\n            self.kwargs = kwargs\n\n        async def run(self):\n            from duh.tdd import PhaseRecord, TDDOutcome\n            return TDDOutcome(True, "completed", [\n                PhaseRecord(phase=TDDPhase.NAVIGATOR_SPEC, actor="navigator", summary="spec")\n            ])\n\n    monkeypatch.setattr("duh.tdd.DoubleAgentTDDSession", FakeSession)\n    args = argparse.Namespace(\n        task="do work",\n        test_command="pytest -q",\n        driver_agent_type="coder",\n        navigator_agent_type="reviewer",\n        driver_model="inherit",\n        navigator_model="inherit",\n        model="stub-model",\n    )\n\n    code = await run_tdd_command(args)\n\n    assert code == 0\n    assert "Double-agent TDD: completed" in capsys.readouterr().out\n')
