@@ -0,0 +1,32 @@
+import functools
+import inspect
+from typing import Callable, Any
+
+from ratelimit.limiters import RateLimiter
+
+class RateLimitExceeded(Exception):
+    def __init__(self, retry_after_ms: int):
+        self.retry_after_ms = retry_after_ms
+        super().__init__(f"Rate limit exceeded. Retry after {retry_after_ms}ms")
+
+def rate_limit(limiter: RateLimiter, key_fn: Callable[..., str], cost: int = 1):
+    def decorator(func: Callable[..., Any]):
+        if inspect.iscoroutinefunction(func):
+            @functools.wraps(func)
+            async def async_wrapper(*args, **kwargs):
+                key = key_fn(*args, **kwargs)
+                decision = limiter.enforce(key, cost)
+                if not decision.allowed:
+                    raise RateLimitExceeded(decision.retry_after_ms)
+                return await func(*args, **kwargs)
+            return async_wrapper
+        else:
+            @functools.wraps(func)
+            def sync_wrapper(*args, **kwargs):
+                key = key_fn(*args, **kwargs)
+                decision = limiter.enforce(key, cost)
+                if not decision.allowed:
+                    raise RateLimitExceeded(decision.retry_after_ms)
+                return func(*args, **kwargs)
+            return sync_wrapper
+    return decorator
