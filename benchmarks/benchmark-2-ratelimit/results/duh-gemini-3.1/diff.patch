@@ -0,0 +1,42 @@
+import pytest
+import time
+from ratelimit import InMemoryBackend, TokenBucketLimiter, SlidingWindowLimiter
+
+def test_token_bucket_limiter():
+    backend = InMemoryBackend()
+    # capacity 5, refill 5 per second -> full in 1 second
+    limiter = TokenBucketLimiter(backend, capacity=5, refill_rate=5.0)
+    
+    key = "test_tb"
+    # Should allow 5 requests
+    for _ in range(5):
+        decision = limiter.enforce(key)
+        assert decision.allowed is True
+        
+    # 6th request should fail
+    decision = limiter.enforce(key)
+    assert decision.allowed is False
+    assert decision.retry_after_ms > 0
+    assert decision.remaining == 0
+
+    # Wait for 1 token (200ms)
+    time.sleep(0.25)
+    decision = limiter.enforce(key)
+    assert decision.allowed is True
+
+def test_sliding_window_limiter():
+    backend = InMemoryBackend()
+    # capacity 3 in 500ms
+    limiter = SlidingWindowLimiter(backend, capacity=3, window_size_ms=500)
+    
+    key = "test_sw"
+    for _ in range(3):
+        assert limiter.enforce(key).allowed is True
+        
+    decision = limiter.enforce(key)
+    assert decision.allowed is False
+    assert decision.remaining == 0
+    assert decision.retry_after_ms > 0
+
+    time.sleep(0.6)
+    assert limiter.enforce(key).allowed is True
