+"""CLI driver for the ``duh tdd`` subcommand.
+
+Wraps :func:`duh.kernel.double_agent_tdd.run_flow` so the red-green-
+refactor flow can be triggered from the shell::
+
+    duh tdd "add a widget-sum endpoint"
+    duh tdd "fix bug in parser" --test-cmd "pytest tests/unit -q"
+
+See ADR-076 for the design. This module is deliberately thin — it
+builds the same ``Deps`` + tool set a print-mode session would, then
+hands control to the kernel flow.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import logging
+import os
+import sys
+from typing import Any
+
+from duh.kernel.double_agent_tdd import (
+    TDDConfig,
+    TDDFlow,
+    format_event,
+    run_flow,
+)
+
+logger = logging.getLogger("duh")
+
+
+def _event_to_json(event: dict[str, Any]) -> dict[str, Any]:
+    """Render a flow event as a JSON-safe dict (artifact → dict)."""
+    out: dict[str, Any] = {k: v for k, v in event.items() if k != "artifact"}
+    artifact = event.get("artifact")
+    if artifact is not None:
+        out["artifact"] = {
+            "phase": getattr(artifact.phase, "value", str(artifact.phase)),
+            "role": getattr(artifact.role, "value", None) if artifact.role else None,
+            "prompt": artifact.prompt,
+            "output": artifact.output,
+            "error": artifact.error,
+        }
+        tr = artifact.test_run
+        if tr is not None:
+            out["artifact"]["test_run"] = {
+                "passed": tr.passed,
+                "exit_code": tr.exit_code,
+                "assertion_failure": tr.assertion_failure,
+            }
+    return out
+
+
+async def run_tdd(args: argparse.Namespace) -> int:
+    """Entry point from ``duh.cli.main``.
+
+    Builds a runner/deps pair the same way print mode does, then streams
+    the flow to stdout (text or JSON, per ``--tdd-output``).
+    """
+    # Import lazily to keep ``duh tdd --help`` fast.
+    from duh.adapters.anthropic import AnthropicProvider
+    from duh.adapters.native_executor import NativeExecutor
+    from duh.cli import exit_codes
+    from duh.cli.runner import BRIEF_INSTRUCTION, SYSTEM_PROMPT
+    from duh.cli.session_builder import (
+        ProviderResolutionError,
+        SessionBuilder,
+        SessionBuilderOptions,
+        _BuilderPatchTargets,
+    )
+    from duh.kernel.deps import Deps
+    from duh.kernel.engine import Engine, EngineConfig
+    from duh.providers.registry import get_anthropic_api_key
+    from duh.tools.registry import get_all_tools
+
+    feature = (args.feature or "").strip()
+    if not feature:
+        sys.stderr.write("duh tdd: <feature> is required\n")
+        return 2
+
+    options = SessionBuilderOptions(
+        include_skills_in_tools=True,
+        include_deferred_tools=False,
+        include_memory_prompt=False,
+        include_env_block=True,
+        include_templates_hint=False,
+        include_model_context_block=False,
+        honour_tool_filters=True,
+        approver_mode="print_mode",
+        wire_hook_registry_in_deps=False,
+        wire_audit_logger_in_deps=True,
+        honour_tool_choice=False,
+        honour_thinking=True,
+        allow_session_id_override=True,
+        log_skip_perms_warning=True,
+        default_system_prompt=SYSTEM_PROMPT,
+        brief_instruction=BRIEF_INSTRUCTION,
+    )
+    patch_targets = _BuilderPatchTargets(
+        engine_cls=Engine,
+        engine_config_cls=EngineConfig,
+        deps_cls=Deps,
+        native_executor_cls=NativeExecutor,
+        get_all_tools_fn=get_all_tools,
+    )
+    builder = SessionBuilder(
+        args, options, cwd=os.getcwd(), debug=getattr(args, "debug", False),
+        patch_targets=patch_targets,
+    )
+    try:
+        build = await builder.build(
+            provider_factories={
+                "anthropic": lambda m: AnthropicProvider(
+                    api_key=get_anthropic_api_key(), model=m
+                ),
+            }
+        )
+    except ProviderResolutionError as exc:
+        sys.stderr.write(f"Error: {exc.message}\n")
+        return exit_codes.PROVIDER_ERROR
+
+    config = TDDConfig(
+        cwd=os.getcwd(),
+        test_cmd=args.test_cmd or "python -m pytest -x -q",
+        driver_model=args.driver_model or "inherit",
+        navigator_model=args.navigator_model or "inherit",
+        max_turns=args.tdd_max_turns or 30,
+        test_timeout=args.test_timeout,
+        max_spec_revisions=args.max_spec_revisions,
+    )
+
+    as_json = getattr(args, "tdd_output", "text") == "json"
+    any_error = False
+
+    try:
+        async for event in run_flow(
+            feature,
+            deps=build.deps,
+            tools=build.tools,
+            parent_model=build.model,
+            config=config,
+        ):
+            if event.get("type") == "tdd_error":
+                any_error = True
+            if as_json:
+                sys.stdout.write(json.dumps(_event_to_json(event)) + "\n")
+            else:
+                sys.stdout.write(format_event(event) + "\n")
+            sys.stdout.flush()
+    except KeyboardInterrupt:
+        sys.stderr.write("\nInterrupted during TDD flow.\n")
+        await build.teardown_mcp()
+        build.close_structured_logger()
+        return 130
+
+    build.close_structured_logger()
+    await build.teardown_mcp()
+    return 1 if any_error else 0
+
+
+def add_tdd_subcommand(subparsers: argparse._SubParsersAction) -> None:
+    """Register the ``tdd`` subparser. Called from ``duh.cli.parser``."""
+    p = subparsers.add_parser(
+        "tdd",
+        help="Run the double-agent TDD flow (ADR-076).",
+        description=(
+            "Drive a strict six-phase red-green-refactor flow with a "
+            "Driver subagent (writes tests + code) and a Navigator "
+            "subagent (drafts spec, reviews, validates). See ADR-076 "
+            "for the full protocol."
+        ),
+    )
+    p.add_argument(
+        "feature", type=str,
+        help="Short description of the feature/bug the flow should address.",
+    )
+    p.add_argument(
+        "--test-cmd", type=str, default=None,
+        help="Shell command to run the project's tests "
+             "(default: 'python -m pytest -x -q').",
+    )
+    p.add_argument(
+        "--driver-model", type=str, default=None,
+        help="Model tier for the Driver subagent: "
+             "small / medium / large / inherit (default: inherit).",
+    )
+    p.add_argument(
+        "--navigator-model", type=str, default=None,
+        help="Model tier for the Navigator subagent: "
+             "small / medium / large / inherit (default: inherit).",
+    )
+    p.add_argument(
+        "--test-timeout", type=float, default=120.0,
+        help="Timeout for each test-runner invocation in seconds "
+             "(default: 120).",
+    )
+    p.add_argument(
+        "--max-spec-revisions", type=int, default=2,
+        help="How many times Navigator may tighten the spec after a "
+             "RED-phase false-positive (default: 2).",
+    )
+    p.add_argument(
+        "--tdd-max-turns", type=int, default=30,
+        help="Maximum agentic turns per sub-agent invocation (default: 30).",
+    )
+    p.add_argument(
+        "--tdd-output", choices=["text", "json"], default="text",
+        help="Stream events as human text (default) or line-delimited JSON.",
+    )
