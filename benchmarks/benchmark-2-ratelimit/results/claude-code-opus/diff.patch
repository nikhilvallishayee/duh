@@ -0,0 +1,85 @@
+"""Tests for RateLimitMiddleware using Starlette's TestClient."""
+
+from __future__ import annotations
+
+import pytest
+from starlette.applications import Starlette
+from starlette.responses import PlainTextResponse
+from starlette.routing import Route
+from starlette.testclient import TestClient
+
+from ratelimit import (
+    InMemoryBackend,
+    RateLimitMiddleware,
+    TokenBucketLimiter,
+)
+
+
+def _build_app(limiter):
+    async def hello(request):
+        return PlainTextResponse("hi")
+
+    async def health(request):
+        return PlainTextResponse("ok")
+
+    app = Starlette(routes=[Route("/", hello), Route("/health", health)])
+
+    def key_fn(scope):
+        # Use a header so tests can simulate distinct clients.
+        for name, value in scope.get("headers") or []:
+            if name == b"x-user":
+                return f"u:{value.decode()}"
+        return "u:default"
+
+    return RateLimitMiddleware(
+        app, limiter, key_fn=key_fn, exempt_paths=("/health",)
+    )
+
+
+def test_middleware_passes_through_and_emits_headers():
+    lim = TokenBucketLimiter(capacity=3, refill_rate=0.001, backend=InMemoryBackend())
+    app = _build_app(lim)
+    client = TestClient(app)
+    r = client.get("/", headers={"x-user": "alice"})
+    assert r.status_code == 200
+    assert r.text == "hi"
+    assert r.headers["x-ratelimit-limit"] == "3"
+    assert int(r.headers["x-ratelimit-remaining"]) == 2
+    assert int(r.headers["x-ratelimit-reset"]) > 0
+
+
+def test_middleware_429_with_retry_after():
+    lim = TokenBucketLimiter(capacity=2, refill_rate=0.001, backend=InMemoryBackend())
+    app = _build_app(lim)
+    client = TestClient(app)
+    r1 = client.get("/", headers={"x-user": "bob"})
+    r2 = client.get("/", headers={"x-user": "bob"})
+    r3 = client.get("/", headers={"x-user": "bob"})
+    assert r1.status_code == 200
+    assert r2.status_code == 200
+    assert r3.status_code == 429
+    assert "retry-after" in r3.headers
+    assert int(r3.headers["retry-after"]) >= 1
+    assert r3.headers["x-ratelimit-limit"] == "2"
+    assert r3.headers["x-ratelimit-remaining"] == "0"
+
+
+def test_middleware_per_key_isolation():
+    lim = TokenBucketLimiter(capacity=1, refill_rate=0.001, backend=InMemoryBackend())
+    app = _build_app(lim)
+    client = TestClient(app)
+    assert client.get("/", headers={"x-user": "a"}).status_code == 200
+    assert client.get("/", headers={"x-user": "b"}).status_code == 200
+    assert client.get("/", headers={"x-user": "a"}).status_code == 429
+
+
+def test_middleware_exempts_health_check():
+    lim = TokenBucketLimiter(capacity=1, refill_rate=0.001, backend=InMemoryBackend())
+    app = _build_app(lim)
+    client = TestClient(app)
+    # Drain.
+    client.get("/", headers={"x-user": "a"})
+    # Health still passes and carries no rate-limit headers.
+    r = client.get("/health")
+    assert r.status_code == 200
+    assert "x-ratelimit-limit" not in r.headers
diff --git a/tests/test_property.py b/tests/test_property.py
new file mode 100644
index 0000000..870eaf6
--- /dev/null
+++ b/tests/test_property.py
@@ -0,0 +1,133 @@
+"""Property-based invariants.
+
+The core invariant we prove (via hypothesis-generated traces):
+
+    At any time t, for any sliding-window limiter of capacity C and
+    period P, the number of admitted requests with timestamps in
+    (t - P, t] is <= C.
+
+For token bucket, we prove:
+
+    At all times, 0 <= tokens <= capacity. Allowing k requests costs
+    exactly sum(costs_of_admitted) tokens, offset by
+    elapsed_time_between_first_and_last * refill_rate (capped at
+    capacity).
+"""
+
+from __future__ import annotations
+
+from hypothesis import HealthCheck, given, settings
+from hypothesis import strategies as st
+
+from ratelimit import (
+    InMemoryBackend,
+    SlidingWindowLimiter,
+    TokenBucketLimiter,
+)
+
+
+@settings(max_examples=60, deadline=None, suppress_health_check=[HealthCheck.too_slow])
+@given(
+    capacity=st.integers(min_value=1, max_value=20),
+    period_ms=st.integers(min_value=50, max_value=5000),
+    # A sequence of (delta_ms, cost) steps.
+    events=st.lists(
+        st.tuples(
+            st.integers(min_value=0, max_value=10_000),
+            st.integers(min_value=1, max_value=3),
+        ),
+        min_size=0,
+        max_size=60,
+    ),
+)
+def test_sliding_window_never_exceeds_capacity(capacity, period_ms, events):
+    backend = InMemoryBackend()
+    lim = SlidingWindowLimiter(
+        capacity=capacity, period_seconds=period_ms / 1000.0, backend=backend
+    )
+
+    admitted_ts: list[int] = []  # each admit costs 1 timestamp entry per cost unit
+    t = 1_000_000
+    for dt, cost in events:
+        t += dt
+        d = lim.enforce("k", cost=cost, now_ms=t)
+        if d.allowed:
+            admitted_ts.extend([t] * cost)
+
+        # Invariant: at this moment, the number of admitted timestamps
+        # still within the period window never exceeds capacity.
+        live = [ts for ts in admitted_ts if ts > t - period_ms]
+        assert len(live) <= capacity, (
+            f"over-grant: {len(live)} > {capacity} at t={t} with period={period_ms}"
+        )
+
+
+@settings(max_examples=60, deadline=None, suppress_health_check=[HealthCheck.too_slow])
+@given(
+    capacity=st.integers(min_value=1, max_value=20),
+    refill_rate=st.floats(min_value=0.1, max_value=50.0, allow_nan=False, allow_infinity=False),
+    events=st.lists(
+        st.tuples(
+            st.integers(min_value=0, max_value=10_000),
+            st.integers(min_value=1, max_value=3),
+        ),
+        min_size=0,
+        max_size=60,
+    ),
+)
+def test_token_bucket_invariants(capacity, refill_rate, events):
+    backend = InMemoryBackend()
+    lim = TokenBucketLimiter(
+        capacity=capacity, refill_rate=refill_rate, backend=backend
+    )
+
+    t = 1_000_000
+    total_granted = 0
+
+    # The invariant: total admitted cost over any window [t0, t1] is
+    # at most capacity + (t1 - t0) * refill_rate. We check the strongest
+    # form: starting from empty state, total_granted <= capacity + elapsed * rate.
+    t0 = t
+    for dt, cost in events:
+        t += dt
+        d = lim.enforce("k", cost=cost, now_ms=t)
+        if d.allowed:
+            total_granted += cost
+        # Remaining must be non-negative.
+        assert d.remaining >= 0, f"negative remaining {d.remaining}"
+        # Bucket-cap invariant: total grants can't exceed initial capacity
+        # plus everything refilled since the start.
+        budget = capacity + ((t - t0) / 1000.0) * refill_rate
+        # Allow tiny float slack (1e-6) to absorb rounding.
+        assert total_granted <= budget + 1e-6, (
+            f"over-grant: {total_granted} > {budget} "
+            f"(cap={capacity}, rate={refill_rate}, elapsed_ms={t - t0})"
+        )
+
+
+@settings(max_examples=30, deadline=None, suppress_health_check=[HealthCheck.too_slow])
+@given(
+    capacity=st.integers(min_value=1, max_value=10),
+    period_ms=st.integers(min_value=100, max_value=2000),
+    n_keys=st.integers(min_value=2, max_value=5),
+    n_events=st.integers(min_value=20, max_value=80),
+)
+def test_sliding_window_per_key_isolated(capacity, period_ms, n_keys, n_events):
+    """Different keys must not share budget."""
+
+    backend = InMemoryBackend()
+    lim = SlidingWindowLimiter(
+        capacity=capacity, period_seconds=period_ms / 1000.0, backend=backend
+    )
+
+    per_key_admits: dict[str, list[int]] = {f"k{i}": [] for i in range(n_keys)}
+    t = 1_000_000
+    for i in range(n_events):
+        t += 10
+        key = f"k{i % n_keys}"
+        d = lim.enforce(key, now_ms=t)
+        if d.allowed:
+            per_key_admits[key].append(t)
+        # Invariant holds per key.
+        live = [ts for ts in per_key_admits[key] if ts > t - period_ms]
+        assert len(live) <= capacity
