+import pytest
+import threading
+import fakeredis
+from ratelimit import RedisBackend, TokenBucketLimiter, SlidingWindowLimiter
+
+@pytest.fixture
+def redis_backend():
+    # Use fakeredis for tests
+    client = fakeredis.FakeStrictRedis(version=7)
+    return RedisBackend(client)
+
+def test_redis_token_bucket(redis_backend):
+    limiter = TokenBucketLimiter(redis_backend, capacity=5, refill_rate=0.0) # no refill
+    key = "r_tb"
+    
+    for _ in range(5):
+        assert limiter.enforce(key).allowed is True
+        
+    assert limiter.enforce(key).allowed is False
+
+def test_redis_sliding_window(redis_backend):
+    limiter = SlidingWindowLimiter(redis_backend, capacity=5, window_size_ms=10000)
+    key = "r_sw"
+    
+    for _ in range(5):
+        assert limiter.enforce(key).allowed is True
+        
+    assert limiter.enforce(key).allowed is False
+
+def test_redis_concurrency(redis_backend):
+    limiter = TokenBucketLimiter(redis_backend, capacity=15, refill_rate=0.0)
+    key = "r_concurrent"
+    
+    allowed_count = 0
+    lock = threading.Lock()
+    
+    def worker():
+        nonlocal allowed_count
+        if limiter.enforce(key).allowed:
+            with lock:
+                allowed_count += 1
+                
+    threads = [threading.Thread(target=worker) for _ in range(100)]
+    for t in threads: t.start()
+    for t in threads: t.join()
+    
+    assert allowed_count == 15
