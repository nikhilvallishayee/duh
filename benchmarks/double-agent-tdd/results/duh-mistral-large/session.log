Now I'll create a test file for the TDD plan mode.  [33m> Write[0m(file_path='tests/unit/test_tdd_plan_mode.py', content='"""Tests for duh.kernel.tdd_plan_mode — six-phase TDD flow with Driver and Navigator."""\n\nfrom __future__ import annotations\n\nimport pytest\nfrom unittest.mock import AsyncMock, patch\n\nfrom duh.kernel.deps import Deps\nfrom duh.kernel.engine import Engine, EngineConfig\nfrom duh.kernel.tdd_plan_mode import TDDPlanMode, TDDPhase, TDDStep\n\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\ndef _make_mock_swarm_tool():\n    """Create a mock SwarmTool that returns canned responses."""\n    mock = AsyncMock()\n    \n    async def run_swarm(tasks):\n        results = []\n        for task in tasks:\n            if "Draft a detailed test specification" in task.prompt:\n                # Navigator drafting test spec\n                result_text = (\n                    "Test File: tests/test_auth.py\\n"\n                    "Test Class: TestAuth\\n"\n                    "Test Method: test_new_feature\\n"\n                    "Assertions:\\n"\n                    "- assert auth.new_feature() == True\\n"\n                    "- assert auth.new_feature_fails_with_invalid_input() raises ValueError"\n                )\n            elif "Write a failing test" in task.prompt:\n                # Driver writing failing test\n                result_text = "Test code written to tests/test_auth.py"\n            elif "Write the minimum implementation code" in task.prompt:\n                # Driver writing implementation\n                result_text = "Implementation code written to auth.py"\n            elif "Propose a refactor" in task.prompt:\n                # Navigator proposing refactor\n                result_text = (\n                    "Refactor Plan:\\n"\n                    "- Extract duplicate logic in auth.py to helper functions\\n"\n                    "- Improve error messages in auth.py"\n                )\n            elif "Apply the following refactor" in task.prompt:\n                # Driver applying refactor\n                result_text = "Refactor applied to auth.py"\n            elif "Validate that the following refactor" in task.prompt:\n                # Navigator validating refactor\n                result_text = "Validation: All tests pass. Refactor applied correctly."\n            else:\n                result_text = "Mock response"\n            \n            # Create a mock result object with result_text attribute\n            result_mock = AsyncMock()\n            result_mock.result_text = result_text\n            results.append(result_mock)\n        \n        return results\n    \n    mock._run_swarm = run_swarm\n    return mock\n\n\ndef _make_mock_bash_tool():\n    """Create a mock BashTool that simulates test runs."""\n    mock = AsyncMock()\n    \n    async def run_bash(command, **kwargs):\n        if "pytest" in command and "FAIL" in command:\n            # Simulate failing test\n            return {"stdout": "=== FAIL: test_auth.py::TestAuth::test_new_feature\\nAssertionError: False is not true"}\n        elif "pytest" in command:\n            # Simulate passing test\n            return {"stdout": "=== 1 passed in 0.12s"}\n        return {"stdout": ""}\n    \n    mock.run = run_bash\n    return mock\n\n\ndef _make_engine():\n    """Create a test engine with mocked dependencies."""\n    deps = Deps(\n        call_model=AsyncMock(),\n        swarm=_make_mock_swarm_tool(),\n        bash=_make_mock_bash_tool()\n    )\n    config = EngineConfig(model="test-model")\n    return Engine(deps=deps, config=config)\n\n\nasync def _collect_events(gen):\n    """Collect all events from an async generator."""\n    events = []\n    async for event in gen:\n        events.append(event)\n    return events\n\n\n# ---------------------------------------------------------------------------\n# TDDPlanMode initialization\n# ---------------------------------------------------------------------------\n\nclass TestTDDPlanModeInit:\n    def test_initial_state(self):\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        assert tdd.current_phase == TDDPhase.SPEC_DRAFT\n        assert tdd.steps == []\n        assert tdd.task_description == ""\n\n    def test_format_status_empty(self):\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        status = tdd.format_status()\n        assert "TDD Flow:" in status\n        assert "No steps completed" in status\n\n\n# ---------------------------------------------------------------------------\n# TDD flow phase transitions\n# ---------------------------------------------------------------------------\n\nclass TestTDDFlow:\n    @pytest.mark.asyncio\n    async def test_full_tdd_flow(self):\n        """Test the full TDD flow with all phases completing successfully."""\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        \n        # Mock the test run to fail initially, then pass\n        with patch.object(tdd, \'_run_test\') as mock_run_test:\n            mock_run_test.side_effect = [\n                "=== FAIL: test_auth.py::TestAuth::test_new_feature\\nAssertionError: False is not true",  # RED phase\n                "=== 1 passed in 0.12s",  # GREEN phase\n                "=== 1 passed in 0.12s"   # VALIDATE phase\n            ]\n            \n            events = await _collect_events(tdd.run("Add new feature to auth module"))\n        \n        # Check phase transitions\n        assert tdd.current_phase == TDDPhase.VALIDATE\n        assert len(tdd.steps) == 6  # All phases completed\n        \n        # Check each phase was completed\n        for step in tdd.steps:\n            assert step.done is True\n        \n        # Check task description was set\n        assert tdd.task_description == "Add new feature to auth module"\n        \n        # Check events include TDD-specific types\n        event_types = [e.get("type") for e in events]\n        assert "tdd_phase" in event_types\n        assert "tdd_output" in event_types\n        assert "tdd_complete" in event_types\n\n    @pytest.mark.asyncio\n    async def test_test_passes_unexpectedly(self):\n        """Test handling when the test passes unexpectedly in RED phase."""\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        \n        # Mock the test run to pass unexpectedly\n        with patch.object(tdd, \'_run_test\') as mock_run_test:\n            mock_run_test.return_value = "=== 1 passed in 0.12s"\n            \n            events = await _collect_events(tdd.run("Add new feature to auth module"))\n        \n        # Should go back to SPEC_DRAFT after test passes unexpectedly\n        assert tdd.current_phase == TDDPhase.SPEC_DRAFT\n        assert any(step.phase == TDDPhase.SPEC_DRAFT and step.done for step in tdd.steps)\n        \n        # Should have two SPEC_DRAFT steps (original + revision)\n        spec_draft_steps = [s for s in tdd.steps if s.phase == TDDPhase.SPEC_DRAFT]\n        assert len(spec_draft_steps) == 2\n\n    @pytest.mark.asyncio\n    async def test_refactor_validation_fails(self):\n        """Test handling when refactor validation fails."""\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        \n        # Mock the test run to fail after refactor\n        with patch.object(tdd, \'_run_test\') as mock_run_test:\n            mock_run_test.side_effect = [\n                "=== FAIL: test_auth.py::TestAuth::test_new_feature\\nAssertionError: False is not true",  # RED phase\n                "=== 1 passed in 0.12s",  # GREEN phase\n                "=== FAIL: test_auth.py::TestAuth::test_new_feature\\nAssertionError: False is not true"   # VALIDATE phase (fails)\n            ]\n            \n            events = await _collect_events(tdd.run("Add new feature to auth module"))\n        \n        # Should go back to REFACTOR_PROPOSE after validation fails\n        assert tdd.current_phase == TDDPhase.REFACTOR_PROPOSE\n        \n        # Should have two REFACTOR_PROPOSE steps (original + revision)\n        refactor_propose_steps = [s for s in tdd.steps if s.phase == TDDPhase.REFACTOR_PROPOSE]\n        assert len(refactor_propose_steps) == 2\n\n\n# ---------------------------------------------------------------------------\n# Phase-specific tests\n# ---------------------------------------------------------------------------\n\nclass TestTDDPhases:\n    @pytest.mark.asyncio\n    async def test_spec_draft_phase(self):\n        """Test the Navigator drafting test spec phase."""\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        \n        with patch.object(tdd, \'_run_navigator\') as mock_run_navigator:\n            mock_run_navigator.return_value = (\n                "Test File: tests/test_auth.py\\n"\n                "Test Class: TestAuth\\n"\n                "Test Method: test_new_feature\\n"\n                "Assertions:\\n"\n                "- assert auth.new_feature() == True"\n            )\n            \n            # Run just the first phase\n            events = []\n            async for event in tdd.run("Add new feature"):\n                events.append(event)\n                if event.get("type") == "tdd_phase" and event.get("phase") == "RED":\n                    break  # Stop after SPEC_DRAFT phase\n        \n        assert tdd.current_phase == TDDPhase.RED\n        assert len(tdd.steps) == 2  # SPEC_DRAFT + RED\n        assert tdd.steps[0].phase == TDDPhase.SPEC_DRAFT\n        assert tdd.steps[0].done is True\n        assert "Test File:" in tdd.steps[0].output\n\n    @pytest.mark.asyncio\n    async def test_red_phase(self):\n        """Test the Driver writing failing test phase."""\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        \n        # Set up test spec\n        tdd._test_spec = (\n            "Test File: tests/test_auth.py\\n"\n            "Test Class: TestAuth\\n"\n            "Test Method: test_new_feature"\n        )\n        \n        with patch.object(tdd, \'_run_driver\') as mock_run_driver, \\\n             patch.object(tdd, \'_run_test\') as mock_run_test:\n            \n            mock_run_driver.return_value = "Test code written"\n            mock_run_test.return_value = "=== FAIL: test_auth.py::TestAuth::test_new_feature\\nAssertionError: False is not true"\n            \n            # Run from RED phase\n            await tdd._transition_phase(TDDPhase.RED)\n            events = await _collect_events(tdd.run("Add new feature"))\n        \n        assert tdd.current_phase == TDDPhase.GREEN\n        assert tdd.steps[-1].phase == TDDPhase.RED\n        assert tdd.steps[-1].done is True\n        assert "Test code written" in tdd.steps[-1].output\n        assert "FAIL" in tdd.steps[-1].output\n\n    @pytest.mark.asyncio\n    async def test_green_phase(self):\n        """Test the Driver writing minimum code to pass phase."""\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        \n        # Set up test code and output\n        tdd._test_code = "def test_new_feature(): assert auth.new_feature() == True"\n        tdd._test_output = "=== FAIL: test_auth.py::TestAuth::test_new_feature\\nAssertionError: False is not true"\n        \n        with patch.object(tdd, \'_run_driver\') as mock_run_driver, \\\n             patch.object(tdd, \'_run_test\') as mock_run_test:\n            \n            mock_run_driver.return_value = "Implementation code written"\n            mock_run_test.return_value = "=== 1 passed in 0.12s"\n            \n            # Run from GREEN phase\n            await tdd._transition_phase(TDDPhase.GREEN)\n            events = await _collect_events(tdd.run("Add new feature"))\n        \n        assert tdd.current_phase == TDDPhase.REFACTOR_PROPOSE\n        assert tdd.steps[-1].phase == TDDPhase.GREEN\n        assert tdd.steps[-1].done is True\n        assert "Implementation code written" in tdd.steps[-1].output\n\n    @pytest.mark.asyncio\n    async def test_refactor_phases(self):\n        """Test the Navigator proposing and Driver applying refactor phases."""\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        \n        # Set up implementation\n        tdd._test_code = "def test_new_feature(): assert auth.new_feature() == True"\n        tdd._implementation_code = "def new_feature(): return True"\n        \n        with patch.object(tdd, \'_run_navigator\') as mock_run_navigator, \\\n             patch.object(tdd, \'_run_driver\') as mock_run_driver:\n            \n            mock_run_navigator.return_value = "Refactor: Extract helper function"\n            mock_run_driver.return_value = "Refactor applied"\n            \n            # Run from REFACTOR_PROPOSE phase\n            await tdd._transition_phase(TDDPhase.REFACTOR_PROPOSE)\n            events = []\n            async for event in tdd.run("Add new feature"):\n                events.append(event)\n                if event.get("type") == "tdd_phase" and event.get("phase") == "REFACTOR_APPLY":\n                    break  # Stop after REFACTOR_PROPOSE phase\n            \n            # Continue to REFACTOR_APPLY phase\n            await tdd._transition_phase(TDDPhase.REFACTOR_APPLY)\n            events.extend(await _collect_events(tdd.run("Add new feature")))\n        \n        assert tdd.current_phase == TDDPhase.REFACTOR_APPLY\n        assert tdd.steps[-2].phase == TDDPhase.REFACTOR_PROPOSE\n        assert tdd.steps[-2].done is True\n        assert tdd.steps[-1].phase == TDDPhase.REFACTOR_APPLY\n        assert tdd.steps[-1].done is True\n\n    @pytest.mark.asyncio\n    async def test_validate_phase(self):\n        """Test the Navigator validating refactor phase."""\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        \n        # Set up refactored code\n        tdd._test_code = "def test_new_feature(): assert auth.new_feature() == True"\n        tdd._refactor_plan = "Extract helper function"\n        tdd._refactored_code = "def new_feature(): return True\\ndef helper(): pass"\n        \n        with patch.object(tdd, \'_run_navigator\') as mock_run_navigator, \\\n             patch.object(tdd, \'_run_test\') as mock_run_test:\n            \n            mock_run_navigator.return_value = "Validation: All tests pass. Refactor applied correctly."\n            mock_run_test.return_value = "=== 1 passed in 0.12s"\n            \n            # Run from VALIDATE phase\n            await tdd._transition_phase(TDDPhase.VALIDATE)\n            events = await _collect_events(tdd.run("Add new feature"))\n        \n        assert tdd.current_phase == TDDPhase.VALIDATE\n        assert tdd.steps[-1].phase == TDDPhase.VALIDATE\n        assert tdd.steps[-1].done is True\n        assert "Validation:" in tdd.steps[-1].output\n        assert "tdd_complete" in [e.get("type") for e in events]\n\n\n# ---------------------------------------------------------------------------\n# Error handling\n# ---------------------------------------------------------------------------\n\nclass TestTDDErrorHandling:\n    @pytest.mark.asyncio\n    async def test_green_phase_retry(self):\n        """Test retry logic when test fails in GREEN phase."""\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        \n        # Set up test code and output\n        tdd._test_code = "def test_new_feature(): assert auth.new_feature() == True"\n        tdd._test_output = "=== FAIL: test_auth.py::TestAuth::test_new_feature\\nAssertionError: False is not true"\n        \n        with patch.object(tdd, \'_run_driver\') as mock_run_driver, \\\n             patch.object(tdd, \'_run_test\') as mock_run_test:\n            \n            # First call returns implementation that still fails, second call fixes it\n            mock_run_driver.side_effect = ["First implementation attempt", "Fixed implementation"]\n            mock_run_test.side_effect = [\n                "=== FAIL: test_auth.py::TestAuth::test_new_feature\\nAssertionError: False is not true",  # First attempt\n                "=== 1 passed in 0.12s"   # Second attempt\n            ]\n            \n            # Run from GREEN phase\n            await tdd._transition_phase(TDDPhase.GREEN)\n            events = await _collect_events(tdd.run("Add new feature"))\n        \n        assert tdd.current_phase == TDDPhase.REFACTOR_PROPOSE\n        assert tdd.steps[-1].phase == TDDPhase.GREEN\n        assert tdd.steps[-1].done is True\n        assert "Fixed implementation" in tdd.steps[-1].output\n\n    @pytest.mark.asyncio\n    async def test_validate_phase_retry(self):\n        """Test retry logic when validation fails."""\n        engine = _make_engine()\n        tdd = TDDPlanMode(engine)\n        \n        # Set up refactored code\n        tdd._test_code = "def test_new_feature(): assert auth.new_feature() == True"\n        tdd._refactor_plan = "Extract helper function"\n        tdd._refactored_code = "def new_feature(): return True\\ndef helper(): pass"\n        \n        with patch.object(tdd, \'_run_navigator\') as mock_run_navigator, \\\n             patch.object(tdd, \'_run_test\') as mock_run_test:\n            \n            # First validation fails, second succeeds\n            mock_run_navigator.side_effect = [\n                "First refactor attempt",\n                "Fixed refactor plan"\n            ]\n            mock_run_test.side_effect = [\n                "=== FAIL: test_auth.py::TestAuth::test_new_feature\\nAssertionError: False is not true",  # First attempt\n                "=== 1 passed in 0.12s"   # Second attempt\n            ]\n            \n            # Run from VALIDATE phase\n            await tdd._transition_phase(TDDPhase.VALIDATE)\n            events = await _collect_events(tdd.run("Add new feature"))\n        \n        # Should complete successfully after retry\n        assert tdd.current_phase == TDDPhase.VALIDATE\n        assert tdd.steps[-1].phase == TDDPhase.VALIDATE\n        assert tdd.steps[-1].done is True\n        assert "Fixed refactor plan" in tdd.steps[-2].output  # REFACTOR_PROPOSE step')
