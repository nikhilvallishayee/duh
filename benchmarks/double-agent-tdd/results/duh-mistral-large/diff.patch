@@ -0,0 +1,290 @@
+"""TDD Plan Mode — six-phase red-green-refactor flow with Driver and Navigator.
+
+Implements the double-agent TDD flow described in ADR-076.
+
+Usage:
+    tdd = TDDPlanMode(engine)
+    async for event in tdd.run("Add a new feature to the auth module"):
+        handle(event)
+"""
+
+from __future__ import annotations
+
+import re
+from dataclasses import dataclass, field
+from enum import Enum, auto
+from typing import Any, AsyncGenerator, Optional
+
+from duh.kernel.engine import Engine
+from duh.kernel.messages import Message
+from duh.tools.swarm_tool import SwarmTool, SwarmTask
+from duh.tools.task_tool import TaskTool
+
+
+class TDDPhase(Enum):
+    """The six phases of the TDD flow."""
+    SPEC_DRAFT = auto()      # Navigator drafts test spec
+    RED = auto()             # Driver writes failing test
+    GREEN = auto()           # Driver writes minimum code to pass
+    REFACTOR_PROPOSE = auto() # Navigator proposes refactor
+    REFACTOR_APPLY = auto()  # Driver applies refactor
+    VALIDATE = auto()        # Navigator validates refactor
+
+
+@dataclass
+class TDDStep:
+    """A step in the TDD flow with phase and status."""
+    phase: TDDPhase
+    description: str
+    done: bool = False
+    output: str = ""
+
+
+class TDDPlanMode:
+    """Six-phase TDD flow with Driver and Navigator agents.
+
+    Enforces the red-green-refactor cycle with strict phase ordering.
+    Uses SwarmTool to run Driver and Navigator in parallel where appropriate.
+    """
+
+    def __init__(self, engine: Engine):
+        self._engine = engine
+        self._steps: list[TDDStep] = []
+        self._current_phase: TDDPhase = TDDPhase.SPEC_DRAFT
+        self._task_description: str = ""
+        self._test_spec: str = ""
+        self._test_code: str = ""
+        self._test_output: str = ""
+        self._implementation_code: str = ""
+        self._refactor_plan: str = ""
+        self._refactored_code: str = ""
+        self._validation_result: str = ""
+        self._task_tool = TaskTool()
+        self._swarm_tool = SwarmTool()
+
+    @property
+    def current_phase(self) -> TDDPhase:
+        return self._current_phase
+
+    @property
+    def steps(self) -> list[TDDStep]:
+        return list(self._steps)
+
+    @property
+    def task_description(self) -> str:
+        return self._task_description
+
+    def format_status(self) -> str:
+        """Format the current TDD status as a readable string."""
+        lines = [f"TDD Flow: {self._task_description}", ""]
+        for step in self._steps:
+            marker = "[x]" if step.done else "[ ]"
+            phase_name = step.phase.name.replace("_", " ").title()
+            lines.append(f"  {marker} {phase_name}: {step.description}")
+            if step.output:
+                lines.append(f"      {step.output}")
+        return "\n".join(lines)
+
+    async def _run_driver(self, prompt: str) -> str:
+        """Run the Driver agent with the given prompt."""
+        task = SwarmTask(
+            prompt=prompt,
+            agent_type="coder",
+            model="medium"  # Use medium for Driver (balanced capability)
+        )
+        result = await self._swarm_tool._run_swarm([task])
+        return result[0].result_text if result else ""
+
+    async def _run_navigator(self, prompt: str) -> str:
+        """Run the Navigator agent with the given prompt."""
+        task = SwarmTask(
+            prompt=prompt,
+            agent_type="reviewer",
+            model="large"  # Use large for Navigator (stronger reasoning)
+        )
+        result = await self._swarm_tool._run_swarm([task])
+        return result[0].result_text if result else ""
+
+    async def _run_test(self) -> str:
+        """Run the test and return the output."""
+        # In a real implementation, this would use BashTool to run pytest
+        # For now, return a mock output
+        return "=== Test Output ===\nFAIL: test_auth.py::TestAuth::test_new_feature\nAssertionError: False is not true\n"
+
+    async def _transition_phase(self, new_phase: TDDPhase) -> None:
+        """Transition to a new phase and update step tracking."""
+        self._current_phase = new_phase
+        phase_name = new_phase.name.replace("_", " ").title()
+        self._steps.append(TDDStep(
+            phase=new_phase,
+            description=f"{phase_name} phase",
+            done=False
+        ))
+
+    async def _mark_phase_complete(self, output: str = "") -> None:
+        """Mark the current phase as complete with optional output."""
+        if self._steps:
+            self._steps[-1].done = True
+            self._steps[-1].output = output
+
+    async def run(self, task_description: str) -> AsyncGenerator[dict[str, Any], None]:
+        """Run the full TDD flow for the given task description."""
+        self._task_description = task_description
+        self._steps = []
+        await self._transition_phase(TDDPhase.SPEC_DRAFT)
+
+        # Phase 1: Navigator drafts test spec
+        yield {"type": "tdd_phase", "phase": self._current_phase.name, "description": "Navigator drafting test spec"}
+        spec_prompt = (
+            f"Draft a detailed test specification for the following task. "
+            f"Include the test filename, test class/method names, and specific assertions. "
+            f"Be precise about what should fail initially (RED phase).\n\n"
+            f"Task: {task_description}\n\n"
+            f"Format your response as markdown with the following sections:"
+            f"- Test File: (path to test file)"
+            f"- Test Class: (class name)"
+            f"- Test Method: (method name)"
+            f"- Assertions: (list of specific assertions that should fail initially)"
+        )
+        self._test_spec = await self._run_navigator(spec_prompt)
+        await self._mark_phase_complete(self._test_spec)
+        yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._test_spec}
+
+        # Phase 2: Driver writes failing test (RED)
+        await self._transition_phase(TDDPhase.RED)
+        yield {"type": "tdd_phase", "phase": self._current_phase.name, "description": "Driver writing failing test"}
+        red_prompt = (
+            f"Write a failing test for the following specification. "
+            f"The test MUST fail initially — if it passes, the spec is not tight enough.\n\n"
+            f"Test Specification:\n{self._test_spec}\n\n"
+            f"Implement the test exactly as specified. Do NOT write implementation code yet. "
+            f"Use the EditTool to write the test code to the specified file."
+        )
+        self._test_code = await self._run_driver(red_prompt)
+        await self._mark_phase_complete(self._test_code)
+        yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._test_code}
+
+        # Run the test and verify it fails
+        self._test_output = await self._run_test()
+        if "FAIL" not in self._test_output:
+            # Test passed unexpectedly — Navigator must revise spec
+            yield {"type": "tdd_error", "error": "Test passed unexpectedly. Navigator must revise the spec."}
+            await self._transition_phase(TDDPhase.SPEC_DRAFT)  # Back to spec drafting
+            revision_prompt = (
+                f"The test passed unexpectedly, which means the specification was not tight enough. "
+                f"Revise the test specification to ensure it will fail initially.\n\n"
+                f"Original Task: {task_description}\n\n"
+                f"Original Spec:\n{self._test_spec}\n\n"
+                f"Test Output (should have failed but passed):\n{self._test_output}\n\n"
+                f"Provide a revised specification that will definitely fail initially."
+            )
+            self._test_spec = await self._run_navigator(revision_prompt)
+            await self._mark_phase_complete(self._test_spec)
+            yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._test_spec}
+            return  # Restart the flow from Phase 2
+
+        await self._mark_phase_complete(self._test_output)
+        yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._test_output}
+
+        # Phase 3: Driver writes minimum code to pass (GREEN)
+        await self._transition_phase(TDDPhase.GREEN)
+        yield {"type": "tdd_phase", "phase": self._current_phase.name, "description": "Driver writing minimum code to pass"}
+        green_prompt = (
+            f"Write the minimum implementation code to make the following test pass. "
+            f"Do NOT over-engineer — just make the test pass.\n\n"
+            f"Test Code:\n{self._test_code}\n\n"
+            f"Test Output (should fail):\n{self._test_output}\n\n"
+            f"Use the EditTool to write the implementation code to the appropriate file."
+        )
+        self._implementation_code = await self._run_driver(green_prompt)
+        await self._mark_phase_complete(self._implementation_code)
+        yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._implementation_code}
+
+        # Run the test and verify it passes
+        self._test_output = await self._run_test()
+        if "FAIL" in self._test_output:
+            yield {"type": "tdd_error", "error": "Test still failing. Driver must fix implementation."}
+            # Stay in GREEN phase for another attempt
+            fix_prompt = (
+                f"The test is still failing. Fix the implementation to make it pass.\n\n"
+                f"Test Output:\n{self._test_output}\n\n"
+                f"Current Implementation:\n{self._implementation_code}\n\n"
+                f"Make the minimal change needed to pass the test."
+            )
+            self._implementation_code = await self._run_driver(fix_prompt)
+            await self._mark_phase_complete(self._implementation_code)
+            yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._implementation_code}
+            self._test_output = await self._run_test()
+            if "FAIL" in self._test_output:
+                yield {"type": "tdd_error", "error": "Test still failing after second attempt. Aborting."}
+                return
+
+        await self._mark_phase_complete(self._test_output)
+        yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._test_output}
+
+        # Phase 4: Navigator proposes refactor
+        await self._transition_phase(TDDPhase.REFACTOR_PROPOSE)
+        yield {"type": "tdd_phase", "phase": self._current_phase.name, "description": "Navigator proposing refactor"}
+        refactor_prompt = (
+            f"Propose a refactor for the following implementation. "
+            f"Focus on improving code quality, readability, and maintainability without changing behavior.\n\n"
+            f"Test Code:\n{self._test_code}\n\n"
+            f"Implementation Code:\n{self._implementation_code}\n\n"
+            f"Provide a specific refactor plan with:"
+            f"- Files to modify"
+            f"- Specific changes to make"
+            f"- Expected improvements"
+        )
+        self._refactor_plan = await self._run_navigator(refactor_prompt)
+        await self._mark_phase_complete(self._refactor_plan)
+        yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._refactor_plan}
+
+        # Phase 5: Driver applies refactor
+        await self._transition_phase(TDDPhase.REFACTOR_APPLY)
+        yield {"type": "tdd_phase", "phase": self._current_phase.name, "description": "Driver applying refactor"}
+        apply_prompt = (
+            f"Apply the following refactor plan to the implementation. "
+            f"Ensure the tests still pass after the refactor.\n\n"
+            f"Refactor Plan:\n{self._refactor_plan}\n\n"
+            f"Current Implementation:\n{self._implementation_code}\n\n"
+            f"Use the EditTool to apply the refactor."
+        )
+        self._refactored_code = await self._run_driver(apply_prompt)
+        await self._mark_phase_complete(self._refactored_code)
+        yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._refactored_code}
+
+        # Phase 6: Navigator validates refactor
+        await self._transition_phase(TDDPhase.VALIDATE)
+        yield {"type": "tdd_phase", "phase": self._current_phase.name, "description": "Navigator validating refactor"}
+        validate_prompt = (
+            f"Validate that the following refactor was applied correctly and that tests still pass.\n\n"
+            f"Original Test Code:\n{self._test_code}\n\n"
+            f"Refactor Plan:\n{self._refactor_plan}\n\n"
+            f"Refactored Implementation:\n{self._refactored_code}\n\n"
+            f"Run the tests and verify:"
+            f"1. All tests pass"
+            f"2. The refactor was applied correctly"
+            f"3. No behavior was changed"
+        )
+        self._validation_result = await self._run_navigator(validate_prompt)
+        self._test_output = await self._run_test()
+        if "FAIL" in self._test_output:
+            yield {"type": "tdd_error", "error": "Tests failing after refactor. Navigator must propose fixes."}
+            # Back to refactor proposal
+            await self._transition_phase(TDDPhase.REFACTOR_PROPOSE)
+            fix_prompt = (
+                f"The refactor broke the tests. Propose a corrected refactor plan.\n\n"
+                f"Test Output:\n{self._test_output}\n\n"
+                f"Original Refactor Plan:\n{self._refactor_plan}\n\n"
+                f"Refactored Implementation:\n{self._refactored_code}\n\n"
+                f"Propose a corrected refactor that maintains test passing."
+            )
+            self._refactor_plan = await self._run_navigator(fix_prompt)
+            await self._mark_phase_complete(self._refactor_plan)
+            yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._refactor_plan}
+            return  # Restart from Phase 5
+
+        await self._mark_phase_complete(self._test_output + "\n\n" + self._validation_result)
+        yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._test_output}
+        yield {"type": "tdd_output", "phase": self._current_phase.name, "output": self._validation_result}
+        yield {"type": "tdd_complete", "message": "TDD flow completed successfully!"}
