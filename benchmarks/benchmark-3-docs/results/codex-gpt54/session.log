    if getattr(args, "tui", False):
        from duh.ui import run_tui
        return run_tui(args)

    # No prompt and no SDK mode → interactive REPL
    from duh.cli.repl import run_repl
    try:
        return asyncio.run(run_repl(args))
    except KeyboardInterrupt:
        sys.stderr.write("\n")
        return 0

