[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "duh-cli"
dynamic = ["version"]
description = "D.U.H. — Duh is a Universal Harness. Provider-agnostic AI coding agent."
readme = "README.md"
license = "Apache-2.0"
requires-python = ">=3.12"
authors = [
    { name = "Nikhil Vallishayee" },
]
keywords = ["ai", "coding", "agent", "harness", "mcp", "cli", "claude", "openai", "ollama"]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Environment :: Console",
    "Intended Audience :: Developers",
    "License :: OSI Approved :: Apache Software License",
    "Programming Language :: Python :: 3.12",
    "Topic :: Software Development",
]
dependencies = [
    # SEC-MEDIUM-7: security-critical deps get tight upper bounds
    # (auth, transport, LLM SDKs). Lower bounds are the oldest version
    # we support; upper bounds are the next major we have NOT vetted.
    "anthropic>=0.40.0,<1.0",
    "httpx>=0.27.0,<1.0",
    "openai>=1.0,<3.0",
    # Native provider SDKs (ADR-075): ship by default so the common
    # Gemini/Groq paths don't need the LiteLLM opt-in. google-genai
    # is the official Google SDK (supersedes google-generativeai).
    "google-genai>=0.3,<2",
    "groq>=0.11,<1",
    "mcp>=1.0,<2.0",
    # Non-security-critical deps: constrain to current major only.
    "pydantic>=2.0,<3.0",
    "rich>=13.0,<16.0",
    "textual>=0.40,<9.0",
    "websockets>=12.0,<17.0",
    "pdfplumber>=0.10,<1.0",
]

[project.urls]
Homepage = "https://github.com/nikhilvallishayee/duh"
Repository = "https://github.com/nikhilvallishayee/duh"
Issues = "https://github.com/nikhilvallishayee/duh/issues"

[project.optional-dependencies]
dev = ["pytest", "pytest-asyncio", "pytest-cov", "pytest-timeout", "hypothesis>=6.0"]
# LiteLLM is opt-in due to supply-chain history (ADR-075). See pyproject for pinned floor.
