@@ -0,0 +1,73 @@
+import pytest
+from unittest.mock import AsyncMock, patch, MagicMock
+
+from duh.kernel.tdd_flow import run_tdd_flow
+from duh.agents import AgentResult
+
+@pytest.mark.asyncio
+async def test_tdd_flow_success(capsys):
+    with patch("duh.kernel.tdd_flow.run_agent") as mock_run_agent:
+        # Phase 1: Reviewer drafts spec
+        res1 = AgentResult(agent_type="reviewer", result_text="Test spec drafted")
+        # Phase 2: Coder writes failing test
+        res2 = AgentResult(agent_type="coder", result_text="Test written and it failed.\nAssertionError")
+        # Phase 3: Coder writes passing test
+        res3 = AgentResult(agent_type="coder", result_text="Test written and it passed.")
+        # Phase 4: Reviewer proposes refactor
+        res4 = AgentResult(agent_type="reviewer", result_text="Propose refactor to simplify function.")
+        # Phase 5: Coder applies refactor
+        res5 = AgentResult(agent_type="coder", result_text="Refactor applied.")
+        # Phase 6: Reviewer validates
+        res6 = AgentResult(agent_type="reviewer", result_text="Refactor validated, tests pass.")
+        
+        mock_run_agent.side_effect = [res1, res2, res3, res4, res5, res6]
+        
+        await run_tdd_flow("Add a new calculator feature", None, [], ".", "fake-model")
+        
+        out, _ = capsys.readouterr()
+        
+        assert "Phase 1: Navigator drafting test spec..." in out
+        assert "Phase 2: Driver writing failing test" in out
+        assert "Phase 3: Driver writing code to pass test" in out
+        assert "Phase 4: Navigator proposing refactor" in out
+        assert "Phase 5: Driver applying refactor" in out
+        assert "Phase 6: Navigator validating refactor" in out
+        assert mock_run_agent.call_count == 6
+
+@pytest.mark.asyncio
+async def test_tdd_flow_no_refactor(capsys):
+    with patch("duh.kernel.tdd_flow.run_agent") as mock_run_agent:
+        res1 = AgentResult(agent_type="reviewer", result_text="Test spec drafted")
+        res2 = AgentResult(agent_type="coder", result_text="Test written and it failed.\nAssertionError")
+        res3 = AgentResult(agent_type="coder", result_text="Test written and it passed.")
+        res4 = AgentResult(agent_type="reviewer", result_text="No refactoring needed.")
+        
+        mock_run_agent.side_effect = [res1, res2, res3, res4]
+        
+        await run_tdd_flow("Add a new calculator feature", None, [], ".", "fake-model")
+        
+        out, _ = capsys.readouterr()
+        
+        assert "Phase 4: Navigator proposing refactor" in out
+        assert "No refactoring needed" in out
+        assert mock_run_agent.call_count == 4
+
+@pytest.mark.asyncio
+async def test_tdd_flow_retry_red(capsys):
+    with patch("duh.kernel.tdd_flow.run_agent") as mock_run_agent:
+        res1 = AgentResult(agent_type="reviewer", result_text="Test spec drafted")
+        # Attempt 1: Test incorrectly passes
+        res2_1 = AgentResult(agent_type="coder", result_text="Test written and it passed.")
+        # Attempt 2: Test fails
+        res2_2 = AgentResult(agent_type="coder", result_text="Test written and it failed.\nAssertionError")
+        res3 = AgentResult(agent_type="coder", result_text="Test written and it passed.")
+        res4 = AgentResult(agent_type="reviewer", result_text="No refactoring needed.")
+        
+        mock_run_agent.side_effect = [res1, res2_1, res2_2, res3, res4]
+        
+        await run_tdd_flow("Add a new calculator feature", None, [], ".", "fake-model")
+        
+        out, _ = capsys.readouterr()
+        
+        assert "Retrying RED phase" in out
+        assert mock_run_agent.call_count == 5
