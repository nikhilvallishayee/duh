+import time
+import pytest
+from ratelimit.backends import InMemoryBackend
+from ratelimit.limiters import TokenBucketLimiter, SlidingWindowLimiter
+
+def test_token_bucket_happy_path():
+    backend = InMemoryBackend()
+    limiter = TokenBucketLimiter(backend, capacity=10, refill_rate=10.0) # 10 tokens/sec
+    
+    # Take 5 tokens
+    dec = limiter.enforce("test1", cost=5)
+    assert dec.allowed is True
+    assert dec.remaining == 5
+    assert dec.retry_after_ms == 0
+
+    # Take another 5 tokens
+    dec = limiter.enforce("test1", cost=5)
+    assert dec.allowed is True
+    assert dec.remaining == 0
+
+    # Next one should be blocked
+    dec = limiter.enforce("test1", cost=1)
+    assert dec.allowed is False
+    assert dec.retry_after_ms > 0
+
+def test_token_bucket_boundary():
+    backend = InMemoryBackend()
+    # High refill rate, test waiting
+    limiter = TokenBucketLimiter(backend, capacity=2, refill_rate=1000.0) # 1000/sec = 1/ms
+    
+    dec = limiter.enforce("test2", cost=2)
+    assert dec.allowed is True
+    
+    dec = limiter.enforce("test2", cost=1)
+    assert dec.allowed is False
+    
+    time.sleep(0.005) # wait 5ms
+    dec = limiter.enforce("test2", cost=1)
+    assert dec.allowed is True
+
+def test_sliding_window_happy_path():
+    backend = InMemoryBackend()
+    limiter = SlidingWindowLimiter(backend, capacity=5, window_ms=100)
+    
+    for _ in range(5):
+        dec = limiter.enforce("test3")
+        assert dec.allowed is True
+        
+    dec = limiter.enforce("test3")
+    assert dec.allowed is False
+    
+    time.sleep(0.15) # wait 150ms
+    dec = limiter.enforce("test3")
+    assert dec.allowed is True
+
+def test_sliding_window_boundary():
+    backend = InMemoryBackend()
+    limiter = SlidingWindowLimiter(backend, capacity=3, window_ms=100)
+    
+    dec1 = limiter.enforce("test4")
+    assert dec1.allowed is True
+    
+    time.sleep(0.06)
+    dec2 = limiter.enforce("test4", cost=2)
+    assert dec2.allowed is True
+    
+    dec3 = limiter.enforce("test4")
+    assert dec3.allowed is False
+    
+    time.sleep(0.05) # total 110ms passed since dec1, dec1 expired
+    dec4 = limiter.enforce("test4")
+    assert dec4.allowed is True
+    
+    # but cost=2 from dec2 still active
+    dec5 = limiter.enforce("test4")
+    assert dec5.allowed is False
