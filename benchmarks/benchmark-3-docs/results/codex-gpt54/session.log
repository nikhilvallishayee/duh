import ast, inspect, importlib, dataclasses, os
from pathlib import Path
from typing import Any

MODULES=[*(f'duh.kernel.{p.stem}' for p in sorted(Path('duh/kernel').glob('*.py'))),*(f'duh.ports.{p.stem}' for p in sorted(Path('duh/ports').glob('*.py')))]
MODULES=[m for m in MODULES if not m.endswith('.__init__')]

intro = \"\"\"# Kernel and Ports API Reference\\n\\nThis reference covers every public class and top-level function in "'`duh/kernel/` and `duh/ports/`. Signatures are reconstructed from the source in this checkout; examples are intentionally short and meant to show call shape, not full workflows.'"\\n\\nConventions:\\n- "'`Exceptions` lists module-specific behavior visible from the implementation; adapter failures and ordinary Python errors can still propagate.'"\\n- Dataclass-style classes list their public fields because their constructor is generated rather than written out in source.\\n- Methods are included under their owning class so you can see the full usable surface area without leaving the module section.\\n\\n\"\"\"


def fmt_args(args: ast.arguments) -> str:
    parts=[]
    posonly=args.posonlyargs
    regular=args.args
    defaults=args.defaults
    total=len(posonly)+len(regular)
    default_start=total-len(defaults)
    all_args=posonly+regular
    for i,a in enumerate(all_args):
        s=a.arg
        if a.annotation:
            s += ': ' + ast.unparse(a.annotation)
        if i >= default_start:
            default = defaults[i-default_start]
            s += ' = ' + ast.unparse(default)
        parts.append(s)
        if posonly and i == len(posonly)-1:
            parts.append('/')
    if args.vararg:
        s='*'+args.vararg.arg
        if args.vararg.annotation:
            s += ': ' + ast.unparse(args.vararg.annotation)
        parts.append(s)
    elif args.kwonlyargs:
        parts.append('*')
    for a,d in zip(args.kwonlyargs,args.kw_defaults):
        s=a.arg
        if a.annotation:
            s += ': ' + ast.unparse(a.annotation)
        if d is not None:
            s += ' = ' + ast.unparse(d)
        parts.append(s)
    if args.kwarg:
        s='**'+args.kwarg.arg
        if args.kwarg.annotation:
            s += ': ' + ast.unparse(args.kwarg.annotation)
        parts.append(s)
    return ', '.join(parts)

def fmt_sig(node):
    prefix='async def' if isinstance(node, ast.AsyncFunctionDef) else 'def'
    sig=f\"{prefix} {node.name}({fmt_args(node.args)})\"
    if node.returns:
        sig += ' -> ' + ast.unparse(node.returns)
    return sig

def short(text:str)->str:
    if not text:
        return 'No module docstring.'
    first=text.strip().splitlines()[0].strip()
    return first.rstrip('.') + '.'

def parse_public(path:Path):
    src=path.read_text()
    tree=ast.parse(src,str(path))
    out=[]
    for node in tree.body:
        if isinstance(node,(ast.FunctionDef,ast.AsyncFunctionDef)) and not node.name.startswith('_'):
            out.append({'kind':'function','name':node.name,'sig':fmt_sig(node),'doc':ast.get_docstring(node) or ''})
        elif isinstance(node,ast.ClassDef) and not node.name.startswith('_'):
            methods=[]
            for sub in node.body:
                if isinstance(sub,(ast.FunctionDef,ast.AsyncFunctionDef)) and not sub.name.startswith('_'):
                    methods.append({'name':sub.name,'sig':fmt_sig(sub),'doc':ast.get_docstring(sub) or ''})
            out.append({'kind':'class','name':node.name,'sig':f'class {node.name}','doc':ast.get_docstring(node) or '', 'methods':methods})
    return short(ast.get_docstring(tree) or ''), out

def dataclass_fields(obj):
    if not dataclasses.is_dataclass(obj):
        return []
    rows=[]
    for f in dataclasses.fields(obj):
        annot=f.type
        if isinstance(annot, type):
            ann=annot.__name__
        else:
            ann=str(annot)
        default='required'
        if f.default is not dataclasses.MISSING:
            default=repr(f.default)
        elif f.default_factory is not dataclasses.MISSING:
            default='factory'
        rows.append((f.name, ann, default))
    return rows

lines=[intro]
for mod in MODULES:
    path=Path(mod.replace('.','/')+'.py')
    mod_summary, items=parse_public(path)
    module=importlib.import_module(mod)
    lines.append(f\"## "'`{mod}`'"\\n\")
    lines.append(f\"{mod_summary}\\n\")
    public_seen=False
    for item in items:
        public_seen=True
        if item['kind']=='function':
            name=item['name']
            obj=getattr(module,name)
            sig=item['sig']
            params=[p for p in inspect.signature(obj).parameters.values()]
            params_txt=', '.join(p.name for p in params) if params else 'none'
            ret=inspect.signature(obj).return_annotation
            ret_txt='None' if ret is inspect.Signature.empty else str(ret).replace('typing.','')
            doc=short(item['doc'])
            example=f\""'`{name}(...)`"
            lines.append(f"### `{name}`'"\\n\")
            lines.append(f\""'```python'"\\n{sig}\\n"'```'"\\n\")
            lines.append(f\"Purpose: {doc}\\n\")
            lines.append(f\"Parameters: {params_txt}.\\n\")
            lines.append(f\"Returns: "'`{ret_txt}`.'"\\n\")
            exc='No dedicated exception contract in this module; ordinary validation, adapter, or I/O errors may propagate unless the implementation converts them to return values.'
            if name in {'check_file_size'}:
                exc='No custom exception path; returns a "'`FileSizeDecision` instead of raising.'"'
            elif name in {'validate_tool_schema'}:
                exc='Raises "'`SchemaValidationError` for invalid schemas; otherwise returns warnings.'"'
            elif name in {'gc_memories','score_facts','merge_consecutive','validate_alternation','count_tokens','count_tokens_for_model','estimate_cost','get_context_limit','format_cost','get_git_warnings','get_git_context','redact_secrets','merge_source','assert_no_tag_loss'}:
                exc='No module-specific exception path beyond ordinary Python errors.'
            lines.append(f\"Exceptions: {exc}\\n\")
            lines.append(f\"Example: {example}.\\n\")
        else:
            name=item['name']
            cls=getattr(module,name)
            fields=dataclass_fields(cls)
            doc=short(item['doc'])
            lines.append(f\"### "'`{name}`'"\\n\")
            lines.append(f\""'```python'"\\n{item['sig']}\\n"'```'"\\n\")
            lines.append(f\"Purpose: {doc}\\n\")
            if fields:
                field_bits=', '.join(f'"'`{n}: {a}` ({d})'"' for n,a,d in fields)
                lines.append(f\"Parameters / fields: {field_bits}.\\n\")
            else:
                lines.append(\"Parameters / fields: constructor-specific state only; inspect the implementation or dataclass defaults where applicable.\\n\")
            lines.append(f\"Returns: "'`{name}` instances.'"\\n\")
            exc='No module-specific constructor exception path beyond ordinary Python validation and any method-specific errors.'
            if name in {'SchemaValidationError','TaintLossError','LethalTrifectaError'}:
                exc='This class is itself an exception type.'
            lines.append(f\"Exceptions: {exc}\\n\")
            ex=f'"'`{name}()`'"' if not fields else f'"'`{name}(...)`'"'
            lines.append(f\"Example: {ex}.\\n\")
            if item['methods']:
                lines.append(\"Public methods:\\n\")
                for m in item['methods']:
                    md=short(m['doc']) if m['doc'] else 'No dedicated method docstring.'
                    lines.append(f\"- "'`{m['"'sig']}"'`: {md}")
                lines.append('"'')
    if not public_seen:
        lines.append('This module exposes no public classes or top-level functions.\\n')

text='\\n'.join(lines)
print(text)
print('WORDS', len(text.split()))
