  [33m> Write[0m(content='from typing import Callable, Any, Awaitable\nfrom .limiters.base import RateLimiter\nfrom .types import Decision\n\nclass RateLimitMiddleware:\n    def __init__(\n        self, \n        app: Any, \n        limiter: RateLimiter, \n        key_fn: Callable[[dict], str] = None,\n        cost_fn: Callable[[dict], int] = None\n    ):\n        self.app = app\n        self.limiter = limiter\n        self.key_fn = key_fn or self.default_key_fn\n        self.cost_fn = cost_fn or (lambda scope: 1)\n\n    @staticmethod\n    def default_key_fn(scope: dict) -> str:\n        client = scope.get("client")\n        if client:\n            return client[0]\n        return "default"\n\n    async def __call__(self, scope: dict, receive: Callable, send: Callable):\n        if scope["type"] != "http":\n            return await self.app(scope, receive, send)\n\n        key = self.key_fn(scope)\n        cost = self.cost_fn(scope)\n        \n        try:\n            decision = self.limiter.enforce(key, cost)\n        except Exception:\n            # Fail-open strategy\n            decision = Decision(allowed=True, limit=0, remaining=0, retry_after_ms=0, reset_ts=0)\n\n        if not decision.allowed:\n            await self._send_429(send, decision)\n            return\n\n        async def send_wrapper(message: dict):\n            if message["type"] == "http.response.start":\n                headers = list(message.get("headers", []))\n                # Append standard rate limiting headers\n                headers.extend([\n                    (b"X-RateLimit-Limit", str(decision.limit).encode()),\n                    (b"X-RateLimit-Remaining", str(decision.remaining).encode()),\n                    (b"X-RateLimit-Reset", str(int(decision.reset_ts / 1000)).encode()),\n                ])\n                message["headers"] = headers\n            await send(message)\n\n        await self.app(scope, receive, send_wrapper)\n\n    async def _send_429(self, send: Callable, decision: Decision):\n        headers = [\n            (b"content-type", b"text/plain"),\n            (b"X-RateLimit-Limit", str(decision.limit).encode()),\n            (b"X-RateLimit-Remaining", str(decision.remaining).encode()),\n            (b"X-RateLimit-Reset", str(int(decision.reset_ts / 1000)).encode()),\n            (b"Retry-After", str(max(1, int(decision.retry_after_ms / 1000))).encode()),\n        ]\n        await send({\n            "type": "http.response.start",\n            "status": 429,\n            "headers": headers\n        })\n        await send({\n            "type": "http.response.body",\n            "body": b"Too Many Requests"\n        })\n', file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-gemini-3.1/ratelimit/middleware.py')
