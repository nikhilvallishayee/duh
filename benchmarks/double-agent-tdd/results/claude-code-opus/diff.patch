+# ---------------------------------------------------------------------------
+# End-to-end against a stub provider
+# ---------------------------------------------------------------------------
+
+
+class TestEndToEnd:
+    async def test_full_flow_emits_six_phases_in_order(self):
+        agents, tests = _happy_path_scripts()
+        flow, _, _ = _make_flow(agent_script=agents, test_script=tests)
+
+        events: list[dict[str, Any]] = []
+        async for evt in flow.run():
+            events.append(evt)
+
+        done_phases = [
+            e["phase"] for e in events if e["type"] == "tdd_phase_done"
+        ]
+        assert done_phases == [
+            TDDPhase.NAVIGATOR_SPEC.value,
+            TDDPhase.DRIVER_RED.value,
+            TDDPhase.DRIVER_GREEN.value,
+            TDDPhase.NAVIGATOR_REFACTOR.value,
+            TDDPhase.DRIVER_REFACTOR.value,
+            TDDPhase.NAVIGATOR_VALIDATE.value,
+        ]
+        assert events[-1]["type"] == "tdd_done"
+        assert flow.phase is TDDPhase.DONE
+
+    async def test_run_flow_function_matches_class_behavior(self):
+        agents, tests = _happy_path_scripts()
+        agent = _ScriptedAgent(agents)
+        runner = _ScriptedRunner(tests)
+
+        events: list[dict[str, Any]] = []
+        async for evt in run_flow(
+            "widget sum endpoint",
+            deps=object(),
+            tools=[],
+            parent_model="stub-model",
+            config=TDDConfig(cwd=".", test_cmd="echo fake-tests"),
+            test_runner=runner,
+            agent_runner=agent,
+        ):
+            events.append(evt)
+
+        assert any(e["type"] == "tdd_done" for e in events)
+        # 6 phase_start + 6 phase_done + 1 done
+        phase_starts = [e for e in events if e["type"] == "tdd_phase_start"]
+        assert len(phase_starts) == 6
+
+    async def test_red_passed_triggers_spec_revision_and_recovery(self):
+        """If RED passes first time, Navigator revises the spec and RED re-runs."""
+        agent_script = [
+            ("reviewer", "1. weak spec"),            # SPEC (too loose)
+            ("coder",    "vacuous test"),            # RED attempt 1 (passes)
+            ("reviewer", "1. tighter spec"),         # SPEC revision
+            ("coder",    "failing test"),            # RED attempt 2 (fails)
+            ("coder",    "impl"),                    # GREEN
+            ("reviewer", "File: x\nChange: y\nWhy: z"),  # refactor suggest
+            ("coder",    "applied"),                 # refactor apply
+            ("reviewer", "PASS"),                    # validate
+        ]
+        test_script = [
+            TestRunResult(passed=True, exit_code=0, output="1 passed"),   # RED #1 (bad)
+            TestRunResult(
+                passed=False, exit_code=1,
+                output="E assert 0 == 1",
+                assertion_failure="assert 0 == 1",
+            ),  # RED #2 (good)
+            TestRunResult(passed=True, exit_code=0, output="2 passed"),   # GREEN
+            TestRunResult(passed=True, exit_code=0, output="2 passed"),   # VALIDATE
+        ]
+        flow, _, _ = _make_flow(
+            agent_script=agent_script, test_script=test_script,
+            config=TDDConfig(cwd=".", test_cmd="echo fake", max_spec_revisions=1),
+        )
+
+        events: list[dict[str, Any]] = []
+        async for evt in flow.run():
+            events.append(evt)
+
+        assert any(e["type"] == "tdd_error" and e["reason"] == "red_passed"
+                   for e in events)
+        assert events[-1]["type"] == "tdd_done"
+        # SPEC phase appears twice because of revision.
+        spec_starts = [
+            e for e in events
+            if e["type"] == "tdd_phase_start"
+            and e["phase"] == TDDPhase.NAVIGATOR_SPEC.value
+        ]
+        assert len(spec_starts) == 2
+
+    async def test_red_passed_halts_when_max_revisions_exhausted(self):
+        agent_script = [
+            ("reviewer", "1. loose spec"),
+            ("coder",    "vacuous test"),
+        ]
+        test_script = [
+            TestRunResult(passed=True, exit_code=0, output="1 passed"),
+        ]
+        flow, _, _ = _make_flow(
+            agent_script=agent_script, test_script=test_script,
+            config=TDDConfig(cwd=".", test_cmd="echo fake", max_spec_revisions=0),
+        )
+
+        events: list[dict[str, Any]] = []
+        async for evt in flow.run():
+            events.append(evt)
+
+        assert events[-1]["type"] == "tdd_error"
+        assert events[-1]["reason"] == "red_passed"
+        assert flow.phase is TDDPhase.DRIVER_RED
+
+    async def test_format_event_renders_each_event_type(self):
+        agents, tests = _happy_path_scripts()
+        flow, _, _ = _make_flow(agent_script=agents, test_script=tests)
+        events: list[dict[str, Any]] = []
+        async for evt in flow.run():
+            events.append(evt)
+        rendered = [format_event(e) for e in events]
+        # Every event renders to a non-empty string without raising.
+        assert all(isinstance(s, str) and s for s in rendered)
+        assert any(s.startswith("▶") for s in rendered)
+        assert any(s.startswith("✓") for s in rendered)
+        assert any(s.startswith("■") for s in rendered)
