index 0000000..ee9e673
--- /dev/null
+++ b/ratelimit/backends/memory.py
@@ -0,0 +1,171 @@
+"""In-process backend. Thread-safe via per-key locks.
+
+Appropriate for single-process deployments and for tests.
+"""
+
+from __future__ import annotations
+
+import math
+import threading
+import time
+from collections import deque
+from dataclasses import dataclass
+
+from ratelimit.backends.base import Backend
+from ratelimit.types import Decision
+
+
+def _now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+@dataclass
+class _BucketState:
+    tokens: float
+    last_refill_ms: int
+
+
+class InMemoryBackend(Backend):
+    """Thread-safe in-memory backend.
+
+    A single global lock guards the dict-of-dicts; per-key state
+    mutation is cheap so we don't need per-key locks. This is fine up
+    to tens of thousands of concurrent keys.
+    """
+
+    def __init__(self) -> None:
+        self._lock = threading.RLock()
+        self._buckets: dict[str, _BucketState] = {}
+        self._windows: dict[str, deque[int]] = {}
+
+    # ------------------------------------------------------------------
+    # token bucket
+    # ------------------------------------------------------------------
+
+    def token_bucket(
+        self,
+        key: str,
+        capacity: int,
+        refill_rate: float,
+        cost: int,
+        now_ms: int | None = None,
+    ) -> Decision:
+        if capacity < 1:
+            raise ValueError("capacity must be >= 1")
+        if cost < 1:
+            raise ValueError("cost must be >= 1")
+        if refill_rate <= 0:
+            raise ValueError("refill_rate must be > 0")
+
+        now = _now_ms() if now_ms is None else now_ms
+
+        with self._lock:
+            state = self._buckets.get(key)
+            if state is None:
+                state = _BucketState(tokens=float(capacity), last_refill_ms=now)
+                self._buckets[key] = state
+            else:
+                elapsed_ms = max(0, now - state.last_refill_ms)
+                state.tokens = min(
+                    float(capacity),
+                    state.tokens + (elapsed_ms / 1000.0) * refill_rate,
+                )
+                state.last_refill_ms = now
+
+            if state.tokens >= cost:
+                state.tokens -= cost
+                remaining = int(math.floor(state.tokens))
+                # Time for the bucket to refill to full from its current level.
+                deficit = capacity - state.tokens
+                reset_ms = now + int(math.ceil(deficit / refill_rate * 1000))
+                return Decision(
+                    allowed=True,
+                    retry_after_ms=0,
+                    remaining=remaining,
+                    reset_ts=reset_ms,
+                )
+
+            needed = cost - state.tokens
+            retry_after_ms = int(math.ceil(needed / refill_rate * 1000))
+            deficit = capacity - state.tokens
+            reset_ms = now + int(math.ceil(deficit / refill_rate * 1000))
+            return Decision(
+                allowed=False,
+                retry_after_ms=max(1, retry_after_ms),
+                remaining=int(math.floor(state.tokens)),
+                reset_ts=reset_ms,
+            )
+
+    # ------------------------------------------------------------------
+    # sliding window log
+    # ------------------------------------------------------------------
+
+    def sliding_window(
+        self,
+        key: str,
+        capacity: int,
+        period_ms: int,
+        cost: int,
+        now_ms: int | None = None,
+    ) -> Decision:
+        if capacity < 1:
+            raise ValueError("capacity must be >= 1")
+        if cost < 1:
+            raise ValueError("cost must be >= 1")
+        if period_ms <= 0:
+            raise ValueError("period_ms must be > 0")
+
+        now = _now_ms() if now_ms is None else now_ms
+        cutoff = now - period_ms
+
+        with self._lock:
+            log = self._windows.get(key)
+            if log is None:
+                log = deque()
+                self._windows[key] = log
+
+            # Evict expired timestamps.
+            while log and log[0] <= cutoff:
+                log.popleft()
+
+            used = len(log)
+            if used + cost <= capacity:
+                for _ in range(cost):
+                    log.append(now)
+                remaining = capacity - (used + cost)
+                reset_ms = (log[0] + period_ms) if log else (now + period_ms)
+                return Decision(
+                    allowed=True,
+                    retry_after_ms=0,
+                    remaining=remaining,
+                    reset_ts=reset_ms,
+                )
+
+            # Denied. retry_after is the time until enough slots free up.
+            # We need (used + cost - capacity) entries to age out.
+            need_to_expire = (used + cost) - capacity
+            if need_to_expire > len(log):
+                # cost > capacity case: impossible to ever admit.
+                return Decision(
+                    allowed=False,
+                    retry_after_ms=period_ms,
+                    remaining=max(0, capacity - used),
+                    reset_ts=now + period_ms,
+                )
+            # The kth-oldest entry must expire, where k = need_to_expire.
+            kth_oldest = log[need_to_expire - 1]
+            retry_after_ms = max(1, (kth_oldest + period_ms) - now)
+            reset_ms = log[0] + period_ms
+            return Decision(
+                allowed=False,
+                retry_after_ms=retry_after_ms,
+                remaining=max(0, capacity - used),
+                reset_ts=reset_ms,
+            )
+
+    # ------------------------------------------------------------------
+
+    def reset(self, key: str) -> None:
+        with self._lock:
+            self._buckets.pop(key, None)
+            self._windows.pop(key, None)
