+import pytest
+import threading
+from ratelimit import InMemoryBackend, TokenBucketLimiter, SlidingWindowLimiter
+
+def test_concurrency_token_bucket():
+    backend = InMemoryBackend()
+    limiter = TokenBucketLimiter(backend, capacity=10, refill_rate=0) # No refill, max 10
+    
+    key = "concurrent_tb"
+    
+    allowed_count = 0
+    lock = threading.Lock()
+    
+    def worker():
+        nonlocal allowed_count
+        if limiter.enforce(key).allowed:
+            with lock:
+                allowed_count += 1
+                
+    threads = [threading.Thread(target=worker) for _ in range(150)]
+    for t in threads: t.start()
+    for t in threads: t.join()
+    
+    assert allowed_count == 10
+
+def test_concurrency_sliding_window():
+    backend = InMemoryBackend()
+    limiter = SlidingWindowLimiter(backend, capacity=20, window_size_ms=10000)
+    
+    key = "concurrent_sw"
+    
+    allowed_count = 0
+    lock = threading.Lock()
+    
+    def worker():
+        nonlocal allowed_count
+        if limiter.enforce(key).allowed:
+            with lock:
+                allowed_count += 1
+                
+    threads = [threading.Thread(target=worker) for _ in range(150)]
+    for t in threads: t.start()
+    for t in threads: t.join()
+    
+    assert allowed_count == 20
