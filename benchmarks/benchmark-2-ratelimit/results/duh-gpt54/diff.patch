@@ -0,0 +1,283 @@
+from __future__ import annotations
+
+import threading
+import time
+from math import ceil
+from typing import Any
+
+from redis import Redis
+
+from .core import Decision
+
+
+class InMemoryBackend:
+    def __init__(self) -> None:
+        self._lock = threading.RLock()
+        self._token_buckets: dict[str, dict[str, float]] = {}
+        self._sliding_windows: dict[str, dict[str, int]] = {}
+
+    def token_bucket_enforce(
+        self,
+        key: str,
+        *,
+        capacity: int,
+        refill_rate: float,
+        cost: int,
+    ) -> Decision:
+        now_ms = self._now_ms()
+        now_monotonic = time.monotonic()
+        refill_per_ms = refill_rate / 1000.0
+        with self._lock:
+            state = self._token_buckets.get(key)
+            if state is None:
+                tokens = float(capacity)
+                last_refill = now_monotonic
+            else:
+                elapsed = max(0.0, now_monotonic - state["last_refill"])
+                tokens = min(float(capacity), state["tokens"] + (elapsed * refill_rate))
+                last_refill = now_monotonic
+
+            allowed = tokens >= cost
+            if allowed:
+                tokens -= cost
+                retry_after_ms = 0
+            else:
+                deficit = cost - tokens
+                retry_after_ms = ceil((deficit / refill_rate) * 1000)
+
+            remaining = max(0, int(tokens)) if allowed else max(0, int(tokens))
+            reset_ts = now_ms + ceil(((capacity - tokens) / refill_per_ms)) if refill_per_ms else now_ms
+            self._token_buckets[key] = {"tokens": tokens, "last_refill": last_refill}
+            return Decision(
+                allowed=allowed,
+                retry_after_ms=retry_after_ms,
+                remaining=remaining,
+                reset_ts=reset_ts,
+            )
+
+    def sliding_window_enforce(
+        self,
+        key: str,
+        *,
+        limit: int,
+        period_ms: int,
+        cost: int,
+    ) -> Decision:
+        now_ms = self._now_ms()
+        bucket_start = now_ms - (now_ms % period_ms)
+        with self._lock:
+            state = self._sliding_windows.get(key)
+            if state is None:
+                state = {
+                    "current_start": bucket_start,
+                    "current_count": 0,
+                    "previous_count": 0,
+                }
+            else:
+                current_start = state["current_start"]
+                if bucket_start == current_start:
+                    pass
+                elif bucket_start == current_start + period_ms:
+                    state = {
+                        "current_start": bucket_start,
+                        "current_count": 0,
+                        "previous_count": state["current_count"],
+                    }
+                else:
+                    state = {
+                        "current_start": bucket_start,
+                        "current_count": 0,
+                        "previous_count": 0,
+                    }
+
+            elapsed = now_ms - state["current_start"]
+            weight = max(0.0, 1.0 - (elapsed / period_ms))
+            effective = state["current_count"] + (state["previous_count"] * weight)
+            allowed = effective + cost <= limit
+            if allowed:
+                state["current_count"] += cost
+                effective += cost
+                retry_after_ms = 0
+            else:
+                if state["previous_count"] == 0:
+                    retry_after_ms = period_ms - elapsed
+                else:
+                    needed_decay = effective + cost - limit
+                    decay_per_ms = state["previous_count"] / period_ms
+                    retry_after_ms = period_ms - elapsed if decay_per_ms <= 0 else ceil(needed_decay / decay_per_ms)
+                    retry_after_ms = max(1, min(period_ms - elapsed if elapsed < period_ms else period_ms, retry_after_ms))
+
+            remaining = max(0, limit - ceil(effective))
+            reset_ts = state["current_start"] + period_ms * 2
+            self._sliding_windows[key] = state
+            return Decision(
+                allowed=allowed,
+                retry_after_ms=retry_after_ms,
+                remaining=remaining,
+                reset_ts=reset_ts,
+            )
+
+    @staticmethod
+    def _now_ms() -> int:
+        return int(time.time() * 1000)
+
+
+class RedisBackend:
+    _TOKEN_BUCKET_SCRIPT = """
+local key = KEYS[1]
+local capacity = tonumber(ARGV[1])
+local refill_rate = tonumber(ARGV[2])
+local cost = tonumber(ARGV[3])
+local ttl_ms = tonumber(ARGV[4])
+
+local now = redis.call('TIME')
+local now_ms = now[1] * 1000 + math.floor(now[2] / 1000)
+
+local data = redis.call('HMGET', key, 'tokens', 'last_refill_ms')
+local tokens = tonumber(data[1])
+local last_refill_ms = tonumber(data[2])
+if not tokens then
+  tokens = capacity
+  last_refill_ms = now_ms
+end
+
+local elapsed = math.max(0, now_ms - last_refill_ms)
+local refilled = math.min(capacity, tokens + (elapsed * refill_rate / 1000.0))
+local allowed = 0
+local retry_after_ms = 0
+
+if refilled >= cost then
+  refilled = refilled - cost
+  allowed = 1
+else
+  local deficit = cost - refilled
+  retry_after_ms = math.ceil((deficit / refill_rate) * 1000)
+end
+
+redis.call('HSET', key, 'tokens', refilled, 'last_refill_ms', now_ms)
+redis.call('PEXPIRE', key, ttl_ms)
+
+local remaining = math.max(0, math.floor(refilled))
+local reset_ts = now_ms + math.ceil(((capacity - refilled) / refill_rate) * 1000)
+return {allowed, retry_after_ms, remaining, reset_ts}
+"""
+
+    _SLIDING_WINDOW_SCRIPT = """
+local key = KEYS[1]
+local limit = tonumber(ARGV[1])
+local period_ms = tonumber(ARGV[2])
+local cost = tonumber(ARGV[3])
+local ttl_ms = tonumber(ARGV[4])
+
+local now = redis.call('TIME')
+local now_ms = now[1] * 1000 + math.floor(now[2] / 1000)
+local bucket_start = now_ms - (now_ms % period_ms)
+
+local data = redis.call('HMGET', key, 'current_start', 'current_count', 'previous_count')
+local current_start = tonumber(data[1])
+local current_count = tonumber(data[2]) or 0
+local previous_count = tonumber(data[3]) or 0
+
+if not current_start then
+  current_start = bucket_start
+  current_count = 0
+  previous_count = 0
+elseif bucket_start == current_start + period_ms then
+  previous_count = current_count
+  current_count = 0
+  current_start = bucket_start
+elseif bucket_start > current_start + period_ms then
+  previous_count = 0
+  current_count = 0
+  current_start = bucket_start
+end
+
+local elapsed = now_ms - current_start
+local weight = math.max(0, 1 - (elapsed / period_ms))
+local effective = current_count + (previous_count * weight)
+local allowed = 0
+local retry_after_ms = 0
+
+if effective + cost <= limit then
+  current_count = current_count + cost
+  effective = effective + cost
+  allowed = 1
+else
+  if previous_count == 0 then
+    retry_after_ms = period_ms - elapsed
+  else
+    local needed_decay = effective + cost - limit
+    local decay_per_ms = previous_count / period_ms
+    if decay_per_ms <= 0 then
+      retry_after_ms = period_ms - elapsed
+    else
+      retry_after_ms = math.ceil(needed_decay / decay_per_ms)
+      local remainder = period_ms - elapsed
+      if retry_after_ms < 1 then retry_after_ms = 1 end
+      if retry_after_ms > remainder then retry_after_ms = remainder end
+    end
+  end
+end
+
+redis.call('HSET', key, 'current_start', current_start, 'current_count', current_count, 'previous_count', previous_count)
+redis.call('PEXPIRE', key, ttl_ms)
+
+local remaining = math.max(0, limit - math.ceil(effective))
+local reset_ts = current_start + period_ms * 2
+return {allowed, retry_after_ms, remaining, reset_ts}
+"""
+
+    def __init__(self, client: Redis) -> None:
+        self._client = client
+        self._token_bucket_sha = self._client.script_load(self._TOKEN_BUCKET_SCRIPT)
+        self._sliding_window_sha = self._client.script_load(self._SLIDING_WINDOW_SCRIPT)
+
+    def token_bucket_enforce(
+        self,
+        key: str,
+        *,
+        capacity: int,
+        refill_rate: float,
+        cost: int,
+    ) -> Decision:
+        ttl_ms = max(1000, ceil((capacity / refill_rate) * 2000))
+        result = self._evalsha(
+            self._token_bucket_sha,
+            1,
+            key,
+            capacity,
+            refill_rate,
+            cost,
+            ttl_ms,
+        )
+        return Decision(bool(result[0]), int(result[1]), int(result[2]), int(result[3]))
+
+    def sliding_window_enforce(
+        self,
+        key: str,
+        *,
+        limit: int,
+        period_ms: int,
+        cost: int,
+    ) -> Decision:
+        ttl_ms = period_ms * 2
+        result = self._evalsha(
+            self._sliding_window_sha,
+            1,
+            key,
+            limit,
+            period_ms,
+            cost,
+            ttl_ms,
+        )
+        return Decision(bool(result[0]), int(result[1]), int(result[2]), int(result[3]))
+
+    def _evalsha(self, sha: str, numkeys: int, *args: Any) -> list[Any]:
+        try:
+            return self._client.evalsha(sha, numkeys, *args)
+        except Exception as exc:
+            if exc.__class__.__name__ != 'NoScriptError':
+                raise
+            self._token_bucket_sha = self._client.script_load(self._TOKEN_BUCKET_SCRIPT)
+            self._sliding_window_sha = self._client.script_load(self._SLIDING_WINDOW_SCRIPT)
+            return self._client.evalsha(sha, numkeys, *args)
