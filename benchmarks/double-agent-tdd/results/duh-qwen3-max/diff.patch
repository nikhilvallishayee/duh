+        assert result.phase == 1
+        assert result.success == True
+        assert result.output == "test output"
+        assert result.error == "test error"
+        assert result.metadata == {"key": "value"}
+
+    def test_tool_properties(self):
+        """Test that the tool has correct properties."""
+        tool = DoubleAgentTDDTool()
+        
+        assert tool.name == "DoubleAgentTDD"
+        assert tool.description is not None
+        assert tool.input_schema is not None
+        assert not tool.is_read_only
+        assert not tool.is_destructive
+
+
+class TestDoubleAgentTDDIntegration:
+    """Integration tests for the double-agent TDD flow."""
+    
+    @pytest.mark.asyncio
+    async def test_full_tdd_flow_phases(self):
+        """Test that all six phases execute in order."""
+        tool = DoubleAgentTDDTool()
+        
+        # Mock all phase methods to return success
+        phase_results = []
+        for phase in range(1, 7):
+            result = TDDPhaseResult(
+                phase=phase,
+                success=True,
+                output=f"Phase {phase} output",
+                metadata={"test_failed": phase == 2, "test_passed": phase == 3}
+            )
+            phase_results.append(result)
+        
+        with patch.multiple(
+            tool,
+            _phase1_draft_spec=AsyncMock(return_value=phase_results[0]),
+            _phase2_write_failing_test=AsyncMock(return_value=phase_results[1]),
+            _phase3_implement_minimum_code=AsyncMock(return_value=phase_results[2]),
+            _phase4_propose_refactor=AsyncMock(return_value=phase_results[3]),
+            _phase5_apply_refactor=AsyncMock(return_value=phase_results[4]),
