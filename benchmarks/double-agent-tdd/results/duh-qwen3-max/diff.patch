+"""Double-agent TDD flow implementation.
+
+Implements the six-phase red-green-refactor flow with Driver/Navigator agents
+as described in ADR-076.
+"""
+from __future__ import annotations
+
+import asyncio
+import json
+import os
+import tempfile
+from dataclasses import dataclass, field
+from typing import Any, Dict, List, Optional, Tuple
+
+from duh.kernel.tool import ToolContext, ToolResult
+from duh.security.trifecta import Capability
+from duh.agents import run_agent, AGENT_TYPES
+
+
+@dataclass
+class TDDPhaseResult:
+    """Result from a single TDD phase."""
+    phase: int
+    success: bool
+    output: str
+    error: str = ""
+    metadata: Dict[str, Any] = field(default_factory=dict)
+
+
+class DoubleAgentTDDTool:
+    """Double-agent TDD flow tool.
+    
+    Implements the six-phase red-green-refactor flow:
+    1. Navigator drafts test spec
+    2. Driver writes failing test (RED)
+    3. Driver implements minimum code (GREEN) 
+    4. Navigator proposes refactor
+    5. Driver applies refactor
+    6. Navigator validates
+    
+    See ADR-076 for complete specification.
+    """
+    name = "DoubleAgentTDD"
+    capabilities = Capability.EXEC
+    description = (
+        "Execute a double-agent TDD flow with six phases: "
+        "1) Navigator drafts test spec, 2) Driver writes failing test (RED), "
+        "3) Driver implements minimum code (GREEN), 4) Navigator proposes refactor, "
+        "5) Driver applies refactor, 6) Navigator validates. "
+        "Follows strict red-green-refactor methodology with driver/navigator roles."
+    )
+    input_schema = {
+        "type": "object",
+        "properties": {
+            "task": {
+                "type": "string",
+                "description": "The feature or bug fix to implement using TDD",
+            },
+            "test_framework": {
+                "type": "string",
+                "description": "Test framework to use (e.g., 'pytest', 'unittest')",
+                "default": "pytest"
+            },
+            "max_turns_per_phase": {
+                "type": "integer",
+                "description": "Maximum turns per phase (default: 10)",
+                "default": 10
+            }
+        },
+        "required": ["task"]
+    }
+    is_read_only = False
+    is_destructive = False
+
+    def __init__(
+        self,
+        *,
+        parent_deps: Any = None,
+        parent_tools: list[Any] | None = None,
+        parent_model: str | callable = "",
+    ):
+        self._parent_deps = parent_deps
+        self._parent_tools = parent_tools
+        self._parent_model: str | callable = parent_model
+
+    def _resolve_parent_model(self) -> str:
+        pm = self._parent_model
+        if callable(pm):
+            try:
+                return pm() or ""
+            except Exception:
+                return ""
+        return pm or ""
+
+    def _child_tools(self) -> list[Any]:
+        """Return parent tools minus Agent and Swarm (prevent recursion)."""
+        if not self._parent_tools:
+            return []
+        excluded = {"Agent", "Swarm", "DoubleAgentTDD"}
+        return [t for t in self._parent_tools if getattr(t, "name", "") not in excluded]
+
+    async def call(self, input: dict[str, Any], context: ToolContext) -> ToolResult:
+        if self._parent_deps is None:
+            return ToolResult(output="DoubleAgentTDD error: no parent deps configured", is_error=True)
+
+        task = input.get("task", "")
+        test_framework = input.get("test_framework", "pytest")
+        max_turns_per_phase = input.get("max_turns_per_phase", 10)
+
+        if not task:
+            return ToolResult(
+                output="DoubleAgentTDD error: missing required 'task' parameter", 
+                is_error=True
+            )
+
+        # Infer appropriate file paths based on the task description
+        # This will be handled by the agents themselves - they will decide
+        # where to create test and implementation files based on the task
+        try:
+            result = await self._execute_tdd_flow(
+                task, test_framework, max_turns_per_phase, context
+            )
+            return ToolResult(output=result)
+        except Exception as e:
+            return ToolResult(output=f"DoubleAgentTDD error: {str(e)}", is_error=True)
+
+    async def _execute_tdd_flow(
+        self, 
+        task: str, 
+        test_framework: str,
+        max_turns_per_phase: int,
+        context: ToolContext
+    ) -> str:
+        """Execute the six-phase TDD flow."""
+        child_tools = self._child_tools()
+        parent_model = self._resolve_parent_model()
+        
+        # Phase 1: Navigator drafts test spec
+        phase1_result = await self._phase1_draft_spec(
+            task, test_framework, max_turns_per_phase,
+            child_tools, parent_model, context
+        )
+        if not phase1_result.success:
+            return f"Phase 1 failed: {phase1_result.error}\n{phase1_result.output}"
+        
+        test_spec = phase1_result.output
+        
+        # Phase 2: Driver writes failing test (RED)
+        phase2_result = await self._phase2_write_failing_test(
+            test_spec, test_framework, max_turns_per_phase,
+            child_tools, parent_model, context
+        )
+        if not phase2_result.success:
+            return f"Phase 2 failed: {phase2_result.error}\n{phase2_result.output}"
+        
+        # Verify test actually fails
+        if not phase2_result.metadata.get("test_failed", False):
+            # Test passed when it should have failed - spec was insufficient
+            return (
+                "Phase 2 validation failed: Test passed when it should have failed. "
+                "This indicates the test specification was not tight enough. "
+                "Navigator needs to revise the spec."
+            )
+        
+        # Phase 3: Driver implements minimum code (GREEN)
+        phase3_result = await self._phase3_implement_minimum_code(
+            test_spec, test_framework, max_turns_per_phase,
+            child_tools, parent_model, context
+        )
+        if not phase3_result.success:
+            return f"Phase 3 failed: {phase3_result.error}\n{phase3_result.output}"
+        
+        # Verify test now passes
+        if not phase3_result.metadata.get("test_passed", False):
+            return f"Phase 3 validation failed: Test still failing after implementation"
+        
+        # Phase 4: Navigator proposes refactor
+        phase4_result = await self._phase4_propose_refactor(
+            test_spec, test_framework, max_turns_per_phase,
+            child_tools, parent_model, context
+        )
+        if not phase4_result.success:
+            return f"Phase 4 failed: {phase4_result.error}\n{phase4_result.output}"
+        
+        refactor_proposal = phase4_result.output
+        
+        # Phase 5: Driver applies refactor
+        phase5_result = await self._phase5_apply_refactor(
+            refactor_proposal, max_turns_per_phase,
+            child_tools, parent_model, context
+        )
+        if not phase5_result.success:
+            return f"Phase 5 failed: {phase5_result.error}\n{phase5_result.output}"
+        
+        # Phase 6: Navigator validates
+        phase6_result = await self._phase6_validate(
+            test_spec, refactor_proposal, test_framework, max_turns_per_phase,
+            child_tools, parent_model, context
+        )
+        if not phase6_result.success:
+            return f"Phase 6 failed: {phase6_result.error}\n{phase6_result.output}"
+        
+        return (
+            "Double-agent TDD flow completed successfully!\n\n"
+            "✅ Phase 1: Navigator drafted test spec\n"
+            "✅ Phase 2: Driver wrote failing test (RED)\n"
+            "✅ Phase 3: Driver implemented minimum code (GREEN)\n"
+            "✅ Phase 4: Navigator proposed refactor\n"
+            "✅ Phase 5: Driver applied refactor\n"
+            "✅ Phase 6: Navigator validated final implementation\n\n"
+            f"Final validation: {phase6_result.output}"
+        )
+
+    async def _phase1_draft_spec(
+        self, task: str, test_framework: str, max_turns_per_phase: int,
+        tools: list, parent_model: str, context: ToolContext
+    ) -> TDDPhaseResult:
+        """Phase 1: Navigator drafts test spec."""
+        prompt = (
+            f"Draft a comprehensive test specification for the following feature:\n\n"
+            f"Feature: {task}\n\n"
+            f"Test framework: {test_framework}\n\n"
+            f"Your specification should include:\n"
+            f"- Clear description of expected behavior\n"
+            f"- Specific file paths for test and implementation files (e.g., 'test_calculator.py' and 'calculator.py')\n"
+            f"- Specific test cases with inputs and expected outputs\n"
+            f"- Edge cases and error conditions to test\n"
+            f"- Validation criteria for what constitutes a proper test failure\n\n"
+            f"Be explicit about file locations and contents. Output ONLY the test specification in clear, structured format."
+        )
+        
+        result = await run_agent(
+            prompt=prompt,
+            agent_type="reviewer",
+            model="inherit",
+            parent_model=parent_model,
+            deps=self._parent_deps,
+            tools=tools,
+        )
+        
+        if result.is_error:
+            return TDDPhaseResult(
+                phase=1, success=False, output="", error=result.error
+            )
+        
+        return TDDPhaseResult(
+            phase=1, success=True, output=result.result_text
+        )
+
+    async def _phase2_write_failing_test(
+        self, test_spec: str, test_framework: str, max_turns_per_phase: int,
+        tools: list, parent_model: str, context: ToolContext
+    ) -> TDDPhaseResult:
+        """Phase 2: Driver writes failing test (RED)."""
+        prompt = (
+            f"Write a test file that implements the following specification:\n\n"
+            f"Test Specification:\n{test_spec}\n\n"
+            f"Test framework: {test_framework}\n\n"
+            f"IMPORTANT: The test should FAIL when run against the current state "
+            f"(which has no implementation yet). Write the test first, then verify it fails.\n\n"
+            f"Steps to follow:\n"
+            f"1. Extract the test file path and implementation file path from the specification\n"
+            f"2. Create the test file with proper test cases\n"
+            f"3. Run the test to verify it fails (use Bash tool)\n"
+            f"4. If test passes, it means the spec is wrong - but assume spec is correct\n"
+            f"5. Output the test file content and the test failure output"
+        )
+        
+        result = await run_agent(
+            prompt=prompt,
+            agent_type="coder",
+            model="inherit",
+            parent_model=parent_model,
+            deps=self._parent_deps,
+            tools=tools,
+        )
+        
+        if result.is_error:
+            return TDDPhaseResult(
+                phase=2, success=False, output="", error=result.error
+            )
+        
+        # Parse result to determine if test actually failed
+        test_failed = "AssertionError" in result.result_text or "FAILED" in result.result_text or "fail" in result.result_text.lower()
+        
+        return TDDPhaseResult(
+            phase=2, 
+            success=True, 
+            output=result.result_text,
+            metadata={"test_failed": test_failed}
+        )
+
+    async def _phase3_implement_minimum_code(
+        self, test_spec: str, test_framework: str, max_turns_per_phase: int,
+        tools: list, parent_model: str, context: ToolContext
+    ) -> TDDPhaseResult:
+        """Phase 3: Driver implements minimum code (GREEN)."""
+        prompt = (
+            f"Implement the minimum code necessary to make the failing test pass.\n\n"
+            f"Test Specification:\n{test_spec}\n\n"
+            f"Test framework: {test_framework}\n\n"
+            f"Steps to follow:\n"
+            f"1. Extract the test file path and implementation file path from the specification\n"
+            f"2. Read the failing test to understand what needs to be implemented\n"
+            f"3. Write ONLY the minimum code needed to make the test pass\n"
+            f"4. Run the test to verify it now passes\n"
+            f"5. Output the implementation code and the test passing output"
+        )
+        
+        result = await run_agent(
+            prompt=prompt,
+            agent_type="coder",
+            model="inherit",
+            parent_model=parent_model,
+            deps=self._parent_deps,
+            tools=tools,
+        )
+        
+        if result.is_error:
+            return TDDPhaseResult(
+                phase=3, success=False, output="", error=result.error
+            )
+        
+        # Parse result to determine if test now passes
+        test_passed = "PASSED" in result.result_text or "passed" in result.result_text.lower() or "OK" in result.result_text
+        
+        return TDDPhaseResult(
+            phase=3, 
+            success=True, 
+            output=result.result_text,
+            metadata={"test_passed": test_passed}
+        )
+
+    async def _phase4_propose_refactor(
+        self, test_spec: str, test_framework: str, max_turns_per_phase: int,
+        tools: list, parent_model: str, context: ToolContext
+    ) -> TDDPhaseResult:
+        """Phase 4: Navigator proposes refactor."""
+        prompt = (
+            f"Review the current implementation and propose specific refactor improvements.\n\n"
+            f"Test Specification:\n{test_spec}\n\n"
+            f"Test framework: {test_framework}\n\n"
+            f"Focus on:\n"
+            f"- Code quality and readability\n"
+            f"- Performance improvements\n"
+            f"- Maintainability and extensibility\n"
+            f"- Following best practices for the language/framework\n\n"
+            f"Extract the implementation file path from the test specification.\n"
+            f"Provide specific, actionable refactor suggestions with code examples if needed.\n"
+            f"Output ONLY the refactor proposal."
+        )
+        
+        result = await run_agent(
+            prompt=prompt,
+            agent_type="reviewer",
+            model="inherit",
+            parent_model=parent_model,
+            deps=self._parent_deps,
+            tools=tools,
+        )
+        
+        if result.is_error:
+            return TDDPhaseResult(
+                phase=4, success=False, output="", error=result.error
+            )
+        
+        return TDDPhaseResult(
+            phase=4, success=True, output=result.result_text
+        )
+
+    async def _phase5_apply_refactor(
+        self, refactor_proposal: str, max_turns_per_phase: int,
+        tools: list, parent_model: str, context: ToolContext
+    ) -> TDDPhaseResult:
+        """Phase 5: Driver applies refactor."""
+        prompt = (
+            f"Apply the following refactor suggestions to the implementation:\n\n"
+            f"Refactor Proposal:\n{refactor_proposal}\n\n"
+            f"Steps to follow:\n"
+            f"1. Determine the implementation file path from the refactor proposal or previous context\n"
+            f"2. Read the current implementation\n"
+            f"3. Apply the refactor suggestions precisely\n"
+            f"4. Ensure the code still works (but don't run tests yet)\n"
+            f"5. Output the refactored code"
+        )
+        
+        result = await run_agent(
+            prompt=prompt,
+            agent_type="coder",
+            model="inherit",
+            parent_model=parent_model,
+            deps=self._parent_deps,
+            tools=tools,
+        )
+        
+        if result.is_error:
+            return TDDPhaseResult(
+                phase=5, success=False, output="", error=result.error
+            )
+        
+        return TDDPhaseResult(
+            phase=5, success=True, output=result.result_text
+        )
+
+    async def _phase6_validate(
+        self, test_spec: str, refactor_proposal: str, test_framework: str, max_turns_per_phase: int,
+        tools: list, parent_model: str, context: ToolContext
+    ) -> TDDPhaseResult:
+        """Phase 6: Navigator validates."""
+        prompt = (
+            f"Validate the final implementation against the original specification "
+            f"and refactor proposal.\n\n"
+            f"Original Test Specification:\n{test_spec}\n\n"
+            f"Refactor Proposal:\n{refactor_proposal}\n\n"
+            f"Test framework: {test_framework}\n\n"
+            f"Validation checklist:\n"
+            f"1. Extract test and implementation file paths from the test specification\n"
+            f"2. All tests pass\n"
+            f"3. Refactor suggestions were properly applied\n"
+            f"4. No functionality was broken\n"
+            f"5. Code quality meets the refactor goals\n\n"
+            f"Run the tests and examine the implementation, then provide a validation report."
+        )
+        
+        result = await run_agent(
+            prompt=prompt,
+            agent_type="reviewer",
+            model="inherit",
+            parent_model=parent_model,
+            deps=self._parent_deps,
+            tools=tools,
+        )
+        
+        if result.is_error:
+            return TDDPhaseResult(
+                phase=6, success=False, output="", error=result.error
+            )
+        
+        return TDDPhaseResult(
+            phase=6, success=True, output=result.result_text
+        )
+
+    async def check_permissions(
+        self, input: dict[str, Any], context: ToolContext
+    ) -> dict[str, Any]:
+        return {"allowed": True}
