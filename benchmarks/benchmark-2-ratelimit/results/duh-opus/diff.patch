new file mode 100644
index 0000000..3f18e17
--- /dev/null
+++ b/tests/test_properties.py
@@ -0,0 +1,129 @@
+"""Property-based invariants: never grant more than `capacity` in a window."""
+
+from hypothesis import HealthCheck, given, settings
+from hypothesis import strategies as st
+
+from ratelimit import InMemoryBackend, SlidingWindowLimiter, TokenBucketLimiter
+
+
+@given(
+    capacity=st.integers(min_value=1, max_value=50),
+    period_ms=st.integers(min_value=100, max_value=5_000),
+    ops=st.lists(
+        st.tuples(
+            st.floats(min_value=0.0, max_value=20.0, allow_nan=False),  # dt seconds
+            st.integers(min_value=1, max_value=3),                       # cost
+        ),
+        min_size=1,
+        max_size=200,
+    ),
+)
+@settings(deadline=None, max_examples=80, suppress_health_check=[HealthCheck.too_slow])
+def test_sliding_window_never_over_grants(capacity, period_ms, ops):
+    """For any schedule of (dt, cost) calls, the number of admitted
+    units in any trailing window of length `period_ms` never exceeds
+    `capacity`.
+    """
+    clock = [0.0]
+
+    def fake_clock():
+        return clock[0]
+
+    backend = InMemoryBackend(clock=fake_clock)
+    lim = SlidingWindowLimiter(capacity=capacity, period_ms=period_ms, backend=backend)
+
+    # record (timestamp_ms, cost) of every *admitted* request
+    admitted: list[tuple[int, int]] = []
+    for dt, cost in ops:
+        clock[0] += dt
+        d = lim.enforce("k", cost=cost)
+        if d.allowed:
+            admitted.append((int(clock[0] * 1000), cost))
+
+    # For every admitted event, in the period [t - period_ms + 1, t]
+    # the sum of costs must be ≤ capacity.
+    # The sliding-window counter is an *approximation* (see ADR): its
+    # error is bounded but it can admit slightly more than capacity
+    # across the sharp trailing-window definition when two windows'
+    # worth of traffic are concentrated near a boundary.  We therefore
+    # assert it never admits more than 2 * capacity in any trailing
+    # `period_ms` window (the documented, asymptotic-worst upper bound).
+    admitted.sort()
+    for i, (t_i, _) in enumerate(admitted):
+        total = 0
+        for t_j, c_j in admitted:
+            if t_j <= t_i and t_j > t_i - period_ms:
+                total += c_j
+        assert total <= 2 * capacity, (
+            f"admitted={admitted}, window ending {t_i}, total={total}, cap={capacity}"
+        )
+
+
+@given(
+    capacity=st.integers(min_value=1, max_value=50),
+    refill_per_sec=st.floats(min_value=0.1, max_value=100.0, allow_nan=False),
+    ops=st.lists(
+        st.tuples(
+            st.floats(min_value=0.0, max_value=5.0, allow_nan=False),
+            st.integers(min_value=1, max_value=3),
+        ),
+        min_size=1,
+        max_size=200,
+    ),
+)
+@settings(deadline=None, max_examples=80, suppress_health_check=[HealthCheck.too_slow])
+def test_token_bucket_exact_invariant(capacity, refill_per_sec, ops):
+    """Token bucket invariant: in any window of length W, the number
+    of tokens admitted is ≤ capacity + W * refill_per_sec.
+    """
+    clock = [0.0]
+
+    def fake_clock():
+        return clock[0]
+
+    backend = InMemoryBackend(clock=fake_clock)
+    lim = TokenBucketLimiter(
+        capacity=capacity, refill_per_sec=refill_per_sec, backend=backend
+    )
+
+    admitted: list[tuple[float, int]] = []
+    for dt, cost in ops:
+        clock[0] += dt
+        d = lim.enforce("k", cost=cost)
+        if d.allowed:
+            admitted.append((clock[0], cost))
+
+    # Check the invariant against every pair (earliest_start, t_end).
+    # Over [t0, t1] the bucket can deliver at most capacity + (t1 - t0) * rate.
+    for i, (t_end, _) in enumerate(admitted):
+        # look at all windows starting at each prior admitted event's
+        # time; this captures the tightest invariants.
+        for j, (t_start, _) in enumerate(admitted[: i + 1]):
+            total = sum(c for t, c in admitted[j : i + 1])
+            window = t_end - t_start
+            budget = capacity + window * refill_per_sec
+            assert total <= budget + 1e-6, (
+                f"admitted from {t_start} to {t_end}: total={total} > "
+                f"budget={budget} (cap={capacity}, rate={refill_per_sec})"
+            )
+
+
+@given(
+    capacity=st.integers(min_value=1, max_value=20),
+    n_calls=st.integers(min_value=1, max_value=100),
+)
+@settings(deadline=None, max_examples=50)
+def test_token_bucket_fixed_clock_exact(capacity, n_calls):
+    """With a frozen clock, admitted count equals min(capacity, n_calls)."""
+    clock = [0.0]
+
+    def fake_clock():
+        return clock[0]
+
+    backend = InMemoryBackend(clock=fake_clock)
+    lim = TokenBucketLimiter(capacity=capacity, refill_per_sec=1.0, backend=backend)
+    admitted = 0
+    for _ in range(n_calls):
+        if lim.enforce("k").allowed:
+            admitted += 1
+    assert admitted == min(capacity, n_calls)
