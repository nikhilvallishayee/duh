+# ---------------------------------------------------------------------------
+# 3. Refactor prompt must contain the Navigator's proposal verbatim
+# ---------------------------------------------------------------------------
+
+
+class TestRefactorContract:
+    """The Navigator's refactor suggestion is actually applied before
+    validation — i.e. the prompt the Driver sees for REFACTOR_APPLY must
+    literally include the Navigator's words.
+    """
+
+    async def test_refactor_plan_text_flows_into_apply_prompt(self):
+        """Record every prompt the Driver engine sees and assert that
+        the REFACTOR_APPLY prompt contains the Navigator's refactor text.
+        """
+        driver_prompts: list[str] = []
+
+        async def capturing_driver_model(**kwargs) -> AsyncGenerator[dict[str, Any], None]:
+            # The user message is the last one with role="user" in the list.
+            messages = kwargs.get("messages", [])
+            for m in reversed(messages):
+                content = getattr(m, "content", m.get("content") if isinstance(m, dict) else None)
+                if isinstance(content, str):
+                    driver_prompts.append(content)
+                    break
+                if isinstance(content, list):
+                    for block in content:
+                        if isinstance(block, dict) and block.get("type") == "text":
+                            driver_prompts.append(block.get("text", ""))
+                            break
+                    else:
+                        continue
+                    break
+            text = "ok"
+            msg = Message(role="assistant", content=[{"type": "text", "text": text}])
+            yield {"type": "text_delta", "text": text}
+            yield {"type": "assistant", "message": msg}
+            yield {"type": "done", "stop_reason": "end_turn", "turns": 1}
+
+        driver = Engine(
+            deps=Deps(call_model=capturing_driver_model),
+            config=EngineConfig(model="test-model"),
+        )
+        navigator = _make_engine(
+            [
+                "spec body",
+                "Refactor: extract compute_total() helper from the if-ladder in cache.py",
+            ],
+        )
+
+        runner = FakeRunner(
+            [
+                GateResult(phase="", exit_code=1, stdout="fail", stderr=""),  # RED
+                GateResult(phase="", exit_code=0, stdout="pass", stderr=""),  # GREEN
+            ],
+        )
+        tdd = TddMode(driver=driver, navigator=navigator, test_runner=runner)
+
+        await _collect(tdd.draft_spec("feature"))
+        await _collect(tdd.red())
+        await _collect(tdd.green())
+        await _collect(tdd.propose_refactor())
+        await _collect(tdd.refactor_apply())
+
+        assert tdd.state == TddState.REFACTOR_APPLY
+        # The Driver received THREE prompts: RED, GREEN, REFACTOR_APPLY.
+        assert len(driver_prompts) == 3
+        apply_prompt = driver_prompts[2]
+        # The Navigator's literal refactor text is spliced in.
+        assert "compute_total()" in apply_prompt
+        assert "cache.py" in apply_prompt
+        # And the APPLY template's leading sentence is present.
+        assert "Apply the Navigator's refactor VERBATIM" in apply_prompt
+
+    async def test_refactor_plan_stored_on_mode(self):
+        """``tdd.refactor_plan`` exposes the Navigator's text so the
+        REPL / renderer can display it."""
+        runner = FakeRunner(
+            [
+                GateResult(phase="", exit_code=1, stdout="fail", stderr=""),
+                GateResult(phase="", exit_code=0, stdout="pass", stderr=""),
+            ],
+        )
+        tdd = TddMode(
+            driver=_make_engine(["wrote test", "wrote code"]),
+            navigator=_make_engine(["spec body", "rename foo to bar"]),
+            test_runner=runner,
+        )
+        await _collect(tdd.draft_spec("feature"))
+        await _collect(tdd.red())
+        await _collect(tdd.green())
+        await _collect(tdd.propose_refactor())
+
+        assert tdd.refactor_plan == "rename foo to bar"
+        assert tdd.state == TddState.REFACTOR_PLAN
+        # History entry for REFACTOR_PLAN captured the same text
+        plan_entries = [h for h in tdd.history if h.phase == "REFACTOR_PLAN"]
+        assert len(plan_entries) == 1
+        assert plan_entries[0].text == "rename foo to bar"
+        assert plan_entries[0].actor == "navigator"
+
