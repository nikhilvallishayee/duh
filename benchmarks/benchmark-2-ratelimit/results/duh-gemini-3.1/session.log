  [33m> Write[0m(content='import pytest\nfrom ratelimit import InMemoryBackend, TokenBucketLimiter, rate_limit, RateLimitMiddleware\nfrom ratelimit.decorator import RateLimitExceeded\n\ndef test_decorator():\n    backend = InMemoryBackend()\n    limiter = TokenBucketLimiter(backend, capacity=2, refill_rate=0)\n    \n    @rate_limit(limiter, key_fn=lambda x: "dec_key")\n    def do_work(x):\n        return x * 2\n        \n    assert do_work(1) == 2\n    assert do_work(2) == 4\n    \n    with pytest.raises(RateLimitExceeded):\n        do_work(3)\n\n@pytest.mark.asyncio\nasync def test_middleware():\n    backend = InMemoryBackend()\n    limiter = TokenBucketLimiter(backend, capacity=2, refill_rate=0)\n    \n    async def app(scope, receive, send):\n        await send({"type": "http.response.start", "status": 200, "headers": []})\n        await send({"type": "http.response.body", "body": b"OK"})\n        \n    middleware = RateLimitMiddleware(app, limiter, key_fn=lambda s: "mw_key")\n    \n    scope = {"type": "http", "client": ("127.0.0.1", 12345)}\n    \n    # 1st request\n    responses = []\n    async def mock_send(msg): responses.append(msg)\n    await middleware(scope, None, mock_send)\n    assert responses[0]["status"] == 200\n    assert any(h[0] == b"X-RateLimit-Remaining" for h in responses[0]["headers"])\n    \n    # 2nd request\n    responses = []\n    await middleware(scope, None, mock_send)\n    assert responses[0]["status"] == 200\n    \n    # 3rd request (should be 429)\n    responses = []\n    await middleware(scope, None, mock_send)\n    assert responses[0]["status"] == 429\n    assert any(h[0] == b"Retry-After" for h in responses[0]["headers"])\n', file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-gemini-3.1/tests/test_integration.py')
