      res1 = AgentResult(agent_type="reviewer", result_text="Test spec drafted")\n        res2 = AgentResult(agent_type="coder", result_text="Test written and it failed.\\nAssertionError")\n        res3 = AgentResult(agent_type="coder", result_text="Test written and it passed.")\n        res4 = AgentResult(agent_type="reviewer", result_text="No refactoring needed.")\n        \n        mock_run_agent.side_effect = [res1, res2, res3, res4]\n        \n        await run_tdd_flow("Add a new calculator feature", None, [], ".", "fake-model")\n        \n        out, _ = capsys.readouterr()\n        \n        assert "Phase 4: Navigator proposing refactor" in out\n        assert "No refactoring needed" in out\n        assert mock_run_agent.call_count == 4\n\n@pytest.mark.asyncio\nasync def test_tdd_flow_retry_red(capsys):\n    with patch("duh.kernel.tdd_flow.run_agent") as mock_run_agent:\n        res1 = AgentResult(agent_type="reviewer", result_text="Test spec drafted")\n        # Attempt 1: Test incorrectly passes\n        res2_1 = AgentResult(agent_type="coder", result_text="Test written and it passed.")\n        # Attempt 2: Test fails\n        res2_2 = AgentResult(agent_type="coder", result_text="Test written and it failed.\\nAssertionError")\n        res3 = AgentResult(agent_type="coder", result_text="Test written and it passed.")\n        res4 = AgentResult(agent_type="reviewer", result_text="No refactoring needed.")\n        \n        mock_run_agent.side_effect = [res1, res2_1, res2_2, res3, res4]\n        \n        await run_tdd_flow("Add a new calculator feature", None, [], ".", "fake-model")\n        \n        out, _ = capsys.readouterr()\n        \n        assert "Retrying RED phase" in out\n        assert mock_run_agent.call_count == 5\nEOF\n')
