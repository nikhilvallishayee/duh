  [33m> Write[0m(file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-opus/tests/test_token_bucket.py', content='"""Token bucket: happy path + boundary conditions."""\n\nimport time\n\nimport pytest\n\nfrom ratelimit import InMemoryBackend, TokenBucketLimiter\n\n\ndef test_fresh_bucket_is_full():\n    lim = TokenBucketLimiter(capacity=5, refill_per_sec=1)\n    for i in range(5):\n        d = lim.enforce("a")\n        assert d.allowed is True, f"iteration {i}"\n    # 6th call is rejected\n    d = lim.enforce("a")\n    assert d.allowed is False\n    assert d.retry_after_ms > 0\n    assert d.remaining == 0\n\n\ndef test_refill_after_time(monkeypatch):\n    clock = [1000.0]\n\n    def fake_clock():\n        return clock[0]\n\n    backend = InMemoryBackend(clock=fake_clock)\n    lim = TokenBucketLimiter(capacity=2, refill_per_sec=1, backend=backend)\n\n    assert lim.enforce("a").allowed\n    assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed\n\n    # advance 1 second → 1 token\n    clock[0] += 1.0\n    d = lim.enforce("a")\n    assert d.allowed\n    assert not lim.enforce("a").allowed\n\n    # advance enough to fully refill (but capacity clamps)\n    clock[0] += 10.0\n    assert lim.enforce("a").allowed\n    assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed  # capacity=2, only 2 admitted\n\n\ndef test_per_key_isolation():\n    lim = TokenBucketLimiter(capacity=3, refill_per_sec=1)\n    # exhaust key "a"\n    for _ in range(3):\n        assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed\n    # key "b" has its own bucket\n    for _ in range(3):\n        assert lim.enforce("b").allowed\n    assert not lim.enforce("b").allowed\n\n\ndef test_capacity_one_edge():\n    """capacity=1 is an easy place to get off-by-one wrong."""\n    clock = [0.0]\n\n    def fake_clock():\n        return clock[0]\n\n    backend = InMemoryBackend(clock=fake_clock)\n    lim = TokenBucketLimiter(capacity=1, refill_per_sec=1, backend=backend)\n    assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed\n    clock[0] += 0.5\n    # half a token so far — still rejected\n    assert not lim.enforce("a").allowed\n    clock[0] += 0.5\n    assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed\n\n\ndef test_zero_cost_never_rejects():\n    lim = TokenBucketLimiter(capacity=1, refill_per_sec=1)\n    # drain\n    assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed\n    # zero-cost probe still allowed — can be used as "peek"\n    d = lim.enforce("a", cost=0)\n    assert d.allowed\n\n\ndef test_large_cost_over_capacity_never_admitted():\n    lim = TokenBucketLimiter(capacity=5, refill_per_sec=1)\n    d = lim.enforce("a", cost=10)\n    assert not d.allowed\n\n\ndef test_retry_after_monotone_under_exhaustion():\n    lim = TokenBucketLimiter(capacity=2, refill_per_sec=1)\n    assert lim.enforce("a").allowed\n    assert lim.enforce("a").allowed\n    d1 = lim.enforce("a")\n    d2 = lim.enforce("a")\n    assert not d1.allowed and not d2.allowed\n    # retry_after should remain bounded (< 2000ms) since refill is 1/s\n    assert d1.retry_after_ms <= 1100\n    assert d2.retry_after_ms <= 1100\n\n\ndef test_invalid_args():\n    with pytest.raises(ValueError):\n        TokenBucketLimiter(capacity=0, refill_per_sec=1)\n    with pytest.raises(ValueError):\n        TokenBucketLimiter(capacity=1, refill_per_sec=0)\n    lim = TokenBucketLimiter(capacity=1, refill_per_sec=1)\n    with pytest.raises(ValueError):\n        lim.enforce("a", cost=-1)\n\n\ndef test_reset_ts_is_future_seconds():\n    lim = TokenBucketLimiter(capacity=2, refill_per_sec=1)\n    d = lim.enforce("a")\n    # reset_ts must be roughly "now" or in the future\n    now = int(time.time())\n    assert d.reset_ts >= now - 1\n    assert d.reset_ts <= now + 10\n')
  [33m> Write[0m(file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-opus/tests/test_sliding_window.py', content='"""Sliding-window counter: happy path + boundary conditions."""\n\nimport pytest\n\nfrom ratelimit import InMemoryBackend, SlidingWindowLimiter\n\n\ndef test_admits_up_to_capacity_within_period():\n    lim = SlidingWindowLimiter(capacity=4, period_ms=1000)\n    for _ in range(4):\n        assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed\n\n\ndef test_per_key_isolation():\n    lim = SlidingWindowLimiter(capacity=2, period_ms=1000)\n    assert lim.enforce("a").allowed\n    assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed\n    assert lim.enforce("b").allowed  # b is untouched\n    assert lim.enforce("b").allowed\n    assert not lim.enforce("b").allowed\n\n\ndef test_window_advances(monkeypatch):\n    clock = [100.0]\n\n    def fake_clock():\n        return clock[0]\n\n    backend = InMemoryBackend(clock=fake_clock)\n    lim = SlidingWindowLimiter(capacity=2, period_ms=1000, backend=backend)\n\n    assert lim.enforce("a").allowed\n    assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed\n\n    # halfway through the window, still rejected\n    clock[0] += 0.5\n    assert not lim.enforce("a").allowed\n\n    # jump a full window — prev=2, count=0, pos=0, estimate = 2*(1-0) = 2\n    # still at capacity, rejected.\n    clock[0] += 0.5\n    assert not lim.enforce("a").allowed\n\n    # half of the new window: estimated = 2*(1-0.5) = 1, + 1 = 2 ≤ capacity\n    clock[0] += 0.5\n    assert lim.enforce("a").allowed\n\n    # skip two whole windows — full reset\n    clock[0] += 5.0\n    for _ in range(2):\n        assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed\n\n\ndef test_capacity_one_edge():\n    clock = [0.0]\n\n    def fake_clock():\n        return clock[0]\n\n    backend = InMemoryBackend(clock=fake_clock)\n    lim = SlidingWindowLimiter(capacity=1, period_ms=1000, backend=backend)\n\n    assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed\n\n    # halfway — estimated = 0*(1-0.5) + 1 = 1, rejected\n    clock[0] += 0.5\n    assert not lim.enforce("a").allowed\n\n    # new window begins at t=1.0; prev=1, count=0, pos=0 → estimate=1, rejected\n    clock[0] += 0.5\n    assert not lim.enforce("a").allowed\n\n    # slide far enough: pos ≈ 0.5 → estimate ≈ 0.5, + 1 > 1, still rejected\n    clock[0] += 0.5\n    assert not lim.enforce("a").allowed\n\n    # reach end of window — estimate → 0\n    clock[0] += 0.6\n    # depending on the boundary, this is a fresh window\n    d = lim.enforce("a")\n    assert d.allowed\n\n\ndef test_zero_cost_probe():\n    lim = SlidingWindowLimiter(capacity=1, period_ms=1000)\n    assert lim.enforce("a").allowed\n    assert not lim.enforce("a").allowed\n    # zero-cost probe: must not consume — stays allowed when zero fits\n    d = lim.enforce("a", cost=0)\n    # at this point estimated = 1, 1 + 0 <= 1 → admitted\n    assert d.allowed\n\n\ndef test_invalid_args():\n    with pytest.raises(ValueError):\n        SlidingWindowLimiter(capacity=0, period_ms=1000)\n    with pytest.raises(ValueError):\n        SlidingWindowLimiter(capacity=1, period_ms=0)\n    lim = SlidingWindowLimiter(capacity=1, period_ms=1000)\n    with pytest.raises(ValueError):\n        lim.enforce("a", cost=-1)\n\n\ndef test_never_admits_more_than_capacity_in_period(monkeypatch):\n    """Tight loop: with a fixed clock, the counter is exact."""\n    clock = [0.0]\n\n    def fake_clock():\n        return clock[0]\n\n    backend = InMemoryBackend(clock=fake_clock)\n    lim = SlidingWindowLimiter(capacity=10, period_ms=1000, backend=backend)\n\n    # clock frozen → we are at a single point in time, prev=0, count rises\n    allowed = 0\n    for _ in range(100):\n        if lim.enforce("a").allowed:\n            allowed += 1\n    assert allowed == 10\n')
  [33m> Write[0m(file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-opus/tests/test_concurrency.py', content='"""Concurrency: hundreds of simultaneous requests must not over-grant."""\n\nimport asyncio\nimport threading\n\nimport pytest\n\nfrom ratelimit import (\n    InMemoryBackend,\n    RedisBackend,\n    SlidingWindowLimiter,\n    TokenBucketLimiter,\n)\n\n\n# ---------------------------------------------------------------------------\n# Threading — token bucket, in-memory\n# ---------------------------------------------------------------------------\n\n\ndef test_token_bucket_no_overgrant_threads_inmemory():\n    """200 threads race to consume a bucket of capacity 50 — exactly 50 admitted."""\n    lim = TokenBucketLimiter(capacity=50, refill_per_sec=0.0001)\n    # refill_per_sec ~0 so no refill during the test — the number of\n    # allowed calls must equal capacity.\n\n    hits = [0]\n    hits_lock = threading.Lock()\n    start = threading.Event()\n\n    def worker():\n        start.wait()\n        d = lim.enforce("k")\n        if d.allowed:\n            with hits_lock:\n                hits[0] += 1\n\n    threads = [threading.Thread(target=worker) for _ in range(200)]\n    for t in threads:\n        t.start()\n    start.set()\n    for t in threads:\n        t.join()\n\n    assert hits[0] == 50\n\n\ndef test_sliding_window_no_overgrant_threads_inmemory():\n    lim = SlidingWindowLimiter(capacity=40, period_ms=60_000)\n\n    hits = [0]\n    hits_lock = threading.Lock()\n    start = threading.Event()\n\n    def worker():\n        start.wait()\n        d = lim.enforce("k")\n        if d.allowed:\n            with hits_lock:\n                hits[0] += 1\n\n    threads = [threading.Thread(target=worker) for _ in range(200)]\n    for t in threads:\n        t.start()\n    start.set()\n    for t in threads:\n        t.join()\n\n    assert hits[0] == 40\n\n\ndef test_token_bucket_no_overgrant_threads_redis(fake_redis):\n    backend = RedisBackend(fake_redis, fail_open=False)\n    lim = TokenBucketLimiter(capacity=30, refill_per_sec=0.0001, backend=backend)\n\n    hits = [0]\n    hits_lock = threading.Lock()\n    start = threading.Event()\n\n    def worker():\n        start.wait()\n        d = lim.enforce("k")\n        if d.allowed:\n            with hits_lock:\n                hits[0] += 1\n\n    threads = [threading.Thread(target=worker) for _ in range(150)]\n    for t in threads:\n        t.start()\n    start.set()\n    for t in threads:\n        t.join()\n\n    # fakeredis serializes commands, so this asserts our Lua\n    # script is correct (no over-grant) regardless of contention.\n    assert hits[0] == 30\n\n\ndef test_sliding_window_no_overgrant_threads_redis(fake_redis):\n    backend = RedisBackend(fake_redis, fail_open=False)\n    lim = SlidingWindowLimiter(capacity=25, period_ms=60_000, backend=backend)\n\n    hits = [0]\n    hits_lock = threading.Lock()\n    start = threading.Event()\n\n    def worker():\n        start.wait()\n        d = lim.enforce("k")\n        if d.allowed:\n            with hits_lock:\n                hits[0] += 1\n\n    threads = [threading.Thread(target=worker) for _ in range(150)]\n    for t in threads:\n        t.start()\n    start.set()\n    for t in threads:\n        t.join()\n\n    assert hits[0] == 25\n\n\n# ---------------------------------------------------------------------------\n# asyncio — drive >=100 tasks concurrently\n# ---------------------------------------------------------------------------\n\n\n@pytest.mark.asyncio\nasync def test_token_bucket_no_overgrant_asyncio():\n    lim = TokenBucketLimiter(capacity=20, refill_per_sec=0.0001)\n\n    async def worker() -> bool:\n        # yield once so the tasks really interleave\n        await asyncio.sleep(0)\n        return lim.enforce("k").allowed\n\n    results = await asyncio.gather(*[worker() for _ in range(150)])\n    assert sum(1 for r in results if r) == 20\n\n\n@pytest.mark.asyncio\nasync def test_sliding_window_no_overgrant_asyncio():\n    lim = SlidingWindowLimiter(capacity=15, period_ms=60_000)\n\n    async def worker() -> bool:\n        await asyncio.sleep(0)\n        return lim.enforce("k").allowed\n\n    results = await asyncio.gather(*[worker() for _ in range(120)])\n    assert sum(1 for r in results if r) == 15\n\n\n# ---------------------------------------------------------------------------\n# Per-key isolation under concurrency\n# ---------------------------------------------------------------------------\n\n\ndef test_per_key_isolation_under_concurrency():\n    """Two keys racing: each must be independently correct."""\n    lim = TokenBucketLimiter(capacity=20, refill_per_sec=0.0001)\n\n    hits = {"a": 0, "b": 0}\n    lock = threading.Lock()\n    start = threading.Event()\n\n    def worker(key: str):\n        start.wait()\n        if lim.enforce(key).allowed:\n            with lock:\n                hits[key] += 1\n\n    threads = []\n    for _ in range(100):\n        threads.append(threading.Thread(target=worker, args=("a",)))\n        threads.append(threading.Thread(target=worker, args=("b",)))\n    for t in threads:\n        t.start()\n    start.set()\n    for t in threads:\n        t.join()\n\n    assert hits["a"] == 20\n    assert hits["b"] == 20\n')
