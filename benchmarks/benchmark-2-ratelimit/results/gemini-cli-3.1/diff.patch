@@ -0,0 +1,69 @@
+from typing import Callable, Awaitable
+import anyio
+from starlette.types import ASGIApp, Receive, Scope, Send
+from starlette.requests import Request
+from starlette.responses import Response
+
+from ratelimit.limiters import RateLimiter
+from ratelimit.models import Decision
+
+def default_key_fn(request: Request) -> str:
+    if request.client:
+        return request.client.host
+    return "unknown"
+
+class RateLimitMiddleware:
+    def __init__(
+        self,
+        app: ASGIApp,
+        limiter: RateLimiter,
+        key_fn: Callable[[Request], str] = default_key_fn,
+        cost: int = 1
+    ):
+        self.app = app
+        self.limiter = limiter
+        self.key_fn = key_fn
+        self.cost = cost
+
+    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:
+        if scope["type"] not in ("http", "websocket"):
+            await self.app(scope, receive, send)
+            return
+
+        request = Request(scope)
+        key = self.key_fn(request)
+
+        try:
+            decision = await anyio.to_thread.run_sync(self.limiter.enforce, key, self.cost)
+        except Exception:
+            # Fallback degradation: if backend fails, allow traffic.
+            decision = Decision(allowed=True, retry_after_ms=0, remaining=-1, reset_ts=0)
+
+        limit = str(getattr(self.limiter, "capacity", -1))
+
+        if not decision.allowed:
+            response = Response(
+                "Rate limit exceeded",
+                status_code=429,
+                headers={
+                    "X-RateLimit-Limit": limit,
+                    "X-RateLimit-Remaining": str(decision.remaining),
+                    "X-RateLimit-Reset": str(int(decision.reset_ts / 1000)),
+                    "Retry-After": str(max(1, int(decision.retry_after_ms / 1000))),
+                }
+            )
+            await response(scope, receive, send)
+            return
+
+        # We must intercept the response to add headers
+        async def send_wrapper(message: dict) -> None:
+            if message["type"] == "http.response.start":
+                headers = message.get("headers", [])
+                headers.append((b"x-ratelimit-limit", limit.encode("latin-1")))
+                headers.append((b"x-ratelimit-remaining", str(decision.remaining).encode("latin-1")))
+                if decision.reset_ts:
+                    headers.append((b"x-ratelimit-reset", str(int(decision.reset_ts / 1000)).encode("latin-1")))
+                message["headers"] = headers
+            await send(message)
+
+        await self.app(scope, receive, send_wrapper)
