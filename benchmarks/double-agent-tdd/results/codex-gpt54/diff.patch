+++ b/tests/unit/test_double_agent_tdd.py
@@ -0,0 +1,158 @@
+"""Tests for the double-agent TDD orchestration."""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from types import SimpleNamespace
+
+import pytest
+
+from duh.kernel.tool import ToolContext, ToolResult
+from duh.tdd import run_double_agent_tdd
+
+
+@dataclass
+class FakeAgentResult:
+    result_text: str
+    error: str = ""
+
+    @property
+    def is_error(self) -> bool:
+        return bool(self.error)
+
+
+class FakeBashTool:
+    name = "Bash"
+
+    def __init__(self, results: list[ToolResult]):
+        self._results = list(results)
+        self.commands: list[str] = []
+
+    async def call(self, input: dict, context: ToolContext) -> ToolResult:
+        self.commands.append(input["command"])
+        return self._results.pop(0)
+
+
+def _passing(output: str = "tests passed") -> ToolResult:
+    return ToolResult(output=output, is_error=False, metadata={"returncode": 0})
+
+
+def _failing(output: str = "AssertionError: expected 3, got 2") -> ToolResult:
+    return ToolResult(output=output, is_error=True, metadata={"returncode": 1})
+
+
+@pytest.mark.asyncio
+async def test_phase_transitions_happen_in_order():
+    bash = FakeBashTool([_failing(), _passing(), _passing()])
+    responses = iter(
+        [
+            "spec",
+            "red done",
+            "green done",
+            "extract helper",
+            "refactor applied",
+            "validation passed",
+        ]
+    )
+
+    async def fake_run_agent(**kwargs):
+        return FakeAgentResult(next(responses))
+
+    result = await run_double_agent_tdd(
+        task="add behavior",
+        test_command="pytest -q",
+        deps=SimpleNamespace(),
+        tools=[bash],
+        run_agent_fn=fake_run_agent,
+    )
+
+    assert result.success is True
+    assert [phase.phase for phase in result.phases] == [
+        "navigator_spec",
+        "driver_red",
+        "driver_green",
+        "navigator_refactor",
+        "driver_refactor",
+        "navigator_validate",
+    ]
+
+
+@pytest.mark.asyncio
+async def test_red_failure_is_distinct_from_green_success():
+    bash = FakeBashTool(
+        [
+            _failing("AssertionError: widget count mismatch"),
+            _passing("1 passed in 0.01s"),
+            _passing("1 passed in 0.01s"),
+        ]
+    )
+    responses = iter(
+        [
+            "spec",
+            "red done",
+            "green done",
+            "extract helper",
+            "refactor applied",
+            "validation passed",
+        ]
+    )
+
+    async def fake_run_agent(**kwargs):
+        return FakeAgentResult(next(responses))
+
+    result = await run_double_agent_tdd(
+        task="fix widget math",
+        test_command="pytest -q",
+        deps=SimpleNamespace(),
+        tools=[bash],
+        run_agent_fn=fake_run_agent,
+    )
+
+    assert result.red_phase is not None
+    assert result.green_phase is not None
+    assert result.red_phase.test_result is not None
+    assert result.green_phase.test_result is not None
+    assert result.red_phase.test_result.passed is False
+    assert result.green_phase.test_result.passed is True
+    assert "AssertionError" in result.red_failure
+    assert "1 passed" in result.green_phase.test_result.output
+
+
+@pytest.mark.asyncio
+async def test_refactor_suggestion_is_applied_before_validation():
+    bash = FakeBashTool([_failing(), _passing(), _passing()])
+    call_prompts: list[str] = []
+
+    async def fake_run_agent(**kwargs):
+        prompt = kwargs["prompt"]
+        call_prompts.append(prompt)
+        if "Draft a tight executable test spec" in prompt:
+            return FakeAgentResult("spec")
+        if "Implement only the failing test" in prompt:
+            return FakeAgentResult("red done")
+        if "Write the minimum production change" in prompt:
+            return FakeAgentResult("green done")
+        if "Review the just-passing implementation" in prompt:
+            return FakeAgentResult("extract helper function")
+        if "Apply the Navigator's refactor" in prompt:
+            assert "extract helper function" in prompt
+            return FakeAgentResult("applied extract helper function")
+        if "final validation" in prompt:
+            assert "applied extract helper function" in prompt
+            return FakeAgentResult("validation passed")
+        raise AssertionError(f"unexpected prompt: {prompt}")
+
+    result = await run_double_agent_tdd(
+        task="refactor parser",
+        test_command="pytest -q",
+        deps=SimpleNamespace(),
+        tools=[bash],
+        run_agent_fn=fake_run_agent,
+    )
+
+    assert result.success is True
+    assert [phase.phase for phase in result.phases][-2:] == [
+        "driver_refactor",
+        "navigator_validate",
+    ]
+    assert len(call_prompts) == 6
