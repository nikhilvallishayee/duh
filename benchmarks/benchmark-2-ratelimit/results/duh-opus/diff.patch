+"""Decorator wrapper for function-level rate limiting."""
+
+from __future__ import annotations
+
+import asyncio
+import contextvars
+import functools
+from typing import Any, Callable
+
+from .limiters import RateLimiter
+from .types import Decision
+
+
+class RateLimitExceeded(Exception):
+    """Raised by ``@rate_limit`` when a call is rejected."""
+
+    def __init__(self, decision: Decision, key: str) -> None:
+        super().__init__(
+            f"rate limit exceeded for key={key!r}; "
+            f"retry after {decision.retry_after_ms} ms"
+        )
+        self.decision = decision
+        self.key = key
+
+
+# Context variable tracking keys currently in flight for re-entrancy
+# detection.  A `frozenset[str]` so nested calls can extend without
+# mutating the parent's set.
+_inflight_keys: contextvars.ContextVar[frozenset[str]] = contextvars.ContextVar(
+    "ratelimit_inflight_keys", default=frozenset()
+)
+
+
+def rate_limit(
+    limiter: RateLimiter,
+    key_fn: Callable[..., str],
+    *,
+    cost: float = 1,
+    reentrant: bool = False,
+    on_rejected: Callable[[Decision, str], Any] | None = None,
+) -> Callable[[Callable[..., Any]], Callable[..., Any]]:
+    """Decorate a function with rate limiting.
+
+    Parameters
+    ----------
+    limiter:
+        The :class:`RateLimiter` that makes the decision.
+    key_fn:
+        Callable receiving the wrapped function's ``*args, **kwargs``
+        and returning the bucket key.
+    cost:
+        Units consumed per call.  Default 1.
+    reentrant:
+        If true, a call whose key is already "in flight" higher up
+        the call stack is admitted without consulting the limiter.
+        Useful for recursion / wrapper composition where re-checking
+        the same key would double-charge.
+    on_rejected:
+        Optional callback invoked instead of raising
+        :class:`RateLimitExceeded`.  If it returns a value that value
+        is returned from the wrapped function; if it returns ``None``
+        the exception is still raised.
+    """
+
+    def decorate(fn: Callable[..., Any]) -> Callable[..., Any]:
+        if asyncio.iscoroutinefunction(fn):
+
+            @functools.wraps(fn)
+            async def async_wrapper(*args: Any, **kwargs: Any) -> Any:
+                key = key_fn(*args, **kwargs)
+                inflight = _inflight_keys.get()
+                if reentrant and key in inflight:
+                    return await fn(*args, **kwargs)
+
+                decision = limiter.enforce(key, cost=cost)
+                if not decision.allowed:
+                    if on_rejected is not None:
+                        result = on_rejected(decision, key)
+                        if result is not None:
+                            return result
+                    raise RateLimitExceeded(decision, key)
+
+                token = _inflight_keys.set(inflight | {key})
+                try:
+                    return await fn(*args, **kwargs)
+                finally:
+                    _inflight_keys.reset(token)
+
+            return async_wrapper
+
+        @functools.wraps(fn)
+        def sync_wrapper(*args: Any, **kwargs: Any) -> Any:
+            key = key_fn(*args, **kwargs)
+            inflight = _inflight_keys.get()
+            if reentrant and key in inflight:
+                return fn(*args, **kwargs)
+
+            decision = limiter.enforce(key, cost=cost)
+            if not decision.allowed:
+                if on_rejected is not None:
+                    result = on_rejected(decision, key)
+                    if result is not None:
+                        return result
+                raise RateLimitExceeded(decision, key)
+
+            token = _inflight_keys.set(inflight | {key})
+            try:
+                return fn(*args, **kwargs)
+            finally:
+                _inflight_keys.reset(token)
+
+        return sync_wrapper
+
+    return decorate
