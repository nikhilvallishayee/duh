+from bisect import bisect_left
+import importlib.util
+
+import pytest
+
+HYPOTHESIS_AVAILABLE = importlib.util.find_spec("hypothesis") is not None
+pytestmark = pytest.mark.skipif(not HYPOTHESIS_AVAILABLE, reason="hypothesis is not installed")
+
+if HYPOTHESIS_AVAILABLE:
+    from hypothesis import given, strategies as st
+
+from ratelimit import InMemoryBackend, SlidingWindowLimiter
+
+
+if HYPOTHESIS_AVAILABLE:
+
+    @given(
+        capacity=st.integers(min_value=1, max_value=8),
+        period_ms=st.integers(min_value=10, max_value=200),
+        deltas=st.lists(st.integers(min_value=0, max_value=40), min_size=1, max_size=80),
+    )
+    def test_sliding_window_never_grants_more_than_capacity_in_any_period(
+        capacity: int,
+        period_ms: int,
+        deltas: list[int],
+    ) -> None:
+        backend = InMemoryBackend()
+        now_ms = [0]
+        backend.now_ms = lambda: now_ms[0]  # type: ignore[method-assign]
+        limiter = SlidingWindowLimiter(
+            capacity=capacity,
+            period_ms=period_ms,
+            backend=backend,
+            namespace="property",
+        )
+
+        accepted: list[int] = []
+        for delta in deltas:
+            now_ms[0] += delta
+            decision = limiter.enforce("user")
+            if decision.allowed:
+                accepted.append(now_ms[0])
+
+        for index, timestamp in enumerate(accepted):
+            window_start = timestamp - period_ms
+            left = bisect_left(accepted, window_start + 1)
+            assert index - left + 1 <= capacity
+
+else:
+
+    def test_sliding_window_never_grants_more_than_capacity_in_any_period() -> None:
+        pytest.skip("hypothesis is not installed")
