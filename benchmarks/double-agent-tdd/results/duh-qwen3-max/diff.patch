+            assert result.success
+            assert result.metadata["test_failed"] == True
+
+        # Test that doesn't contain failure indicators should be marked as passed
+        with patch('duh.tools.double_agent_tdd.run_agent') as mock_run_agent:
+            mock_result = Mock()
+            mock_result.is_error = False
+            mock_result.result_text = "Test output with no errors"
+            mock_run_agent.return_value = mock_result
+            
+            result = await tool._phase2_write_failing_test(
+                "spec", "pytest", 10,
+                self.tools, "test-model", self.context
+            )
+            
+            assert result.success
+            assert result.metadata["test_failed"] == False
+
+    def test_tdd_phase_result_creation(self):
+        """Test TDDPhaseResult dataclass creation."""
+        result = TDDPhaseResult(
+            phase=1,
+            success=True,
