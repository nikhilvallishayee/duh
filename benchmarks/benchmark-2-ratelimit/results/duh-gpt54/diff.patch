@@ -0,0 +1,45 @@
+from __future__ import annotations
+
+from typing import Callable
+
+from starlette.middleware.base import BaseHTTPMiddleware
+from starlette.requests import Request
+from starlette.responses import JSONResponse, Response
+
+from .core import Decision, RateLimiter
+
+
+class RateLimitMiddleware(BaseHTTPMiddleware):
+    def __init__(self, app, limiter: RateLimiter, key_fn: Callable[[Request], str], fail_open: bool = True) -> None:
+        super().__init__(app)
+        self.limiter = limiter
+        self.key_fn = key_fn
+        self.fail_open = fail_open
+
+    async def dispatch(self, request: Request, call_next) -> Response:
+        try:
+            decision = self.limiter.enforce(self.key_fn(request))
+        except Exception:
+            if not self.fail_open:
+                raise
+            return await call_next(request)
+
+        if not decision.allowed:
+            response = JSONResponse({"detail": "rate limit exceeded"}, status_code=429)
+            _apply_headers(response, decision, self._limit_value())
+            return response
+
+        response = await call_next(request)
+        _apply_headers(response, decision, self._limit_value())
+        return response
+
+    def _limit_value(self) -> int:
+        return getattr(self.limiter, "capacity", getattr(self.limiter, "limit", 0))
+
+
+def _apply_headers(response: Response, decision: Decision, limit_value: int) -> None:
+    response.headers["X-RateLimit-Limit"] = str(limit_value)
+    response.headers["X-RateLimit-Remaining"] = str(decision.remaining)
+    response.headers["X-RateLimit-Reset"] = str(decision.reset_ts)
+    if decision.retry_after_ms > 0:
+        response.headers["Retry-After"] = str(max(1, (decision.retry_after_ms + 999) // 1000))
