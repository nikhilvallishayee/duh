index 0000000..df2410e
--- /dev/null
+++ b/tests/test_concurrency.py
@@ -0,0 +1,127 @@
+"""Concurrency tests.
+
+Drive >= 100 simultaneous requests and assert no over-grant.
+
+Covers:
+- InMemoryBackend with threading
+- RedisBackend (via fakeredis) with threading
+"""
+
+from __future__ import annotations
+
+import threading
+
+import pytest
+
+from ratelimit import (
+    InMemoryBackend,
+    RedisBackend,
+    SlidingWindowLimiter,
+    TokenBucketLimiter,
+)
+
+
+def _drive_parallel(limiter, key: str, n_requests: int) -> tuple[int, int]:
+    """Fire ``n_requests`` parallel ``enforce`` calls. Return (allowed, denied)."""
+
+    allowed = 0
+    denied = 0
+    lock = threading.Lock()
+    barrier = threading.Barrier(n_requests)
+
+    def worker():
+        nonlocal allowed, denied
+        barrier.wait()  # everyone starts at the same instant
+        d = limiter.enforce(key)
+        with lock:
+            if d.allowed:
+                allowed += 1
+            else:
+                denied += 1
+
+    threads = [threading.Thread(target=worker) for _ in range(n_requests)]
+    for t in threads:
+        t.start()
+    for t in threads:
+        t.join()
+
+    return allowed, denied
+
+
+# --------------------------------------------------------------
+# In-memory: token bucket
+# --------------------------------------------------------------
+
+
+def test_memory_token_bucket_no_overgrant():
+    # capacity=25, rate tiny -> refill cannot cover during the burst
+    b = InMemoryBackend()
+    lim = TokenBucketLimiter(capacity=25, refill_rate=0.001, backend=b)
+    allowed, denied = _drive_parallel(lim, "k", 200)
+    assert allowed == 25, f"expected 25 allowed, got {allowed}"
+    assert denied == 175
+
+
+def test_memory_sliding_window_no_overgrant():
+    b = InMemoryBackend()
+    lim = SlidingWindowLimiter(capacity=37, period_seconds=60, backend=b)
+    allowed, denied = _drive_parallel(lim, "k", 150)
+    assert allowed == 37, f"expected 37 allowed, got {allowed}"
+    assert denied == 113
+
+
+# --------------------------------------------------------------
+# Redis: token bucket + sliding window
+# --------------------------------------------------------------
+
+
+def test_redis_token_bucket_no_overgrant(fake_redis):
+    backend = RedisBackend(fake_redis, namespace="test")
+    lim = TokenBucketLimiter(capacity=50, refill_rate=0.001, backend=backend)
+    allowed, denied = _drive_parallel(lim, "k", 150)
+    assert allowed == 50
+    assert denied == 100
+
+
+def test_redis_sliding_window_no_overgrant(fake_redis):
+    backend = RedisBackend(fake_redis, namespace="test")
+    lim = SlidingWindowLimiter(capacity=42, period_seconds=60, backend=backend)
+    allowed, denied = _drive_parallel(lim, "k", 150)
+    assert allowed == 42
+    assert denied == 108
+
+
+# --------------------------------------------------------------
+# Multiple distinct keys should not cross-contaminate under contention
+# --------------------------------------------------------------
+
+
+def test_memory_per_key_isolation_under_load():
+    b = InMemoryBackend()
+    lim = TokenBucketLimiter(capacity=10, refill_rate=0.001, backend=b)
+    lock = threading.Lock()
+    per_key = {"a": 0, "b": 0, "c": 0}
+    per_key_denied = {"a": 0, "b": 0, "c": 0}
+    barrier = threading.Barrier(150)
+
+    def worker(key):
+        barrier.wait()
+        d = lim.enforce(key)
+        with lock:
+            if d.allowed:
+                per_key[key] += 1
+            else:
+                per_key_denied[key] += 1
+
+    threads = []
+    for k in ("a", "b", "c"):
+        for _ in range(50):
+            threads.append(threading.Thread(target=worker, args=(k,)))
+    for t in threads:
+        t.start()
+    for t in threads:
+        t.join()
+
+    for k in ("a", "b", "c"):
+        assert per_key[k] == 10, f"key {k} allowed {per_key[k]} != 10"
+        assert per_key_denied[k] == 40
