new file mode 100644
index 0000000..e85efff
--- /dev/null
+++ b/tests/test_concurrency.py
@@ -0,0 +1,184 @@
+"""Concurrency: hundreds of simultaneous requests must not over-grant."""
+
+import asyncio
+import threading
+
+import pytest
+
+from ratelimit import (
+    InMemoryBackend,
+    RedisBackend,
+    SlidingWindowLimiter,
+    TokenBucketLimiter,
+)
+
+
+# ---------------------------------------------------------------------------
+# Threading — token bucket, in-memory
+# ---------------------------------------------------------------------------
+
+
+def test_token_bucket_no_overgrant_threads_inmemory():
+    """200 threads race to consume a bucket of capacity 50 — exactly 50 admitted."""
+    lim = TokenBucketLimiter(capacity=50, refill_per_sec=0.0001)
+    # refill_per_sec ~0 so no refill during the test — the number of
+    # allowed calls must equal capacity.
+
+    hits = [0]
+    hits_lock = threading.Lock()
+    start = threading.Event()
+
+    def worker():
+        start.wait()
+        d = lim.enforce("k")
+        if d.allowed:
+            with hits_lock:
+                hits[0] += 1
+
+    threads = [threading.Thread(target=worker) for _ in range(200)]
+    for t in threads:
+        t.start()
+    start.set()
+    for t in threads:
+        t.join()
+
+    assert hits[0] == 50
+
+
+def test_sliding_window_no_overgrant_threads_inmemory():
+    lim = SlidingWindowLimiter(capacity=40, period_ms=60_000)
+
+    hits = [0]
+    hits_lock = threading.Lock()
+    start = threading.Event()
+
+    def worker():
+        start.wait()
+        d = lim.enforce("k")
+        if d.allowed:
+            with hits_lock:
+                hits[0] += 1
+
+    threads = [threading.Thread(target=worker) for _ in range(200)]
+    for t in threads:
+        t.start()
+    start.set()
+    for t in threads:
+        t.join()
+
+    assert hits[0] == 40
+
+
+def test_token_bucket_no_overgrant_threads_redis(fake_redis):
+    backend = RedisBackend(fake_redis, fail_open=False)
+    lim = TokenBucketLimiter(capacity=30, refill_per_sec=0.0001, backend=backend)
+
+    hits = [0]
+    hits_lock = threading.Lock()
+    start = threading.Event()
+
+    def worker():
+        start.wait()
+        d = lim.enforce("k")
+        if d.allowed:
+            with hits_lock:
+                hits[0] += 1
+
+    threads = [threading.Thread(target=worker) for _ in range(150)]
+    for t in threads:
+        t.start()
+    start.set()
+    for t in threads:
+        t.join()
+
+    # fakeredis serializes commands, so this asserts our Lua
+    # script is correct (no over-grant) regardless of contention.
+    assert hits[0] == 30
+
+
+def test_sliding_window_no_overgrant_threads_redis(fake_redis):
+    backend = RedisBackend(fake_redis, fail_open=False)
+    lim = SlidingWindowLimiter(capacity=25, period_ms=60_000, backend=backend)
+
+    hits = [0]
+    hits_lock = threading.Lock()
+    start = threading.Event()
+
+    def worker():
+        start.wait()
+        d = lim.enforce("k")
+        if d.allowed:
+            with hits_lock:
+                hits[0] += 1
+
+    threads = [threading.Thread(target=worker) for _ in range(150)]
+    for t in threads:
+        t.start()
+    start.set()
+    for t in threads:
+        t.join()
+
+    assert hits[0] == 25
+
+
+# ---------------------------------------------------------------------------
+# asyncio — drive >=100 tasks concurrently
+# ---------------------------------------------------------------------------
+
+
+@pytest.mark.asyncio
+async def test_token_bucket_no_overgrant_asyncio():
+    lim = TokenBucketLimiter(capacity=20, refill_per_sec=0.0001)
+
+    async def worker() -> bool:
+        # yield once so the tasks really interleave
+        await asyncio.sleep(0)
+        return lim.enforce("k").allowed
+
+    results = await asyncio.gather(*[worker() for _ in range(150)])
+    assert sum(1 for r in results if r) == 20
+
+
+@pytest.mark.asyncio
+async def test_sliding_window_no_overgrant_asyncio():
+    lim = SlidingWindowLimiter(capacity=15, period_ms=60_000)
+
+    async def worker() -> bool:
+        await asyncio.sleep(0)
+        return lim.enforce("k").allowed
+
+    results = await asyncio.gather(*[worker() for _ in range(120)])
+    assert sum(1 for r in results if r) == 15
+
+
+# ---------------------------------------------------------------------------
+# Per-key isolation under concurrency
+# ---------------------------------------------------------------------------
+
+
+def test_per_key_isolation_under_concurrency():
+    """Two keys racing: each must be independently correct."""
+    lim = TokenBucketLimiter(capacity=20, refill_per_sec=0.0001)
+
+    hits = {"a": 0, "b": 0}
+    lock = threading.Lock()
+    start = threading.Event()
+
+    def worker(key: str):
+        start.wait()
+        if lim.enforce(key).allowed:
+            with lock:
+                hits[key] += 1
+
+    threads = []
+    for _ in range(100):
+        threads.append(threading.Thread(target=worker, args=("a",)))
+        threads.append(threading.Thread(target=worker, args=("b",)))
+    for t in threads:
+        t.start()
+    start.set()
+    for t in threads:
+        t.join()
+
+    assert hits["a"] == 20
+    assert hits["b"] == 20
diff --git a/tests/test_decorator.py b/tests/test_decorator.py
new file mode 100644
index 0000000..19d3d49
--- /dev/null
+++ b/tests/test_decorator.py
@@ -0,0 +1,111 @@
+"""Decorator: sync + async, reentrancy, callback."""
+
+import asyncio
+
+import pytest
+
+from ratelimit import (
+    RateLimitExceeded,
+    TokenBucketLimiter,
+    rate_limit,
+)
+
+
+def test_sync_decorator_allows_then_rejects():
+    lim = TokenBucketLimiter(capacity=2, refill_per_sec=0.0001)
+
+    @rate_limit(lim, key_fn=lambda user: f"u:{user}")
+    def greet(user: str) -> str:
+        return f"hi {user}"
+
+    assert greet("a") == "hi a"
+    assert greet("a") == "hi a"
+    with pytest.raises(RateLimitExceeded):
+        greet("a")
+
+    # Different key — independent budget.
+    assert greet("b") == "hi b"
+
+
+@pytest.mark.asyncio
+async def test_async_decorator():
+    lim = TokenBucketLimiter(capacity=2, refill_per_sec=0.0001)
+
+    @rate_limit(lim, key_fn=lambda user: f"u:{user}")
+    async def agreet(user: str) -> str:
+        await asyncio.sleep(0)
+        return f"hi {user}"
+
+    assert await agreet("a") == "hi a"
+    assert await agreet("a") == "hi a"
+    with pytest.raises(RateLimitExceeded):
+        await agreet("a")
+
+
+def test_on_rejected_callback():
+    lim = TokenBucketLimiter(capacity=1, refill_per_sec=0.0001)
+
+    sentinel = object()
+
+    @rate_limit(
+        lim,
+        key_fn=lambda: "k",
+        on_rejected=lambda decision, key: sentinel,
+    )
+    def f():
+        return "ok"
+
+    assert f() == "ok"
+    assert f() is sentinel  # rejected but callback returned a value
+
+
+def test_reentrant_does_not_double_charge():
+    """A recursive function using the same key should charge once."""
+    lim = TokenBucketLimiter(capacity=2, refill_per_sec=0.0001)
+
+    calls = {"n": 0}
+
+    @rate_limit(lim, key_fn=lambda depth: "recursive", reentrant=True)
+    def recurse(depth: int) -> int:
+        calls["n"] += 1
+        if depth == 0:
+            return 0
+        return recurse(depth - 1)
+
+    # Single top-level call, 5 recursive calls inside — should use 1 token.
+    recurse(5)
+    assert calls["n"] == 6  # function body ran 6 times
+    # We still have one token left since only the top call charged.
+    d = lim.enforce("recursive")
+    assert d.allowed
+    d2 = lim.enforce("recursive")
+    assert not d2.allowed
+
+
+def test_non_reentrant_charges_each_call():
+    """Without reentrant=True, recursion exhausts the bucket fast."""
+    lim = TokenBucketLimiter(capacity=3, refill_per_sec=0.0001)
+
+    @rate_limit(lim, key_fn=lambda depth: "recursive")
+    def recurse(depth: int) -> int:
+        if depth == 0:
+            return 0
+        return recurse(depth - 1)
+
+    # 3 tokens: depth=2 → 3 calls (ok); next top-level call triggers 1 more, fails
+    recurse(2)
+    with pytest.raises(RateLimitExceeded):
+        recurse(0)
+
+
+def test_cost_arg():
+    lim = TokenBucketLimiter(capacity=5, refill_per_sec=0.0001)
+
+    @rate_limit(lim, key_fn=lambda: "k", cost=2)
+    def f() -> str:
+        return "ok"
+
+    assert f() == "ok"
+    assert f() == "ok"
+    with pytest.raises(RateLimitExceeded):
+        f()  # would need 2, only 1 left
