"description": "Navigator proposing refactor"},\n            {"type": "tdd_output", "phase": "REFACTOR_PROPOSE", "output": "Refactor proposed"},\n            {"type": "tdd_phase", "phase": "REFACTOR_APPLY", "description": "Driver applying refactor"},\n            {"type": "tdd_output", "phase": "REFACTOR_APPLY", "output": "Refactor applied"},\n            {"type": "tdd_phase", "phase": "VALIDATE", "description": "Navigator validating refactor"},\n            {"type": "tdd_output", "phase": "VALIDATE", "output": "Refactor validated"},\n            {"type": "tdd_complete", "message": "TDD flow completed successfully!"},\n        ]\n        \n        async def mock_run(prompt):\n            for event in mock_events:\n                yield event\n        \n        mock_tdd.run = mock_run\n        mock_create.return_value = mock_tdd\n        \n        # Run the CLI\n        exit_code = await run_print_mode(args)\n        \n        # Verify the TDD flow was created with correct type\n        mock_create.assert_called_once()\n        call_args = mock_create.call_args\n        assert call_args[0][1] == PlanModeType.TDD\n        \n        # Verify the flow was run with the correct prompt\n        mock_tdd.run.assert_called_once_with("Add a new feature to auth module")\n        \n        # Verify exit code\n        assert exit_code == 0\n\n\n@pytest.mark.asyncio\nasync def test_tdd_flow_phase_transitions():\n    """Test that the TDD flow correctly transitions through all phases."""\n    # Create a test engine with stub provider\n    from duh.kernel.deps import Deps\n    from duh.kernel.engine import Engine, EngineConfig\n    \n    deps = Deps(call_model=AsyncMock())\n    engine = Engine(deps=deps, config=EngineConfig(model="stub-model"))\n    \n    # Create TDD plan mode\n    tdd = TDDPlanMode(engine)\n    \n    # Mock the test run to fail initially, then pass\n    with patch.object(tdd, \'_run_test\') as mock_run_test, \\\n         patch.object(tdd, \'_run_driver\') as mock_run_driver, \\\n         patch.object(tdd, \'_run_navigator\') as mock_run_navigator:\n        \n        # Set up mock responses\n        mock_run_navigator.side_effect = [\n            "Test spec",  # SPEC_DRAFT\n            "Refactor plan",  # REFACTOR_PROPOSE\n            "Validation result"  # VALIDATE\n        ]\n        \n        mock_run_driver.side_effect = [\n            "Test code",  # RED\n            "Implementation code",  # GREEN\n            "Refactored code"  # REFACTOR_APPLY\n        ]\n        \n        mock_run_test.side_effect = [\n            "=== FAIL: test_auth.py::TestAuth::test_new_feature\\nAssertionError: False is not true",  # RED phase\n            "=== 1 passed in 0.12s",  # GREEN phase\n            "=== 1 passed in 0.12s"   # VALIDATE phase\n        ]\n        \n        # Run the full flow\n        events = []\n        async for event in tdd.run("Add new feature"):\n            events.append(event)\n        \n        # Verify all phases were completed\n        assert tdd.current_phase == TDDPhase.VALIDATE\n        assert len(tdd.steps) == 6  # All phases\n        \n        # Verify each phase was completed\n        for step in tdd.steps:\n            assert step.done is True\n        \n        # Verify task description\n        assert tdd.task_description == "Add new feature"\n        \n        # Verify events include TDD-specific types\n        event_types = [e.get("type") for e in events]\n        assert "tdd_phase" in event_types\n        assert "tdd_output" in event_types\n        assert "tdd_complete" in event_types\n\n\n@pytest.mark.asyncio\nasync def test_tdd_flow_error_handling():\n    """Test TDD flow error handling when test passes unexpectedly."""\n    from duh.kernel.deps import Deps\n    from duh.kernel.engine import Engine, EngineConfig\n    \n    deps = Deps(call_model=AsyncMock())\n    engine = Engine(deps=deps, config=EngineConfig(model="stub-model"))\n    \n    tdd = TDDPlanMode(engine)\n    \n    # Mock the test to pass unexpectedly\n    with patch.object(tdd, \'_run_test\') as mock_run_test, \\\n         patch.object(tdd, \'_run_navigator\') as mock_run_navigator:\n        \n        # First call passes unexpectedly, second call returns a revised spec\n        mock_run_test.side_effect = [\n            "=== 1 passed in 0.12s",  # Unexpected pass\n            "=== FAIL: test_auth.py::TestAuth::test_new_feature\\nAssertionError: False is not true"  # After revision\n        ]\n        \n        mock_run_navigator.side_effect = [\n            "Original test spec",  # First SPEC_DRAFT\n            "Revised test spec"   # Second SPEC_DRAFT after error\n        ]\n        \n        # Run the flow\n        events = []\n        async for event in tdd.run("Add new feature"):\n            events.append(event)\n            # Stop after the first error to avoid infinite loop in test\n            if any(e.get("type") == "tdd_error" for e in events):\n                break\n        \n        # Should go back to SPEC_DRAFT after test passes unexpectedly\n        assert tdd.current_phase == TDDPhase.SPEC_DRAFT\n        \n        # Should have two SPEC_DRAFT steps (original + revision)\n        spec_draft_steps = [s for s in tdd.steps if s.phase == TDDPhase.SPEC_DRAFT]\n        assert len(spec_draft_steps) == 2\n        assert spec_draft_steps[0].done is True\n        assert spec_draft_steps[1].done is True')
