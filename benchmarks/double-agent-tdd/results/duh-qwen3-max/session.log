ls,\n            parent_model="test-model"\n        )\n        \n        # Mock the _execute_tdd_flow method to raise an exception\n        with patch.object(tool, \'_execute_tdd_flow\', side_effect=Exception("Test error")):\n            result = await tool.call({\n                "task": "implement a calculator",\n                "test_framework": "pytest"\n            }, self.context)\n            \n            assert result.is_error\n            assert "Test error" in result.output\n\n    @pytest.mark.asyncio\n    async def test_phase1_draft_spec_success(self):\n        """Test phase 1 draft spec success."""\n        tool = DoubleAgentTDDTool(\n            parent_deps=self.deps,\n            parent_tools=self.tools,\n            parent_model="test-model"\n        )\n        \n        # Mock run_agent to return success\n        with patch(\'duh.tools.double_agent_tdd.run_agent\') as mock_run_agent:\n            mock_result = Mock()\n            mock_result.is_error = False\n            mock_result.result_text = "Test specification content"\n            mock_run_agent.return_value = mock_result\n            \n            result = await tool._phase1_draft_spec(\n                "implement calculator", "pytest", 10,\n                self.tools, "test-model", self.context\n            )\n            \n            assert result.success\n            assert result.output == "Test specification content"\n            assert result.phase == 1\n\n    @pytest.mark.asyncio\n    async def test_phase1_draft_spec_error(self):\n        """Test phase 1 draft spec error handling."""\n        tool = DoubleAgentTDDTool(\n            parent_deps=self.deps,\n            parent_tools=self.tools,\n            parent_model="test-model"\n        )\n        \n        # Mock run_agent to return error\n        with patch(\'duh.tools.double_agent_tdd.run_agent\') as mock_run_agent:\n            mock_result = Mock()\n            mock_result.is_error = True\n            mock_result.error = "Agent error"\n            mock_run_agent.return_value = mock_result\n            \n            result = await tool._phase1_draft_spec(\n                "implement calculator", "pytest", 10,\n                self.tools, "test-model", self.context\n            )\n            \n            assert not result.success\n            assert result.error == "Agent error"\n            assert result.phase == 1\n\n    @pytest.mark.asyncio\n    async def test_phase2_test_failure_detection(self):\n        """Test that phase 2 correctly detects test failures."""\n        tool = DoubleAgentTDDTool(\n            parent_deps=self.deps,\n            parent_tools=self.tools,\n            parent_model="test-model"\n        )\n        \n        # Test that contains "AssertionError" should be marked as failed\n        with patch(\'duh.tools.double_agent_tdd.run_agent\') as mock_run_agent:\n            mock_result = Mock()\n            mock_result.is_error = False\n            mock_result.result_text = "Test output with AssertionError"\n            mock_run_agent.return_value = mock_result\n            \n            result = await tool._phase2_write_failing_test(\n                "spec", "pytest", 10,\n                self.tools, "test-model", self.context\n            )\n            \n            assert result.success\n            assert result.metadata["test_failed"] == True\n\n        # Test that doesn\'t contain failure indicators should be marked as passed\n        with patch(\'duh.tools.double_agent_tdd.run_agent\') as mock_run_agent:\n            mock_result = Mock()\n            mock_result.is_error = False\n            mock_result.result_text = "Test output with no errors"\n            mock_run_agent.return_value = mock_result\n            \n            result = await tool._phase2_write_failing_test(\n                "spec", "pytest", 10,\n                self.tools, "test-model", self.context\n            )\n            \n            assert result.success\n            assert result.metadata["test_failed"] == False\n\n    def test_tdd_phase_result_creation(self):\n        """Test TDDPhaseResult dataclass creation."""\n        result = TDDPhaseResult(\n            phase=1,\n            success=True,\n            output="test output",\n            error="test error",\n            metadata={"key": "value"}\n        )\n        \n        assert result.phase == 1\n        assert result.success == True\n        assert result.output == "test output"\n        assert result.error == "test error"\n        assert result.metadata == {"key": "value"}\n\n    def test_tool_properties(self):\n        """Test that the tool has correct properties."""\n        tool = DoubleAgentTDDTool()\n        \n        assert tool.name == "DoubleAgentTDD"\n        assert tool.description is not None\n        assert tool.input_schema is not None\n        assert not tool.is_read_only\n        assert not tool.is_destructive\n\n\nclass TestDoubleAgentTDDIntegration:\n    """Integration tests for the double-agent TDD flow."""\n    \n    @pytest.mark.asyncio\n    async def test_full_tdd_flow_phases(self):\n        """Test that all six phases execute in order."""\n        tool = DoubleAgentTDDTool()\n        \n        # Mock all phase methods to return success\n        phase_results = []\n        for phase in range(1, 7):\n            result = TDDPhaseResult(\n                phase=phase,\n                success=True,\n                output=f"Phase {phase} output",\n                metadata={"test_failed": phase == 2, "test_passed": phase == 3}\n            )\n            phase_results.append(result)\n        \n        with patch.multiple(\n            tool,\n            _phase1_draft_spec=AsyncMock(return_value=phase_results[0]),\n            _phase2_write_failing_test=AsyncMock(return_value=phase_results[1]),\n            _phase3_implement_minimum_code=AsyncMock(return_value=phase_results[2]),\n            _phase4_propose_refactor=AsyncMock(return_value=phase_results[3]),\n         