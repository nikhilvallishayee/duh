+"""Integration coverage for the double-agent TDD flow."""
+
+from __future__ import annotations
+
+from pathlib import Path
+
+import pytest
+
+from duh.agents import AgentResult
+from duh.cli.parser import build_parser
+from duh.cli.session_builder import SessionBuilder, SessionBuilderOptions
+from duh.kernel.tool import ToolContext
+from duh.tdd import run_double_agent_tdd
+
+
+def _options() -> SessionBuilderOptions:
+    return SessionBuilderOptions(
+        include_skills_in_tools=False,
+        include_deferred_tools=False,
+        include_memory_prompt=False,
+        include_env_block=False,
+        include_templates_hint=False,
+        include_model_context_block=False,
+        honour_tool_filters=True,
+        approver_mode="print_mode",
+        wire_hook_registry_in_deps=False,
+        wire_audit_logger_in_deps=False,
+        honour_tool_choice=True,
+        honour_thinking=True,
+        allow_session_id_override=True,
+        log_skip_perms_warning=False,
+        default_system_prompt="system",
+        brief_instruction="brief",
+    )
+
+
+def _find_tool(tools: list[object], name: str) -> object:
+    for tool in tools:
+        if getattr(tool, "name", "") == name:
+            return tool
+    raise AssertionError(f"tool not found: {name}")
+
+
+@pytest.mark.asyncio
+async def test_full_flow_completes_against_stub_provider(tmp_path: Path, monkeypatch):
+    monkeypatch.setenv("DUH_STUB_PROVIDER", "1")
+
+    calc_file = tmp_path / "calc.py"
+    calc_file.write_text("def add(a, b):\n    return a - b\n", encoding="utf-8")
+
+    parser = build_parser()
+    args = parser.parse_args(
+        [
+            "tdd",
+            "fix add() so it sums numbers",
+            "--test-command",
+            "python -m pytest -q test_calc.py",
+        ]
+    )
+    args.dangerously_skip_permissions = True
+
+    builder = SessionBuilder(args, _options(), cwd=str(tmp_path), debug=False)
+    build = await builder.build()
+
+    async def fake_run_agent(**kwargs):
+        prompt = kwargs["prompt"]
+        tools = kwargs["tools"]
+        write_tool = _find_tool(tools, "Write")
+
+        async def _write(path: Path, content: str) -> None:
+            result = await write_tool.call(
+                {"file_path": str(path), "content": content},
+                ToolContext(cwd=str(tmp_path)),
+            )
+            assert not result.is_error
+
+        if "Draft a tight executable test spec" in prompt:
+            return AgentResult(agent_type="reviewer", result_text="Add a test for add(1, 2) == 3")
+        if "Implement only the failing test" in prompt:
+            await _write(
+                tmp_path / "test_calc.py",
+                (
+                    "from calc import add\n\n\n"
+                    "def test_add_sums_numbers():\n"
+                    "    assert add(1, 2) == 3\n"
+                ),
+            )
+            return AgentResult(agent_type="coder", result_text="Wrote failing test")
+        if "Write the minimum production change" in prompt:
+            await _write(
+                calc_file,
+                "def add(a, b):\n    return a + b\n",
+            )
+            return AgentResult(agent_type="coder", result_text="Applied minimal GREEN fix")
+        if "Review the just-passing implementation" in prompt:
+            return AgentResult(agent_type="reviewer", result_text="Refactor to store the sum in a named local before returning it.")
+        if "Apply the Navigator's refactor" in prompt:
+            await _write(
+                calc_file,
+                "def add(a, b):\n    total = a + b\n    return total\n",
+            )
+            return AgentResult(agent_type="coder", result_text="Applied refactor suggestion")
+        if "final validation" in prompt:
+            return AgentResult(agent_type="reviewer", result_text="Validation complete: refactor landed cleanly and tests still pass.")
+        raise AssertionError(f"unexpected prompt: {prompt}")
+
+    try:
+        result = await run_double_agent_tdd(
+            task="fix add() so it sums numbers",
+            test_command="python -m pytest -q test_calc.py",
+            deps=build.deps,
+            tools=build.tools,
+            cwd=str(tmp_path),
+            parent_model=build.model,
+            run_agent_fn=fake_run_agent,
+        )
+    finally:
+        build.close_structured_logger()
+        await build.teardown_mcp()
+        monkeypatch.delenv("DUH_STUB_PROVIDER", raising=False)
+
+    assert result.success is True
+    assert [phase.phase for phase in result.phases] == [
+        "navigator_spec",
+        "driver_red",
+        "driver_green",
+        "navigator_refactor",
+        "driver_refactor",
+        "navigator_validate",
+    ]
+    assert result.red_phase is not None
+    assert result.validation_phase is not None
+    assert result.red_phase.test_result is not None
+    assert result.validation_phase.test_result is not None
+    assert result.red_phase.test_result.passed is False
+    assert result.validation_phase.test_result.passed is True
+    assert "total = a + b" in calc_file.read_text(encoding="utf-8")
