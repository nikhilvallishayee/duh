@@ -0,0 +1,141 @@
+import time
+import math
+import uuid
+from typing import Any
+from ..types import Decision
+from .base import Backend
+import redis
+
+TOKEN_BUCKET_LUA = """
+local key = KEYS[1]
+local capacity = tonumber(ARGV[1])
+local refill_rate = tonumber(ARGV[2])
+local cost = tonumber(ARGV[3])
+
+local time_arr = redis.call('TIME')
+local now_ms = tonumber(time_arr[1]) * 1000 + math.floor(tonumber(time_arr[2]) / 1000)
+
+local state = redis.call('HGETALL', key)
+local tokens = capacity
+local last_refill_ts = now_ms
+
+if #state > 0 then
+    for i = 1, #state, 2 do
+        if state[i] == 'tokens' then
+            tokens = tonumber(state[i+1])
+        elseif state[i] == 'last_refill_ts' then
+            last_refill_ts = tonumber(state[i+1])
+        end
+    end
+end
+
+local elapsed_ms = math.max(0, now_ms - last_refill_ts)
+tokens = math.min(capacity, tokens + (elapsed_ms / 1000.0) * refill_rate)
+
+local allowed = 0
+if tokens >= cost then
+    tokens = tokens - cost
+    allowed = 1
+end
+
+redis.call('HSET', key, 'tokens', tostring(tokens), 'last_refill_ts', tostring(now_ms))
+local ttl = 1
+if refill_rate > 0 then
+    ttl = math.ceil((capacity / refill_rate))
+end
+redis.call('EXPIRE', key, ttl)
+
+return {allowed, tostring(tokens), now_ms}
+"""
+
+SLIDING_WINDOW_LUA = """
+local key = KEYS[1]
+local capacity = tonumber(ARGV[1])
+local window_size_ms = tonumber(ARGV[2])
+local cost = tonumber(ARGV[3])
+local unique_id = ARGV[4]
+
+local time_arr = redis.call('TIME')
+local now_ms = tonumber(time_arr[1]) * 1000 + math.floor(tonumber(time_arr[2]) / 1000)
+local cutoff_ms = now_ms - window_size_ms
+
+-- Evict old elements
+redis.call('ZREMRANGEBYSCORE', key, '-inf', cutoff_ms)
+
+local count = redis.call('ZCARD', key)
+local allowed = 0
+local retry_after_ms = 0
+local reset_ts = now_ms
+
+if count + cost <= capacity then
+    allowed = 1
+    for i = 1, cost do
+        redis.call('ZADD', key, now_ms, unique_id .. '_' .. i)
+    end
+    count = count + cost
+else
+    -- Find the timestamp that needs to be evicted to make room
+    local needed_evictions = (count + cost) - capacity
+    local elements = redis.call('ZRANGE', key, needed_evictions - 1, needed_evictions - 1, 'WITHSCORES')
+    if #elements >= 2 then
+        local oldest_to_evict_score = tonumber(elements[2])
+        retry_after_ms = oldest_to_evict_score - cutoff_ms
+    else
+        retry_after_ms = window_size_ms
+    end
+end
+
+redis.call('PEXPIRE', key, window_size_ms)
+
+-- Get the latest score for reset_ts
+local latest = redis.call('ZREVRANGE', key, 0, 0, 'WITHSCORES')
+if #latest >= 2 then
+    reset_ts = tonumber(latest[2]) + window_size_ms
+end
+
+return {allowed, count, retry_after_ms, reset_ts}
+"""
+
+class RedisBackend(Backend):
+    def __init__(self, redis_client: redis.Redis):
+        self.redis = redis_client
+
+    def token_bucket(self, key: str, capacity: int, refill_rate: float, cost: int) -> Decision:
+        result = self.redis.eval(TOKEN_BUCKET_LUA, 1, key, capacity, refill_rate, cost)
+        allowed_int, tokens_str, now_ms = result
+        allowed = bool(allowed_int)
+        tokens = float(tokens_str)
+        
+        if not allowed:
+            tokens_needed = cost - tokens
+            retry_after_ms = int((tokens_needed / refill_rate) * 1000) if refill_rate > 0 else 0
+        else:
+            retry_after_ms = 0
+            
+        remaining = int(tokens)
+        time_to_full_ms = int(((capacity - tokens) / refill_rate) * 1000) if refill_rate > 0 else 0
+        reset_ts = now_ms + time_to_full_ms
+
+        return Decision(
+            allowed=allowed,
+            limit=capacity,
+            remaining=remaining,
+            retry_after_ms=retry_after_ms,
+            reset_ts=reset_ts
+        )
+
+    def sliding_window(self, key: str, capacity: int, window_size_ms: int, cost: int) -> Decision:
+        unique_id = uuid.uuid4().hex
+        result = self.redis.eval(SLIDING_WINDOW_LUA, 1, key, capacity, window_size_ms, cost, unique_id)
+        allowed_int, count, retry_after_ms, reset_ts = result
+        allowed = bool(allowed_int)
+        
+        remaining = max(0, capacity - count)
+
+        return Decision(
+            allowed=allowed,
+            limit=capacity,
+            remaining=remaining,
+            retry_after_ms=retry_after_ms,
+            reset_ts=reset_ts
+        )
