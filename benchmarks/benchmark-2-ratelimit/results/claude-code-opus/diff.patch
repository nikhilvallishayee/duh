+"""Integration tests for RedisBackend using fakeredis."""
+
+from __future__ import annotations
+
+import pytest
+
+from ratelimit import RedisBackend, SlidingWindowLimiter, TokenBucketLimiter
+
+
+def test_redis_token_bucket_basic(fake_redis):
+    backend = RedisBackend(fake_redis, namespace="t1")
+    lim = TokenBucketLimiter(capacity=3, refill_rate=1.0, backend=backend)
+    t0 = 10_000_000
+    assert lim.enforce("k", now_ms=t0).allowed
+    assert lim.enforce("k", now_ms=t0).allowed
+    assert lim.enforce("k", now_ms=t0).allowed
+    d = lim.enforce("k", now_ms=t0)
+    assert d.allowed is False
+    assert 500 <= d.retry_after_ms <= 1500
+
+
+def test_redis_token_bucket_refills(fake_redis):
+    backend = RedisBackend(fake_redis, namespace="t2")
+    lim = TokenBucketLimiter(capacity=2, refill_rate=2.0, backend=backend)
+    t0 = 10_000_000
+    lim.enforce("k", now_ms=t0)
+    lim.enforce("k", now_ms=t0)
+    assert lim.enforce("k", now_ms=t0).allowed is False
+    # 500ms -> one token back.
+    assert lim.enforce("k", now_ms=t0 + 500).allowed
+    assert lim.enforce("k", now_ms=t0 + 500).allowed is False
+
+
+def test_redis_sliding_window_basic(fake_redis):
+    backend = RedisBackend(fake_redis, namespace="t3")
+    lim = SlidingWindowLimiter(capacity=3, period_seconds=1.0, backend=backend)
+    t0 = 10_000_000
+    assert lim.enforce("k", now_ms=t0).allowed
+    assert lim.enforce("k", now_ms=t0 + 100).allowed
+    assert lim.enforce("k", now_ms=t0 + 200).allowed
+    d = lim.enforce("k", now_ms=t0 + 300)
+    assert d.allowed is False
+    # After the oldest (t0) expires:
+    assert lim.enforce("k", now_ms=t0 + 1001).allowed
+
+
+def test_redis_per_key_namespace_isolation(fake_redis):
+    a = RedisBackend(fake_redis, namespace="A")
+    b = RedisBackend(fake_redis, namespace="B")
+    la = TokenBucketLimiter(capacity=1, refill_rate=0.001, backend=a)
+    lb = TokenBucketLimiter(capacity=1, refill_rate=0.001, backend=b)
+    assert la.enforce("k").allowed
+    # Same key, different namespace: independent.
+    assert lb.enforce("k").allowed
+    # But the same namespace+key is exhausted.
+    assert la.enforce("k").allowed is False
+
+
+def test_redis_reset_clears_state(fake_redis):
+    backend = RedisBackend(fake_redis, namespace="t4")
+    lim = TokenBucketLimiter(capacity=1, refill_rate=0.001, backend=backend)
+    assert lim.enforce("k").allowed
+    assert lim.enforce("k").allowed is False
+    backend.reset("k")
+    assert lim.enforce("k").allowed
+
+
+# --------------------------------------------------------------
+# Fail-open / fail-closed behavior when the client errors.
+# --------------------------------------------------------------
+
+
+class _BrokenClient:
+    """Minimal client whose register_script succeeds but every call raises."""
+
+    def register_script(self, src):
+        def _script(keys, args):
+            raise ConnectionError("redis down")
+
+        return _script
+
+    def delete(self, *keys):
+        raise ConnectionError("redis down")
+
+
+def test_fail_open_on_error():
+    backend = RedisBackend(_BrokenClient(), on_error="fail_open")
+    d = backend.token_bucket("k", capacity=5, refill_rate=1.0, cost=1)
+    assert d.allowed is True
+    d = backend.sliding_window("k", capacity=5, period_ms=1000, cost=1)
+    assert d.allowed is True
+
+
+def test_fail_closed_on_error():
+    backend = RedisBackend(
+        _BrokenClient(), on_error="fail_closed", fail_closed_cooldown_ms=500
+    )
+    d = backend.token_bucket("k", capacity=5, refill_rate=1.0, cost=1)
+    assert d.allowed is False
+    assert d.retry_after_ms == 500
+
+
+def test_redis_sliding_window_cost_greater_than_one(fake_redis):
+    backend = RedisBackend(fake_redis, namespace="cost")
+    lim = SlidingWindowLimiter(capacity=10, period_seconds=60, backend=backend)
+    d = lim.enforce("k", cost=6, now_ms=1_000_000)
+    assert d.allowed
+    assert d.remaining == 4
+    d = lim.enforce("k", cost=5, now_ms=1_000_000)
+    assert d.allowed is False
+
+
+def test_redis_capacity_one_edge(fake_redis):
+    backend = RedisBackend(fake_redis, namespace="c1")
+    lim = SlidingWindowLimiter(capacity=1, period_seconds=1.0, backend=backend)
+    t0 = 10_000_000
+    assert lim.enforce("k", now_ms=t0).allowed
+    assert lim.enforce("k", now_ms=t0 + 500).allowed is False
+    assert lim.enforce("k", now_ms=t0 + 1001).allowed
