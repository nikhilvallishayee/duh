+"""Unit tests for the double-agent TDD flow."""
+import asyncio
+from unittest.mock import AsyncMock, Mock, patch
+
+import pytest
+
+from duh.tools.double_agent_tdd import DoubleAgentTDDTool, TDDPhaseResult
+from duh.kernel.tool import ToolContext, ToolResult
+
+
+class TestDoubleAgentTDDTool:
+    """Test the DoubleAgentTDDTool class."""
+
+    def setup_method(self):
+        """Set up test dependencies."""
+        self.deps = Mock()
+        self.tools = [Mock()]
+        self.context = ToolContext(deps=self.deps, cwd=".")
+
+    @pytest.mark.asyncio
+    async def test_call_missing_task_parameter(self):
+        """Test that missing task parameter returns error."""
+        tool = DoubleAgentTDDTool(
+            parent_deps=self.deps,
+            parent_tools=self.tools,
+            parent_model="test-model"
+        )
+        
+        result = await tool.call({}, self.context)
+        assert result.is_error
+        assert "missing required 'task' parameter" in result.output
+
+    @pytest.mark.asyncio
+    async def test_call_successful_execution(self):
+        """Test successful execution of the TDD flow."""
+        tool = DoubleAgentTDDTool(
+            parent_deps=self.deps,
+            parent_tools=self.tools,
+            parent_model="test-model"
+        )
+        
+        # Mock the _execute_tdd_flow method to return success
+        with patch.object(tool, '_execute_tdd_flow', return_value="Success!"):
+            result = await tool.call({
+                "task": "implement a calculator",
+                "test_framework": "pytest"
+            }, self.context)
+            
+            assert not result.is_error
+            assert result.output == "Success!"
+
+    @pytest.mark.asyncio
+    async def test_call_execution_error(self):
+        """Test that execution errors are properly handled."""
+        tool = DoubleAgentTDDTool(
+            parent_deps=self.deps,
+            parent_tools=self.tools,
+            parent_model="test-model"
+        )
+        
+        # Mock the _execute_tdd_flow method to raise an exception
+        with patch.object(tool, '_execute_tdd_flow', side_effect=Exception("Test error")):
+            result = await tool.call({
+                "task": "implement a calculator",
+                "test_framework": "pytest"
+            }, self.context)
+            
+            assert result.is_error
+            assert "Test error" in result.output
+
+    @pytest.mark.asyncio
+    async def test_phase1_draft_spec_success(self):
+        """Test phase 1 draft spec success."""
+        tool = DoubleAgentTDDTool(
+            parent_deps=self.deps,
+            parent_tools=self.tools,
+            parent_model="test-model"
+        )
+        
+        # Mock run_agent to return success
+        with patch('duh.tools.double_agent_tdd.run_agent') as mock_run_agent:
+            mock_result = Mock()
+            mock_result.is_error = False
+            mock_result.result_text = "Test specification content"
+            mock_run_agent.return_value = mock_result
+            
+            result = await tool._phase1_draft_spec(
+                "implement calculator", "pytest", 10,
+                self.tools, "test-model", self.context
+            )
+            
+            assert result.success
+            assert result.output == "Test specification content"
+            assert result.phase == 1
+
+    @pytest.mark.asyncio
+    async def test_phase1_draft_spec_error(self):
+        """Test phase 1 draft spec error handling."""
+        tool = DoubleAgentTDDTool(
+            parent_deps=self.deps,
+            parent_tools=self.tools,
+            parent_model="test-model"
+        )
+        
+        # Mock run_agent to return error
+        with patch('duh.tools.double_agent_tdd.run_agent') as mock_run_agent:
+            mock_result = Mock()
+            mock_result.is_error = True
+            mock_result.error = "Agent error"
+            mock_run_agent.return_value = mock_result
+            
+            result = await tool._phase1_draft_spec(
+                "implement calculator", "pytest", 10,
+                self.tools, "test-model", self.context
+            )
+            
+            assert not result.success
+            assert result.error == "Agent error"
+            assert result.phase == 1
+
+    @pytest.mark.asyncio
+    async def test_phase2_test_failure_detection(self):
+        """Test that phase 2 correctly detects test failures."""
+        tool = DoubleAgentTDDTool(
+            parent_deps=self.deps,
+            parent_tools=self.tools,
+            parent_model="test-model"
+        )
+        
+        # Test that contains "AssertionError" should be marked as failed
+        with patch('duh.tools.double_agent_tdd.run_agent') as mock_run_agent:
+            mock_result = Mock()
+            mock_result.is_error = False
+            mock_result.result_text = "Test output with AssertionError"
+            mock_run_agent.return_value = mock_result
+            
+            result = await tool._phase2_write_failing_test(
+                "spec", "pytest", 10,
+                self.tools, "test-model", self.context
