  [33m> Write[0m(file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-gpt54/ratelimit/backends.py', content='from __future__ import annotations\n\nimport threading\nimport time\nfrom math import ceil\nfrom typing import Any\n\nfrom redis import Redis\n\nfrom .core import Decision\n\n\nclass InMemoryBackend:\n    def __init__(self) -> None:\n        self._lock = threading.RLock()\n        self._token_buckets: dict[str, dict[str, float]] = {}\n        self._sliding_windows: dict[str, dict[str, int]] = {}\n\n    def token_bucket_enforce(\n        self,\n        key: str,\n        *,\n        capacity: int,\n        refill_rate: float,\n        cost: int,\n    ) -> Decision:\n        now_ms = self._now_ms()\n        now_monotonic = time.monotonic()\n        refill_per_ms = refill_rate / 1000.0\n        with self._lock:\n            state = self._token_buckets.get(key)\n            if state is None:\n                tokens = float(capacity)\n                last_refill = now_monotonic\n            else:\n                elapsed = max(0.0, now_monotonic - state["last_refill"])\n                tokens = min(float(capacity), state["tokens"] + (elapsed * refill_rate))\n                last_refill = now_monotonic\n\n            allowed = tokens >= cost\n            if allowed:\n                tokens -= cost\n                retry_after_ms = 0\n            else:\n                deficit = cost - tokens\n                retry_after_ms = ceil((deficit / refill_rate) * 1000)\n\n            remaining = max(0, int(tokens)) if allowed else max(0, int(tokens))\n            reset_ts = now_ms + ceil(((capacity - tokens) / refill_per_ms)) if refill_per_ms else now_ms\n            self._token_buckets[key] = {"tokens": tokens, "last_refill": last_refill}\n            return Decision(\n                allowed=allowed,\n                retry_after_ms=retry_after_ms,\n                remaining=remaining,\n                reset_ts=reset_ts,\n            )\n\n    def sliding_window_enforce(\n        self,\n        key: str,\n        *,\n        limit: int,\n        period_ms: int,\n        cost: int,\n    ) -> Decision:\n        now_ms = self._now_ms()\n        bucket_start = now_ms - (now_ms % period_ms)\n        with self._lock:\n            state = self._sliding_windows.get(key)\n            if state is None:\n                state = {\n                    "current_start": bucket_start,\n                    "current_count": 0,\n                    "previous_count": 0,\n                }\n            else:\n                current_start = state["current_start"]\n                if bucket_start == current_start:\n                    pass\n                elif bucket_start == current_start + period_ms:\n                    state = {\n                        "current_start": bucket_start,\n                        "current_count": 0,\n                        "previous_count": state["current_count"],\n                    }\n                else:\n                    state = {\n                        "current_start": bucket_start,\n                        "current_count": 0,\n                        "previous_count": 0,\n                    }\n\n            elapsed = now_ms - state["current_start"]\n            weight = max(0.0, 1.0 - (elapsed / period_ms))\n            effective = state["current_count"] + (state["previous_count"] * weight)\n            allowed = effective + cost <= limit\n            if allowed:\n                state["current_count"] += cost\n                effective += cost\n                retry_after_ms = 0\n            else:\n                if state["previous_count"] == 0:\n                    retry_after_ms = period_ms - elapsed\n                else:\n                    needed_decay = effective + cost - limit\n                    decay_per_ms = state["previous_count"] / period_ms\n                    retry_after_ms = period_ms - elapsed if decay_per_ms <= 0 else ceil(needed_decay / decay_per_ms)\n                    retry_after_ms = max(1, min(period_ms - elapsed if elapsed < period_ms else period_ms, retry_after_ms))\n\n            remaining = max(0, limit - ceil(effective))\n            reset_ts = state["current_start"] + period_ms * 2\n            self._sliding_windows[key] = state\n            return Decision(\n                allowed=allowed,\n                retry_after_ms=retry_after_ms,\n                remaining=remaining,\n                reset_ts=reset_ts,\n            )\n\n    @staticmethod\n    def _now_ms() -> int:\n        return int(time.time() * 1000)\n\n\nclass RedisBackend:\n    _TOKEN_BUCKET_SCRIPT = """\nlocal key = KEYS[1]\nlocal capacity = tonumber(ARGV[1])\nlocal refill_rate = tonumber(ARGV[2])\nlocal cost = tonumber(ARGV[3])\nlocal ttl_ms = tonumber(ARGV[4])\n\nlocal now = redis.call(\'TIME\')\nlocal now_ms = now[1] * 1000 + math.floor(now[2] / 1000)\n\nlocal data = redis.call(\'HMGET\', key, \'tokens\', \'last_refill_ms\')\nlocal tokens = tonumber(data[1])\nlocal last_refill_ms = tonumber(data[2])\nif not tokens then\n  tokens = capacity\n  last_refill_ms = now_ms\nend\n\nlocal elapsed = math.max(0, now_ms - last_refill_ms)\nlocal refilled = math.min(capacity, tokens + (elapsed * refill_rate / 1000.0))\nlocal allowed = 0\nlocal retry_after_ms = 0\n\nif refilled >= cost then\n  refilled = refilled - cost\n  allowed = 1\nelse\n  local deficit = cost - refilled\n  retry_after_ms = math.ceil((deficit / refill_rate) * 1000)\nend\n\nredis.call(\'HSET\', key, \'tokens\', refilled, \'last_refill_ms\', now_ms)\nredis.call(\'PEXPIRE\', key, ttl_ms)\n\nlocal remaining = math.max(0, math.floor(refilled))\nlocal reset_ts = now_ms + math.ceil(((capacity - refilled) / refill_rate) * 1000)\nreturn {allowed, retry_after_ms, remaining, reset_ts}\n"""\n\n    _SLIDING_WINDOW_SCRIPT = """\nlocal key = KEYS[1]\nlocal limit = tonumber(ARGV[1])\nlocal period_ms = tonumber(ARGV[2])\nlocal cost = tonumber(ARGV[3])\nlocal ttl_ms = tonumber(ARGV[4])\n\nlocal now = redis.call(\'TIME\')\nlocal now_ms = now[1] * 1000 + math.floor(now[2] / 1000)\nlocal bucket_start = now_ms - (now_ms % period_ms)\n\nlocal data = redis.call(\'HMGET\', key, \'current_start\', \'current_count\', \'previous_count\')\nlocal current_start = tonumber(data[1])\nlocal current_count = tonumber(data[2]) or 0\nlocal previous_count = tonumber(data[3]) or 0\n\nif not current_start then\n  current_start = bucket_start\n  current_count = 0\n  previous_count = 0\nelseif bucket_start == current_start + period_ms then\n  previous_count = current_count\n  current_count = 0\n  current_start = bucket_start\nelseif bucket_start > current_start + period_ms then\n  previous_count = 0\n  current_count = 0\n  current_start = bucket_start\nend\n\nlocal elapsed = now_ms - current_start\nlocal weight = math.max(0, 1 - (elapsed / period_ms))\nlocal effective = current_count + (previous_count * weight)\nlocal allowed = 0\nlocal retry_after_ms = 0\n\nif effective + cost <= limit then\n  current_count = current_count + cost\n  effective = effective + cost\n  allowed = 1\nelse\n  if previous_count == 0 then\n    retry_after_ms = period_ms - elapsed\n  else\n    local needed_decay = effective + cost - limit\n    local decay_per_ms = previous_count / period_ms\n    if decay_per_ms <= 0 then\n      retry_after_ms = period_ms - elapsed\n    else\n      retry_after_ms = math.ceil(needed_decay / decay_per_ms)\n      local remainder = period_ms - elapsed\n      if retry_after_ms < 1 then retry_after_ms = 1 end\n      if retry_after_ms > remainder then retry_after_ms = remainder end\n    end\n  end\nend\n\nredis.call(\'HSET\', key, \'current_start\', current_start, \'current_count\', current_count, \'previous_count\', previous_count)\nredis.call(\'PEXPIRE\', key, ttl_ms)\n\nlocal remaining = math.max(0, limit - math.ceil(effective))\nlocal reset_ts = current_start + period_ms * 2\nreturn {allowed, retry_after_ms, remaining, reset_ts}\n"""\n\n    def __init__(self, client: Redis) -> None:\n        self._client = client\n        self._token_bucket_sha = self._client.script_load(self._TOKEN_BUCKET_SCRIPT)\n        self._sliding_window_sha = self._client.script_load(self._SLIDING_WINDOW_SCRIPT)\n\n    def token_bucket_enforce(\n        self,\n        key: str,\n        *,\n        capacity: int,\n        refill_rate: float,\n        cost: int,\n    ) -> Decision:\n        ttl_ms = max(1000, ceil((capacity / refill_rate) * 2000))\n        result = self._evalsha(\n            self._token_bucket_sha,\n            1,\n            key,\n            capacity,\n            refill_rate,\n            cost,\n            ttl_ms,\n        )\n        return Decision(bool(result[0]), int(result[1]), int(result[2]), int(result[3]))\n\n    def sliding_window_enforce(\n        self,\n        key: str,\n        *,\n        limit: int,\n        period_ms: int,\n        cost: int,\n    ) -> Decision:\n        ttl_ms = period_ms * 2\n        result = self._evalsha(\n            self._sliding_window_sha,\n            1,\n            key,\n            limit,\n            period_ms,\n            cost,\n            ttl_ms,\n        )\n        return Decision(bool(result[0]), int(result[1]), int(result[2]), int(result[3]))\n\n    def _evalsha(self, sha: str, numkeys: int, *args: Any) -> list[Any]:\n        try:\n            return self._client.evalsha(sha, numkeys, *args)\n        except Exception as exc:\n            if exc.__class__.__name__ != \'NoScriptError\':\n                raise\n            self._token_bucket_sha = self._client.script_load(self._TOKEN_BUCKET_SCRIPT)\n            self._sliding_window_sha = self._client.script_load(self._SLIDING_WINDOW_SCRIPT)\n            return self._client.evalsha(sha, numkeys, *args)\n')
  [33m> Write[0m(file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-gpt54/ratelimit/limiters.py', content='from __future__ import annotations\n\nfrom .core import Backend, Decision, RateLimiter\n\n\nclass TokenBucketLimiter(RateLimiter):\n    def __init__(self, *, backend: Backend, capacity: int, refill_rate: float, prefix: str = "tb") -> None:\n        if capacity <= 0:\n            raise ValueError("capacity must be positive")\n        if refill_rate <= 0:\n            raise ValueError("refill_rate must be positive")\n        self.backend = backend\n        self.capacity = capacity\n        self.refill_rate = refill_rate\n        self.prefix = prefix\n\n    def enforce(self, key: str, cost: int = 1) -> Decision:\n        if cost <= 0:\n            raise ValueError("cost must be positive")\n        return self.backend.token_bucket_enforce(\n            self._key(key),\n            capacity=self.capacity,\n            refill_rate=self.refill_rate,\n            cost=cost,\n        )\n\n    def _key(self, key: str) -> str:\n        return f"{self.prefix}:{key}"\n\n\nclass SlidingWindowLimiter(RateLimiter):\n    def __init__(self, *, backend: Backend, limit: int, period_ms: int, prefix: str = "sw") -> None:\n        if limit <= 0:\n            raise ValueError("limit must be positive")\n        if period_ms <= 0:\n            raise ValueError("period_ms must be positive")\n        self.backend = backend\n        self.limit = limit\n        self.period_ms = period_ms\n        self.prefix = prefix\n\n    def enforce(self, key: str, cost: int = 1) -> Decision:\n        if cost <= 0:\n            raise ValueError("cost must be positive")\n        return self.backend.sliding_window_enforce(\n            self._key(key),\n            limit=self.limit,\n            period_ms=self.period_ms,\n            cost=cost,\n        )\n\n    def _key(self, key: str) -> str:\n        return f"{self.prefix}:{key}"\n')
