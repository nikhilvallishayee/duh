+import threading
+import pytest
+from ratelimit.backends import InMemoryBackend
+from ratelimit.limiters import SlidingWindowLimiter
+
+def test_concurrency_no_overgrant():
+    backend = InMemoryBackend()
+    capacity = 10
+    limiter = SlidingWindowLimiter(backend, capacity=capacity, window_ms=5000)
+    key = "concurrent_key"
+
+    allowed_count = 0
+    lock = threading.Lock()
+
+    def worker():
+        nonlocal allowed_count
+        dec = limiter.enforce(key)
+        if dec.allowed:
+            with lock:
+                allowed_count += 1
+
+    threads = []
+    # Drive 100 concurrent requests
+    for _ in range(100):
+        t = threading.Thread(target=worker)
+        threads.append(t)
+    
+    for t in threads:
+        t.start()
+    for t in threads:
+        t.join()
+
+    # The limiter should only allow exactly 'capacity' requests
+    assert allowed_count == capacity
