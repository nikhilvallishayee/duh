index 0000000..40b791a
--- /dev/null
+++ b/ratelimit/backends.py
@@ -0,0 +1,188 @@
+import time
+import threading
+from typing import Protocol, Dict, Tuple, List
+from collections import defaultdict
+import redis
+
+from ratelimit.models import Decision
+
+class Backend(Protocol):
+    def eval_token_bucket(self, key: str, capacity: int, refill_rate: float, cost: int, now_ms: int) -> Decision:
+        ...
+
+    def eval_sliding_window(self, key: str, capacity: int, window_ms: int, cost: int, now_ms: int) -> Decision:
+        ...
+
+class InMemoryBackend(Backend):
+    def __init__(self):
+        self.lock = threading.Lock()
+        self.tb_state: Dict[str, Tuple[float, int]] = {}
+        self.sw_state: Dict[str, List[int]] = defaultdict(list)
+
+    def eval_token_bucket(self, key: str, capacity: int, refill_rate: float, cost: int, now_ms: int) -> Decision:
+        with self.lock:
+            if key not in self.tb_state:
+                tokens = float(capacity)
+                last_update = now_ms
+            else:
+                tokens, last_update = self.tb_state[key]
+                delta_ms = max(0, now_ms - last_update)
+                refilled = delta_ms * (refill_rate / 1000.0)
+                tokens = min(float(capacity), tokens + refilled)
+                last_update = now_ms
+            
+            if tokens >= cost:
+                tokens -= cost
+                allowed = True
+                remaining = int(tokens)
+                retry_after_ms = 0
+            else:
+                allowed = False
+                remaining = int(tokens)
+                needed = cost - tokens
+                retry_after_ms = int(needed / (refill_rate / 1000.0))
+            
+            reset_ts = now_ms + int((capacity - remaining) / (refill_rate / 1000.0))
+            self.tb_state[key] = (tokens, last_update)
+            return Decision(allowed, retry_after_ms, remaining, reset_ts)
+
+    def eval_sliding_window(self, key: str, capacity: int, window_ms: int, cost: int, now_ms: int) -> Decision:
+        with self.lock:
+            cutoff = now_ms - window_ms
+            state = self.sw_state[key]
+            # keep only timestamps > cutoff
+            idx = 0
+            while idx < len(state) and state[idx] <= cutoff:
+                idx += 1
+            state = state[idx:]
+            
+            current_count = len(state)
+            
+            if current_count + cost <= capacity:
+                allowed = True
+                remaining = capacity - current_count - cost
+                retry_after_ms = 0
+                for _ in range(cost):
+                    state.append(now_ms)
+            else:
+                allowed = False
+                remaining = capacity - current_count
+                if cost > capacity:
+                    retry_after_ms = -1
+                else:
+                    needed_drops = current_count + cost - capacity
+                    retry_after_ms = state[needed_drops - 1] + window_ms - now_ms
+            
+            reset_ts = state[-1] + window_ms if state else now_ms
+            self.sw_state[key] = state
+            return Decision(allowed, max(0, retry_after_ms), max(0, remaining), reset_ts)
+
+TB_LUA = """
+local key = KEYS[1]
+local capacity = tonumber(ARGV[1])
+local refill_rate = tonumber(ARGV[2])
+local cost = tonumber(ARGV[3])
+local now_ms = tonumber(ARGV[4])
+
+local state = redis.call('HMGET', key, 'tokens', 'last_update')
+local tokens = tonumber(state[1])
+local last_update = tonumber(state[2])
+
+if not tokens then
+    tokens = capacity
+    last_update = now_ms
+else
+    local delta_ms = math.max(0, now_ms - last_update)
+    local refilled = delta_ms * (refill_rate / 1000.0)
+    tokens = math.min(capacity, tokens + refilled)
+    last_update = now_ms
+end
+
+local allowed = 0
+local remaining = math.floor(tokens)
+local retry_after_ms = 0
+
+if tokens >= cost then
+    tokens = tokens - cost
+    allowed = 1
+    remaining = math.floor(tokens)
+else
+    local needed = cost - tokens
+    retry_after_ms = math.ceil(needed / (refill_rate / 1000.0))
+end
+
+local reset_ts = now_ms + math.ceil((capacity - remaining) / (refill_rate / 1000.0))
+
+redis.call('HMSET', key, 'tokens', tostring(tokens), 'last_update', tostring(last_update))
+local ttl = math.ceil((capacity - remaining) / refill_rate)
+redis.call('EXPIRE', key, math.max(1, ttl + 1))
+
+return {allowed, retry_after_ms, remaining, reset_ts}
+"""
+
+SW_LUA = """
+local key = KEYS[1]
+local capacity = tonumber(ARGV[1])
+local window_ms = tonumber(ARGV[2])
+local cost = tonumber(ARGV[3])
+local now_ms = tonumber(ARGV[4])
+local counter = tonumber(ARGV[5])
+
+local cutoff = now_ms - window_ms
+redis.call('ZREMRANGEBYSCORE', key, '-inf', cutoff)
+
+local current_count = redis.call('ZCARD', key)
+
+local allowed = 0
+local remaining = capacity - current_count
+local retry_after_ms = 0
+local reset_ts = now_ms
+
+if current_count + cost <= capacity then
+    allowed = 1
+    remaining = remaining - cost
+    for i=1,cost do
+        redis.call('ZADD', key, now_ms, now_ms .. '-' .. (counter + i))
+    end
+    redis.call('PEXPIRE', key, window_ms)
+else
+    if cost > capacity then
+        retry_after_ms = -1
+    else
+        local needed_drops = current_count + cost - capacity
+        local elements = redis.call('ZRANGE', key, needed_drops - 1, needed_drops - 1, 'WITHSCORES')
+        if #elements > 0 then
+            local oldest_score = tonumber(elements[2])
+            retry_after_ms = oldest_score + window_ms - now_ms
+        end
+    end
+end
+
+local all_elements = redis.call('ZRANGE', key, -1, -1, 'WITHSCORES')
+if #all_elements > 0 then
+    reset_ts = tonumber(all_elements[2]) + window_ms
+end
+
+return {allowed, retry_after_ms, remaining, reset_ts}
+"""
+
+class RedisBackend(Backend):
+    def __init__(self, client: redis.Redis):
+        self.client = client
+        self._tb_script = self.client.register_script(TB_LUA)
+        self._sw_script = self.client.register_script(SW_LUA)
+        self.lock = threading.Lock()
+        self.counter = 0
+
+    def eval_token_bucket(self, key: str, capacity: int, refill_rate: float, cost: int, now_ms: int) -> Decision:
+        res = self._tb_script(keys=[key], args=[capacity, refill_rate, cost, now_ms])
+        allowed, retry_after_ms, remaining, reset_ts = res
+        return Decision(bool(allowed), retry_after_ms, remaining, reset_ts)
+
+    def eval_sliding_window(self, key: str, capacity: int, window_ms: int, cost: int, now_ms: int) -> Decision:
+        with self.lock:
+            self.counter += cost
+            c = self.counter
+        res = self._sw_script(keys=[key], args=[capacity, window_ms, cost, now_ms, c])
+        allowed, retry_after_ms, remaining, reset_ts = res
+        return Decision(bool(allowed), max(0, retry_after_ms), max(0, remaining), reset_ts)
