  [33m> Write[0m(file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-gpt54/ratelimit/middleware.py', content='from __future__ import annotations\n\nfrom typing import Callable\n\nfrom starlette.middleware.base import BaseHTTPMiddleware\nfrom starlette.requests import Request\nfrom starlette.responses import JSONResponse, Response\n\nfrom .core import Decision, RateLimiter\n\n\nclass RateLimitMiddleware(BaseHTTPMiddleware):\n    def __init__(self, app, limiter: RateLimiter, key_fn: Callable[[Request], str], fail_open: bool = True) -> None:\n        super().__init__(app)\n        self.limiter = limiter\n        self.key_fn = key_fn\n        self.fail_open = fail_open\n\n    async def dispatch(self, request: Request, call_next) -> Response:\n        try:\n            decision = self.limiter.enforce(self.key_fn(request))\n        except Exception:\n            if not self.fail_open:\n                raise\n            return await call_next(request)\n\n        if not decision.allowed:\n            response = JSONResponse({"detail": "rate limit exceeded"}, status_code=429)\n            _apply_headers(response, decision, self._limit_value())\n            return response\n\n        response = await call_next(request)\n        _apply_headers(response, decision, self._limit_value())\n        return response\n\n    def _limit_value(self) -> int:\n        return getattr(self.limiter, "capacity", getattr(self.limiter, "limit", 0))\n\n\ndef _apply_headers(response: Response, decision: Decision, limit_value: int) -> None:\n    response.headers["X-RateLimit-Limit"] = str(limit_value)\n    response.headers["X-RateLimit-Remaining"] = str(decision.remaining)\n    response.headers["X-RateLimit-Reset"] = str(decision.reset_ts)\n    if decision.retry_after_ms > 0:\n        response.headers["Retry-After"] = str(max(1, (decision.retry_after_ms + 999) // 1000))\n')
