new file mode 100644
index 0000000000000000000000000000000000000000..c81bd0ddf420bad523be358e0f36ddd8724a9b9e
--- /dev/null
+++ b/duh/cli/tdd.py
@@ -0,0 +1,70 @@
+"""CLI entry point for the double-agent TDD flow."""
+
+from __future__ import annotations
+
+import argparse
+import os
+import sys
+
+from duh.cli import exit_codes
+from duh.tdd import format_tdd_result, run_double_agent_tdd
+
+
+async def run_tdd(args: argparse.Namespace) -> int:
+    from duh.cli.runner import BRIEF_INSTRUCTION, SYSTEM_PROMPT, _no_provider_message
+    from duh.cli.session_builder import (
+        ProviderResolutionError,
+        SessionBuilder,
+        SessionBuilderOptions,
+    )
+
+    options = SessionBuilderOptions(
+        include_skills_in_tools=True,
+        include_deferred_tools=True,
+        include_memory_prompt=True,
+        include_env_block=True,
+        include_templates_hint=True,
+        include_model_context_block=False,
+        honour_tool_filters=True,
+        approver_mode="print_mode",
+        wire_hook_registry_in_deps=False,
+        wire_audit_logger_in_deps=True,
+        honour_tool_choice=True,
+        honour_thinking=True,
+        allow_session_id_override=True,
+        log_skip_perms_warning=True,
+        default_system_prompt=SYSTEM_PROMPT,
+        brief_instruction=BRIEF_INSTRUCTION,
+    )
+
+    builder = SessionBuilder(args, options, cwd=os.getcwd(), debug=getattr(args, "debug", False))
+    try:
+        build = await builder.build()
+    except ProviderResolutionError as exc:
+        if exc.provider_name is None:
+            sys.stderr.write(_no_provider_message())
+        else:
+            sys.stderr.write(f"Error: {exc.message}\n")
+        return exit_codes.PROVIDER_ERROR
+
+    try:
+        result = await run_double_agent_tdd(
+            task=args.task,
+            test_command=args.test_command,
+            deps=build.deps,
+            tools=build.tools,
+            cwd=os.getcwd(),
+            parent_model=build.model,
+            driver_model=args.driver_model,
+            navigator_model=args.navigator_model,
+            driver_max_turns=args.driver_max_turns,
+            navigator_max_turns=args.navigator_max_turns,
+            max_red_revisions=args.max_red_revisions,
+            shell=args.shell,
+        )
+        sys.stdout.write(format_tdd_result(result))
+        sys.stdout.write("\n")
+        return exit_codes.SUCCESS if result.success else exit_codes.ERROR
+    finally:
+        build.close_structured_logger()
+        await build.teardown_mcp()
