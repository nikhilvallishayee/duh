+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+def _make_mock_swarm_tool():
+    """Create a mock SwarmTool that returns canned responses."""
+    mock = AsyncMock()
+    
+    async def run_swarm(tasks):
+        results = []
+        for task in tasks:
+            if "Draft a detailed test specification" in task.prompt:
+                # Navigator drafting test spec
+                result_text = (
+                    "Test File: tests/test_auth.py\n"
+                    "Test Class: TestAuth\n"
+                    "Test Method: test_new_feature\n"
+                    "Assertions:\n"
+                    "- assert auth.new_feature() == True\n"
+                    "- assert auth.new_feature_fails_with_invalid_input() raises ValueError"
+                )
+            elif "Write a failing test" in task.prompt:
+                # Driver writing failing test
+                result_text = "Test code written to tests/test_auth.py"
+            elif "Write the minimum implementation code" in task.prompt:
+                # Driver writing implementation
+                result_text = "Implementation code written to auth.py"
+            elif "Propose a refactor" in task.prompt:
+                # Navigator proposing refactor
+                result_text = (
+                    "Refactor Plan:\n"
+                    "- Extract duplicate logic in auth.py to helper functions\n"
+                    "- Improve error messages in auth.py"
+                )
+            elif "Apply the following refactor" in task.prompt:
+                # Driver applying refactor
+                result_text = "Refactor applied to auth.py"
+            elif "Validate that the following refactor" in task.prompt:
+                # Navigator validating refactor
+                result_text = "Validation: All tests pass. Refactor applied correctly."
+            else:
+                result_text = "Mock response"
+            
+            # Create a mock result object with result_text attribute
+            result_mock = AsyncMock()
+            result_mock.result_text = result_text
+            results.append(result_mock)
+        
+        return results
+    
+    mock._run_swarm = run_swarm
+    return mock
+
+
+def _make_mock_bash_tool():
+    """Create a mock BashTool that simulates test runs."""
+    mock = AsyncMock()
+    
+    async def run_bash(command, **kwargs):
+        if "pytest" in command and "FAIL" in command:
+            # Simulate failing test
+            return {"stdout": "=== FAIL: test_auth.py::TestAuth::test_new_feature\nAssertionError: False is not true"}
+        elif "pytest" in command:
+            # Simulate passing test
+            return {"stdout": "=== 1 passed in 0.12s"}
+        return {"stdout": ""}
+    
+    mock.run = run_bash
+    return mock
+
+
+def _make_engine():
+    """Create a test engine with mocked dependencies."""
+    deps = Deps(
+        call_model=AsyncMock(),
+        swarm=_make_mock_swarm_tool(),
+        bash=_make_mock_bash_tool()
+    )
+    config = EngineConfig(model="test-model")
+    return Engine(deps=deps, config=config)
+
+
+async def _collect_events(gen):
+    """Collect all events from an async generator."""
+    events = []
+    async for event in gen:
+        events.append(event)
+    return events
+
+
+# ---------------------------------------------------------------------------
+# TDDPlanMode initialization
+# ---------------------------------------------------------------------------
+
+class TestTDDPlanModeInit:
+    def test_initial_state(self):
+        engine = _make_engine()
+        tdd = TDDPlanMode(engine)
+        assert tdd.current_phase == TDDPhase.SPEC_DRAFT
+        assert tdd.steps == []
+        assert tdd.task_description == ""
+
+    def test_format_status_empty(self):
+        engine = _make_engine()
+        tdd = TDDPlanMode(engine)
+        status = tdd.format_status()
+        assert "TDD Flow:" in status
+        assert "No steps completed" in status
