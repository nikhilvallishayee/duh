+import pytest
+import asyncio
+from ratelimit.backends import InMemoryBackend
+from ratelimit.limiters import TokenBucketLimiter
+from ratelimit.decorators import rate_limit, RateLimitExceeded
+
+def test_sync_decorator():
+    backend = InMemoryBackend()
+    limiter = TokenBucketLimiter(backend, capacity=2, refill_rate=10.0)
+    
+    @rate_limit(limiter, key_fn=lambda arg: f"key_{arg}")
+    def my_func(arg):
+        return arg * 2
+
+    assert my_func(1) == 2
+    assert my_func(1) == 2
+    
+    with pytest.raises(RateLimitExceeded):
+        my_func(1)
+        
+    # Different key should pass
+    assert my_func(2) == 4
+
+@pytest.mark.asyncio
+async def test_async_decorator():
+    backend = InMemoryBackend()
+    limiter = TokenBucketLimiter(backend, capacity=2, refill_rate=10.0)
+    
+    @rate_limit(limiter, key_fn=lambda arg: f"key_{arg}")
+    async def my_async_func(arg):
+        return arg * 2
+
+    assert await my_async_func(1) == 2
+    assert await my_async_func(1) == 2
+    
+    with pytest.raises(RateLimitExceeded):
+        await my_async_func(1)
