index 0000000..7e5e405
--- /dev/null
+++ b/tests/test_decorator.py
@@ -0,0 +1,109 @@
+"""Tests for the @rate_limit decorator."""
+
+from __future__ import annotations
+
+import asyncio
+
+import pytest
+
+from ratelimit import (
+    InMemoryBackend,
+    RateLimitExceeded,
+    TokenBucketLimiter,
+    rate_limit,
+)
+
+
+def test_decorator_allows_then_denies():
+    lim = TokenBucketLimiter(capacity=2, refill_rate=0.001, backend=InMemoryBackend())
+
+    @rate_limit(lim, key_fn=lambda user: f"u:{user}")
+    def greet(user: str) -> str:
+        return f"hi {user}"
+
+    assert greet("alice") == "hi alice"
+    assert greet("alice") == "hi alice"
+    with pytest.raises(RateLimitExceeded) as exc_info:
+        greet("alice")
+    assert exc_info.value.key == "u:alice"
+    assert exc_info.value.decision.allowed is False
+
+
+def test_decorator_keys_independent():
+    lim = TokenBucketLimiter(capacity=1, refill_rate=0.001, backend=InMemoryBackend())
+
+    @rate_limit(lim, key_fn=lambda user: f"u:{user}")
+    def f(user: str) -> str:
+        return user
+
+    assert f("a") == "a"
+    assert f("b") == "b"
+    with pytest.raises(RateLimitExceeded):
+        f("a")
+
+
+def test_decorator_re_entry_uses_same_bucket():
+    """If a decorated function calls itself via recursion, each call
+    is independently rate-limited. This verifies re-entry correctness
+    (bucket state is shared, not double-counted, not lost)."""
+
+    lim = TokenBucketLimiter(capacity=3, refill_rate=0.001, backend=InMemoryBackend())
+
+    results = []
+
+    @rate_limit(lim, key_fn=lambda n: "recur")
+    def step(n: int) -> int:
+        results.append(n)
+        if n <= 0:
+            return 0
+        try:
+            return step(n - 1)
+        except RateLimitExceeded:
+            return -1
+
+    # First call: admitted, then two more recursive admits, then denied.
+    out = step(5)
+    assert out == -1
+    assert results == [5, 4, 3]
+
+
+def test_decorator_cost_callable():
+    lim = TokenBucketLimiter(capacity=10, refill_rate=0.001, backend=InMemoryBackend())
+
+    @rate_limit(lim, key_fn=lambda x: "k", cost=lambda x: int(x))
+    def pay(amount: int) -> int:
+        return amount
+
+    assert pay(3) == 3
+    assert pay(5) == 5
+    with pytest.raises(RateLimitExceeded):
+        pay(3)
+
+
+def test_decorator_async():
+    lim = TokenBucketLimiter(capacity=2, refill_rate=0.001, backend=InMemoryBackend())
+
+    @rate_limit(lim, key_fn=lambda x: "ak")
+    async def hello(x: int) -> int:
+        await asyncio.sleep(0)
+        return x * 2
+
+    async def main():
+        assert await hello(1) == 2
+        assert await hello(2) == 4
+        with pytest.raises(RateLimitExceeded):
+            await hello(3)
+
+    asyncio.run(main())
+
+
+def test_decorator_preserves_metadata():
+    lim = TokenBucketLimiter(capacity=5, refill_rate=1, backend=InMemoryBackend())
+
+    @rate_limit(lim, key_fn=lambda: "k")
+    def original() -> str:
+        """A docstring."""
+        return "ok"
+
+    assert original.__name__ == "original"
+    assert original.__doc__ == "A docstring."
