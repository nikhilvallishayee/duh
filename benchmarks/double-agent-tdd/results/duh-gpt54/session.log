 tdd_parser.add_argument("--navigator-model", default="inherit",\n                            help="Model tier or literal model for the Navigator (default: inherit).")\n\n    batch_parser = subparsers.add_parser("batch", help="Process multiple prompts from a file")\n'}, {'file_path': '/Users/nomind/Code/Tengu/tengu-cockpit/benchmarks/double-agent-tdd/worktrees/duh-gpt54/duh/cli/main.py', 'old_string': '    if args.command == "batch":\n        from duh.cli.batch import run_batch\n        try:\n            return asyncio.run(run_batch(args))\n        except KeyboardInterrupt:\n            sys.stderr.write("\\nInterrupted.\\n")\n            return 130\n\n    if args.command == "review":\n', 'new_string': '    if args.command == "batch":\n        from duh.cli.batch import run_batch\n        try:\n            return asyncio.run(run_batch(args))\n        except KeyboardInterrupt:\n            sys.stderr.write("\\nInterrupted.\\n")\n            return 130\n\n    if args.command == "tdd":\n        from duh.tdd import run_tdd_command\n        try:\n            return asyncio.run(run_tdd_command(args))\n        except KeyboardInterrupt:\n            sys.stderr.write("\\nInterrupted.\\n")\n            return 130\n\n    if args.command == "review":\n'}, {'file_path': '/Users/nomind/Code/Tengu/tengu-cockpit/benchmarks/double-agent-tdd/worktrees/duh-gpt54/duh/cli/slash_commands.py', 'old_string': 'SLASH_COMMANDS: dict[str, str] = {\n    "/help": "Show available commands",\n', 'new_string': 'SLASH_COMMANDS: dict[str, str] = {\n    "/help": "Show available commands",\n    "/tdd": "Double-agent TDD is available via CLI: duh tdd <task> --test-command <cmd>",\n'}])
