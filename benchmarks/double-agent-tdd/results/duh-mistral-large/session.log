  [33m> Now let me update the post-compact module to handle TDD plan mode.[0m(file_path='duh/kernel/post_compact.py', old_string='def restore_plan_context(engine: Any) -> str:\n    """If plan mode is active, return the plan content as a context string.\n\n    Inspects the engine for a ``_plan_mode`` attribute (set by the REPL\n    or TUI when plan mode is in use).  If a plan is currently proposed\n    or executing, returns a formatted string with the plan description\n    and steps.\n    """\n    plan_mode = getattr(engine, "_plan_mode", None)\n    if plan_mode is None:\n        return ""\n    from duh.kernel.plan_mode import PlanState\n    state = getattr(plan_mode, "state", None)\n    if state not in (PlanState.PROPOSED, PlanState.EXECUTING):\n        return ""\n    description = getattr(plan_mode, "description", "") or ""\n    steps = getattr(plan_mode, "steps", []) or []\n    if not steps:\n        return ""\n    lines = [f"[Plan restoration] {description}", ""]\n    for step in steps:\n        marker = "[x]" if step.done else "[ ]"\n        lines.append(f"  {marker} {step.number}. {step.description}")\n    return "\\n".join(lines)')
