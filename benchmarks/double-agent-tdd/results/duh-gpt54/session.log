  [33m> Write[0m(file_path='/Users/nomind/Code/Tengu/tengu-cockpit/benchmarks/double-agent-tdd/worktrees/duh-gpt54/duh/tdd.py', content='from __future__ import annotations\n\nimport argparse\nimport asyncio\nimport os\nfrom dataclasses import dataclass, field\nfrom enum import Enum\nfrom typing import Awaitable, Callable\n\nfrom duh.agents import AgentResult, run_agent\nfrom duh.kernel.deps import Deps\n\n\nclass TDDPhase(str, Enum):\n    NAVIGATOR_SPEC = "navigator_spec"\n    DRIVER_RED = "driver_red"\n    DRIVER_GREEN = "driver_green"\n    NAVIGATOR_REFACTOR = "navigator_refactor"\n    DRIVER_REFACTOR = "driver_refactor"\n    NAVIGATOR_VALIDATE = "navigator_validate"\n\n\n@dataclass\nclass PhaseRecord:\n    phase: TDDPhase\n    actor: str\n    summary: str\n    test_exit_code: int | None = None\n    test_output: str = ""\n\n\n@dataclass\nclass TDDOutcome:\n    success: bool\n    status: str\n    phases: list[PhaseRecord] = field(default_factory=list)\n\n\nAgentRunner = Callable[..., Awaitable[AgentResult]]\nTestRunner = Callable[[str, str], Awaitable[tuple[int, str]]]\n\n\ndef _default_test_runner(command: str, cwd: str) -> Awaitable[tuple[int, str]]:\n    return _run_test_command(command, cwd)\n\n\nasync def _run_test_command(command: str, cwd: str) -> tuple[int, str]:\n    proc = await asyncio.create_subprocess_shell(\n        command,\n        cwd=cwd,\n        stdout=asyncio.subprocess.PIPE,\n        stderr=asyncio.subprocess.STDOUT,\n    )\n    stdout, _ = await proc.communicate()\n    return proc.returncode or 0, stdout.decode("utf-8", errors="replace")\n\n\nclass DoubleAgentTDDSession:\n    def __init__(\n        self,\n        *,\n        task: str,\n        test_command: str,\n        deps: Deps | None = None,\n        cwd: str = ".",\n        driver_agent_type: str = "coder",\n        navigator_agent_type: str = "reviewer",\n        driver_model: str = "inherit",\n        navigator_model: str = "inherit",\n        parent_model: str = "",\n        agent_runner: AgentRunner = run_agent,\n        test_runner: TestRunner = _default_test_runner,\n    ) -> None:\n        self.task = task\n        self.test_command = test_command\n        self.deps = deps\n        self.cwd = cwd\n        self.driver_agent_type = driver_agent_type\n        self.navigator_agent_type = navigator_agent_type\n        self.driver_model = driver_model\n        self.navigator_model = navigator_model\n        self.parent_model = parent_model\n        self.agent_runner = agent_runner\n        self.test_runner = test_runner\n        self._phases: list[PhaseRecord] = []\n\n    @property\n    def phases(self) -> list[PhaseRecord]:\n        return list(self._phases)\n\n    async def _run_navigator(self, phase: TDDPhase, prompt: str) -> AgentResult:\n        return await self.agent_runner(\n            prompt=prompt,\n            agent_type=self.navigator_agent_type,\n            model=self.navigator_model,\n            parent_model=self.parent_model,\n            deps=self.deps,\n            cwd=self.cwd,\n        )\n\n    async def _run_driver(self, phase: TDDPhase, prompt: str) -> AgentResult:\n        return await self.agent_runner(\n            prompt=prompt,\n            agent_type=self.driver_agent_type,\n            model=self.driver_model,\n            parent_model=self.parent_model,\n            deps=self.deps,\n            cwd=self.cwd,\n        )\n\n    def _record(\n        self,\n        phase: TDDPhase,\n        actor: str,\n        summary: str,\n        *,\n        test_exit_code: int | None = None,\n        test_output: str = "",\n    ) -> None:\n        self._phases.append(\n            PhaseRecord(\n                phase=phase,\n                actor=actor,\n                summary=summary,\n                test_exit_code=test_exit_code,\n                test_output=test_output,\n            )\n        )\n\n    async def run(self) -> TDDOutcome:\n        spec = await self._run_navigator(\n            TDDPhase.NAVIGATOR_SPEC,\n            (\n                "Draft a tight TDD test spec for this task. State the expected behavior, "\n                "the failure target, and what the RED test should prove.\\n\\n"\n                f"Task: {self.task}\\n"\n                f"Test command: {self.test_command}\\n"\n            ),\n        )\n        self._record(TDDPhase.NAVIGATOR_SPEC, "navigator", spec.result_text or spec.error)\n        if spec.is_error:\n            return TDDOutcome(False, "navigator_spec_error", self.phases)\n\n        red = await self._run_driver(\n            TDDPhase.DRIVER_RED,\n            (\n                "Write the failing test for this spec. Do only the RED step. "\n                "Do not make production code pass yet.\\n\\n"\n                f"Task: {self.task}\\n"\n                f"Navigator spec:\\n{spec.result_text}\\n"\n                f"Test command to verify RED: {self.test_command}\\n"\n            ),\n        )\n        red_code, red_output = await self.test_runner(self.test_command, self.cwd)\n        self._record(\n            TDDPhase.DRIVER_RED,\n            "driver",\n            red.result_text or red.error,\n            test_exit_code=red_code,\n            test_output=red_output,\n        )\n        if red.is_error:\n            return TDDOutcome(False, "driver_red_error", self.phases)\n        if red_code == 0:\n            revision = await self._run_navigator(\n                TDDPhase.NAVIGATOR_SPEC,\n                (\n                    "The RED test unexpectedly passed. Tighten the spec so the failure is distinct.\\n\\n"\n                    f"Original task: {self.task}\\n"\n                    f"Previous spec:\\n{spec.result_text}\\n"\n                    f"RED test output:\\n{red_output}\\n"\n                ),\n            )\n            self._record(TDDPhase.NAVIGATOR_SPEC, "navigator", revision.result_text or revision.error)\n            return TDDOutcome(False, "red_not_failing", self.phases)\n\n        green = await self._run_driver(\n            TDDPhase.DRIVER_GREEN,\n            (\n                "Make the RED test pass with the minimum production change. Do not refactor yet.\\n\\n"\n                f"Task: {self.task}\\n"\n                f"Navigator spec:\\n{spec.result_text}\\n"\n                f"RED failure output:\\n{red_output}\\n"\n                f"Test command to verify GREEN: {self.test_command}\\n"\n            ),\n        )\n        green_code, green_output = await self.test_runner(self.test_command, self.cwd)\n        self._record(\n            TDDPhase.DRIVER_GREEN,\n            "driver",\n            green.result_text or green.error,\n            test_exit_code=green_code,\n            test_output=green_output,\n        )\n        if green.is_error:\n            return TDDOutcome(False, "driver_green_error", self.phases)\n        if green_code != 0:\n            return TDDOutcome(False, "green_failed", self.phases)\n\n        refactor = await self._run_navigator(\n            TDDPhase.NAVIGATOR_REFACTOR,\n            (\n                "Tests are GREEN. Propose one behavior-preserving refactor to improve the code. "\n                "Be concrete about what the Driver should change.\\n\\n"\n                f"Task: {self.task}\\n"\n                f"Navigator spec:\\n{spec.result_text}\\n"\n                f"GREEN result:\\n{green.result_text}\\n"\n            ),\n        )\n        self._record(TDDPhase.NAVIGATOR_REFACTOR, "navigator", refactor.result_text or refactor.error)\n        if refactor.is_error:\n            return TDDOutcome(False, "navigator_refactor_error", self.phases)\n\n        driver_refactor = await self._run_driver(\n            TDDPhase.DRIVER_REFACTOR,\n            (\n                "Apply the Navigator\'s refactor now. Preserve behavior and keep tests green.\\n\\n"\n                f"Task: {self.task}\\n"\n                f"Refactor proposal:\\n{refactor.result_text}\\n"\n            ),\n        )\n        self._record(TDDPhase.DRIVER_REFACTOR, "driver", driver_refactor.result_text or driver_refactor.error)\n        if driver_refactor.is_error:\n            return TDDOutcome(False, "driver_refactor_error", self.phases)\n\n        validate_code, validate_output = await self.test_runner(self.test_command, self.cwd)\n        validation = await self._run_navigator(\n            TDDPhase.NAVIGATOR_VALIDATE,\n            (\n                "Validate that the refactor landed cleanly and that tests still pass. "\n                "Call out whether the refactor suggestion appears applied.\\n\\n"\n                f"Task: {self.task}\\n"\n                f"Refactor proposal:\\n{refactor.result_text}\\n"\n                f"Driver refactor result:\\n{driver_refactor.result_text}\\n"\n                f"Validation test exit code: {validate_code}\\n"\n                f"Validation test output:\\n{validate_output}\\n"\n            ),\n        )\n        self._record(\n            TDDPhase.NAVIGATOR_VALIDATE,\n            "navigator",\n            validation.result_text or validation.error,\n            test_exit_code=validate_code,\n            test_output=validate_output,\n        )\n        if validation.is_error:\n            return TDDOutcome(False, "navigator_validate_error", self.phases)\n        if validate_code != 0:\n            return TDDOutcome(False, "validation_failed", self.phases)\n        return TDDOutcome(True, "completed", self.phases)\n\n\ndef format_tdd_outcome(outcome: TDDOutcome) -> str:\n    lines = [f"Double-agent TDD: {outcome.status}"]\n    for record in outcome.phases:\n        lines.append(f"- {record.phase.value}: {record.actor}")\n        if record.summary:\n            lines.append(f"  {record.summary}")\n        if record.test_exit_code is not None:\n            lines.append(f"  test_exit_code={record.test_exit_code}")\n    return "\\n".join(lines)\n\n\nasync def run_tdd_command(args: argparse.Namespace) -> int:\n    session = DoubleAgentTDDSession(\n        task=args.task,\n        test_command=args.test_command,\n        deps=Deps(),\n        cwd=os.getcwd(),\n        driver_agent_type=args.driver_agent_type,\n        navigator_agent_type=args.navigator_agent_type,\n        driver_model=args.driver_model,\n        navigator_model=args.navigator_model,\n        parent_model=args.model or "",\n    )\n    outcome = await session.run()\n    print(format_tdd_outcome(outcome))\n    return 0 if outcome.success else 1\n')
