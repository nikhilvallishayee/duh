+class TestSlashAndCli:
+    def test_tdd_in_slash_commands(self):
+        from duh.cli.slash_commands import SLASH_COMMANDS, SlashDispatcher
+        assert "/tdd" in SLASH_COMMANDS
+        assert "/tdd" in SlashDispatcher._HANDLERS
+
+    def test_tdd_slash_returns_sentinel(self):
+        from duh.cli.slash_commands import SlashContext, SlashDispatcher
+        from unittest.mock import MagicMock
+        ctx = SlashContext(
+            engine=MagicMock(),
+            model="m",
+            deps=MagicMock(),
+        )
+        dispatcher = SlashDispatcher(ctx)
+        keep, model = dispatcher.dispatch("/tdd", "add widget endpoint")
+        assert keep is True
+        assert model.startswith("\x00tdd\x00")
+        assert "add widget endpoint" in model
+
+    def test_tdd_slash_bare_shows_usage(self, capsys):
+        from duh.cli.slash_commands import SlashContext, SlashDispatcher
+        from unittest.mock import MagicMock
+        ctx = SlashContext(
+            engine=MagicMock(), model="m", deps=MagicMock(),
+        )
+        dispatcher = SlashDispatcher(ctx)
+        keep, model = dispatcher.dispatch("/tdd", "")
+        assert keep is True
+        assert model == "m"
+        captured = capsys.readouterr()
+        assert "Usage" in captured.out
+
+    def test_tdd_subparser_registered(self):
+        from duh.cli.parser import build_parser
+        parser = build_parser()
+        # argparse does not expose subparsers easily; parse a known
+        # invocation and make sure it does not error out.
+        ns = parser.parse_args(["tdd", "my feature"])
+        assert ns.command == "tdd"
+        assert ns.feature == "my feature"
+        # Defaults from tdd subparser exist:
+        assert hasattr(ns, "test_cmd")
+        assert hasattr(ns, "driver_model")
+        assert hasattr(ns, "max_spec_revisions")
