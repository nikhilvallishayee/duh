@@ -0,0 +1,580 @@
+"""Tests for :mod:`duh.kernel.tdd_mode` — the double-agent TDD flow.
+
+Covers the six-phase contract defined in ADR-076:
+
+  1. Phase transitions happen in order; out-of-order calls raise.
+  2. The RED-phase gate surfaces the assertion failure distinctly from
+     GREEN (different event ``phase`` tag, different pass condition).
+  3. The Navigator's refactor suggestion is actually reproduced verbatim
+     in the prompt the Driver receives for REFACTOR_APPLY, and the apply
+     phase refuses to run if no refactor has been proposed.
+  4. A full end-to-end run completes against the deterministic stub
+     provider and advances to :attr:`TddState.DONE`.
+"""
+
+from __future__ import annotations
+
+import os
+from typing import Any, AsyncGenerator
+from unittest.mock import patch
+
+import pytest
+
+from duh.kernel.deps import Deps
+from duh.kernel.engine import Engine, EngineConfig
+from duh.kernel.messages import Message
+from duh.kernel.tdd_mode import (
+    DEFAULT_TEST_COMMAND,
+    GateResult,
+    REFACTOR_APPLY_PROMPT,
+    RED_PROMPT,
+    SPEC_PROMPT,
+    TddMode,
+    TddState,
+)
+
+
+# ---------------------------------------------------------------------------
+# Test doubles
+# ---------------------------------------------------------------------------
+
+
+def _scripted_model(responses: list[str]):
+    """Factory: build an async call_model that replies with the next
+    scripted response on each call.  Allows each Engine to produce a
+    different answer per phase.
+    """
+    iterator = iter(responses)
+
+    async def call_model(**kwargs) -> AsyncGenerator[dict[str, Any], None]:
+        try:
+            text = next(iterator)
+        except StopIteration:
+            text = ""
+        msg = Message(
+            role="assistant",
+            content=[{"type": "text", "text": text}],
+        )
+        yield {"type": "text_delta", "text": text}
+        yield {"type": "assistant", "message": msg}
+        yield {"type": "done", "stop_reason": "end_turn", "turns": 1}
+
+    return call_model
+
+
+def _make_engine(responses: list[str]) -> Engine:
+    """Build a minimal Engine backed by a scripted call_model.  Tools
+    are empty — the Driver/Navigator cannot actually touch the disk in
+    unit tests, which is exactly what we want.
+    """
+    deps = Deps(call_model=_scripted_model(responses))
+    return Engine(deps=deps, config=EngineConfig(model="test-model"))
+
+
+class FakeRunner:
+    """Pluggable test runner that returns scripted :class:`GateResult`
+    outcomes in order.  Every call also records the command + cwd it was
+    given so the tests can assert against them.
+    """
+
+    def __init__(self, results: list[GateResult]) -> None:
+        self._queue = list(results)
+        self.calls: list[tuple[list[str], str]] = []
+
+    def __call__(self, cmd: list[str], cwd: str) -> GateResult:
+        self.calls.append((list(cmd), cwd))
+        if not self._queue:
+            # Default to a passing test if the test forgot to queue one.
+            return GateResult(phase="", exit_code=0, stdout="", stderr="")
+        return self._queue.pop(0)
+
+
+def _collect(gen):
+    """Drain an async generator into a list."""
+
+    async def _run():
+        out: list[dict[str, Any]] = []
+        async for event in gen:
+            out.append(event)
+        return out
+
+    return _run()
+
+
+# ---------------------------------------------------------------------------
+# 1. Phase transitions in strict order
+# ---------------------------------------------------------------------------
+
+
+class TestPhaseOrdering:
+    """Each phase must be entered only from the immediately prior state."""
+
+    def test_initial_state_is_empty(self):
+        tdd = TddMode(
+            driver=_make_engine([""]),
+            navigator=_make_engine([""]),
+            test_runner=FakeRunner([]),
+        )
+        assert tdd.state == TddState.EMPTY
+        assert tdd.spec == ""
+        assert tdd.history == []
+
+    async def test_spec_advances_empty_to_spec(self):
+        tdd = TddMode(
+            driver=_make_engine([""]),
+            navigator=_make_engine(["spec: write a failing test for X"]),
+            test_runner=FakeRunner([]),
+        )
+        await _collect(tdd.draft_spec("feature X"))
+        assert tdd.state == TddState.SPEC
+        assert "failing test" in tdd.spec
+        assert tdd.description == "feature X"
+        assert len(tdd.history) == 1
+        assert tdd.history[0].phase == "SPEC"
+        assert tdd.history[0].actor == "navigator"
+
+    async def test_cannot_run_red_from_empty(self):
+        tdd = TddMode(
+            driver=_make_engine([""]),
+            navigator=_make_engine([""]),
+            test_runner=FakeRunner([]),
+        )
+        with pytest.raises(ValueError, match="expected SPEC"):
+            await _collect(tdd.red())
+
+    async def test_cannot_run_green_from_spec(self):
+        """GREEN requires the RED gate to have fired (failing test)."""
+        tdd = TddMode(
+            driver=_make_engine([""]),
+            navigator=_make_engine(["spec"]),
+            test_runner=FakeRunner([]),
+        )
+        await _collect(tdd.draft_spec("feature"))
+        with pytest.raises(ValueError, match="expected RED"):
+            await _collect(tdd.green())
+
+    async def test_cannot_propose_refactor_before_green(self):
+        tdd = TddMode(
+            driver=_make_engine(["wrote test"]),
+            navigator=_make_engine(["spec"]),
+            test_runner=FakeRunner(
+                [GateResult(phase="", exit_code=1, stdout="AssertionError", stderr="")],
+            ),
+        )
+        await _collect(tdd.draft_spec("feature"))
+        await _collect(tdd.red())
+        with pytest.raises(ValueError, match="expected GREEN"):
+            await _collect(tdd.propose_refactor())
+
+    async def test_cannot_apply_refactor_before_plan(self):
+        tdd = TddMode(
+            driver=_make_engine(["wrote test", "wrote code"]),
+            navigator=_make_engine(["spec"]),
+            test_runner=FakeRunner(
+                [
+                    GateResult(phase="", exit_code=1, stdout="AssertionError", stderr=""),
+                    GateResult(phase="", exit_code=0, stdout="1 passed", stderr=""),
+                ],
+            ),
+        )
+        await _collect(tdd.draft_spec("feature"))
+        await _collect(tdd.red())
+        await _collect(tdd.green())
+        with pytest.raises(ValueError, match="expected REFACTOR_PLAN"):
+            await _collect(tdd.refactor_apply())
+
+    async def test_apply_refuses_when_plan_is_empty(self):
+        """Edge case: if the Navigator returned an empty refactor, apply
+        must not proceed — we never send a Driver to "apply nothing.""" ""
+        tdd = TddMode(
+            driver=_make_engine(["wrote test", "wrote code"]),
+            navigator=_make_engine(["spec", "   "]),  # whitespace-only refactor
+            test_runner=FakeRunner(
+                [
+                    GateResult(phase="", exit_code=1, stdout="fail", stderr=""),
+                    GateResult(phase="", exit_code=0, stdout="pass", stderr=""),
+                ],
+            ),
+        )
+        await _collect(tdd.draft_spec("feature"))
+        await _collect(tdd.red())
+        await _collect(tdd.green())
+        await _collect(tdd.propose_refactor())
+        assert tdd.refactor_plan == ""  # whitespace stripped
+        with pytest.raises(ValueError, match="refactor_plan is empty"):
+            await _collect(tdd.refactor_apply())
+
+    async def test_phase_events_fire_in_order(self):
+        """Every phase emits a ``tdd_phase`` event before yielding model
+        events — renderers depend on this ordering.
+        """
+        runner = FakeRunner(
+            [
+                GateResult(phase="", exit_code=1, stdout="fail", stderr=""),  # RED
+                GateResult(phase="", exit_code=0, stdout="pass", stderr=""),  # GREEN
+                GateResult(phase="", exit_code=0, stdout="pass", stderr=""),  # VALIDATE
+            ],
+        )
+        tdd = TddMode(
+            driver=_make_engine(["wrote test", "wrote code", "applied refactor"]),
+            navigator=_make_engine(["spec body", "refactor: rename foo→bar", "approved"]),
+            test_runner=runner,
+        )
+
+        phase_events: list[tuple[str, str]] = []
+        async for event in tdd.run_all("feature"):
+            if event.get("type") == "tdd_phase":
+                phase_events.append((event["phase"], event["actor"]))
+
+        assert phase_events == [
+            ("SPEC", "navigator"),
+            ("RED", "driver"),
+            ("GREEN", "driver"),
+            ("REFACTOR_PLAN", "navigator"),
+            ("REFACTOR_APPLY", "driver"),
+            ("VALIDATE", "navigator"),
+        ]
+        assert tdd.state == TddState.DONE
+
