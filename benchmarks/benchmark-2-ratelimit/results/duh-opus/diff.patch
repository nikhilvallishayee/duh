index 0000000..9584b5e
--- /dev/null
+++ b/tests/test_adversarial.py
@@ -0,0 +1,165 @@
+"""Tests for the stated adversarial surface.
+
+- clock skew (caller's clock going backwards)
+- capacity=1 edge
+- per-key isolation
+- decorator re-entry
+"""
+
+import threading
+
+from ratelimit import (
+    InMemoryBackend,
+    SlidingWindowLimiter,
+    TokenBucketLimiter,
+    rate_limit,
+)
+
+
+def test_clock_skew_backward_does_not_grant_free_tokens():
+    """If the clock moves backwards between two calls, the limiter
+    must not hand out free tokens.  We simulate a caller whose clock
+    first reads 100.0 then 90.0."""
+    clock = [100.0]
+
+    def fake_clock():
+        return clock[0]
+
+    backend = InMemoryBackend(clock=fake_clock)
+    lim = TokenBucketLimiter(capacity=3, refill_per_sec=1, backend=backend)
+    for _ in range(3):
+        assert lim.enforce("k").allowed
+    assert not lim.enforce("k").allowed
+
+    # clock jumps backwards
+    clock[0] = 90.0
+    # must still be rejected — the clamp must set elapsed=0 and
+    # refill must not happen.
+    assert not lim.enforce("k").allowed
+    assert not lim.enforce("k").allowed
+
+
+def test_clock_skew_backward_sliding_window():
+    clock = [1000.0]
+
+    def fake_clock():
+        return clock[0]
+
+    backend = InMemoryBackend(clock=fake_clock)
+    lim = SlidingWindowLimiter(capacity=2, period_ms=1000, backend=backend)
+    assert lim.enforce("k").allowed
+    assert lim.enforce("k").allowed
+    assert not lim.enforce("k").allowed
+
+    # clock jumps back; still rejected (no phantom window advance)
+    clock[0] = 500.0
+    assert not lim.enforce("k").allowed
+
+
+def test_capacity_one_many_threads():
+    """Race 100 threads on a capacity=1 bucket — exactly one wins."""
+    lim = TokenBucketLimiter(capacity=1, refill_per_sec=0.0001)
+    hits = [0]
+    lock = threading.Lock()
+    start = threading.Event()
+
+    def worker():
+        start.wait()
+        if lim.enforce("solo").allowed:
+            with lock:
+                hits[0] += 1
+
+    threads = [threading.Thread(target=worker) for _ in range(100)]
+    for t in threads:
+        t.start()
+    start.set()
+    for t in threads:
+        t.join()
+
+    assert hits[0] == 1
+
+
+def test_chaos_drops_via_sporadic_failures():
+    """Backend intermittently raises. fail_open=True must keep the
+    app alive; fail_open=False must reject in a bounded way."""
+    from ratelimit import RedisBackend
+
+    class FlakyClient:
+        def __init__(self):
+            self.n = 0
+
+        def register_script(self, src):
+            outer = self
+
+            class _S:
+                def __call__(self, *, keys, args):
+                    outer.n += 1
+                    if outer.n % 2 == 0:
+                        raise ConnectionError("chaos")
+                    # Succeed: pretend the bucket is fine.
+                    return [1, 5, 0, 0]
+
+            return _S()
+
+    backend_open = RedisBackend(FlakyClient(), fail_open=True)
+    lim = TokenBucketLimiter(capacity=10, refill_per_sec=1, backend=backend_open)
+    # Every call must produce an allowed decision.
+    for _ in range(20):
+        d = lim.enforce("k")
+        assert d.allowed  # fail_open keeps traffic flowing
+
+    backend_closed = RedisBackend(FlakyClient(), fail_open=False)
+    lim2 = TokenBucketLimiter(capacity=10, refill_per_sec=1, backend=backend_closed)
+    rejections = 0
+    for _ in range(20):
+        d = lim2.enforce("k")
+        if not d.allowed:
+            rejections += 1
+    # About half of the calls must be rejected (the failure path).
+    assert 5 <= rejections <= 15
+
+
+def test_decorator_reentry_deep():
+    """Deep recursion with reentrant=True charges exactly once."""
+    lim = TokenBucketLimiter(capacity=1, refill_per_sec=0.0001)
+
+    @rate_limit(lim, key_fn=lambda depth: "deep", reentrant=True)
+    def go(depth: int) -> int:
+        if depth == 0:
+            return 0
+        return go(depth - 1)
+
+    # One top-level call consumes the single token; recursion
+    # (50 deep) does not exhaust anything.
+    assert go(50) == 0
+    # Second top-level call rejected (no more tokens).
+    import pytest
+
+    from ratelimit import RateLimitExceeded
+
+    with pytest.raises(RateLimitExceeded):
+        go(0)
+
+
+def test_decorator_reentry_across_distinct_keys_still_charges():
+    """Reentry detection is per-key: a nested call with a *different*
+    key must still consume a token from its own bucket."""
+    lim = TokenBucketLimiter(capacity=1, refill_per_sec=0.0001)
+
+    @rate_limit(lim, key_fn=lambda key: key, reentrant=True)
+    def f(key: str) -> str:
+        if key == "outer":
+            return f("inner")
+        return key
+
+    # Each key has its own bucket of capacity 1.  The nested call uses
+    # key "inner" so it must charge that bucket independently.
+    assert f("outer") == "inner"
+    # Both "outer" and "inner" now exhausted.
+    from ratelimit import RateLimitExceeded
+    import pytest
+
+    with pytest.raises(RateLimitExceeded):
+        f("outer")  # outer bucket empty
+    with pytest.raises(RateLimitExceeded):
+        f("inner")  # inner bucket empty
