@@ -0,0 +1,34 @@
+import time
+from abc import ABC, abstractmethod
+from typing import Optional
+
+from ratelimit.models import Decision
+from ratelimit.backends import Backend
+
+class RateLimiter(ABC):
+    def __init__(self, backend: Backend):
+        self.backend = backend
+
+    @abstractmethod
+    def enforce(self, key: str, cost: int = 1) -> Decision:
+        pass
+
+class TokenBucketLimiter(RateLimiter):
+    def __init__(self, backend: Backend, capacity: int, refill_rate: float):
+        super().__init__(backend)
+        self.capacity = capacity
+        self.refill_rate = refill_rate
+
+    def enforce(self, key: str, cost: int = 1) -> Decision:
+        now_ms = int(time.time() * 1000)
+        return self.backend.eval_token_bucket(key, self.capacity, self.refill_rate, cost, now_ms)
+
+class SlidingWindowLimiter(RateLimiter):
+    def __init__(self, backend: Backend, capacity: int, window_ms: int):
+        super().__init__(backend)
+        self.capacity = capacity
+        self.window_ms = window_ms
+
+    def enforce(self, key: str, cost: int = 1) -> Decision:
+        now_ms = int(time.time() * 1000)
+        return self.backend.eval_sliding_window(key, self.capacity, self.window_ms, cost, now_ms)
