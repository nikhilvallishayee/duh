import asyncio
import os
from pathlib import Path
import tempfile

from duh.agents import AgentResult
from duh.cli.parser import build_parser
from duh.cli.session_builder import SessionBuilder, SessionBuilderOptions
from duh.kernel.tool import ToolContext
from duh.tdd import run_double_agent_tdd


def options():
    return SessionBuilderOptions(
        include_skills_in_tools=False,
        include_deferred_tools=False,
        include_memory_prompt=False,
        include_env_block=False,
        include_templates_hint=False,
        include_model_context_block=False,
        honour_tool_filters=True,
        approver_mode='print_mode',
        wire_hook_registry_in_deps=False,
        wire_audit_logger_in_deps=False,
        honour_tool_choice=True,
        honour_thinking=True,
        allow_session_id_override=True,
        log_skip_perms_warning=False,
        default_system_prompt='system',
        brief_instruction='brief',
    )

def find_tool(tools, name):
    for tool in tools:
        if getattr(tool, 'name', '') == name:
            return tool
    raise RuntimeError(name)

async def main():
    with tempfile.TemporaryDirectory() as tmpdir:
        tmp = Path(tmpdir)
        (tmp / 'calc.py').write_text('def add(a, b):\\n    return a - b\\n', encoding='utf-8')
        os.environ['DUH_STUB_PROVIDER'] = '1'
        try:
            parser = build_parser()
            args = parser.parse_args([
                'tdd', 'fix add()', '--test-command', '/opt/homebrew/bin/python3.12 -m unittest -q test_calc.py'
            ])
            args.dangerously_skip_permissions = True
            builder = SessionBuilder(args, options(), cwd=str(tmp), debug=False)
            build = await builder.build()
            async def fake_run_agent(**kwargs):
                prompt = kwargs['prompt']
                tools = kwargs['tools']
                write_tool = find_tool(tools, 'Write')
                async def write(path, content):
                    result = await write_tool.call({'file_path': str(path), 'content': content}, ToolContext(cwd=str(tmp)))
                    assert not result.is_error, result.output
                if 'Draft a tight executable test spec' in prompt:
                    return AgentResult(agent_type='reviewer', result_text='Add a unit test for add(1, 2) == 3')
                if 'Implement only the failing test' in prompt:
                    await write(tmp / 'test_calc.py', 'import unittest\\nfrom calc import add\\n\\nclass CalcTests(unittest.TestCase):\\n    def test_add(self):\\n        self.assertEqual(add(1, 2), 3)\\n\\nif __name__ == \"__main__\":\\n    unittest.main()\\n')
                    return AgentResult(agent_type='coder', result_text='Wrote failing test')
                if 'Write the minimum production change' in prompt:
                    await write(tmp / 'calc.py', 'def add(a, b):\\n    return a + b\\n')
                    return AgentResult(agent_type='coder', result_text='Applied GREEN fix')
                if 'Review the just-passing implementation' in prompt:
                    return AgentResult(agent_type='reviewer', result_text='Introduce a named local before returning.')
                if \"Apply the Navigator's refactor\" in prompt:
                    await write(tmp / 'calc.py', 'def add(a, b):\\n    total = a + b\\n    return total\\n')
                    return AgentResult(agent_type='coder', result_text='Applied refactor')
                if 'final validation' in prompt:
                    return AgentResult(agent_type='reviewer', result_text='Validated')
                raise AssertionError(prompt)
            result = await run_double_agent_tdd(
                task='fix add()',
                test_command='/opt/homebrew/bin/python3.12 -m unittest -q test_calc.py',
                deps=build.deps,
                tools=build.tools,
                cwd=str(tmp),
                parent_model=build.model,
                run_agent_fn=fake_run_agent,
            )
            assert result.success is True
            assert result.red_phase.test_result.passed is False
            assert result.validation_phase.test_result.passed is True
            assert 'total = a + b' in (tmp / 'calc.py').read_text(encoding='utf-8')
            print('integration-smoke-ok')
        finally:
            os.environ.pop('DUH_STUB_PROVIDER', None)
            try:
                build.close_structured_logger()
                await build.teardown_mcp()
            except Exception:
                pass

asyncio.run(main())
