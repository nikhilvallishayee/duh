--- /dev/null
+++ b/tests/unit/test_tdd.py
@@ -0,0 +1,249 @@
+from __future__ import annotations
+
+import argparse
+
+import pytest
+
+from duh.agents import AgentResult
+from duh.tdd import DoubleAgentTDDSession, TDDPhase, format_tdd_outcome, run_tdd_command
+
+
+class AgentSequence:
+    def __init__(self, results):
+        self.results = list(results)
+        self.calls = []
+
+    async def __call__(self, **kwargs):
+        self.calls.append(kwargs)
+        return self.results.pop(0)
+
+
+class TestSequence:
+    def __init__(self, results):
+        self.results = list(results)
+        self.calls = []
+
+    async def __call__(self, command: str, cwd: str):
+        self.calls.append((command, cwd))
+        return self.results.pop(0)
+
+
+def _ok(text: str) -> AgentResult:
+    return AgentResult(agent_type="general", result_text=text)
+
+
+@pytest.mark.asyncio
+async def test_phase_transitions_happen_in_strict_order():
+    agents = AgentSequence([
+        _ok("spec"),
+        _ok("red"),
+        _ok("green"),
+        _ok("refactor suggestion"),
+        _ok("refactor applied"),
+        _ok("validated"),
+    ])
+    tests = TestSequence([
+        (1, "AssertionError: expected fail"),
+        (0, "1 passed"),
+        (0, "1 passed"),
+    ])
+    session = DoubleAgentTDDSession(
+        task="add feature",
+        test_command="pytest -q",
+        agent_runner=agents,
+        test_runner=tests,
+    )
+
+    outcome = await session.run()
+
+    assert outcome.success is True
+    assert [record.phase for record in outcome.phases] == [
+        TDDPhase.NAVIGATOR_SPEC,
+        TDDPhase.DRIVER_RED,
+        TDDPhase.DRIVER_GREEN,
+        TDDPhase.NAVIGATOR_REFACTOR,
+        TDDPhase.DRIVER_REFACTOR,
+        TDDPhase.NAVIGATOR_VALIDATE,
+    ]
+
+
+@pytest.mark.asyncio
+async def test_red_phase_surfaces_assertion_failure_distinctly_from_green():
+    agents = AgentSequence([
+        _ok("spec"),
+        _ok("red"),
+        _ok("green"),
+        _ok("refactor suggestion"),
+        _ok("refactor applied"),
+        _ok("validated"),
+    ])
+    tests = TestSequence([
+        (1, "AssertionError: expected 2 == 3"),
+        (0, "1 passed in 0.02s"),
+        (0, "1 passed in 0.02s"),
+    ])
+    session = DoubleAgentTDDSession(
+        task="fix bug",
+        test_command="pytest tests/unit/test_bug.py -q",
+        agent_runner=agents,
+        test_runner=tests,
+    )
+
+    outcome = await session.run()
+
+    red_record = outcome.phases[1]
+    green_record = outcome.phases[2]
+    assert red_record.phase is TDDPhase.DRIVER_RED
+    assert red_record.test_exit_code == 1
+    assert "AssertionError" in red_record.test_output
+    assert green_record.phase is TDDPhase.DRIVER_GREEN
+    assert green_record.test_exit_code == 0
+    assert "passed" in green_record.test_output
+
+
+@pytest.mark.asyncio
+async def test_navigator_refactor_suggestion_is_applied_before_validation():
+    agents = AgentSequence([
+        _ok("spec"),
+        _ok("red"),
+        _ok("green"),
+        _ok("Extract helper named normalize_user_id"),
+        _ok("Applied normalize_user_id helper refactor"),
+        _ok("Validation: normalize_user_id refactor is present and tests pass"),
+    ])
+    tests = TestSequence([
+        (1, "AssertionError"),
+        (0, "1 passed"),
+        (0, "1 passed"),
+    ])
+    session = DoubleAgentTDDSession(
+        task="normalize ids",
+        test_command="pytest -q",
+        agent_runner=agents,
+        test_runner=tests,
+    )
+
+    outcome = await session.run()
+
+    validate_prompt = agents.calls[-1]["prompt"]
+    assert "Extract helper named normalize_user_id" in validate_prompt
+    assert "Applied normalize_user_id helper refactor" in validate_prompt
+    assert outcome.phases[4].phase is TDDPhase.DRIVER_REFACTOR
+    assert outcome.phases[5].phase is TDDPhase.NAVIGATOR_VALIDATE
+
+
+@pytest.mark.asyncio
+async def test_red_not_failing_triggers_navigator_revision():
+    agents = AgentSequence([
+        _ok("spec"),
+        _ok("red"),
+        _ok("revised spec"),
+    ])
+    tests = TestSequence([
+        (0, "1 passed unexpectedly"),
+    ])
+    session = DoubleAgentTDDSession(
+        task="tighten spec",
+        test_command="pytest -q",
+        agent_runner=agents,
+        test_runner=tests,
+    )
+
+    outcome = await session.run()
+
+    assert outcome.success is False
+    assert outcome.status == "red_not_failing"
+    assert [record.phase for record in outcome.phases] == [
+        TDDPhase.NAVIGATOR_SPEC,
+        TDDPhase.DRIVER_RED,
+        TDDPhase.NAVIGATOR_SPEC,
+    ]
+
+
+@pytest.mark.asyncio
+async def test_full_flow_completes_end_to_end_against_stub_provider():
+    calls = []
+
+    async def fake_agent_runner(**kwargs):
+        calls.append(kwargs)
+        prompt = kwargs["prompt"]
+        if "Draft a tight TDD test spec" in prompt:
+            return _ok("Spec: add a focused failing test")
+        if "Write the failing test" in prompt:
+            return _ok("Driver wrote failing test")
+        if "Make the RED test pass" in prompt:
+            return _ok("Driver made minimal code change")
+        if "Propose one behavior-preserving refactor" in prompt:
+            return _ok("Refactor: extract small helper")
+        if "Apply the Navigator's refactor" in prompt:
+            return _ok("Driver applied helper extraction")
+        return _ok("Navigator validated final state")
+
+    tests = TestSequence([
+        (1, "AssertionError: failing test"),
+        (0, "1 passed"),
+        (0, "1 passed"),
+    ])
+    session = DoubleAgentTDDSession(
+        task="implement helper",
+        test_command="pytest tests/unit/test_helper.py -q",
+        parent_model="stub-model",
+        agent_runner=fake_agent_runner,
+        test_runner=tests,
+    )
+
+    outcome = await session.run()
+
+    assert outcome.success is True
+    assert outcome.status == "completed"
+    assert len(calls) == 6
+    assert all(call["parent_model"] == "stub-model" for call in calls)
+    assert tests.calls == [
+        ("pytest tests/unit/test_helper.py -q", "."),
+        ("pytest tests/unit/test_helper.py -q", "."),
+        ("pytest tests/unit/test_helper.py -q", "."),
+    ]
+
+
+def test_format_tdd_outcome_includes_phase_status():
+    from duh.tdd import PhaseRecord, TDDOutcome
+
+    outcome = TDDOutcome(
+        success=True,
+        status="completed",
+        phases=[PhaseRecord(phase=TDDPhase.NAVIGATOR_SPEC, actor="navigator", summary="spec")],
+    )
+
+    text = format_tdd_outcome(outcome)
+
+    assert "Double-agent TDD: completed" in text
+    assert "navigator_spec" in text
+
+
+@pytest.mark.asyncio
+async def test_run_tdd_command_returns_zero_on_success(monkeypatch, capsys):
+    class FakeSession:
+        def __init__(self, **kwargs):
+            self.kwargs = kwargs
+
+        async def run(self):
+            from duh.tdd import PhaseRecord, TDDOutcome
+            return TDDOutcome(True, "completed", [
+                PhaseRecord(phase=TDDPhase.NAVIGATOR_SPEC, actor="navigator", summary="spec")
+            ])
+
+    monkeypatch.setattr("duh.tdd.DoubleAgentTDDSession", FakeSession)
+    args = argparse.Namespace(
+        task="do work",
+        test_command="pytest -q",
+        driver_agent_type="coder",
+        navigator_agent_type="reviewer",
+        driver_model="inherit",
+        navigator_model="inherit",
+        model="stub-model",
+    )
+
+    code = await run_tdd_command(args)
+
+    assert code == 0
+    assert "Double-agent TDD: completed" in capsys.readouterr().out
