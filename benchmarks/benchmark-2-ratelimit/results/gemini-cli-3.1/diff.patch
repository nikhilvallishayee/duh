@@ -0,0 +1,60 @@
+import pytest
+from starlette.testclient import TestClient
+from starlette.applications import Starlette
+from starlette.responses import JSONResponse
+from starlette.routing import Route
+
+from ratelimit.backends import InMemoryBackend
+from ratelimit.limiters import TokenBucketLimiter
+from ratelimit.middleware import RateLimitMiddleware
+
+def test_middleware():
+    backend = InMemoryBackend()
+    limiter = TokenBucketLimiter(backend, capacity=2, refill_rate=1.0) # very slow refill
+    
+    async def homepage(request):
+        return JSONResponse({"hello": "world"})
+    
+    app = Starlette(routes=[Route("/", homepage)])
+    app.add_middleware(RateLimitMiddleware, limiter=limiter, cost=1)
+    
+    client = TestClient(app)
+    
+    # First request
+    resp = client.get("/")
+    assert resp.status_code == 200
+    assert resp.headers["x-ratelimit-remaining"] == "1"
+    assert resp.headers["x-ratelimit-limit"] == "2"
+    
+    # Second request
+    resp = client.get("/")
+    assert resp.status_code == 200
+    assert resp.headers["x-ratelimit-remaining"] == "0"
+    
+    # Third request, should be limited
+    resp = client.get("/")
+    assert resp.status_code == 429
+    assert resp.headers["x-ratelimit-limit"] == "2"
+    assert "retry-after" in resp.headers
+    assert int(resp.headers["retry-after"]) > 0
+
+def test_middleware_backend_failure_degradation():
+    class FailingBackend:
+        def eval_token_bucket(self, *args, **kwargs):
+            raise Exception("Redis down")
+            
+    limiter = TokenBucketLimiter(FailingBackend(), capacity=2, refill_rate=1.0)
+    
+    async def homepage(request):
+        return JSONResponse({"hello": "world"})
+        
+    app = Starlette(routes=[Route("/", homepage)])
+    app.add_middleware(RateLimitMiddleware, limiter=limiter, cost=1)
+    
+    client = TestClient(app)
+    
+    # Should allow traffic on failure
+    resp = client.get("/")
+    assert resp.status_code == 200
+    # The default degradation decision has remaining -1
+    assert resp.headers["x-ratelimit-remaining"] == "-1"
