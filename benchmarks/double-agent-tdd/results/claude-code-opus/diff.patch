@@ -0,0 +1,901 @@
+"""Double-agent TDD flow — driver/navigator pair-programming over
+red-green-refactor. See ADR-076 for the full rationale.
+
+Two cooperating subagents march through a strict six-phase sequence:
+
+    1. NAVIGATOR_SPEC       Navigator drafts the test spec.
+    2. DRIVER_RED           Driver writes the failing test; tests MUST
+                            fail. If they pass, Navigator revises.
+    3. DRIVER_GREEN         Driver writes the minimum code; tests pass.
+    4. NAVIGATOR_REFACTOR   Navigator proposes a refactor.
+    5. DRIVER_REFACTOR      Driver applies the refactor.
+    6. NAVIGATOR_VALIDATE   Navigator confirms tests still pass and the
+                            refactor actually landed.
+
+Each phase produces a ``TDDArtifact`` recorded in the flow's history.
+Phase transitions are enforced — calling out of order raises
+``TDDError``. See ``duh/kernel/plan_mode.py`` for the same pattern at
+two phases.
+
+Entry points:
+
+* ``TDDFlow(...)`` — the state machine itself.
+* ``run_flow(feature, ...)`` — convenience driver that runs the flow
+  end-to-end and yields phase events.
+* ``duh tdd "<feature>"`` — CLI subcommand (see ``duh/cli/tdd.py``).
+* ``/tdd <feature>`` — REPL slash command.
+"""
+
+from __future__ import annotations
+
+import asyncio
+import logging
+import os
+import re
+import shlex
+from dataclasses import dataclass, field
+from enum import Enum
+from typing import Any, AsyncGenerator, Awaitable, Callable
+
+from duh.agents import AgentResult, run_agent
+
+logger = logging.getLogger(__name__)
+
+
+# ---------------------------------------------------------------------------
+# Phase / role enums and data types
+# ---------------------------------------------------------------------------
+
+
+class TDDPhase(str, Enum):
+    """The six phases of the double-agent TDD flow.
+
+    Values are stable strings so they survive JSON serialization (used by
+    the ``tdd_phase`` events emitted by ``run_flow``).
+    """
+
+    IDLE = "idle"
+    NAVIGATOR_SPEC = "navigator_spec"
+    DRIVER_RED = "driver_red"
+    DRIVER_GREEN = "driver_green"
+    NAVIGATOR_REFACTOR = "navigator_refactor"
+    DRIVER_REFACTOR = "driver_refactor"
+    NAVIGATOR_VALIDATE = "navigator_validate"
+    DONE = "done"
+
+
+# Strict successor map — used to enforce phase order.
+_NEXT_PHASE: dict[TDDPhase, TDDPhase] = {
+    TDDPhase.IDLE: TDDPhase.NAVIGATOR_SPEC,
+    TDDPhase.NAVIGATOR_SPEC: TDDPhase.DRIVER_RED,
+    TDDPhase.DRIVER_RED: TDDPhase.DRIVER_GREEN,
+    TDDPhase.DRIVER_GREEN: TDDPhase.NAVIGATOR_REFACTOR,
+    TDDPhase.NAVIGATOR_REFACTOR: TDDPhase.DRIVER_REFACTOR,
+    TDDPhase.DRIVER_REFACTOR: TDDPhase.NAVIGATOR_VALIDATE,
+    TDDPhase.NAVIGATOR_VALIDATE: TDDPhase.DONE,
+}
+
+
+class Role(str, Enum):
+    DRIVER = "driver"
+    NAVIGATOR = "navigator"
+
+
+class TDDError(RuntimeError):
+    """Raised when a flow invariant is violated.
+
+    ``phase`` identifies the phase that failed. ``reason`` is a short
+    machine-readable tag; ``detail`` is the human-readable message.
+    """
+
+    def __init__(self, phase: TDDPhase, reason: str, detail: str = ""):
+        self.phase = phase
+        self.reason = reason
+        self.detail = detail
+        super().__init__(f"[{phase.value}:{reason}] {detail}".rstrip())
+
+
+@dataclass
+class TestRunResult:
+    """Outcome of running the project's test command between phases.
+
+    ``assertion_failure`` is the extracted assertion-style failure text;
+    when populated and ``passed=False``, we know the test actually ran
+    and asserted something false (as opposed to a syntax/collection
+    error). This is how ``DRIVER_RED`` is told apart from ``DRIVER_GREEN``
+    at the data level.
+    """
+
+    # Tell pytest not to collect this dataclass — the "Test" prefix is
+    # semantic, not a pytest marker. Without this, pytest emits a
+    # PytestCollectionWarning on every run.
+    __test__ = False
+
+    passed: bool
+    exit_code: int
+    output: str = ""
+    assertion_failure: str = ""
+
+    @property
+    def has_assertion_failure(self) -> bool:
+        return bool(self.assertion_failure.strip())
+
+
+@dataclass
+class TDDArtifact:
+    """One step's worth of output — persisted to ``TDDFlow.history``."""
+
+    phase: TDDPhase
+    role: Role | None  # None for pure test-runner phases (none at the moment)
+    prompt: str
+    output: str
+    test_run: TestRunResult | None = None
+    error: str = ""
+
+
+@dataclass
+class TDDConfig:
+    """Configuration for a flow run."""
+
+    # Working directory for subagents and the test runner.
+    cwd: str = "."
+
+    # Shell command used to execute the project's test suite.
+    test_cmd: str = "python -m pytest -x -q"
+
+    # Model tier aliases passed to ``run_agent`` for each role. These
+    # resolve per-provider at call time via the registry — see ADR-063.
+    driver_model: str = "inherit"
+    navigator_model: str = "inherit"
+
+    # Maximum agentic turns per subagent invocation.
+    max_turns: int = 30
+
+    # Per-phase timeout for the test runner (seconds).
+    test_timeout: float = 120.0
+
+    # Maximum number of times Navigator is allowed to revise the spec
+    # after a RED-phase failure (i.e. the test unexpectedly passed).
+    max_spec_revisions: int = 2
+
+
+# ---------------------------------------------------------------------------
+# Prompt templates (exported so tests and docs can inspect them)
+# ---------------------------------------------------------------------------
+
+SPEC_PROMPT = (
+    "You are the NAVIGATOR in a double-agent TDD flow. Draft a tight, "
+    "falsifiable test specification for the following feature. Output a "
+    "numbered list (1., 2., 3., ...) of observable behaviors the "
+    "implementation must satisfy. Each bullet must describe an input, "
+    "the expected output/effect, and at least one concrete assertion the "
+    "test should make. Do NOT write code yet.\n\n"
+    "Feature: "
+)
+
+SPEC_REVISION_PROMPT = (
+    "You are the NAVIGATOR. The Driver wrote a test against your previous "
+    "spec and ran it — it PASSED immediately, which means the spec was "
+    "not tight enough to force an implementation change. Tighten the "
+    "spec so any naive stub would fail the first assertion.\n\n"
+    "Previous spec:\n{spec}\n\n"
+    "Feature: {feature}\n"
+)
+
+RED_PROMPT = (
+    "You are the DRIVER in a double-agent TDD flow. Write exactly one "
+    "new failing test that exercises the following specification. Use "
+    "the project's existing test framework. Do NOT write the "
+    "implementation — the test MUST fail when run. Output the test code "
+    "and the path you wrote it to.\n\n"
+    "Specification:\n{spec}\n"
+)
+
+GREEN_PROMPT = (
+    "You are the DRIVER. Your failing test (below) must now pass. Write "
+    "the MINIMUM production code that makes the test pass. Do not "
+    "generalize beyond what this test demands. Do not modify the test.\n"
+    "\n"
+    "Failing test:\n{test_code}\n\n"
+    "Red-phase assertion failure:\n{assertion}\n"
+)
+
+REFACTOR_SUGGEST_PROMPT = (
+    "You are the NAVIGATOR. The implementation now passes the test. "
+    "Propose ONE concrete refactor that improves clarity or reduces "
+    "duplication, without changing behavior. State: (a) the target file, "
+    "(b) the change in 1–3 sentences, (c) why it is safe under the "
+    "current tests. Output in that exact structure. Do NOT apply the "
+    "refactor yourself.\n\n"
+    "Implementation summary from driver:\n{impl}\n"
+)
+
+REFACTOR_APPLY_PROMPT = (
+    "You are the DRIVER. Apply the Navigator's refactor suggestion "
+    "exactly. Do not add unrelated changes. Tests MUST still pass "
+    "afterwards.\n\n"
+    "Refactor suggestion:\n{suggestion}\n"
+)
+
+VALIDATE_PROMPT = (
+    "You are the NAVIGATOR. Confirm that (a) all tests still pass and "
+    "(b) the refactor described below was actually applied to the "
+    "codebase. Output a short PASS/FAIL verdict with one supporting "
+    "sentence.\n\n"
+    "Refactor suggestion:\n{suggestion}\n\n"
+    "Test output:\n{test_output}\n"
+)
+
+
+# ---------------------------------------------------------------------------
+# Test runner — subprocess default + injection hook
+# ---------------------------------------------------------------------------
+
+
+TestRunnerFn = Callable[[str, str, float], Awaitable[TestRunResult]]
+
+
+_ASSERTION_PATTERNS = (
+    re.compile(r"^E\s+(assert .+)$", re.MULTILINE),
+    re.compile(r"^E\s+AssertionError:?\s*(.*)$", re.MULTILINE),
+    re.compile(r"^(FAILED .+)$", re.MULTILINE),
+)
+
+
+def _extract_assertion_failure(output: str) -> str:
+    """Best-effort extraction of the assertion-failure summary.
+
+    Used to distinguish a real RED-phase failure (``passed=False`` *and*
+    a matched assertion line) from a spurious failure (syntax error,
+    import error). When none of the patterns match, the empty string is
+    returned — the flow will then treat the failure as non-assertion and
+    surface it verbatim.
+    """
+    for pat in _ASSERTION_PATTERNS:
+        match = pat.search(output)
+        if match:
+            return match.group(1).strip() if match.groups() else match.group(0).strip()
+    return ""
+
+
+async def default_test_runner(
+    cmd: str, cwd: str, timeout: float,
+) -> TestRunResult:
+    """Run *cmd* as a subprocess in *cwd*; return a ``TestRunResult``.
+
+    ``timeout`` bounds the subprocess. On timeout we return a failure
+    result so the flow surfaces the problem instead of hanging.
+    """
+    try:
+        proc = await asyncio.create_subprocess_shell(
+            cmd,
+            cwd=cwd,
+            stdout=asyncio.subprocess.PIPE,
+            stderr=asyncio.subprocess.STDOUT,
+        )
+        try:
+            stdout, _ = await asyncio.wait_for(proc.communicate(), timeout=timeout)
+        except asyncio.TimeoutError:
+            proc.kill()
+            await proc.wait()
+            return TestRunResult(
+                passed=False,
+                exit_code=-1,
+                output=f"[test runner timed out after {timeout:.0f}s]",
+                assertion_failure="",
+            )
+        output = (stdout or b"").decode("utf-8", errors="replace")
+        exit_code = proc.returncode if proc.returncode is not None else -1
+        passed = exit_code == 0
+        return TestRunResult(
+            passed=passed,
+            exit_code=exit_code,
+            output=output,
+            assertion_failure="" if passed else _extract_assertion_failure(output),
+        )
+    except FileNotFoundError as exc:
+        return TestRunResult(
+            passed=False,
+            exit_code=-1,
+            output=f"[test runner not found: {exc}]",
+            assertion_failure="",
+        )
+
+
+# ---------------------------------------------------------------------------
+# Agent runner — small indirection so tests can stub without monkeypatching
+# ---------------------------------------------------------------------------
+
+
+AgentRunnerFn = Callable[..., Awaitable[AgentResult]]
+
+
+async def _default_agent_runner(
+    *,
+    prompt: str,
+    agent_type: str,
+    model: str,
+    parent_model: str,
+    deps: Any,
+    tools: list[Any] | None,
+    cwd: str,
+    max_turns: int,
+) -> AgentResult:
+    return await run_agent(
+        prompt=prompt,
+        agent_type=agent_type,
+        model=model,
+        parent_model=parent_model,
+        deps=deps,
+        tools=tools or [],
+        cwd=cwd,
+        max_turns=max_turns,
+    )
+
+
+# ---------------------------------------------------------------------------
+# The flow itself
+# ---------------------------------------------------------------------------
+
+
+class TDDFlow:
+    """State machine that orchestrates the six-phase TDD sequence.
+
+    Construction:
+        flow = TDDFlow(
+            feature="add a widget-sum endpoint",
+            deps=deps,
+            tools=my_tools,
+            parent_model="claude-sonnet-4-6",
+            config=TDDConfig(cwd="."),
+        )
+
+    Advance one phase at a time (enforced order):
+        spec = await flow.draft_spec()
+        red  = await flow.write_failing_test()
+        green = await flow.write_implementation()
+        ...
+
+    Or run end-to-end:
+        async for evt in flow.run():
+            print(evt)
+    """
+
+    def __init__(
+        self,
+        *,
+        feature: str,
+        deps: Any,
+        tools: list[Any] | None = None,
+        parent_model: str = "",
+        config: TDDConfig | None = None,
+        test_runner: TestRunnerFn | None = None,
+        agent_runner: AgentRunnerFn | None = None,
+    ):
+        self._feature = feature
+        self._deps = deps
+        self._tools = list(tools or [])
+        self._parent_model = parent_model
+        self._config = config or TDDConfig()
+        self._test_runner = test_runner or default_test_runner
+        self._agent_runner = agent_runner or _default_agent_runner
+
+        self._phase: TDDPhase = TDDPhase.IDLE
+        self._history: list[TDDArtifact] = []
+
+        # Phase artifacts, surfaced as attributes for downstream consumers.
+        self._spec_text: str = ""
+        self._red_test_code: str = ""
+        self._red_result: TestRunResult | None = None
+        self._green_impl: str = ""
+        self._green_result: TestRunResult | None = None
+        self._refactor_suggestion: str = ""
+        self._refactor_applied: str = ""
+        self._validation_verdict: str = ""
+        self._validate_result: TestRunResult | None = None
+        self._spec_revisions: int = 0
+
+    # ------------------------------------------------------------------
+    # Public read-only accessors
+    # ------------------------------------------------------------------
+
+    @property
+    def phase(self) -> TDDPhase:
+        return self._phase
+
+    @property
+    def feature(self) -> str:
+        return self._feature
+
+    @property
+    def history(self) -> list[TDDArtifact]:
+        return list(self._history)
+
+    @property
+    def spec(self) -> str:
+        return self._spec_text
+
+    @property
+    def red_result(self) -> TestRunResult | None:
+        return self._red_result
+
+    @property
+    def green_result(self) -> TestRunResult | None:
+        return self._green_result
+
+    @property
+    def refactor_suggestion(self) -> str:
+        return self._refactor_suggestion
+
+    @property
+    def validation_verdict(self) -> str:
+        return self._validation_verdict
+
+    # ------------------------------------------------------------------
+    # Phase transition helpers
+    # ------------------------------------------------------------------
+
+    def _expect(self, current_expected: TDDPhase) -> None:
+        """Raise ``TDDError`` unless ``self._phase == current_expected``."""
+        if self._phase != current_expected:
+            raise TDDError(
+                self._phase,
+                "out_of_order",
+                f"expected phase {current_expected.value}, was {self._phase.value}",
+            )
+
+    def _advance(self) -> None:
+        """Step ``self._phase`` to the next phase in the strict sequence."""
+        self._phase = _NEXT_PHASE[self._phase]
+
+    async def _run_role(
+        self, *, role: Role, phase: TDDPhase, prompt: str,
+    ) -> TDDArtifact:
+        """Invoke the appropriate subagent for *role* and record history."""
+        if role is Role.DRIVER:
+            agent_type = "coder"
+            model = self._config.driver_model
+        else:
+            agent_type = "reviewer"
+            model = self._config.navigator_model
+
+        result = await self._agent_runner(
+            prompt=prompt,
+            agent_type=agent_type,
+            model=model,
+            parent_model=self._parent_model,
+            deps=self._deps,
+            tools=self._tools,
+            cwd=self._config.cwd,
+            max_turns=self._config.max_turns,
+        )
+        artifact = TDDArtifact(
+            phase=phase,
+            role=role,
+            prompt=prompt,
+            output=result.result_text,
+            error=result.error,
+        )
+        self._history.append(artifact)
+        if result.is_error:
+            raise TDDError(phase, "agent_error", result.error)
+        return artifact
+
+    async def _run_tests(self, phase: TDDPhase) -> TestRunResult:
+        """Run the configured test command and record the invocation.
+
+        Records a synthetic artifact so tests and observers can see the
+        test-runner output interleaved with role artifacts. ``role=None``
+        marks this as a runner step rather than a role step.
+        """
+        cmd = self._config.test_cmd
+        res = await self._test_runner(cmd, self._config.cwd, self._config.test_timeout)
+        self._history.append(
+            TDDArtifact(
+                phase=phase,
+                role=None,
+                prompt=f"[test-runner] {cmd}",
+                output=res.output,
+                test_run=res,
+            )
+        )
+        return res
+
+    # ------------------------------------------------------------------
+    # Individual phase methods (strict order)
+    # ------------------------------------------------------------------
+
+    async def draft_spec(self) -> TDDArtifact:
+        """Phase 1 — Navigator drafts the test spec."""
+        self._expect(TDDPhase.IDLE)
+        self._phase = TDDPhase.NAVIGATOR_SPEC
+        artifact = await self._run_role(
+            role=Role.NAVIGATOR,
+            phase=TDDPhase.NAVIGATOR_SPEC,
+            prompt=SPEC_PROMPT + self._feature,
+        )
+        self._spec_text = artifact.output.strip()
+        return artifact
+
+    async def revise_spec(self) -> TDDArtifact:
+        """Re-enter phase 1 after a RED-phase false-positive.
+
+        Called when ``write_failing_test`` detected that the spec was not
+        tight enough (the test passed without implementation). Moves the
+        phase back to ``NAVIGATOR_SPEC`` and produces a tighter spec.
+        """
+        if self._phase not in (TDDPhase.NAVIGATOR_SPEC, TDDPhase.DRIVER_RED):
+            raise TDDError(
+                self._phase,
+                "revise_not_allowed",
+                "revise_spec can only be called after a RED-phase "
+                "false-positive",
+            )
+        if self._spec_revisions >= self._config.max_spec_revisions:
+            raise TDDError(
+                self._phase,
+                "max_revisions",
+                f"spec already revised {self._spec_revisions} time(s); "
+                f"max is {self._config.max_spec_revisions}",
+            )
+        self._spec_revisions += 1
+        self._phase = TDDPhase.NAVIGATOR_SPEC
+        prompt = SPEC_REVISION_PROMPT.format(
+            spec=self._spec_text, feature=self._feature,
+        )
+        artifact = await self._run_role(
+            role=Role.NAVIGATOR, phase=TDDPhase.NAVIGATOR_SPEC, prompt=prompt,
+        )
+        self._spec_text = artifact.output.strip()
+        # Clear RED-side state so the next write_failing_test starts fresh.
+        self._red_test_code = ""
+        self._red_result = None
+        return artifact
+
+    async def write_failing_test(self) -> TDDArtifact:
+        """Phase 2 — Driver writes the failing test; tests MUST fail.
+
+        Raises ``TDDError(reason="red_passed")`` when the test unexpectedly
+        passed — the caller can decide to ``revise_spec()`` and retry.
+        """
+        self._expect(TDDPhase.NAVIGATOR_SPEC)
+        self._phase = TDDPhase.DRIVER_RED
+        artifact = await self._run_role(
+            role=Role.DRIVER,
+            phase=TDDPhase.DRIVER_RED,
+            prompt=RED_PROMPT.format(spec=self._spec_text),
+        )
+        self._red_test_code = artifact.output
+        res = await self._run_tests(TDDPhase.DRIVER_RED)
+        self._red_result = res
+        if res.passed:
+            # The test DID NOT fail — spec too loose. Keep phase at
+            # DRIVER_RED so revise_spec() is allowed; surface the issue.
+            raise TDDError(
+                TDDPhase.DRIVER_RED,
+                "red_passed",
+                "failing test unexpectedly passed — spec not tight enough",
+            )
+        return artifact
+
+    async def write_implementation(self) -> TDDArtifact:
+        """Phase 3 — Driver writes the minimum code to turn the test green."""
+        self._expect(TDDPhase.DRIVER_RED)
+        # Only advance to GREEN once RED is confirmed failing.
+        if self._red_result is None or self._red_result.passed:
+            raise TDDError(
+                TDDPhase.DRIVER_RED,
+                "red_not_failing",
+                "cannot enter GREEN until RED confirms a failing test",
+            )
+        self._phase = TDDPhase.DRIVER_GREEN
+        artifact = await self._run_role(
+            role=Role.DRIVER,
+            phase=TDDPhase.DRIVER_GREEN,
+            prompt=GREEN_PROMPT.format(
+                test_code=self._red_test_code,
+                assertion=self._red_result.assertion_failure or self._red_result.output[-400:],
+            ),
+        )
+        self._green_impl = artifact.output
+        res = await self._run_tests(TDDPhase.DRIVER_GREEN)
+        self._green_result = res
+        if not res.passed:
+            raise TDDError(
+                TDDPhase.DRIVER_GREEN,
+                "green_still_failing",
+                "implementation did not make the test pass",
+            )
+        return artifact
+
+    async def propose_refactor(self) -> TDDArtifact:
+        """Phase 4 — Navigator suggests one concrete refactor."""
+        self._expect(TDDPhase.DRIVER_GREEN)
+        self._phase = TDDPhase.NAVIGATOR_REFACTOR
+        artifact = await self._run_role(
+            role=Role.NAVIGATOR,
+            phase=TDDPhase.NAVIGATOR_REFACTOR,
+            prompt=REFACTOR_SUGGEST_PROMPT.format(impl=self._green_impl),
+        )
+        self._refactor_suggestion = artifact.output.strip()
+        return artifact
+
+    async def apply_refactor(self) -> TDDArtifact:
+        """Phase 5 — Driver applies the refactor.
+
+        Invariant: ``self._refactor_suggestion`` must be non-empty before
+        this phase runs, so that ``validate()`` can confirm the suggestion
+        landed.
+        """
+        self._expect(TDDPhase.NAVIGATOR_REFACTOR)
+        if not self._refactor_suggestion:
+            raise TDDError(
+                TDDPhase.NAVIGATOR_REFACTOR,
+                "no_refactor_suggested",
+                "Navigator did not propose a refactor",
+            )
+        self._phase = TDDPhase.DRIVER_REFACTOR
+        artifact = await self._run_role(
+            role=Role.DRIVER,
+            phase=TDDPhase.DRIVER_REFACTOR,
+            prompt=REFACTOR_APPLY_PROMPT.format(suggestion=self._refactor_suggestion),
+        )
+        self._refactor_applied = artifact.output
+        return artifact
+
+    async def validate(self) -> TDDArtifact:
+        """Phase 6 — Navigator re-runs tests and confirms the refactor."""
+        self._expect(TDDPhase.DRIVER_REFACTOR)
+        self._phase = TDDPhase.NAVIGATOR_VALIDATE
+        # Run tests one more time — must still pass after refactor.
+        res = await self._run_tests(TDDPhase.NAVIGATOR_VALIDATE)
+        self._validate_result = res
+        if not res.passed:
+            raise TDDError(
+                TDDPhase.NAVIGATOR_VALIDATE,
+                "validate_regressed",
+                "tests regressed after refactor",
+            )
+        artifact = await self._run_role(
+            role=Role.NAVIGATOR,
+            phase=TDDPhase.NAVIGATOR_VALIDATE,
+            prompt=VALIDATE_PROMPT.format(
+                suggestion=self._refactor_suggestion,
+                test_output=res.output,
+            ),
+        )
+        self._validation_verdict = artifact.output.strip()
+        self._phase = TDDPhase.DONE
+        return artifact
+
+    # ------------------------------------------------------------------
+    # End-to-end orchestration
+    # ------------------------------------------------------------------
+
+    async def run(self) -> AsyncGenerator[dict[str, Any], None]:
+        """Drive the full six-phase flow end-to-end.
+
+        Yields a stream of events so CLI/REPL callers can render
+        progress. Event shape:
+
+            {"type": "tdd_phase_start", "phase": "navigator_spec"}
+            {"type": "tdd_phase_done",  "phase": "navigator_spec",
+             "artifact": TDDArtifact}
+            {"type": "tdd_error",       "phase": "driver_red",
+             "reason": "red_passed", "detail": "..."}
+            {"type": "tdd_done",        "verdict": "..."}
+
+        Errors do not propagate out of the generator — they are emitted
+        as ``tdd_error`` events so the caller can decide how to surface
+        them. The flow halts on the first error.
+        """
+
+        async def _step(
+            label: TDDPhase,
+            fn: Callable[[], Awaitable[TDDArtifact]],
+        ) -> bool:
+            yield_event = {"type": "tdd_phase_start", "phase": label.value}
+            events.append(yield_event)
+            try:
+                artifact = await fn()
+            except TDDError as exc:
+                events.append({
+                    "type": "tdd_error",
+                    "phase": exc.phase.value,
+                    "reason": exc.reason,
+                    "detail": exc.detail,
+                })
+                return False
+            events.append({
+                "type": "tdd_phase_done",
+                "phase": label.value,
+                "artifact": artifact,
+            })
+            return True
+
+        # Collect events in order; yield at the end so callers see phase
+        # boundaries cleanly.  For streaming, consumers can call the
+        # individual phase methods directly.
+        events: list[dict[str, Any]] = []
+
+        # Phase 1, with up to max_spec_revisions retries when RED passes.
+        ok = await _step(TDDPhase.NAVIGATOR_SPEC, self.draft_spec)
+        for ev in events:
+            yield ev
+        events.clear()
+        if not ok:
+            return
+
+        # Phase 2 with retry loop for red_passed.
+        attempt = 0
+        while True:
+            attempt += 1
+            events.clear()
+            yield {"type": "tdd_phase_start", "phase": TDDPhase.DRIVER_RED.value}
+            try:
+                artifact = await self.write_failing_test()
+            except TDDError as exc:
+                if (
+                    exc.reason == "red_passed"
+                    and self._spec_revisions < self._config.max_spec_revisions
+                ):
+                    yield {
+                        "type": "tdd_error",
+                        "phase": exc.phase.value,
+                        "reason": exc.reason,
+                        "detail": exc.detail,
+                    }
+                    # Revise the spec and retry RED.
+                    yield {
+                        "type": "tdd_phase_start",
+                        "phase": TDDPhase.NAVIGATOR_SPEC.value,
+                    }
+                    try:
+                        revised = await self.revise_spec()
+                    except TDDError as rexc:
+                        yield {
+                            "type": "tdd_error",
+                            "phase": rexc.phase.value,
+                            "reason": rexc.reason,
+                            "detail": rexc.detail,
+                        }
+                        return
+                    yield {
+                        "type": "tdd_phase_done",
+                        "phase": TDDPhase.NAVIGATOR_SPEC.value,
+                        "artifact": revised,
+                    }
+                    continue
+                yield {
+                    "type": "tdd_error",
+                    "phase": exc.phase.value,
+                    "reason": exc.reason,
+                    "detail": exc.detail,
+                }
+                return
+            yield {
+                "type": "tdd_phase_done",
+                "phase": TDDPhase.DRIVER_RED.value,
+                "artifact": artifact,
+            }
+            break
+
+        # Phases 3..6
+        for label, fn in [
+            (TDDPhase.DRIVER_GREEN, self.write_implementation),
+            (TDDPhase.NAVIGATOR_REFACTOR, self.propose_refactor),
+            (TDDPhase.DRIVER_REFACTOR, self.apply_refactor),
+            (TDDPhase.NAVIGATOR_VALIDATE, self.validate),
+        ]:
+            yield {"type": "tdd_phase_start", "phase": label.value}
+            try:
+                artifact = await fn()
+            except TDDError as exc:
+                yield {
+                    "type": "tdd_error",
+                    "phase": exc.phase.value,
+                    "reason": exc.reason,
+                    "detail": exc.detail,
+                }
+                return
+            yield {
+                "type": "tdd_phase_done",
+                "phase": label.value,
+                "artifact": artifact,
+            }
+
+        yield {"type": "tdd_done", "verdict": self._validation_verdict}
+
+
+# ---------------------------------------------------------------------------
+# Module-level convenience driver
+# ---------------------------------------------------------------------------
+
+
+async def run_flow(
+    feature: str,
+    *,
+    deps: Any,
+    tools: list[Any] | None = None,
+    parent_model: str = "",
+    config: TDDConfig | None = None,
+    test_runner: TestRunnerFn | None = None,
+    agent_runner: AgentRunnerFn | None = None,
+) -> AsyncGenerator[dict[str, Any], None]:
+    """Build a ``TDDFlow`` and drive it to completion, yielding events."""
+    flow = TDDFlow(
+        feature=feature,
+        deps=deps,
+        tools=tools,
+        parent_model=parent_model,
+        config=config,
+        test_runner=test_runner,
+        agent_runner=agent_runner,
+    )
+    async for event in flow.run():
+        yield event
+
+
+# ---------------------------------------------------------------------------
+# Rendering helpers used by both the CLI subcommand and the /tdd slash
+# command. Keeping them here avoids duplicating the phase-pretty-print
+# logic across entry points.
+# ---------------------------------------------------------------------------
+
+_PHASE_LABELS: dict[str, str] = {
+    TDDPhase.NAVIGATOR_SPEC.value:      "1. Navigator drafts test spec",
+    TDDPhase.DRIVER_RED.value:          "2. Driver writes failing test (RED)",
+    TDDPhase.DRIVER_GREEN.value:        "3. Driver writes minimum code (GREEN)",
+    TDDPhase.NAVIGATOR_REFACTOR.value:  "4. Navigator proposes refactor",
+    TDDPhase.DRIVER_REFACTOR.value:     "5. Driver applies refactor",
+    TDDPhase.NAVIGATOR_VALIDATE.value:  "6. Navigator validates",
+}
+
+
+def format_event(event: dict[str, Any]) -> str:
+    """Human-readable one-block rendering of a flow event."""
+    etype = event.get("type", "")
+    phase = event.get("phase", "")
+    label = _PHASE_LABELS.get(phase, phase or "?")
+    if etype == "tdd_phase_start":
+        return f"▶ Phase {label} — starting"
+    if etype == "tdd_phase_done":
+        artifact = event.get("artifact")
+        out = getattr(artifact, "output", "") if artifact else ""
+        preview = out.strip().splitlines()[0][:120] if out else "(no output)"
+        tr = getattr(artifact, "test_run", None) if artifact else None
+        if tr is not None:
+            status = "PASS" if tr.passed else "FAIL"
+            return f"✓ Phase {label} — done [tests: {status}]\n    {preview}"
+        return f"✓ Phase {label} — done\n    {preview}"
+    if etype == "tdd_error":
+        reason = event.get("reason", "?")
+        detail = event.get("detail", "")
+        return f"✗ Phase {label} — error [{reason}] {detail}"
+    if etype == "tdd_done":
+        verdict = event.get("verdict", "")
+        return f"■ Flow complete. Verdict: {verdict}"
+    return f"[{etype}] {event}"
+
+
+__all__ = [
+    "TDDPhase",
+    "Role",
+    "TDDError",
+    "TestRunResult",
+    "TDDArtifact",
+    "TDDConfig",
+    "TDDFlow",
+    "TestRunnerFn",
+    "AgentRunnerFn",
+    "run_flow",
+    "default_test_runner",
+    "format_event",
+    "SPEC_PROMPT",
+    "SPEC_REVISION_PROMPT",
+    "RED_PROMPT",
+    "GREEN_PROMPT",
+    "REFACTOR_SUGGEST_PROMPT",
+    "REFACTOR_APPLY_PROMPT",
+    "VALIDATE_PROMPT",
+]
