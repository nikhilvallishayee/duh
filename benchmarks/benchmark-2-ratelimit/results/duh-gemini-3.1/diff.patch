@@ -0,0 +1,18 @@
+import functools
+from typing import Callable, Any
+from .limiters.base import RateLimiter
+
+class RateLimitExceeded(Exception):
+    pass
+
+def rate_limit(limiter: RateLimiter, key_fn: Callable[..., str], cost: int = 1):
+    def decorator(func: Callable[..., Any]):
+        @functools.wraps(func)
+        def wrapper(*args, **kwargs):
+            key = key_fn(*args, **kwargs)
+            decision = limiter.enforce(key, cost)
+            if not decision.allowed:
+                raise RateLimitExceeded(f"Rate limit exceeded. Retry after {decision.retry_after_ms}ms")
+            return func(*args, **kwargs)
+        return wrapper
+    return decorator
