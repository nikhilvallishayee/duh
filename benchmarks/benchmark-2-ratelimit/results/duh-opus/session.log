rue)\n    lim = TokenBucketLimiter(capacity=3, refill_per_sec=1, backend=backend)\n    d = lim.enforce("k")\n    assert d.allowed\n    assert d.remaining == -1\n\n\ndef test_fail_closed_on_connection_error():\n    class DeadClient:\n        def register_script(self, src):\n            class _S:\n                def __call__(self, *, keys, args):\n                    raise ConnectionError("boom")\n\n            return _S()\n\n    backend = RedisBackend(DeadClient(), fail_open=False)\n    lim = TokenBucketLimiter(capacity=3, refill_per_sec=1, backend=backend)\n    d = lim.enforce("k")\n    assert not d.allowed\n    assert d.retry_after_ms == 1000\n\n\ndef test_redis_atomicity_no_lost_update(fake_redis):\n    """A thin but pointed test: two processes sharing one Redis should\n    collectively consume exactly `capacity` tokens.\n\n    Emulated by two `RedisBackend` objects sharing one fakeredis — any\n    lost-update bug would show up as allowed > capacity.\n    """\n    import threading\n\n    backend_a = RedisBackend(fake_redis, fail_open=False)\n    backend_b = RedisBackend(fake_redis, fail_open=False)\n    lim_a = TokenBucketLimiter(capacity=20, refill_per_sec=0.0001, backend=backend_a)\n    lim_b = TokenBucketLimiter(capacity=20, refill_per_sec=0.0001, backend=backend_b)\n\n    hits = [0]\n    lock = threading.Lock()\n    start = threading.Event()\n\n    def worker(lim):\n        start.wait()\n        if lim.enforce("shared").allowed:\n            with lock:\n                hits[0] += 1\n\n    threads = []\n    for _ in range(60):\n        threads.append(threading.Thread(target=worker, args=(lim_a,)))\n        threads.append(threading.Thread(target=worker, args=(lim_b,)))\n    for t in threads:\n        t.start()\n    start.set()\n    for t in threads:\n        t.join()\n\n    assert hits[0] == 20\n')
  [33m> Write[0m(file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-opus/tests/test_decorator.py', content='"""Decorator: sync + async, reentrancy, callback."""\n\nimport asyncio\n\nimport pytest\n\nfrom ratelimit import (\n    RateLimitExceeded,\n    TokenBucketLimiter,\n    rate_limit,\n)\n\n\ndef test_sync_decorator_allows_then_rejects():\n    lim = TokenBucketLimiter(capacity=2, refill_per_sec=0.0001)\n\n    @rate_limit(lim, key_fn=lambda user: f"u:{user}")\n    def greet(user: str) -> str:\n        return f"hi {user}"\n\n    assert greet("a") == "hi a"\n    assert greet("a") == "hi a"\n    with pytest.raises(RateLimitExceeded):\n        greet("a")\n\n    # Different key — independent budget.\n    assert greet("b") == "hi b"\n\n\n@pytest.mark.asyncio\nasync def test_async_decorator():\n    lim = TokenBucketLimiter(capacity=2, refill_per_sec=0.0001)\n\n    @rate_limit(lim, key_fn=lambda user: f"u:{user}")\n    async def agreet(user: str) -> str:\n        await asyncio.sleep(0)\n        return f"hi {user}"\n\n    assert await agreet("a") == "hi a"\n    assert await agreet("a") == "hi a"\n    with pytest.raises(RateLimitExceeded):\n        await agreet("a")\n\n\ndef test_on_rejected_callback():\n    lim = TokenBucketLimiter(capacity=1, refill_per_sec=0.0001)\n\n    sentinel = object()\n\n    @rate_limit(\n        lim,\n        key_fn=lambda: "k",\n        on_rejected=lambda decision, key: sentinel,\n    )\n    def f():\n        return "ok"\n\n    assert f() == "ok"\n    assert f() is sentinel  # rejected but callback returned a value\n\n\ndef test_reentrant_does_not_double_charge():\n    """A recursive function using the same key should charge once."""\n    lim = TokenBucketLimiter(capacity=2, refill_per_sec=0.0001)\n\n    calls = {"n": 0}\n\n    @rate_limit(lim, key_fn=lambda depth: "recursive", reentrant=True)\n    def recurse(depth: int) -> int:\n        calls["n"] += 1\n        if depth == 0:\n            return 0\n        return recurse(depth - 1)\n\n    # Single top-level call, 5 recursive calls inside — should use 1 token.\n    recurse(5)\n    assert calls["n"] == 6  # function body ran 6 times\n    # We still have one token left since only the top call charged.\n    d = lim.enforce("recursive")\n    assert d.allowed\n    d2 = lim.enforce("recursive")\n    assert not d2.allowed\n\n\ndef test_non_reentrant_charges_each_call():\n    """Without reentrant=True, recursion exhausts the bucket fast."""\n    lim = TokenBucketLimiter(capacity=3, refill_per_sec=0.0001)\n\n    @rate_limit(lim, key_fn=lambda depth: "recursive")\n    def recurse(depth: int) -> int:\n        if depth == 0:\n            return 0\n        return recurse(depth - 1)\n\n    # 3 tokens: depth=2 → 3 calls (ok); next top-level call triggers 1 more, fails\n    recurse(2)\n    with pytest.raises(RateLimitExceeded):\n        recurse(0)\n\n\ndef test_cost_arg():\n    lim = TokenBucketLimiter(capacity=5, refill_per_sec=0.0001)\n\n    @rate_limit(lim, key_fn=lambda: "k", cost=2)\n    def f() -> str:\n        return "ok"\n\n    assert f() == "ok"\n    assert f() == "ok"\n    with pytest.raises(RateLimitExceeded):\n        f()  # would need 2, only 1 left\n')
  [33m> Write[0m(file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-opus/tests/test_middleware.py', content='"""ASGI middleware tests using Starlette + httpx."""\n\nimport pytest\nfrom starlette.applications import Starlette\nfrom starlette.requests import Request\nfrom starlette.responses import PlainTextResponse\nfrom starlette.routing import Route\n\nfrom ratelimit import (\n    RateLimitMiddleware,\n    TokenBucketLimiter,\n)\n\n\ndef _make_app(limiter, *, key_fn=None):\n    async def hello(request: Request) -> PlainTextResponse:\n        return PlainTextResponse("hi")\n\n    routes = [Route("/hi", hello)]\n    app = Starlette(routes=routes)\n\n    def default_key(scope):\n        return scope["path"]\n\n    app = RateLimitMiddleware(app, limiter, key_fn=key_fn or default_key)\n    return app\n\n\n@pytest.mark.asyncio\nasync def test_middleware_passes_under_limit():\n    import httpx\n\n    lim = TokenBucketLimiter(capacity=3, refill_per_sec=0.0001)\n    app = _make_app(lim)\n    transport = httpx.ASGITransport(app=app)\n    async with httpx.AsyncClient(transport=transport, base_url="http://t") as client:\n        for _ in range(3):\n            r = await client.get("/hi")\n            assert r.status_code == 200\n            assert r.headers["x-ratelimit-limit"] == "3"\n            assert "x-ratelimit-remaining" in r.headers\n            assert "x-ratelimit-reset" in r.headers\n        # 4th request is rejected\n        r = await client.get("/hi")\n        assert r.status_code == 429\n        assert r.headers["retry-after"]\n        assert r.headers["x-ratelimit-limit"] == "3"\n        assert r.headers["x-ratelimit-remaining"] == "0"\n\n\n@pytest.mark.asyncio\nasync def test_middleware_per_key_isolation():\n    import httpx\n\n    lim = TokenBucketLimiter(capacity=1, refill_per_sec=0.0001)\n\n    def key_fn(scope):\n        # Split by first header "x-user"\n        for k, v in scope["headers"]:\n            if k == b"x-user":\n                return v.decode()\n        return "anon"\n\n    app = _make_app(lim, key_fn=key_fn)\n    transport = httpx.ASGITransport(app=app)\n    async with httpx.AsyncClient(transport=transport, base_url="http://t") as client:\n        r = await client.get("/hi", headers={"x-user": "alice"})\n        assert r.status_code == 200\n        # alice\'s bucket is empty now\n        r = await client.get("/hi", headers={"x-user": "alice"})\n        assert r.status_code == 429\n        # bob has his own\n        r = await client.get("/hi", headers={"x-user": "bob"})\n        assert r.status_code == 200\n        r = await client.get("/hi", headers={"x-user": "bob"})\n        assert r.status_code == 429\n\n\n@pytest.mark.asyncio\nasync def test_middleware_429_body_present():\n    import httpx\n\n    lim = TokenBucketLimiter(capacity=1, refill_per_sec=0.0001)\n    app = _make_app(lim)\n    transport = httpx.ASGITransport(app=app)\n    async with httpx.AsyncClient(transport=transport, base_url="http://t") as client:\n        await client.get("/hi")\n        r = await client.get("/hi")\n        assert r.status_code == 429\n        assert b"Too Many Requests" in r.content\n')
Now the hypothesis property test.  [33m> Write[0m(file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-opus/tests/test_properties.py', content='"""Property-based invariants: never grant more than `capacity` in a window."""\n\nfrom hypothesis import HealthCheck, given, settings\nfrom hypothesis import strategies as st\n\nfrom ratelimit import InMemoryBackend, SlidingWindowLimiter, TokenBucketLimiter\n\n\n@given(\n    capacity=st.integers(min_value=1, max_value=50),\n    period_ms=st.integers(min_value=100, max_value=5_000),\n    ops=st.lists(\n        st.tuples(\n            st.floats(min_value=0.0, max_value=20.0, allow_nan=False),  # dt seconds\n            st.integers(min_value=1, max_value=3),                       # cost\n        ),\n        min_size=1,\n        max_size=200,\n    ),\n)\n@settings(deadline=None, max_examples=80, suppress_health_check=[HealthCheck.too_slow])\ndef test_sliding_window_never_over_grants(capacity, period_ms, ops):\n    """For any schedule of (dt, cost) calls, the number of admitted\n    units in any trailing window of length `period_ms` never exceeds\n    `capacity`.\n    """\n    clock = [0.0]\n\n    def fake_clock():\n        return clock[0]\n\n    backend = InMemoryBackend(clock=fake_clock)\n    lim = SlidingWindowLimiter(capacity=capacity, period_ms=period_ms, backend=backend)\n\n    # record (timestamp_ms, cost) of every *admitted* request\n    admitted: list[tuple[int, int]] = []\n    for dt, cost in ops:\n        clock[0] += dt\n        d = lim.enforce("k", cost=cost)\n        if d.allowed:\n            admitted.append((int(clock[0] * 1000), cost))\n\n    # For every admitted event, in the period [t - period_ms + 1, t]\n    # the sum of costs must be ≤ capacity.\n    # The sliding-window counter is an *approximation* (see ADR): its\n    # error is bounded but it can admit slightly more than capacity\n    # across the sharp trailing-window definition when two windows\'\n    # worth of traffic are concentrated near a boundary.  We therefore\n    # assert it never admits more than 2 * capacity in any trailing\n    # `period_ms` window (the documented, asymptotic-worst upper bound).\n    admitted.sort()\n    for i, (t_i, _) in enumerate(admitted):\n        total = 0\n        for t_j, c_j in admitted:\n            if t_j <= t_i and t_j > t_i - period_ms:\n                total += c_j\n        assert total <= 2 * capacity, (\n            f"admitted={admitted}, window ending {t_i}, total={total}, cap={capacity}"\n        )\n\n\n@given(\n    capacity=st.integers(min_value=1, max_value=50),\n    refill_per_sec=st.floats(min_value=0.1, max_value=100.0, allow_nan=False),\n    ops=st.lists(\n        st.tuples(\n            st.floats(min_value=0.0, max_value=5.0, allow_nan=False),\n            st.integers(min_value=1, max_value=3),\n        ),\n        min_size=1,\n        max_size=200,\n    ),\n)\n@settings(deadline=None, max_examples=80, suppress_health_check=[HealthCheck.too_slow])\ndef test_token_bucket_exact_invariant(capacity, refill_per_sec, ops):\n    """Token bucket invariant: in any window of length W, the number\n    of tokens admitted is ≤ capacity + W * refill_per_sec.\n    """\n    clock = [0.0]\n\n    def fake_clock():\n        return clock[0]\n\n    backend = InMemoryBackend(clock=fake_clock)\n    lim = TokenBucketLimiter(\n        capacity=capacity, refill_per_sec=refill_per_sec, backend=backend\n    )\n\n    admitted: list[tuple[float, int]] = []\n    for dt, cost in ops:\n        clock[0] += dt\n        d = lim.enforce("k", cost=cost)\n        if d.allowed:\n            admitted.append((clock[0], cost))\n\n    # Check the invariant against every pair (earliest_start, t_end).\n    # Over [t0, t1] the bucket can deliver at most capacity + (t1 - t0) * rate.\n    for i, (t_end, _) in enumerate(admitted):\n        # look at all windows starting at each prior admitted event\'s\n        # time; this captures the tightest invariants.\n        for j, (t_start, _) in enumerate(admitted[: i + 1]):\n            total = sum(c for t, c in admitted[j : i + 1])\n            window = t_end - t_start\n            budget = capacity + window * refill_per_sec\n            assert total <= budget + 1e-6, (\n                f"admitted from {t_start} to {t_end}: total={total} > "\n                f"budget={budget} (cap={capacity}, rate={refill_per_sec})"\n            )\n\n\n@given(\n    capacity=st.integers(min_value=1, max_value=20),\n    n_calls=st.integers(min_value=1, max_value=100),\n)\n@settings(deadline=None, max_examples=50)\ndef test_token_bucket_fixed_clock_exact(capacity, n_calls):\n    """With a frozen clock, admitted count equals min(capacity, n_calls)."""\n    clock = [0.0]\n\n    def fake_clock():\n        return clock[0]\n\n    backend = InMemoryBackend(clock=fake_clock)\n    lim = TokenBucketLimiter(capacity=capacity, refill_per_sec=1.0, backend=backend)\n    admitted = 0\n    for _ in range(n_calls):\n        if lim.enforce("k").allowed:\n            admitted += 1\n    assert admitted == min(capacity, n_calls)\n')
