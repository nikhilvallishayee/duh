  [33m> Write[0m(content='from ..backends.base import Backend\nfrom .base import RateLimiter\nfrom ..types import Decision\n\nclass TokenBucketLimiter(RateLimiter):\n    def __init__(self, backend: Backend, capacity: int, refill_rate: float):\n        if capacity < 0:\n            raise ValueError("Capacity must be non-negative")\n        if refill_rate < 0:\n            raise ValueError("Refill rate must be non-negative")\n        self.backend = backend\n        self.capacity = capacity\n        self.refill_rate = refill_rate\n\n    def enforce(self, key: str, cost: int = 1) -> Decision:\n        return self.backend.token_bucket(key, self.capacity, self.refill_rate, cost)\n', file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-gemini-3.1/ratelimit/limiters/token_bucket.py')
  [33m> Write[0m(content='from ..backends.base import Backend\nfrom .base import RateLimiter\nfrom ..types import Decision\n\nclass SlidingWindowLimiter(RateLimiter):\n    def __init__(self, backend: Backend, capacity: int, window_size_ms: int):\n        if capacity < 0:\n            raise ValueError("Capacity must be non-negative")\n        if window_size_ms <= 0:\n            raise ValueError("Window size must be positive")\n        self.backend = backend\n        self.capacity = capacity\n        self.window_size_ms = window_size_ms\n\n    def enforce(self, key: str, cost: int = 1) -> Decision:\n        return self.backend.sliding_window(key, self.capacity, self.window_size_ms, cost)\n', file_path='/Users/nomind/Code/duh/benchmarks/benchmark-2-ratelimit/worktrees/duh-gemini-3.1/ratelimit/limiters/sliding_window.py')
