    "libtmux>=0.35,<1",
]
all = [
    "litellm>=1.83.8,<2",
    "pytest-textual-snapshot>=1.0,<2",
    "pexpect>=4.9,<5",
    "pyte>=0.8,<1",
    "libtmux>=0.35,<1",
]

