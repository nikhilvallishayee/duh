  [33m> Write[0m(content='"""Double-agent TDD flow implementation.\n\nImplements the six-phase red-green-refactor flow with Driver/Navigator agents\nas described in ADR-076.\n"""\nfrom __future__ import annotations\n\nimport asyncio\nimport json\nimport os\nimport tempfile\nfrom dataclasses import dataclass, field\nfrom typing import Any, Dict, List, Optional, Tuple\n\nfrom duh.kernel.tool import ToolContext, ToolResult\nfrom duh.security.trifecta import Capability\nfrom duh.agents import run_agent, AGENT_TYPES\n\n\n@dataclass\nclass TDDPhaseResult:\n    """Result from a single TDD phase."""\n    phase: int\n    success: bool\n    output: str\n    error: str = ""\n    metadata: Dict[str, Any] = field(default_factory=dict)\n\n\nclass DoubleAgentTDDTool:\n    """Double-agent TDD flow tool.\n    \n    Implements the six-phase red-green-refactor flow:\n    1. Navigator drafts test spec\n    2. Driver writes failing test (RED)\n    3. Driver implements minimum code (GREEN) \n    4. Navigator proposes refactor\n    5. Driver applies refactor\n    6. Navigator validates\n    \n    See ADR-076 for complete specification.\n    """\n    name = "DoubleAgentTDD"\n    capabilities = Capability.EXEC\n    description = (\n        "Execute a double-agent TDD flow with six phases: "\n        "1) Navigator drafts test spec, 2) Driver writes failing test (RED), "\n        "3) Driver implements minimum code (GREEN), 4) Navigator proposes refactor, "\n        "5) Driver applies refactor, 6) Navigator validates. "\n        "Follows strict red-green-refactor methodology with driver/navigator roles."\n    )\n    input_schema = {\n        "type": "object",\n        "properties": {\n            "feature_description": {\n                "type": "string",\n                "description": "Description of the feature to implement via TDD",\n            },\n            "test_file": {\n                "type": "string",\n                "description": "Path to the test file to create/modify",\n            },\n            "implementation_file": {\n                "type": "string",\n                "description": "Path to the implementation file to create/modify",\n            },\n            "test_framework": {\n                "type": "string",\n                "description": "Test framework to use (e.g., \'pytest\', \'unittest\')",\n                "default": "pytest"\n            }\n        },\n        "required": ["feature_description", "test_file", "implementation_file"]\n    }\n    is_read_only = False\n    is_destructive = False\n\n    def __init__(\n        self,\n        *,\n        parent_deps: Any = None,\n        parent_tools: list[Any] | None = None,\n        parent_model: str | callable = "",\n    ):\n        self._parent_deps = parent_deps\n        self._parent_tools = parent_tools\n        self._parent_model: str | callable = parent_model\n\n    def _resolve_parent_model(self) -> str:\n        pm = self._parent_model\n        if callable(pm):\n            try:\n                return pm() or ""\n            except Exception:\n                return ""\n        return pm or ""\n\n    def _child_tools(self) -> list[Any]:\n        """Return parent tools minus Agent and Swarm (prevent recursion)."""\n        if not self._parent_tools:\n            return []\n        excluded = {"Agent", "Swarm", "DoubleAgentTDD"}\n        return [t for t in self._parent_tools if getattr(t, "name", "") not in excluded]\n\n    async def call(self, input: dict[str, Any], context: ToolContext) -> ToolResult:\n        if self._parent_deps is None:\n            return ToolResult(output="DoubleAgentTDD error: no parent deps configured", is_error=True)\n\n        feature_desc = input.get("feature_description", "")\n        test_file = input.get("test_file", "")\n        impl_file = input.get("implementation_file", "")\n        test_framework = input.get("test_framework", "pytest")\n\n        if not feature_desc or not test_file or not impl_file:\n            return ToolResult(\n                output="DoubleAgentTDD error: missing required parameters", \n                is_error=True\n            )\n\n        try:\n            result = await self._execute_tdd_flow(\n                feature_desc, test_file, impl_file, test_framework, context\n            )\n            return ToolResult(output=result)\n        except Exception as e:\n            return ToolResult(output=f"DoubleAgentTDD error: {str(e)}", is_error=True)\n\n    async def _execute_tdd_flow(\n        self, \n        feature_desc: str, \n        test_file: str, \n        impl_file: str,\n        test_framework: str,\n        context: ToolContext\n    ) -> str:\n        """Execute the six-phase TDD flow."""\n        child_tools = self._child_tools()\n        parent_model = self._resolve_parent_model()\n        \n        # Phase 1: Navigator drafts test spec\n        phase1_result = await self._phase1_draft_spec(\n            feature_desc, test_file, impl_file, test_framework, \n            child_tools, parent_model, context\n        )\n        if not phase1_result.success:\n            return f"Phase 1 failed: {phase1_result.error}\\n{phase1_result.output}"\n        \n        test_spec = phase1_result.output\n        \n        # Phase 2: Driver writes failing test (RED)\n        phase2_result = await self._phase2_write_failing_test(\n            test_spec, test_file, impl_file, test_framework,\n            child_tools, parent_model, context\n        )\n        if not phase2_result.success:\n            return f"Phase 2 failed: {phase2_result.error}\\n{phase2_result.output}"\n        \n        # Verify test actually fails\n        if not phase2_result.metadata.get("test_failed", False):\n            # Test passed when it should have failed - spec was insufficient\n            return (\n                "Phase 2 validation failed: Test passed when it should have failed. "\n                "This indicates the test specification was not tight enough. "\n                "Navigator needs to revise the spec."\n            )\n        \n        # Phase 3: Driver implements minimum code (GREEN)\n        phase3_result = await self._phase3_implement_minimum_code(\n            test_spec, test_file, impl_file, test_framework,\n            child_tools, parent_model, context\n        )\n        if not phase3_result.success:\n            return f"Phase 3 failed: {phase3_result.error}\\n{phase3_result.output}"\n        \n        # Verify test now passes\n        if not phase3_result.metadata.get("test_passed", False):\n            return f"Phase 3 validation failed: Test still failing after implementation"\n        \n        # Phase 4: Navigator proposes refactor\n        phase4_result = await self._phase4_propose_refactor(\n            test_spec, impl_file, test_framework,\n            child_tools, parent_model, context\n        )\n        if not phase4_result.success:\n            return f"Phase 4 failed: {phase4_result.error}\\n{phase4_result.output}"\n        \n        refactor_proposal = phase4_result.output\n        \n        # Phase 5: Driver applies refactor\n        phase5_result = await self._phase5_apply_refactor(\n            refactor_proposal, impl_file,\n            child_tools, parent_model, context\n        )\n        if not phase5_result.success:\n            return f"Phase 5 failed: {phase5_result.error}\\n{phase5_result.output}"\n        \n        # Phase 6: Navigator validates\n        phase6_result = await self._phase6_validate(\n            test_spec, refactor_proposal, test_file, impl_file, test_framework,\n            child_tools, parent_model, context\n        )\n        if not phase6_result.success:\n            return f"Phase 6 failed: {phase6_result.error}\\n{phase6_result.output}"\n        \n        return (\n            "Double-agent TDD flow completed successfully!\\n\\n"\n            "✅ Phase 1: Navigator drafted test spec\\n"\n            "✅ Phase 2: Driver wrote failing test (RED)\\n"\n            "✅ Phase 3: Driver implemented minimum code (GREEN)\\n"\n            "✅ Phase 4: Navigator proposed refactor\\n"\n            "✅ Phase 5: Driver applied refactor\\n"\n            "✅ Phase 6: Navigator validated final implementation\\n\\n"\n            f"Final validation: {phase6_result.output}"\n        )\n\n    async def _phase1_draft_spec(\n        self, feature_desc: str, test_file: str, impl_file: str, test_framework: str,\n        tools: list, parent_model: str, context: ToolContext\n    ) -> TDDPhaseResult:\n        """Phase 1: Navigator drafts test spec."""\n        prompt = (\n            f"Draft a comprehensive test specification for the following feature:\\n\\n"\n            f"Feature: {feature_desc}\\n\\n"\n            f"Test file: {test_file}\\n"\n            f"Implementation file: {impl_file}\\n"\n            f"Test framework: {test_framework}\\n\\n"\n            f"Your specification should include:\\n"\n            f"- Clear description of expected behavior\\n"\n            f"- Specific test cases with inputs and expected outputs\\n"\n            f"- Edge cases and error conditions to test\\n"\n            f"- Validation criteria for what constitutes a proper test failure\\n\\n"\n            f"Output ONLY the test specification in clear, structured format."\n        )\n        \n        result = await run_agent(\n            prompt=prompt,\n            agent_type="reviewer",\n            model="inherit",\n            parent_model=parent_model,\n            deps=self._parent_deps,\n            tools=tools,\n        )\n        \n        if result.is_error:\n            return TDDPhaseResult(\n                phase=1, success=False, output="", error=result.error\n            )\n        \n        return TDDPhaseResult(\n            phase=1, success=True, output=result.result_text\n        )\n\n    async def _phase2_write_failing_test(\n        self, test_spec: str, test_file: str, impl_file: str, test_framework: str,\n        tools: list, parent_model: str, context: ToolContext\n    ) -> TDDPhaseResult:\n        """Phase 2: Driver writes failing test (RED)."""\n        prompt = (\n            f"Write a test file that implements the following specification:\\n\\n"\n            f"Test Specification:\\n{test_spec}\\n\\n"\n            f"Test file path: {test_file}\\n"\n            f"Implementation file: {impl_file}\\n"\n            f"Test framework: {test_framework}\\n\\n"\n            f"IMPORTANT: The test should FAIL when run against the current state "\n            f"(which has no implementation yet). Write the test first, then verify it fails.\\n\\n"\n            f"Steps to follow:\\n"\n            f"1. Create the test file with proper test cases\\n"\n            f"2. Run the test to verify it fails (use Bash tool)\\n"\n            f"3. If test passes, it means the spec is wrong - but assume spec is correct\\n"\n            f"4. Output the test file content and the test failure output"\n        )\n        \n        result = await run_agent(\n            prompt=prompt,\n            agent_type="coder",\n            model="inherit",\n            parent_model=parent_model,\n            deps=self._parent_deps,\n            tools=tools,\n        )\n        \n        if result.is_error:\n            return TDDPhaseResult(\n                phase=2, success=False, output="", error=result.error\n            )\n        \n        # Parse result to determine if test actually failed\n        test_failed = "AssertionError" in result.result_text or "FAILED" in result.result_text or "fail" in result.result_text.lower()\n        \n        return TDDPhaseResult(\n            phase=2, \n            success=True, \n            output=result.result_text,\n            metadata={"test_failed": test_failed}\n        )\n\n    async def _phase3_implement_minimum_code(\n        self, test_spec: str, test_file: str, impl_file: str, test_framework: str,\n        tools: list, parent_model: str, context: ToolContext\n    ) -> TDDPhaseResult:\n        """Phase 3: Driver implements minimum code (GREEN)."""\n        prompt = (\n            f"Implement the minimum code necessary to make the failing test pass.\\n\\n"\n            f"Test Specification:\\n{test_spec}\\n\\n"\n            f"Test file: {test_file}\\n"\n            f"Implementation file: {impl_file}\\n"\n            f"Test framework: {test_framework}\\n\\n"\n            f"Steps to follow:\\n"\n            f"1. Read the failing test to understand what needs to be implemented\\n"\n            f"2. Write ONLY the minimum code needed to make the test pass\\n"\n            f"3. Run the test to verify it now passes\\n"\n            f"4. Output the implementation code and the test passing output"\n        )\n        \n        result = await run_agent(\n            prompt=prompt,\n            agent_type="coder",\n            model="inherit",\n            parent_model=parent_model,\n            deps=self._parent_deps,\n            tools=tools,\n        )\n        \n        if result.is_error:\n            return TDDPhaseResult(\n                phase=3, success=False, output="", error=result.error\n            )\n        \n        # Parse result to determine if test now passes\n        test_passed = "PASSED" in result.result_text or "passed" in result.result_text.lower() or "OK" in result.result_text\n        \n        return TDDPhaseResult(\n            phase=3, \n            success=True, \n            output=result.result_text,\n            metadata={"test_passed": test_passed}\n        )\n\n    async def _phase4_propose_refactor(\n        self, test_spec: str, impl_file: str, test_framework: str,\n        tools: list, parent_model: str, context: ToolContext\n    ) -> TDDPhaseResult:\n        """Phase 4: Navigator proposes refactor."""\n        prompt = (\n            f"Review the current implementation and propose specific refactor improvements.\\n\\n"\n            f"Test Specification:\\n{test_spec}\\n\\n"\n            f"Implementation file: {impl_file}\\n"\n            f"Test framework: {test_framework}\\n\\n"\n            f"Focus on:\\n"\n            f"- Code quality and readability\\n"\n            f"- Performance improvements\\n"\n            f"- Maintainability and extensibility\\n"\n            f"- Following best practices for the language/framework\\n\\n"\n            f"Provide specific, actionable refactor suggestions with code examples if needed.\\n"\n            f"Output ONLY the refactor proposal."\n        )\n        \n        result = await run_agent(\n            prompt=prompt,\n            agent_type="reviewer",\n            model="inherit",\n            parent_model=parent_model,\n            deps=self._parent_deps,\n            tools=tools,\n        )\n        \n        if result.is_error:\n            return TDDPhaseResult(\n                phase=4, success=False, output="", error=result.error\n            )\n        \n        return TDDPhaseResult(\n            phase=4, success=True, output=result.result_text\n        )\n\n    async def _phase5_apply_refactor(\n        self, refactor_proposal: str, impl_file: str,\n        tools: list, parent_model: str, context: ToolContext\n    ) -> TDDPhaseResult:\n        """Phase 5: Driver applies refactor."""\n        prompt = (\n            f"Apply the following refactor suggestions to the implementation:\\n\\n"\n            f"Refactor Proposal:\\n{refactor_proposal}\\n\\n"\n            f"Implementation file: {impl_file}\\n\\n"\n            f"Steps to follow:\\n"\n            f"1. Read the current implementation\\n"\n            f"2. Apply the refactor suggestions precisely\\n"\n            f"3. Ensure the code still works (but don\'t run tests yet)\\n"\n            f"4. Output the refactored code"\n        )\n        \n        result = await run_agent(\n            prompt=prompt,\n            agent_type="coder",\n            model="inherit",\n            parent_model=parent_model,\n            deps=self._parent_deps,\n            tools=tools,\n        )\n        \n        if result.is_error:\n            return TDDPhaseResult(\n                phase=5, success=False, output="", error=result.error\n            )\n        \n        return TDDPhaseResult(\n            phase=5, success=True, output=result.result_text\n        )\n\n    async def _phase6_validate(\n        self, test_spec: str, refactor_proposal: str, test_file: str, impl_file: str, test_framework: str,\n        tools: list, parent_model: str, context: ToolContext\n    ) -> TDDPhaseResult:\n        """Phase 6: Navigator validates."""\n        prompt = (\n            f"Validate the final implementation against the original specification "\n            f"and refactor proposal.\\n\\n"\n            f"Original Test Specification:\\n{test_spec}\\n\\n"\n            f"Refactor Proposal:\\n{refactor_proposal}\\n\\n"\n            f"Test file: {test_file}\\n"\n            f"Implementation file: {impl_file}\\n"\n            f"Test framework: {test_framework}\\n\\n"\n            f"Validation checklist:\\n"\n            f"1. All tests pass\\n"\n            f"2. Refactor suggestions were properly applied\\n"\n            f"3. No functionality was broken\\n"\n            f"4. Code quality meets the refactor goals\\n\\n"\n            f"Run the tests and examine the implementation, then provide a validation report."\n        )\n        \n        result = await run_agent(\n            prompt=prompt,\n            agent_type="reviewer",\n            model="inherit",\n            parent_model=parent_model,\n            deps=self._parent_deps,\n            tools=tools,\n        )\n        \n        if result.is_error:\n            return TDDPhaseResult(\n                phase=6, success=False, output="", error=result.error\n            )\n        \n        return TDDPhaseResult(\n            phase=6, success=True, output=result.result_text\n        )\n\n    async def check_permissions(\n        self, input: dict[str, Any], context: ToolContext\n    ) -> dict[str, Any]:\n        return {"allowed": True