+from __future__ import annotations
+
+import asyncio
+import threading
+import time
+
+import fakeredis
+import pytest
+from fastapi import FastAPI
+from fastapi.testclient import TestClient
+from hypothesis import given, settings
+from hypothesis import strategies as st
+
+from ratelimit import (
+    InMemoryBackend,
+    RateLimitExceeded,
+    RateLimitMiddleware,
+    RedisBackend,
+    SlidingWindowLimiter,
+    TokenBucketLimiter,
+    rate_limit,
+)
+
+
+class TestTokenBucketLimiter:
+    def test_allows_until_capacity(self) -> None:
+        limiter = TokenBucketLimiter(backend=InMemoryBackend(), capacity=3, refill_rate=10)
+        assert limiter.enforce("a").allowed is True
+        assert limiter.enforce("a").allowed is True
+        third = limiter.enforce("a")
+        assert third.allowed is True
+        blocked = limiter.enforce("a")
+        assert blocked.allowed is False
+        assert blocked.retry_after_ms > 0
+        assert blocked.remaining == 0
+
+    def test_refills_over_time(self) -> None:
+        limiter = TokenBucketLimiter(backend=InMemoryBackend(), capacity=1, refill_rate=20)
+        assert limiter.enforce("a").allowed is True
+        assert limiter.enforce("a").allowed is False
+        time.sleep(0.06)
+        assert limiter.enforce("a").allowed is True
+
+    def test_cost_must_be_positive(self) -> None:
+        limiter = TokenBucketLimiter(backend=InMemoryBackend(), capacity=1, refill_rate=1)
+        with pytest.raises(ValueError):
+            limiter.enforce("a", cost=0)
+
+
+class TestSlidingWindowLimiter:
+    def test_blocks_after_limit(self) -> None:
+        limiter = SlidingWindowLimiter(backend=InMemoryBackend(), limit=2, period_ms=1000)
+        assert limiter.enforce("a").allowed is True
+        assert limiter.enforce("a").allowed is True
+        denied = limiter.enforce("a")
+        assert denied.allowed is False
+        assert denied.retry_after_ms > 0
+
+    def test_isolates_keys(self) -> None:
+        limiter = SlidingWindowLimiter(backend=InMemoryBackend(), limit=1, period_ms=1000)
+        assert limiter.enforce("a").allowed is True
+        assert limiter.enforce("b").allowed is True
+
+    def test_capacity_one_edge(self) -> None:
+        limiter = SlidingWindowLimiter(backend=InMemoryBackend(), limit=1, period_ms=100)
+        assert limiter.enforce("a").allowed is True
+        assert limiter.enforce("a").allowed is False
+
+
+class TestDecorator:
+    def test_sync_decorator(self) -> None:
+        limiter = TokenBucketLimiter(backend=InMemoryBackend(), capacity=1, refill_rate=100)
+
+        @rate_limit(limiter, key_fn=lambda user: user)
+        def fn(user: str) -> str:
+            return user
+
+        assert fn("u") == "u"
+        with pytest.raises(RateLimitExceeded):
+            fn("u")
+
+    def test_async_decorator_reentry(self) -> None:
+        limiter = SlidingWindowLimiter(backend=InMemoryBackend(), limit=2, period_ms=1000)
+
+        @rate_limit(limiter, key_fn=lambda user: user)
+        async def fn(user: str) -> str:
+            return user
+
+        assert asyncio.run(fn("u")) == "u"
+        assert asyncio.run(fn("u")) == "u"
+        with pytest.raises(RateLimitExceeded):
+            asyncio.run(fn("u"))
+
+
+class TestMiddleware:
+    def test_adds_headers_and_blocks(self) -> None:
+        app = FastAPI()
+        limiter = TokenBucketLimiter(backend=InMemoryBackend(), capacity=1, refill_rate=1)
+        app.add_middleware(RateLimitMiddleware, limiter=limiter, key_fn=lambda request: "client")
+
+        @app.get("/")
+        def index() -> dict[str, bool]:
+            return {"ok": True}
+
+        client = TestClient(app)
+        allowed = client.get("/")
+        assert allowed.status_code == 200
+        assert allowed.headers["X-RateLimit-Limit"] == "1"
+        blocked = client.get("/")
+        assert blocked.status_code == 429
+        assert blocked.headers["Retry-After"] == "1"
+
+    def test_fail_open(self) -> None:
+        class BrokenLimiter:
+            capacity = 1
+
+            def enforce(self, key: str, cost: int = 1):
+                raise RuntimeError("down")
+
+        app = FastAPI()
+        app.add_middleware(RateLimitMiddleware, limiter=BrokenLimiter(), key_fn=lambda request: "k", fail_open=True)
+
+        @app.get("/")
+        def index() -> dict[str, bool]:
+            return {"ok": True}
+
+        client = TestClient(app)
+        response = client.get("/")
+        assert response.status_code == 200
+
+
+class TestRedisBackend:
+    def test_fakeredis_integration(self) -> None:
+        client = fakeredis.FakeRedis()
+        backend = RedisBackend(client)
+        limiter = TokenBucketLimiter(backend=backend, capacity=2, refill_rate=100)
+        assert limiter.enforce("a").allowed is True
+        assert limiter.enforce("a").allowed is True
+        assert limiter.enforce("a").allowed is False
+
+
+def test_inmemory_token_bucket_concurrency() -> None:
+    limiter = TokenBucketLimiter(backend=InMemoryBackend(), capacity=20, refill_rate=0.0001)
+    allowed = 0
+    lock = threading.Lock()
+    barrier = threading.Barrier(120)
+
+    def worker() -> None:
+        nonlocal allowed
+        barrier.wait()
+        decision = limiter.enforce("shared")
+        if decision.allowed:
+            with lock:
+                allowed += 1
+
+    threads = [threading.Thread(target=worker) for _ in range(120)]
+    for thread in threads:
+        thread.start()
+    for thread in threads:
+        thread.join()
+
+    assert allowed == 20
+
+
+def test_redis_token_bucket_concurrency() -> None:
+    client = fakeredis.FakeRedis()
+    limiter = TokenBucketLimiter(backend=RedisBackend(client), capacity=15, refill_rate=0.0001)
+    allowed = 0
+    lock = threading.Lock()
+    barrier = threading.Barrier(100)
+
+    def worker() -> None:
+        nonlocal allowed
+        barrier.wait()
+        decision = limiter.enforce("shared")
+        if decision.allowed:
+            with lock:
+                allowed += 1
+
+    threads = [threading.Thread(target=worker) for _ in range(100)]
+    for thread in threads:
+        thread.start()
+    for thread in threads:
+        thread.join()
+
+    assert allowed == 15
+
+
+@given(st.lists(st.integers(min_value=0, max_value=10), min_size=1, max_size=30))
+@settings(max_examples=50)
+def test_token_bucket_property_never_exceeds_capacity(offsets: list[int]) -> None:
+    capacity = 5
+    refill_rate = 1000.0 / 1000.0
+    limiter = TokenBucketLimiter(backend=InMemoryBackend(), capacity=capacity, refill_rate=refill_rate)
+    start = time.time()
+    granted_times: list[float] = []
+
+    for offset in offsets:
+        target = start + (offset / 1000.0)
+        while time.time() < target:
+            time.sleep(0.0005)
+        decision = limiter.enforce("prop")
+        if decision.allowed:
+            granted_times.append(time.time())
+
+    period = capacity / refill_rate
+    for current in granted_times:
+        in_window = [t for t in granted_times if current - period <= t <= current]
+        assert len(in_window) <= capacity
