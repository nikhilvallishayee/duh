+++ b/duh/tdd.py
@@ -0,0 +1,473 @@
+"""Double-agent TDD orchestration.
+
+Implements a strict red-green-refactor loop using two cooperating child
+agents:
+
+- Navigator: drafts/revises the test spec, proposes refactors, validates
+  the landing.
+- Driver: writes the failing test, then the minimum fix, then applies the
+  refactor.
+
+The orchestration reuses ``duh.agents.run_agent`` for child execution and
+the parent session's existing tool wiring for test execution.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from typing import Any, Awaitable, Callable, Literal
+
+from duh.agents import run_agent
+from duh.kernel.tool import ToolContext, ToolResult
+
+TddPhaseName = Literal[
+    "navigator_spec",
+    "driver_red",
+    "driver_green",
+    "navigator_refactor",
+    "driver_refactor",
+    "navigator_validate",
+]
+TddRole = Literal["navigator", "driver"]
+
+
+@dataclass
+class TestCommandResult:
+    command: str
+    output: str
+    returncode: int
+    passed: bool
+
+
+@dataclass
+class TddPhaseResult:
+    phase: TddPhaseName
+    role: TddRole
+    prompt: str
+    response: str
+    status: Literal["ok", "needs_revision", "error"]
+    test_result: TestCommandResult | None = None
+
+
+@dataclass
+class DoubleAgentTddResult:
+    task: str
+    test_command: str
+    phases: list[TddPhaseResult] = field(default_factory=list)
+    success: bool = False
+    error: str = ""
+
+    @property
+    def red_phase(self) -> TddPhaseResult | None:
+        for phase in self.phases:
+            if phase.phase == "driver_red" and phase.test_result is not None:
+                return phase
+        return None
+
+    @property
+    def green_phase(self) -> TddPhaseResult | None:
+        for phase in self.phases:
+            if phase.phase == "driver_green" and phase.test_result is not None:
+                return phase
+        return None
+
+    @property
+    def validation_phase(self) -> TddPhaseResult | None:
+        for phase in self.phases:
+            if phase.phase == "navigator_validate" and phase.test_result is not None:
+                return phase
+        return None
+
+    @property
+    def red_failure(self) -> str:
+        phase = self.red_phase
+        if phase is None or phase.test_result is None:
+            return ""
+        return phase.test_result.output
+
+
+def _child_tools(tools: list[Any]) -> list[Any]:
+    return [tool for tool in tools if getattr(tool, "name", "") not in {"Agent", "Swarm"}]
+
+
+def _find_bash_tool(tools: list[Any]) -> Any:
+    for tool in tools:
+        if getattr(tool, "name", "") == "Bash":
+            return tool
+    raise ValueError("Double-agent TDD requires the Bash tool to run the test command")
+
+
+async def _run_test_command(
+    *,
+    bash_tool: Any,
+    command: str,
+    cwd: str,
+    shell: str,
+) -> TestCommandResult:
+    result = await bash_tool.call(
+        {"command": command, "shell": shell},
+        ToolContext(cwd=cwd),
+    )
+    if not isinstance(result, ToolResult):
+        text = str(result)
+        return TestCommandResult(command=command, output=text, returncode=0, passed=True)
+    return TestCommandResult(
+        command=command,
+        output=str(result.output),
+        returncode=int(result.metadata.get("returncode", 0) or 0),
+        passed=not result.is_error,
+    )
+
+
+def _navigator_spec_prompt(task: str, *, revision_context: str = "") -> str:
+    prompt = (
+        "You are the Navigator in a strict red-green-refactor TDD loop.\n"
+        "Draft a tight executable test spec for the Driver.\n"
+        "Do not edit files. Do not write production code.\n"
+        "Describe only the next failing test the Driver should add, why it should fail, "
+        "and what behavior it proves.\n\n"
+        f"Task:\n{task}\n"
+    )
+    if revision_context:
+        prompt += f"\nThe last RED attempt passed unexpectedly. Tighten the spec.\n{revision_context}\n"
+    return prompt
+
+
+def _driver_red_prompt(task: str, spec: str, test_command: str) -> str:
+    return (
+        "You are the Driver in a strict red-green-refactor TDD loop.\n"
+        "Implement only the failing test described below.\n"
+        "Do not change production code yet.\n"
+        f"After editing, the parent orchestrator will run this test command:\n{test_command}\n\n"
+        f"Task:\n{task}\n\n"
+        f"Navigator spec:\n{spec}\n"
+    )
+
+
+def _driver_green_prompt(
+    task: str,
+    spec: str,
+    red_failure: str,
+    test_command: str,
+) -> str:
+    return (
+        "You are the Driver in GREEN.\n"
+        "Write the minimum production change needed to make the failing test pass.\n"
+        "Keep the change small and focused. Do not refactor yet.\n"
+        f"The parent orchestrator will rerun:\n{test_command}\n\n"
+        f"Task:\n{task}\n\n"
+        f"Navigator spec:\n{spec}\n\n"
+        f"Observed RED failure:\n{red_failure}\n"
+    )
+
+
+def _navigator_refactor_prompt(task: str, spec: str, green_output: str) -> str:
+    return (
+        "You are the Navigator after GREEN.\n"
+        "Review the just-passing implementation and propose a small, concrete refactor.\n"
+        "Do not edit files. Explain exactly what the Driver should change.\n\n"
+        f"Task:\n{task}\n\n"
+        f"Navigator spec:\n{spec}\n\n"
+        f"GREEN test output:\n{green_output}\n"
+    )
+
+
+def _driver_refactor_prompt(
+    task: str,
+    spec: str,
+    refactor_plan: str,
+    test_command: str,
+) -> str:
+    return (
+        "You are the Driver in REFACTOR.\n"
+        "Apply the Navigator's refactor without changing the externally tested behavior.\n"
+        f"The parent orchestrator will rerun:\n{test_command}\n\n"
+        f"Task:\n{task}\n\n"
+        f"Navigator spec:\n{spec}\n\n"
+        f"Navigator refactor plan:\n{refactor_plan}\n"
+    )
+
+
+def _navigator_validate_prompt(
+    task: str,
+    spec: str,
+    refactor_plan: str,
+    driver_refactor_response: str,
+    validation_output: str,
+) -> str:
+    return (
+        "You are the Navigator in final validation.\n"
+        "Confirm that the refactor described below was applied cleanly and that the passing "
+        "test run indicates behavior stayed intact.\n"
+        "Do not edit files.\n\n"
+        f"Task:\n{task}\n\n"
+        f"Navigator spec:\n{spec}\n\n"
+        f"Refactor plan:\n{refactor_plan}\n\n"
+        f"Driver refactor summary:\n{driver_refactor_response}\n\n"
+        f"Validation test output:\n{validation_output}\n"
+    )
+
+
+async def _run_phase_agent(
+    *,
+    phase: TddPhaseName,
+    role: TddRole,
+    prompt: str,
+    agent_type: str,
+    model: str,
+    parent_model: str,
+    deps: Any,
+    tools: list[Any],
+    max_turns: int,
+    run_agent_fn: Callable[..., Awaitable[Any]],
+) -> TddPhaseResult:
+    result = await run_agent_fn(
+        prompt=prompt,
+        agent_type=agent_type,
+        model=model,
+        parent_model=parent_model,
+        deps=deps,
+        tools=tools,
+        max_turns=max_turns,
+    )
+    if getattr(result, "is_error", False):
+        return TddPhaseResult(
+            phase=phase,
+            role=role,
+            prompt=prompt,
+            response=getattr(result, "error", "") or "",
+            status="error",
+        )
+    return TddPhaseResult(
+        phase=phase,
+        role=role,
+        prompt=prompt,
+        response=getattr(result, "result_text", "") or "",
+        status="ok",
+    )
+
+
+async def run_double_agent_tdd(
+    *,
+    task: str,
+    test_command: str,
+    deps: Any,
+    tools: list[Any],
+    cwd: str = ".",
+    parent_model: str = "",
+    driver_model: str = "inherit",
+    navigator_model: str = "inherit",
+    driver_max_turns: int = 50,
+    navigator_max_turns: int = 50,
+    max_red_revisions: int = 2,
+    shell: str = "auto",
+    run_agent_fn: Callable[..., Awaitable[Any]] = run_agent,
+) -> DoubleAgentTddResult:
+    """Run the full double-agent TDD loop."""
+    flow = DoubleAgentTddResult(task=task, test_command=test_command)
+    bash_tool = _find_bash_tool(tools)
+    child_tools = _child_tools(tools)
+
+    spec_text = ""
+    red_attempts = 0
+    revision_context = ""
+
+    while True:
+        spec_prompt = _navigator_spec_prompt(task, revision_context=revision_context)
+        spec_phase = await _run_phase_agent(
+            phase="navigator_spec",
+            role="navigator",
+            prompt=spec_prompt,
+            agent_type="reviewer",
+            model=navigator_model,
+            parent_model=parent_model,
+            deps=deps,
+            tools=child_tools,
+            max_turns=navigator_max_turns,
+            run_agent_fn=run_agent_fn,
+        )
+        flow.phases.append(spec_phase)
+        if spec_phase.status == "error":
+            flow.error = "Navigator failed while drafting the test spec"
+            return flow
+        spec_text = spec_phase.response
+
+        red_prompt = _driver_red_prompt(task, spec_text, test_command)
+        red_phase = await _run_phase_agent(
+            phase="driver_red",
+            role="driver",
+            prompt=red_prompt,
+            agent_type="coder",
+            model=driver_model,
+            parent_model=parent_model,
+            deps=deps,
+            tools=child_tools,
+            max_turns=driver_max_turns,
+            run_agent_fn=run_agent_fn,
+        )
+        if red_phase.status == "error":
+            flow.phases.append(red_phase)
+            flow.error = "Driver failed while writing the RED test"
+            return flow
+
+        red_test = await _run_test_command(
+            bash_tool=bash_tool,
+            command=test_command,
+            cwd=cwd,
+            shell=shell,
+        )
+        red_phase.test_result = red_test
+        if red_test.passed:
+            red_phase.status = "needs_revision"
+            flow.phases.append(red_phase)
+            red_attempts += 1
+            if red_attempts > max_red_revisions:
+                flow.error = "RED never failed; Navigator could not tighten the spec enough"
+                return flow
+            revision_context = (
+                "The test command passed after the RED step. Revise the spec so the next test is tighter.\n\n"
+                f"Test command:\n{test_command}\n\n"
+                f"Observed output:\n{red_test.output}\n"
+            )
+            continue
+
+        flow.phases.append(red_phase)
+        break
+
+    green_prompt = _driver_green_prompt(task, spec_text, flow.red_failure, test_command)
+    green_phase = await _run_phase_agent(
+        phase="driver_green",
+        role="driver",
+        prompt=green_prompt,
+        agent_type="coder",
+        model=driver_model,
+        parent_model=parent_model,
+        deps=deps,
+        tools=child_tools,
+        max_turns=driver_max_turns,
+        run_agent_fn=run_agent_fn,
+    )
+    if green_phase.status == "error":
+        flow.phases.append(green_phase)
+        flow.error = "Driver failed while implementing GREEN"
+        return flow
+
+    green_test = await _run_test_command(
+        bash_tool=bash_tool,
+        command=test_command,
+        cwd=cwd,
+        shell=shell,
+    )
+    green_phase.test_result = green_test
+    if not green_test.passed:
+        green_phase.status = "error"
+        flow.phases.append(green_phase)
+        flow.error = "GREEN did not pass the test command"
+        return flow
+    flow.phases.append(green_phase)
+
+    refactor_prompt = _navigator_refactor_prompt(task, spec_text, green_test.output)
+    refactor_phase = await _run_phase_agent(
+        phase="navigator_refactor",
+        role="navigator",
+        prompt=refactor_prompt,
+        agent_type="reviewer",
+        model=navigator_model,
+        parent_model=parent_model,
+        deps=deps,
+        tools=child_tools,
+        max_turns=navigator_max_turns,
+        run_agent_fn=run_agent_fn,
+    )
+    flow.phases.append(refactor_phase)
+    if refactor_phase.status == "error":
+        flow.error = "Navigator failed while proposing the refactor"
+        return flow
+
+    driver_refactor_prompt = _driver_refactor_prompt(
+        task,
+        spec_text,
+        refactor_phase.response,
+        test_command,
+    )
+    driver_refactor_phase = await _run_phase_agent(
+        phase="driver_refactor",
+        role="driver",
+        prompt=driver_refactor_prompt,
+        agent_type="coder",
+        model=driver_model,
+        parent_model=parent_model,
+        deps=deps,
+        tools=child_tools,
+        max_turns=driver_max_turns,
+        run_agent_fn=run_agent_fn,
+    )
+    flow.phases.append(driver_refactor_phase)
+    if driver_refactor_phase.status == "error":
+        flow.error = "Driver failed while applying the refactor"
+        return flow
+
+    validation_test = await _run_test_command(
+        bash_tool=bash_tool,
+        command=test_command,
+        cwd=cwd,
+        shell=shell,
+    )
+    validation_prompt = _navigator_validate_prompt(
+        task,
+        spec_text,
+        refactor_phase.response,
+        driver_refactor_phase.response,
+        validation_test.output,
+    )
+    validation_phase = await _run_phase_agent(
+        phase="navigator_validate",
+        role="navigator",
+        prompt=validation_prompt,
+        agent_type="reviewer",
+        model=navigator_model,
+        parent_model=parent_model,
+        deps=deps,
+        tools=child_tools,
+        max_turns=navigator_max_turns,
+        run_agent_fn=run_agent_fn,
+    )
+    validation_phase.test_result = validation_test
+    if validation_phase.status == "error":
+        flow.phases.append(validation_phase)
+        flow.error = "Navigator failed during final validation"
+        return flow
+    if not validation_test.passed:
+        validation_phase.status = "error"
+        flow.phases.append(validation_phase)
+        flow.error = "Validation tests failed after the refactor"
+        return flow
+
+    flow.phases.append(validation_phase)
+    flow.success = True
+    return flow
+
+
+def format_tdd_result(result: DoubleAgentTddResult) -> str:
+    """Render a concise CLI summary for the completed flow."""
+    lines = [
+        f"Task: {result.task}",
+        f"Test command: {result.test_command}",
+        "",
+    ]
+    for phase in result.phases:
+        lines.append(f"[{phase.phase}] {phase.role} -> {phase.status}")
+        if phase.test_result is not None:
+            verdict = "PASS" if phase.test_result.passed else "FAIL"
+            lines.append(
+                f"  test: {verdict} (exit {phase.test_result.returncode})"
+            )
+        preview = phase.response.strip().replace("\n", " ")
+        if preview:
+            lines.append(f"  response: {preview[:160]}")
+    lines.append("")
+    if result.success:
+        lines.append("Double-agent TDD completed successfully.")
+    else:
+        lines.append(f"Double-agent TDD failed: {result.error or 'unknown error'}")
+    return "\n".join(lines)
