new file mode 100644
index 0000000..c9398cb
--- /dev/null
+++ b/ratelimit/middleware.py
@@ -0,0 +1,128 @@
+"""ASGI middleware for Starlette / FastAPI rate limiting.
+
+Emits the standard rate-limit response headers:
+
+- ``X-RateLimit-Limit``     - configured capacity
+- ``X-RateLimit-Remaining`` - remaining tokens/slots at the time of the check
+- ``X-RateLimit-Reset``     - unix epoch seconds at which the counter resets
+- ``Retry-After``           - seconds until retry (when rejected)
+
+The middleware is algorithm-agnostic: you hand it a ``RateLimiter``
+instance and a ``key_fn`` that derives a key from the ASGI scope.
+"""
+
+from __future__ import annotations
+
+import math
+from typing import Any, Awaitable, Callable, Optional
+
+from ratelimit.limiters import RateLimiter
+from ratelimit.types import Decision
+
+Scope = dict[str, Any]
+Receive = Callable[[], Awaitable[dict[str, Any]]]
+Send = Callable[[dict[str, Any]], Awaitable[None]]
+ASGIApp = Callable[[Scope, Receive, Send], Awaitable[None]]
+KeyFn = Callable[[Scope], str]
+
+
+def _default_key_fn(scope: Scope) -> str:
+    client = scope.get("client")
+    if client and isinstance(client, (list, tuple)) and client:
+        return f"ip:{client[0]}"
+    return "ip:unknown"
+
+
+class RateLimitMiddleware:
+    """ASGI middleware enforcing a :class:`RateLimiter`.
+
+    Parameters
+    ----------
+    app:
+        Wrapped ASGI application.
+    limiter:
+        A ``RateLimiter`` instance.
+    key_fn:
+        Maps an ASGI scope dict to a string key. Default: client IP.
+    cost_fn:
+        Optional callable returning the cost for this request
+        (default: 1).
+    exempt_paths:
+        Sequence of path prefixes that bypass the limiter (health checks etc.).
+    """
+
+    def __init__(
+        self,
+        app: ASGIApp,
+        limiter: RateLimiter,
+        *,
+        key_fn: KeyFn = _default_key_fn,
+        cost_fn: Optional[Callable[[Scope], int]] = None,
+        exempt_paths: tuple[str, ...] = (),
+    ) -> None:
+        self.app = app
+        self.limiter = limiter
+        self.key_fn = key_fn
+        self.cost_fn = cost_fn
+        self.exempt_paths = tuple(exempt_paths)
+
+    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:
+        if scope.get("type") != "http":
+            await self.app(scope, receive, send)
+            return
+
+        path = scope.get("path", "")
+        if any(path.startswith(p) for p in self.exempt_paths):
+            await self.app(scope, receive, send)
+            return
+
+        key = self.key_fn(scope)
+        cost = int(self.cost_fn(scope)) if self.cost_fn else 1
+        decision = self.limiter.enforce(key, cost=cost)
+
+        if not decision.allowed:
+            await self._send_429(send, decision)
+            return
+
+        # Allowed: wrap send to inject headers on the outgoing response.
+        limiter_headers = _build_headers(self.limiter.capacity, decision)
+
+        async def send_with_headers(message: dict[str, Any]) -> None:
+            if message.get("type") == "http.response.start":
+                existing = list(message.get("headers") or [])
+                existing.extend(limiter_headers)
+                message = {**message, "headers": existing}
+            await send(message)
+
+        await self.app(scope, receive, send_with_headers)
+
+    async def _send_429(self, send: Send, decision: Decision) -> None:
+        headers = _build_headers(self.limiter.capacity, decision)
+        body = b'{"detail":"rate limit exceeded"}'
+        await send(
+            {
+                "type": "http.response.start",
+                "status": 429,
+                "headers": [
+                    (b"content-type", b"application/json"),
+                    (b"content-length", str(len(body)).encode("ascii")),
+                    *headers,
+                ],
+            }
+        )
+        await send({"type": "http.response.body", "body": body, "more_body": False})
+
+
+def _build_headers(capacity: int, decision: Decision) -> list[tuple[bytes, bytes]]:
+    reset_seconds = (
+        math.ceil(decision.reset_ts / 1000) if decision.reset_ts else 0
+    )
+    headers: list[tuple[bytes, bytes]] = [
+        (b"x-ratelimit-limit", str(capacity).encode("ascii")),
+        (b"x-ratelimit-remaining", str(max(0, decision.remaining)).encode("ascii")),
+        (b"x-ratelimit-reset", str(reset_seconds).encode("ascii")),
+    ]
+    if not decision.allowed:
+        retry_seconds = max(1, math.ceil(decision.retry_after_ms / 1000))
+        headers.append((b"retry-after", str(retry_seconds).encode("ascii")))
+    return headers
diff --git a/ratelimit/types.py b/ratelimit/types.py
new file mode 100644
index 0000000..dd202f1
--- /dev/null
+++ b/ratelimit/types.py
@@ -0,0 +1,33 @@
+"""Shared types for the rate limiter: Decision, configuration, exceptions."""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Literal
+
+
+@dataclass(frozen=True, slots=True)
+class Decision:
+    """Result of an admission check.
+
+    allowed         - whether the request should be served
+    retry_after_ms  - minimum ms before the client should retry; 0 when allowed
+    remaining       - tokens / slots left for this key after this call
+    reset_ts        - unix epoch ms at which the key returns to full capacity
+    """
+
+    allowed: bool
+    retry_after_ms: int
+    remaining: int
+    reset_ts: int
+
+
+OnError = Literal["fail_open", "fail_closed"]
+
+
+class RateLimitError(Exception):
+    """Base for rate-limiter errors."""
+
+
+class BackendUnavailable(RateLimitError):
+    """Raised internally when a backend call fails; translated per policy."""
