+"""Unit tests for SlidingWindowLimiter on the in-memory backend."""
+
+from __future__ import annotations
+
+import pytest
+
+from ratelimit import InMemoryBackend, SlidingWindowLimiter
+
+
+def test_constructor_rejects_bad_params():
+    with pytest.raises(ValueError):
+        SlidingWindowLimiter(capacity=0, period_seconds=1.0)
+    with pytest.raises(ValueError):
+        SlidingWindowLimiter(capacity=1, period_seconds=0)
+
+
+def test_happy_path_allows_up_to_capacity():
+    b = InMemoryBackend()
+    lim = SlidingWindowLimiter(capacity=5, period_seconds=60, backend=b)
+    t0 = 1_000_000
+    for i in range(5):
+        d = lim.enforce("k", now_ms=t0 + i)
+        assert d.allowed, f"{i}th admit unexpectedly denied"
+    d = lim.enforce("k", now_ms=t0 + 5)
+    assert d.allowed is False
+    # The oldest entry was at t0, so retry in ~60s.
+    assert 59_000 <= d.retry_after_ms <= 60_000
+
+
+def test_window_slides():
+    b = InMemoryBackend()
+    lim = SlidingWindowLimiter(capacity=2, period_seconds=1.0, backend=b)
+    t0 = 1_000_000
+    assert lim.enforce("k", now_ms=t0).allowed
+    assert lim.enforce("k", now_ms=t0 + 100).allowed
+    assert lim.enforce("k", now_ms=t0 + 200).allowed is False
+    # After the oldest expires (t0 + 1000 + 1):
+    d = lim.enforce("k", now_ms=t0 + 1001)
+    assert d.allowed
+    # Now one of the two remaining windows is t0+100, still in range.
+    # Another call at t0+1001 should be denied (we have t0+100, t0+1001).
+    d = lim.enforce("k", now_ms=t0 + 1001)
+    assert d.allowed is False
+
+
+def test_per_key_isolation():
+    b = InMemoryBackend()
+    lim = SlidingWindowLimiter(capacity=1, period_seconds=60, backend=b)
+    t0 = 1_000_000
+    assert lim.enforce("a", now_ms=t0).allowed
+    assert lim.enforce("b", now_ms=t0).allowed
+    assert lim.enforce("a", now_ms=t0).allowed is False
+
+
+def test_capacity_one_edge():
+    b = InMemoryBackend()
+    lim = SlidingWindowLimiter(capacity=1, period_seconds=0.5, backend=b)
+    t0 = 1_000_000
+    assert lim.enforce("k", now_ms=t0).allowed
+    assert lim.enforce("k", now_ms=t0 + 499).allowed is False
+    assert lim.enforce("k", now_ms=t0 + 501).allowed
+
+
+def test_cost_greater_than_capacity():
+    b = InMemoryBackend()
+    lim = SlidingWindowLimiter(capacity=3, period_seconds=1.0, backend=b)
+    d = lim.enforce("k", cost=5)
+    assert d.allowed is False
+
+
+def test_cost_exactly_capacity():
+    b = InMemoryBackend()
+    lim = SlidingWindowLimiter(capacity=3, period_seconds=1.0, backend=b)
+    d = lim.enforce("k", cost=3)
+    assert d.allowed
+    assert d.remaining == 0
+    d = lim.enforce("k", cost=1)
+    assert d.allowed is False
+
+
+def test_remaining_after_admit():
+    b = InMemoryBackend()
+    lim = SlidingWindowLimiter(capacity=10, period_seconds=60, backend=b)
+    for i in range(4):
+        lim.enforce("k", now_ms=1_000_000 + i)
+    d = lim.enforce("k", now_ms=1_000_100)
+    assert d.allowed
+    assert d.remaining == 5  # 10 - 5 after admits
