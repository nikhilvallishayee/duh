+"""Unit tests for TokenBucketLimiter on the in-memory backend."""
+
+from __future__ import annotations
+
+import pytest
+
+from ratelimit import InMemoryBackend, TokenBucketLimiter
+
+
+def test_constructor_rejects_bad_params():
+    with pytest.raises(ValueError):
+        TokenBucketLimiter(capacity=0, refill_rate=1.0)
+    with pytest.raises(ValueError):
+        TokenBucketLimiter(capacity=1, refill_rate=0)
+    with pytest.raises(ValueError):
+        TokenBucketLimiter(capacity=1, refill_rate=-1)
+
+
+def test_happy_path_single_admit():
+    b = InMemoryBackend()
+    lim = TokenBucketLimiter(capacity=5, refill_rate=1.0, backend=b)
+    d = lim.enforce("user:1")
+    assert d.allowed is True
+    assert d.remaining == 4
+    assert d.retry_after_ms == 0
+
+
+def test_exhaust_bucket_denies_further():
+    b = InMemoryBackend()
+    lim = TokenBucketLimiter(capacity=3, refill_rate=1.0, backend=b)
+    now = 1_000_000
+    for _ in range(3):
+        d = lim.enforce("k", now_ms=now)
+        assert d.allowed is True
+    d = lim.enforce("k", now_ms=now)
+    assert d.allowed is False
+    # At 1 token/sec we expect ~1000ms to retry.
+    assert 500 <= d.retry_after_ms <= 1500
+
+
+def test_refill_over_time():
+    b = InMemoryBackend()
+    lim = TokenBucketLimiter(capacity=2, refill_rate=2.0, backend=b)
+    t0 = 1_000_000
+    lim.enforce("k", now_ms=t0)
+    lim.enforce("k", now_ms=t0)
+    # After 500ms we expect exactly 1 token refilled (rate=2/sec).
+    d = lim.enforce("k", now_ms=t0 + 500)
+    assert d.allowed is True
+    # Another immediate try should fail.
+    d = lim.enforce("k", now_ms=t0 + 500)
+    assert d.allowed is False
+
+
+def test_refill_cap_at_capacity():
+    b = InMemoryBackend()
+    lim = TokenBucketLimiter(capacity=3, refill_rate=10.0, backend=b)
+    t0 = 1_000_000
+    # Drain.
+    for _ in range(3):
+        assert lim.enforce("k", now_ms=t0).allowed
+    # Wait a long time; bucket must not exceed capacity.
+    d = lim.enforce("k", now_ms=t0 + 1_000_000)
+    assert d.allowed
+    assert d.remaining == 2  # spent one after refilling to 3
+
+
+def test_cost_greater_than_one():
+    b = InMemoryBackend()
+    lim = TokenBucketLimiter(capacity=10, refill_rate=1.0, backend=b)
+    d = lim.enforce("k", cost=7, now_ms=0)
+    assert d.allowed
+    assert d.remaining == 3
+    d = lim.enforce("k", cost=4, now_ms=0)
+    assert d.allowed is False
+
+
+def test_cost_exceeds_capacity_always_denied():
+    b = InMemoryBackend()
+    lim = TokenBucketLimiter(capacity=3, refill_rate=1.0, backend=b)
+    d = lim.enforce("k", cost=5)
+    assert d.allowed is False
+    assert d.retry_after_ms > 0
+
+
+def test_per_key_isolation():
+    b = InMemoryBackend()
+    lim = TokenBucketLimiter(capacity=1, refill_rate=0.01, backend=b)
+    assert lim.enforce("a").allowed
+    # a is exhausted, but b is fresh.
+    assert lim.enforce("b").allowed
+    # a still denied.
+    assert lim.enforce("a", now_ms=1).allowed is False
+
+
+def test_capacity_one_edge():
+    b = InMemoryBackend()
+    lim = TokenBucketLimiter(capacity=1, refill_rate=1.0, backend=b)
+    t0 = 1_000_000
+    assert lim.enforce("k", now_ms=t0).allowed
+    assert lim.enforce("k", now_ms=t0).allowed is False
+    assert lim.enforce("k", now_ms=t0 + 1000).allowed
+
+
+def test_cost_validation():
+    b = InMemoryBackend()
+    lim = TokenBucketLimiter(capacity=10, refill_rate=1, backend=b)
+    with pytest.raises(ValueError):
+        lim.enforce("k", cost=0)
+    with pytest.raises(ValueError):
+        lim.enforce("k", cost=-1)
