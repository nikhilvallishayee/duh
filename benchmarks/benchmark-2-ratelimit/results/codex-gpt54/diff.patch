+import httpx
+import pytest
+from starlette.applications import Starlette
+from starlette.responses import PlainTextResponse
+from starlette.routing import Route
+
+from ratelimit import InMemoryBackend, RateLimitMiddleware, SlidingWindowLimiter
+
+
+async def homepage(request):
+    return PlainTextResponse("ok")
+
+
+@pytest.mark.asyncio
+async def test_rate_limit_middleware_sets_headers_and_denies() -> None:
+    app = Starlette(routes=[Route("/", homepage)])
+    limiter = SlidingWindowLimiter(capacity=1, period_ms=1_000, backend=InMemoryBackend(), namespace="mw")
+    app.add_middleware(RateLimitMiddleware, limiter=limiter, key_fn=lambda request: request.client.host)
+
+    transport = httpx.ASGITransport(app=app)
+    async with httpx.AsyncClient(transport=transport, base_url="http://testserver") as client:
+        allowed = await client.get("/")
+        denied = await client.get("/")
+
+    assert allowed.status_code == 200
+    assert allowed.headers["X-RateLimit-Limit"] == "1"
+    assert allowed.headers["X-RateLimit-Remaining"] == "0"
+    assert "X-RateLimit-Reset" in allowed.headers
+
+    assert denied.status_code == 429
+    assert denied.headers["X-RateLimit-Limit"] == "1"
+    assert denied.headers["Retry-After"] == "1"
+
+
+@pytest.mark.asyncio
+async def test_rate_limit_middleware_can_fail_open() -> None:
+    app = Starlette(routes=[Route("/", homepage)])
+    limiter = SlidingWindowLimiter(capacity=1, period_ms=1_000, backend=InMemoryBackend(), namespace="mw-open")
+    app.add_middleware(
+        RateLimitMiddleware,
+        limiter=limiter,
+        key_fn=lambda request: request.client.host,
+        cost_fn=lambda request: 0,
+        fail_open=True,
+    )
+
+    transport = httpx.ASGITransport(app=app)
+    async with httpx.AsyncClient(transport=transport, base_url="http://testserver") as client:
+        response = await client.get("/")
+
+    assert response.status_code == 200
