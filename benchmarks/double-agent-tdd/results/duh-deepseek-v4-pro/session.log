  [33m> Write[0m(file_path='/Users/nomind/Code/duh/benchmarks/double-agent-tdd/worktrees/duh-deepseek-v4-pro/duh/tools/double_agent_tdd.py', content='"""Double-agent TDD flow — Driver/Navigator pair following red-green-refactor.\n\nImplements ADR-076: two cooperating agents execute a strict six-phase TDD cycle.\n\n    result = await run_tdd_flow(\n        task="Add a divide(a, b) function that raises on zero division",\n        deps=deps,\n        tools=tools,\n        model="claude-sonnet-4-6",\n    )\n    print(result.success)  # True if all six phases passed\n\nAlso exposed as::\n\n    duh tdd --prompt "Add a divide function"\n"""\n\nfrom __future__ import annotations\n\nimport logging\nfrom dataclasses import dataclass, field\nfrom enum import Enum, auto\nfrom typing import Any\n\nfrom duh.agents import run_agent, AgentResult\n\nlogger = logging.getLogger(__name__)\n\n# Maximum number of RED/GREEN retries before giving up.\nMAX_RED_RETRIES = 3\nMAX_GREEN_RETRIES = 2\n\n\n# ---------------------------------------------------------------------------\n# Phase enumeration\n# ---------------------------------------------------------------------------\n\n\nclass TddPhase(Enum):\n    """The six phases of the double-agent TDD flow."""\n    SPEC = auto()             # 1: Navigator drafts test spec\n    RED = auto()              # 2: Driver writes failing test\n    GREEN = auto()            # 3: Driver writes minimum code\n    REFACTOR_PROPOSE = auto()  # 4: Navigator proposes refactor\n    REFACTOR_APPLY = auto()   # 5: Driver applies refactor\n    VALIDATE = auto()         # 6: Navigator validates\n\n\nPHASE_ORDER: list[TddPhase] = [\n    TddPhase.SPEC,\n    TddPhase.RED,\n    TddPhase.GREEN,\n    TddPhase.REFACTOR_PROPOSE,\n    TddPhase.REFACTOR_APPLY,\n    TddPhase.VALIDATE,\n]\n\nPHASE_LABELS: dict[TddPhase, str] = {\n    TddPhase.SPEC: "SPEC (Navigator drafts test spec)",\n    TddPhase.RED: "RED (Driver writes failing test)",\n    TddPhase.GREEN: "GREEN (Driver writes minimum code)",\n    TddPhase.REFACTOR_PROPOSE: "REFACTOR_PROPOSE (Navigator proposes refactor)",\n    TddPhase.REFACTOR_APPLY: "REFACTOR_APPLY (Driver applies refactor)",\n    TddPhase.VALIDATE: "VALIDATE (Navigator validates)",\n}\n\n\n# ---------------------------------------------------------------------------\n# Phase result\n# ---------------------------------------------------------------------------\n\n\n@dataclass\nclass PhaseResult:\n    """Outcome of a single TDD phase."""\n    phase: TddPhase\n    success: bool\n    output: str = ""\n    error: str = ""\n\n\n# ---------------------------------------------------------------------------\n# Top-level result\n# ---------------------------------------------------------------------------\n\n\n@dataclass\nclass TddResult:\n    """Result of a full double-agent TDD run."""\n    task: str\n    success: bool\n    phases: list[PhaseResult] = field(default_factory=list)\n    model: str = ""\n\n    @property\n    def failed_phase(self) -> TddPhase | None:\n        """Return the first failed phase, or None if all passed."""\n        for pr in self.phases:\n            if not pr.success:\n                return pr.phase\n        return None\n\n    def format_summary(self) -> str:\n        """Human-readable summary of all phases."""\n        lines: list[str] = []\n        for pr in self.phases:\n            status = "PASS" if pr.success else "FAIL"\n            lines.append(f"  [{status}] {PHASE_LABELS.get(pr.phase, pr.phase.name)}")\n            if pr.error:\n                lines.append(f"         Error: {pr.error}")\n        if self.success:\n            lines.append("\\n  All phases passed.")\n        else:\n            fp = self.failed_phase\n            if fp:\n                lines.append(f"\\n  Flow aborted at phase: {PHASE_LABELS.get(fp, fp.name)}")\n        return "\\n".join(lines)\n\n\n# ---------------------------------------------------------------------------\n# Prompt templates for each phase\n# ---------------------------------------------------------------------------\n\n\ndef _spec_prompt(task: str) -> str:\n    return (\n        "You are the Navigator in a TDD pair. Draft a test specification for "\n        "the following task. Describe:\\n"\n        "  1. What behavior to test.\\n"\n        "  2. The expected inputs and outputs.\\n"\n        \'  3. Edge cases that should be covered.\\n\'\n        \'  4. The test framework to use (e.g. pytest).\\n\'\n        "\\n"\n        "Output ONLY the spec. Do NOT write any code or tests yourself.\\n"\n        "\\n"\n        f"Task: {task}\\n"\n    )\n\n\ndef _red_prompt(spec: str, task: str) -> str:\n    return (\n        "You are the Driver in a TDD pair. Based on the spec below, write a "\n        "FAILING test. The test MUST fail — the code to make it pass does "\n        "not exist yet. Use the project\'s test framework.\\n"\n        "\\n"\n        "After writing the test file, run the tests and report the result. "\n        "If the test PASSES (unexpectedly), say so clearly.\\n"\n        "\\n"\n        f"[SPEC]\\n{spec}\\n[/SPEC]\\n"\n        "\\n"\n        f"Task: {task}\\n"\n    )\n\n\ndef _red_retry_prompt(spec: str, task: str, previous_output: str) -> str:\n    return (\n        "You are the Driver in a TDD pair. Your previous test PASSED "\n        "unexpectedly — the spec was not tight enough. The Navigator has "\n        "revised the spec below.\\n"\n        "\\n"\n        f"[PREVIOUS TEST OUTPUT]\\n{previous_output}\\n[/PREVIOUS TEST OUTPUT]\\n"\n        "\\n"\n        f"[REVISED SPEC]\\n{spec}\\n[/REVISED SPEC]\\n"\n        "\\n"\n        f"Task: {task}\\n"\n        "\\n"\n        "Write a new failing test against the revised spec. Run it and "\n        "confirm it FAILS.\\n"\n    )\n\n\ndef _green_prompt(spec: str, test_code: str, task: str) -> str:\n    return (\n        "You are the Driver in a TDD pair. The test below is currently "\n        "failing (RED phase complete). Write the MINIMUM code to make it "\n        "pass. Do NOT add features, error handling, or polish beyond what "\n        "the test requires.\\n"\n        "\\n"\n        f"[TEST CODE]\\n{test_code}\\n[/TEST CODE]\\n"\n        "\\n"\n        f"[SPEC]\\n{spec}\\n[/SPEC]\\n"\n        "\\n"\n        f"Task: {task}\\n"\n        "\\n"\n        "Implement the minimum code, then run the tests to confirm they PASS.\\n"\n    )\n\n\ndef _green_retry_prompt(spec: str, test_code: str, task: str, previous_output: str) -> str:\n    return (\n        "You are the Driver in a TDD pair. Your previous attempt did not "\n        "make all tests pass. Try again — write the minimum code to make "\n        "the test below pass.\\n"\n        "\\n"\n        f"[PREVIOUS ATTEMPT OUTPUT]\\n{previous_output}\\n[/PREVIOUS ATTEMPT OUTPUT]\\n"\n        "\\n"\n        f"[TEST CODE]\\n{test_code}\\n[/TEST CODE]\\n"\n        "\\n"\n        f"[SPEC]\\n{spec}\\n[/SPEC]\\n"\n        "\\n"\n        f"Task: {task}\\n"\n    )\n\n\ndef _refactor_propose_prompt(green_output: str, task: str) -> str:\n    return (\n        "You are the Navigator in a TDD pair. The Driver has made the test "\n        "pass (GREEN phase complete). Review the implementation below and "\n        "propose a refactor. The refactor must:\\n"\n        "  1. Improve code clarity or structure.\\n"\n        \'  2. NOT change behavior (all tests must stay green).\\n\'\n        "  3. Be specific — reference concrete lines or patterns.\\n"\n        "\\n"\n        f"[GREEN IMPLEMENTATION]\\n{green_output}\\n[/GREEN IMPLEMENTATION]\\n"\n        "\\n"\n        f"Task: {task}\\n"\n        "\\n"\n        "Output your refactor suggestions as a clear, numbered list.\\n"\n    )\n\n\ndef _refactor_apply_prompt(refactor_suggestions: str, task: str) -> str:\n    return (\n        "You are the Driver in a TDD pair. Apply the Navigator\'s refactor "\n        "suggestions below. After applying, run the tests to confirm they "\n        "still pass.\\n"\n        "\\n"\n        f"[REFACTOR SUGGESTIONS]\\n{refactor_suggestions}\\n[/REFACTOR SUGGESTIONS]\\n"\n        "\\n"\n        f"Task: {task}\\n"\n    )\n\n\ndef _validate_prompt(refactor_output: str, task: str) -> str:\n    return (\n        "You are the Navigator in a TDD pair. The Driver has applied your "\n        "refactor. Validate that:\\n"\n        "  1. Tests still pass.\\n"\n        \'  2. The refactor landed cleanly.\\n\'\n        "  3. No behavior was changed.\\n"\n        "\\n"\n        f"[REFACTORED OUTPUT]\\n{refactor_output}\\n[/REFACTORED OUTPUT]\\n"\n        "\\n"\n        f"Task: {task}\\n"\n        "\\n"\n        "Report PASS or FAIL with reasoning.\\n"\n    )\n\n\n# ---------------------------------------------------------------------------\n# Core flow execution\n# ---------------------------------------------------------------------------\n\n\nasync def run_tdd_flow(\n    *,\n    task: str,\n    deps: Any,\n    tools: list[Any] | None = None,\n    model: str = "",\n    cwd: str = ".",\n    max_turns_per_phase: int = 30,\n    on_phase_start: Any = None,\n    on_phase_end: Any = None,\n) -> TddResult:\n    """Run the full six-phase double-agent TDD flow.\n\n    Args:\n        task: The programming task (e.g. "Add a divide function").\n        deps: Deps instance with call_model and approve.\n        tools: Tool instances available to agents.\n        model: Model to use for both Driver and Navigator.\n        cwd: Working directory.\n        max_turns_per_phase: Maximum turns per agent phase.\n        on_phase_start: Optional async callback(phase: TddPhase).\n        on_phase_end: Optional async callback(result: PhaseResult).\n\n    Returns:\n        TddResult with success status and per-phase details.\n    """\n    phases: list[PhaseResult] = []\n    accumulated_test_code: str = ""\n    accumulated_impl_output: str = ""\n    spec_text: str = ""\n\n    # ------------------------------------------------------------------\n    # Phase 1: SPEC — Navigator drafts test spec\n    # ------------------------------------------------------------------\n    if on_phase_start:\n        await on_phase_start(TddPhase.SPEC)\n\n    nav_result = await _run_agent_phase(\n        prompt=_spec_prompt(task),\n        agent_type="reviewer",\n        model=model,\n        deps=deps,\n        tools=tools,\n        cwd=cwd,\n        max_turns=max_turns_per_phase,\n    )\n    spec_text = nav_result.result_text if nav_result.result_text else ""\n    spec_success = bool(spec_text.strip()) and not nav_result.is_error\n\n    spec_pr = PhaseResult(\n        phase=TddPhase.SPEC,\n        success=spec_success,\n        output=spec_text,\n        error=nav_result.error,\n    )\n    phases.append(spec_pr)\n    if on_phase_end:\n        await on_phase_end(spec_pr)\n    if not spec_success:\n        return TddResult(task=task, success=False, phases=phases, model=model)\n\n    # ------------------------------------------------------------------\n    # Phase 2: RED — Driver writes failing test\n    # ------------------------------------------------------------------\n    red_pr: PhaseResult | None = None\n    for red_attempt in range(1, MAX_RED_RETRIES + 1):\n        if on_phase_start:\n            await on_phase_start(TddPhase.RED)\n\n        if red_attempt == 1:\n            drv_prompt = _red_prompt(spec_text, task)\n        else:\n            drv_prompt = _red_retry_prompt(spec_text, task, red_pr.output if red_pr else "")\n\n        drv_result = await _run_agent_phase(\n            prompt=drv_prompt,\n            agent_type="coder",\n            model=model,\n            deps=deps,\n            tools=tools,\n            cwd=cwd,\n            max_turns=max_turns_per_phase,\n        )\n\n        red_output = drv_result.result_text if drv_result.result_text else ""\n        test_did_fail = _detect_test_failure(red_output)\n\n        if test_did_fail or drv_result.is_error:\n            # Test failed (good) OR agent errored — proceed to GREEN.\n            red_pr = PhaseResult(\n                phase=TddPhase.RED,\n                success=True,\n                output=red_output,\n                error=drv_result.error if drv_result.is_error else "",\n            )\n            if drv_result.error and not test_did_fail:\n                # Agent error but we can\'t confirm test failure — mark as\n                # success anyway since there\'s an error flag.\n                pass\n            phases.append(red_pr)\n            if on_phase_end:\n                await on_phase_end(red_pr)\n            accumulated_test_code = red_output\n            break\n        else:\n            # Test passed unexpectedly — spec not tight enough.\n            red_pr = PhaseResult(\n                phase=TddPhase.RED,\n                success=False,\n                output=red_output,\n                error="Test passed unexpectedly. Spec revision needed.",\n            )\n            phases.append(red_pr)\n            if on_phase_end:\n                await on_phase_end(red_pr)\n\n            if red_attempt < MAX_RED_RETRIES:\n                # Revise spec: ask Navigator to tighten it.\n                if on_phase_start:\n                    await on_phase_start(TddPhase.SPEC)\n                revised_nav = await _run_agent_phase(\n                    prompt=_spec_retry_prompt(spec_text, red_output, task),\n                    agent_type="reviewer",\n                    model=model,\n                    deps=deps,\n                    tools=tools,\n                    cwd=cwd,\n                    max_turns=max_turns_per_phase,\n                )\n                new_spec = revised_nav.result_text if revised_nav.result_text else ""\n                if new_spec.strip():\n                    spec_text = new_spec\n                spec_pr2 = PhaseResult(\n                    phase=TddPhase.SPEC,\n                    success=bool(new_spec.strip()),\n                    output=new_spec,\n                    error=revised_nav.error,\n                )\n                phases.append(spec_pr2)\n                if on_phase_end:\n                    await on_phase_end(spec_pr2)\n    else:\n        # Exhausted RED retries.\n        return TddResult(task=task, success=False, phases=phases, model=model)\n\n    if not accumulated_test_code:\n        return TddResult(task=task, success=False, phases=phases, model=model)\n\n    # ------------------------------------------------------------------\n    # Phase 3: GREEN — Driver writes minimum code\n    # ------------------------------------------------------------------\n    green_pr: PhaseResult | None = None\n    for green_attempt in range(1, MAX_GREEN_RETRIES + 1):\n        if on_phase_start:\n            await on_phase_start(TddPhase.GREEN)\n\n        if green_attempt == 1:\n            drv_prompt = _green_prompt(spec_text, accumulated_test_code, task)\n        else:\n            drv_prompt = _green_retry_prompt(\n                spec_text, accumulated_test_code, task,\n                green_pr.output if green_pr else "",\n            )\n\n        drv_result = await _run_agent_phase(\n            prompt=drv_prompt,\n            agent_type="coder",\n            model=model,\n            deps=deps,\n            tools=tools,\n            cwd=cwd,\n            max_turns=max_turns_per_phase,\n        )\n\n        green_output = drv_result.result_text if drv_result.result_text else ""\n        test_did_pass = _detect_test_pass(green_output)\n\n        if test_did_pass and not drv_result.is_error:\n            green_pr = PhaseResult(\n                phase=TddPhase.GREEN,\n                success=True,\n                output=green_output,\n            )\n            phases.append(green_pr)\n            if on_phase_end:\n                await on_phase_end(green_pr)\n            accumulated_impl_output = green_output\n            break\n        else:\n            green_pr = PhaseResult(\n                phase=TddPhase.GREEN,\n                success=False,\n                output=green_output,\n                error=drv_result.error or "Tests did not pass.",\n            )\n            phases.append(green_pr)\n            if on_phase_end:\n                await on_phase_end(green_pr)\n    else:\n        return TddResult(task=task, success=False, phases=phases, model=model)\n\n    if not accumulated_impl_output:\n        return TddResult(task=task, success=False, phases=phases, model=model)\n\n    # ------------------------------------------------------------------\n    # Phase 4: REFACTOR_PROPOSE — Navigator proposes refactor\n    # ------------------------------------------------------------------\n    if on_phase_start:\n        await on_phase_start(TddPhase.REFACTOR_PROPOSE)\n\n    nav_result = await _run_agent_phase(\n        prompt=_refactor_propose_prompt(accumulated_impl_output, task),\n        agent_type="reviewer",\n        model=model,\n        deps=deps,\n        tools=tools,\n        cwd=cwd,\n        max_turns=max_turns_per_phase,\n    )\n    refactor_suggestions = nav_result.result_text if nav_result.result_text else ""\n    refactor_propose_success = bool(refactor_suggestions.strip()) and not nav_result.is_error\n\n    refactor_propose_pr = PhaseResult(\n        phase=TddPhase.REFACTOR_PROPOSE,\n        success=refactor_propose_success,\n        output=refactor_suggestions,\n        error=nav_result.error,\n    )\n    phases.append(refactor_propose_pr)\n    if on_phase_end:\n        await on_phase_end(refactor_propose_pr)\n    if not refactor_propose_success:\n        return TddResult(task=task, success=False, phases=phases, model=model)\n\n    # ------------------------------------------------------------------\n    # Phase 5: REFACTOR_APPLY — Driver applies refactor\n    # ------------------------------------------------------------------\n    if on_phase_start:\n        await on_phase_start(TddPhase.REFACTOR_APPLY)\n\n    drv_result = await _run_agent_phase(\n        prompt=_refactor_apply_prompt(refactor_suggestions, task),\n        agent_type="coder",\n        model=model,\n        deps=deps,\n        tools=tools,\n        cwd=cwd,\n        max_turns=max_turns_per_phase,\n    )\n    refactor_output = drv_result.result_text if drv_result.result_text else ""\n    test_still_pass = _detect_test_pass(refactor_output)\n    refactor_apply_success = test_still_pass and not drv_result.is_error\n\n    refactor_apply_pr = PhaseResult(\n        phase=TddPhase.REFACTOR_APPLY,\n        success=refactor_apply_success,\n        output=refactor_output,\n        error=drv_result.error if drv_result.is_error else (\n            "" if test_still_pass else "Tests did not pass after refactor."\n        ),\n    )\n    phases.append(refactor_apply_pr)\n    if on_phase_end:\n        await on_phase_end(refactor_apply_pr)\n    if not refactor_apply_success:\n        return TddResult(task=task, success=False, phases=phases, model=model)\n\n    # ------------------------------------------------------------------\n    # Phase 6: VALIDATE — Navigator validates\n    # ------------------------------------------------------------------\n    if on_phase_start:\n        await on_phase_start(TddPhase.VALIDATE)\n\n    nav_result = await _run_agent_phase(\n        prompt=_validate_prompt(refactor_output, task),\n        agent_type="reviewer",\n        model=model,\n        deps=deps,\n        tools=tools,\n        cwd=cwd,\n        max_turns=max_turns_per_phase,\n    )\n    validate_text = nav_result.result_text if nav_result.result_text else ""\n    validate_pass = _detect_validate_pass(validate_text) and not nav_result.is_error\n\n    validate_pr = PhaseResult(\n        phase=TddPhase.VALIDATE,\n        success=validate_pass,\n        output=validate_text,\n        error=nav_result.error if nav_result.is_error else (\n            "" if validate_pass else "Validation did not report PASS."\n        ),\n    )\n    phases.append(validate_pr)\n    if on_phase_end:\n        await on_phase_end(validate_pr)\n\n    all_passed = all(p.success for p in phases)\n    return TddResult(task=task, success=all_passed, phases=phases, model=model)\n\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\n\ndef _spec_retry_prompt(previous_spec: str, test_output: str, task: str) -> str:\n    """Prompt for Navigator to revise the spec after RED pass."""\n    return (\n        "You are the Navigator in a TDD pair. The test you specified PASSED "\n        "unexpectedly — the spec was not tight enough (the test didn\'t "\n        "actually exercise new behavior). Revise the spec to be more "\n        "specific. Focus on the NEW behavior that does NOT exist yet.\\n"\n        "\\n"\n        f"[PREVIOUS SPEC]\\n{previous_spec}\\n[/PREVIOUS SPEC]\\n"\n        "\\n"\n        f"[TEST OUTPUT]\\n{test_output}\\n[/TEST OUTPUT]\\n"\n        "\\n"\n        f"Task: {task}\\n"\n        "\\n"\n        "Output only the revised spec.\\n"\n    )\n\n\nasync def _run_agent_phase(\n    *,\n    prompt: str,\n    agent_type: str,\n    model: str,\n    deps: Any,\n    tools: list[Any] | None,\n    cwd: str,\n    max_turns: int,\n) -> AgentResult:\n    """Run a single agent for one phase of the TDD flow.\n\n    Wraps run_agent with the standard phase configuration.\n    """\n    return await run_agent(\n        prompt=prompt,\n        agent_type=agent_type,\n        model=model,\n        parent_model=model,\n        deps=deps,\n        tools=tools,\n        cwd=cwd,\n        max_turns=max_turns,\n    )\n\n\ndef _detect_test_failure(output: str) -> bool:\n    """Detect whether test output indicates test failure.\n\n    Looks for patterns like \'FAILED\', \'AssertionError\', \'1 failed\',\n    \'FAIL\', exit code patterns, etc.\n    """\n    text = output.lower()\n    # Strong signals of test failure.\n    failure_signals = [\n        "failed",\n        "assertionerror",\n        "assertion error",\n        "fail:",\n        "tests failed",\n        "1 failed",\n        "failures=",\n        "error",  # pytest error during collection/execution\n        "exit code 1",\n        "exitcode 1",\n        "exited with code 1",\n    ]\n    # Signals that suggest tests passed (should NOT count as failure).\n    pass_signals = [\n        "passed",\n        "1 passed",\n        "all tests passed",\n        "ok",\n        "exit code 0",\n        "exitcode 0",\n        "exited with code 0",\n    ]\n\n    has_failure = any(sig in text for sig in failure_signals)\n    has_pass = any(sig in text for sig in pass_signals)\n\n    # If we see both, prefer failure (a failure signal is stronger).\n    return has_failure\n\n\ndef _detect_test_pass(output: str) -> bool:\n    """Detect whether test output indicates tests passed."""\n    text = output.lower()\n    pass_signals = [\n        "passed",\n        "1 passed",\n        "all tests passed",\n        "tests passed",\n        "test passed",\n        "exit code 0",\n        "exitcode 0",\n        "exited with code 0",\n        "ok",\n    ]\n    failure_signals = [\n        "failed",\n        "assertionerror",\n        "assertion error",\n        "fail:",\n        "1 failed",\n        "failures=",\n        "exit code 1",\n        "exitcode 1",\n    ]\n\n    has_pass = any(sig in text for sig in pass_signals)\n    has_failure = any(sig in text for sig in failure_signals)\n\n    #alen If we see failure and pass, default to failure.\n    if has_failure:\n        return False\n    return has_pass\n\n\ndef _detect_validate_pass(output: str) -> bool:\n    """Detect whether Navigator\'s validation says PASS."""\n    text = output.upper()\n    # Simple: look for "PASS" at start of line or as a standalone word.\n    if "PASS" in text:\n        # Check it\'s not part of a failure sentence.\n        fail_context = [\n            "NOT PASS", "DID NOT PASS", "DOES NOT PASS",\n            "FAIL", "DIDN\'T PASS", "DIDNT PASS",\n        ]\n        if not any(fc in text for fc in fail_context):\n            return True\n    return False')
