 lock = threading.Lock()\n    start = threading.Event()\n\n    def worker():\n        start.wait()\n        if lim.enforce("solo").allowed:\n            with lock:\n                hits[0] += 1\n\n    threads = [threading.Thread(target=worker) for _ in range(100)]\n    for t in threads:\n        t.start()\n    start.set()\n    for t in threads:\n        t.join()\n\n    assert hits[0] == 1\n\n\ndef test_chaos_drops_via_sporadic_failures():\n    """Backend intermittently raises. fail_open=True must keep the\n    app alive; fail_open=False must reject in a bounded way."""\n    from ratelimit import RedisBackend\n\n    class FlakyClient:\n        def __init__(self):\n            self.n = 0\n\n        def register_script(self, src):\n            outer = self\n\n            class _S:\n                def __call__(self, *, keys, args):\n                    outer.n += 1\n                    if outer.n % 2 == 0:\n                        raise ConnectionError("chaos")\n                    # Succeed: pretend the bucket is fine.\n                    return [1, 5, 0, 0]\n\n            return _S()\n\n    backend_open = RedisBackend(FlakyClient(), fail_open=True)\n    lim = TokenBucketLimiter(capacity=10, refill_per_sec=1, backend=backend_open)\n    # Every call must produce an allowed decision.\n    for _ in range(20):\n        d = lim.enforce("k")\n        assert d.allowed  # fail_open keeps traffic flowing\n\n    backend_closed = RedisBackend(FlakyClient(), fail_open=False)\n    lim2 = TokenBucketLimiter(capacity=10, refill_per_sec=1, backend=backend_closed)\n    rejections = 0\n    for _ in range(20):\n        d = lim2.enforce("k")\n        if not d.allowed:\n            rejections += 1\n    # About half of the calls must be rejected (the failure path).\n    assert 5 <= rejections <= 15\n\n\ndef test_decorator_reentry_deep():\n    """Deep recursion with reentrant=True charges exactly once."""\n    lim = TokenBucketLimiter(capacity=1, refill_per_sec=0.0001)\n\n    @rate_limit(lim, key_fn=lambda depth: "deep", reentrant=True)\n    def go(depth: int) -> int:\n        if depth == 0:\n            return 0\n        return go(depth - 1)\n\n    # One top-level call consumes the single token; recursion\n    # (50 deep) does not exhaust anything.\n    assert go(50) == 0\n    # Second top-level call rejected (no more tokens).\n    import pytest\n\n    from ratelimit import RateLimitExceeded\n\n    with pytest.raises(RateLimitExceeded):\n        go(0)\n\n\ndef test_decorator_reentry_across_distinct_keys_still_charges():\n    """Reentry detection is per-key: a nested call with a *different*\n    key must still consume a token from the limiter."""\n    lim = TokenBucketLimiter(capacity=2, refill_per_sec=0.0001)\n\n    @rate_limit(lim, key_fn=lambda key: key, reentrant=True)\n    def f(key: str) -> str:\n        if key == "outer":\n            return f("inner")\n        return key\n\n    # outer: 1 token, inner: 1 token → bucket empty\n    assert f("outer") == "inner"\n    # Now both outer and inner are exhausted\n    from ratelimit import RateLimitExceeded\n    import pytest\n\n    with pytest.raises(RateLimitExceeded):\n        f("outer")\n')
