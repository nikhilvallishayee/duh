+# ---------------------------------------------------------------------------
+# 2. RED phase gate — assertion failure tagged distinctly
+# ---------------------------------------------------------------------------
+
+
+class TestRedGreenGateTagging:
+    """The RED and GREEN gates are inverse: at RED, a failing test is
+    success; at GREEN, a passing test is success.  Consumers rely on
+    the ``phase`` tag on ``tdd_gate`` events to disambiguate.
+    """
+
+    async def test_red_gate_tags_event_with_red_phase(self):
+        tdd = TddMode(
+            driver=_make_engine(["wrote test"]),
+            navigator=_make_engine(["spec"]),
+            test_runner=FakeRunner(
+                [GateResult(phase="", exit_code=1, stdout="AssertionError: x != y", stderr="")],
+            ),
+        )
+        await _collect(tdd.draft_spec("feature"))
+
+        events = []
+        async for event in tdd.red():
+            events.append(event)
+
+        gate_events = [e for e in events if e.get("type") == "tdd_gate"]
+        assert len(gate_events) == 1
+        gate = gate_events[0]
+        assert gate["phase"] == "RED"
+        assert gate["passed"] is True        # RED-gate passes on failure
+        assert gate["test_passed"] is False  # but the test itself failed
+        assert gate["exit_code"] == 1
+        assert "AssertionError" in gate["stdout"]
+
+    async def test_green_gate_tags_event_with_green_phase(self):
+        runner = FakeRunner(
+            [
+                GateResult(phase="", exit_code=1, stdout="fail", stderr=""),
+                GateResult(phase="", exit_code=0, stdout="1 passed", stderr=""),
+            ],
+        )
+        tdd = TddMode(
+            driver=_make_engine(["wrote test", "wrote code"]),
+            navigator=_make_engine(["spec"]),
+            test_runner=runner,
+        )
+        await _collect(tdd.draft_spec("feature"))
+        await _collect(tdd.red())
+
+        events = []
+        async for event in tdd.green():
+            events.append(event)
+
+        gate_events = [e for e in events if e.get("type") == "tdd_gate"]
+        assert len(gate_events) == 1
+        assert gate_events[0]["phase"] == "GREEN"
+        assert gate_events[0]["passed"] is True
+        assert gate_events[0]["test_passed"] is True
+        assert gate_events[0]["exit_code"] == 0
+
+    async def test_red_passing_test_reverts_to_empty_and_counts_revision(self):
+        """If the RED test passes, the spec was too loose — revert to
+        EMPTY so the Navigator can re-draft a tighter spec.
+        """
+        tdd = TddMode(
+            driver=_make_engine(["wrote vacuous test"]),
+            navigator=_make_engine(["loose spec"]),
+            test_runner=FakeRunner(
+                [GateResult(phase="", exit_code=0, stdout="1 passed", stderr="")],
+            ),
+        )
+        await _collect(tdd.draft_spec("feature"))
+        assert tdd.state == TddState.SPEC
+
+        events = []
+        async for event in tdd.red():
+            events.append(event)
+
+        # Gate event present and indicates failure
+        gate_events = [e for e in events if e.get("type") == "tdd_gate"]
+        assert gate_events[0]["phase"] == "RED"
+        assert gate_events[0]["passed"] is False
+        # State reverted so the caller can call .spec() again
+        assert tdd.state == TddState.EMPTY
+        assert tdd.spec_revisions == 1
+        assert tdd.spec == ""
+
+    async def test_green_failing_test_stays_in_red_state(self):
+        """If GREEN's test still fails, we do NOT silently advance."""
+        runner = FakeRunner(
+            [
+                GateResult(phase="", exit_code=1, stdout="fail", stderr=""),  # RED
+                GateResult(phase="", exit_code=1, stdout="still failing", stderr=""),  # GREEN
+            ],
+        )
+        tdd = TddMode(
+            driver=_make_engine(["wrote test", "wrote wrong code"]),
+            navigator=_make_engine(["spec"]),
+            test_runner=runner,
+        )
+        await _collect(tdd.draft_spec("feature"))
+        await _collect(tdd.red())
+        assert tdd.state == TddState.RED
+        await _collect(tdd.green())
+        # GREEN gate failed, so we remain in RED.
+        assert tdd.state == TddState.RED
+
