@@ -0,0 +1,64 @@
+import threading
+from concurrent.futures import ThreadPoolExecutor
+
+import fakeredis
+
+from ratelimit import InMemoryBackend, RedisBackend, SlidingWindowLimiter, TokenBucketLimiter
+
+
+def _run_concurrent_enforcement(limiter, key: str, workers: int = 128):
+    barrier = threading.Barrier(workers)
+    decisions = []
+    guard = threading.Lock()
+
+    def invoke():
+        barrier.wait()
+        decision = limiter.enforce(key)
+        with guard:
+            decisions.append(decision)
+
+    with ThreadPoolExecutor(max_workers=workers) as pool:
+        futures = [pool.submit(invoke) for _ in range(workers)]
+        for future in futures:
+            future.result()
+
+    return decisions
+
+
+def test_inmemory_token_bucket_does_not_overgrant_under_concurrency() -> None:
+    limiter = TokenBucketLimiter(
+        capacity=25,
+        refill_rate=0.001,
+        backend=InMemoryBackend(),
+        namespace="concurrent-tb",
+    )
+
+    decisions = _run_concurrent_enforcement(limiter, "shared")
+
+    assert sum(1 for decision in decisions if decision.allowed) == 25
+
+
+def test_inmemory_sliding_window_does_not_overgrant_under_concurrency() -> None:
+    limiter = SlidingWindowLimiter(
+        capacity=25,
+        period_ms=60_000,
+        backend=InMemoryBackend(),
+        namespace="concurrent-sw",
+    )
+
+    decisions = _run_concurrent_enforcement(limiter, "shared")
+
+    assert sum(1 for decision in decisions if decision.allowed) == 25
+
+
+def test_redis_sliding_window_does_not_overgrant_under_concurrency() -> None:
+    limiter = SlidingWindowLimiter(
+        capacity=25,
+        period_ms=60_000,
+        backend=RedisBackend(fakeredis.FakeRedis()),
+        namespace="concurrent-redis-sw",
+    )
+
+    decisions = _run_concurrent_enforcement(limiter, "shared")
+
+    assert sum(1 for decision in decisions if decision.allowed) == 25
