@@ -0,0 +1,66 @@
+from __future__ import annotations
+
+import inspect
+import math
+from collections.abc import Awaitable, Callable
+from typing import Any, Optional, Union
+
+from starlette.middleware.base import BaseHTTPMiddleware
+from starlette.requests import Request
+from starlette.responses import PlainTextResponse, Response
+
+from ratelimit.limiters import RateLimiter
+
+
+class RateLimitMiddleware(BaseHTTPMiddleware):
+    def __init__(
+        self,
+        app: Any,
+        limiter: RateLimiter,
+        key_fn: Callable[[Request], Union[str, Awaitable[str]]],
+        cost_fn: Optional[Callable[[Request], Union[int, Awaitable[int]]]] = None,
+        fail_open: bool = False,
+    ) -> None:
+        super().__init__(app)
+        self.limiter = limiter
+        self.key_fn = key_fn
+        self.cost_fn = cost_fn
+        self.fail_open = fail_open
+
+    async def dispatch(self, request: Request, call_next: Callable[[Request], Awaitable[Response]]) -> Response:
+        try:
+            key = self.key_fn(request)
+            if inspect.isawaitable(key):
+                key = await key
+
+            cost = 1
+            if self.cost_fn is not None:
+                cost = self.cost_fn(request)
+                if inspect.isawaitable(cost):
+                    cost = await cost
+
+            decision = self.limiter.enforce(key=key, cost=cost)
+        except Exception:
+            if not self.fail_open:
+                raise
+            response = await call_next(request)
+            return response
+
+        headers = _decision_headers(self.limiter.limit, decision.retry_after_ms, decision.remaining, decision.reset_ts)
+        if not decision.allowed:
+            return PlainTextResponse("Rate limit exceeded", status_code=429, headers=headers)
+
+        response = await call_next(request)
+        response.headers.update(headers)
+        return response
+
+
+def _decision_headers(limit: int, retry_after_ms: int, remaining: int, reset_ts: int) -> dict[str, str]:
+    headers = {
+        "X-RateLimit-Limit": str(limit),
+        "X-RateLimit-Remaining": str(remaining),
+        "X-RateLimit-Reset": str(reset_ts),
+    }
+    if retry_after_ms > 0:
+        headers["Retry-After"] = str(max(1, math.ceil(retry_after_ms / 1000)))
+    return headers
