+# ---------------------------------------------------------------------------
+# 4. Full end-to-end run against the stub provider
+# ---------------------------------------------------------------------------
+
+
+class TestEndToEndStubProvider:
+    """Exercise every phase against the real :class:`StubProvider` — the
+    same deterministic provider the CI smoke tests use.  This proves the
+    wiring (Engine + Deps + phase sequencing + gate) all compose.
+    """
+
+    async def test_full_run_completes_against_stub(self, monkeypatch):
+        from duh.adapters.stub_provider import StubProvider
+
+        # Build two engines, each with its own StubProvider.  The stub
+        # always replies with "stub-ok" — we don't care about the text,
+        # we care that the phases run and the state advances.
+        stub = StubProvider(model="stub-model")
+        driver = Engine(
+            deps=Deps(call_model=stub.stream),
+            config=EngineConfig(model="stub-model"),
+        )
+        navigator = Engine(
+            deps=Deps(call_model=stub.stream),
+            config=EngineConfig(model="stub-model"),
+        )
+
+        # Scripted test runner: RED fails, GREEN passes, VALIDATE passes.
+        runner = FakeRunner(
+            [
+                GateResult(phase="", exit_code=1, stdout="E  AssertionError", stderr=""),
+                GateResult(phase="", exit_code=0, stdout="1 passed", stderr=""),
+                GateResult(phase="", exit_code=0, stdout="1 passed", stderr=""),
+            ],
+        )
+        tdd = TddMode(
+            driver=driver,
+            navigator=navigator,
+            test_runner=runner,
+            test_command=["pytest", "-x"],
+        )
+
+        events = []
+        async for event in tdd.run_all("LRU cache drops oldest entry"):
+            events.append(event)
+
+        # Final state reached
+        assert tdd.state == TddState.DONE
+        # All six phases ran
+        phase_names = [e["phase"] for e in events if e.get("type") == "tdd_phase"]
+        assert phase_names == [
+            "SPEC",
+            "RED",
+            "GREEN",
+            "REFACTOR_PLAN",
+            "REFACTOR_APPLY",
+            "VALIDATE",
+        ]
+        # Three gate events: RED (passed=True because test failed),
+        # GREEN (passed=True because test passed), VALIDATE (same).
+        gate_events = [e for e in events if e.get("type") == "tdd_gate"]
+        assert [g["phase"] for g in gate_events] == ["RED", "GREEN", "VALIDATE"]
+        assert all(g["passed"] for g in gate_events)
+        # History has one entry per phase (6 total).
+        assert [h.phase for h in tdd.history] == [
+            "SPEC",
+            "RED",
+            "GREEN",
+            "REFACTOR_PLAN",
+            "REFACTOR_APPLY",
+            "VALIDATE",
+        ]
+        # Spec + refactor_plan populated from the stub's canned response.
+        assert tdd.spec != ""
+        assert tdd.refactor_plan != ""
+        # The runner was called three times (once per gate), each time
+        # with the custom test command we passed in.
+        assert len(runner.calls) == 3
+        for cmd, _cwd in runner.calls:
+            assert cmd == ["pytest", "-x"]
+
