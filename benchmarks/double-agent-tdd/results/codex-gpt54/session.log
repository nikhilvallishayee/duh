+        try:
+            return asyncio.run(run_tdd(args))
+        except KeyboardInterrupt:
+            sys.stderr.write("\nInterrupted.\n")
+            return 130
+
     if args.command == "bridge":
         from duh.bridge.server import BridgeServer
 
