+from __future__ import annotations
+
+from .core import Backend, Decision, RateLimiter
+
+
+class TokenBucketLimiter(RateLimiter):
+    def __init__(self, *, backend: Backend, capacity: int, refill_rate: float, prefix: str = "tb") -> None:
+        if capacity <= 0:
+            raise ValueError("capacity must be positive")
+        if refill_rate <= 0:
+            raise ValueError("refill_rate must be positive")
+        self.backend = backend
+        self.capacity = capacity
+        self.refill_rate = refill_rate
+        self.prefix = prefix
+
+    def enforce(self, key: str, cost: int = 1) -> Decision:
+        if cost <= 0:
+            raise ValueError("cost must be positive")
+        return self.backend.token_bucket_enforce(
+            self._key(key),
+            capacity=self.capacity,
+            refill_rate=self.refill_rate,
+            cost=cost,
+        )
+
+    def _key(self, key: str) -> str:
+        return f"{self.prefix}:{key}"
+
+
+class SlidingWindowLimiter(RateLimiter):
+    def __init__(self, *, backend: Backend, limit: int, period_ms: int, prefix: str = "sw") -> None:
+        if limit <= 0:
+            raise ValueError("limit must be positive")
+        if period_ms <= 0:
+            raise ValueError("period_ms must be positive")
+        self.backend = backend
+        self.limit = limit
+        self.period_ms = period_ms
+        self.prefix = prefix
+
+    def enforce(self, key: str, cost: int = 1) -> Decision:
+        if cost <= 0:
+            raise ValueError("cost must be positive")
+        return self.backend.sliding_window_enforce(
+            self._key(key),
+            limit=self.limit,
+            period_ms=self.period_ms,
+            cost=cost,
+        )
+
+    def _key(self, key: str) -> str:
+        return f"{self.prefix}:{key}"
