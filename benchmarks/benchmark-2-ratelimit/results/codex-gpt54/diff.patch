+import time
+
+import fakeredis
+import pytest
+
+from ratelimit import InMemoryBackend, RedisBackend, SlidingWindowLimiter, TokenBucketLimiter
+
+
+def test_token_bucket_limiter_refills_and_denies() -> None:
+    backend = InMemoryBackend()
+    current_ms = [1_000]
+    backend.now_ms = lambda: current_ms[0]  # type: ignore[method-assign]
+    limiter = TokenBucketLimiter(capacity=5, refill_rate=2.0, backend=backend, namespace="tb-unit")
+
+    first = limiter.enforce("user")
+    second = limiter.enforce("user", cost=4)
+    third = limiter.enforce("user")
+    current_ms[0] += 500
+    fourth = limiter.enforce("user")
+
+    assert first.allowed is True
+    assert first.remaining == 4
+    assert second.allowed is True
+    assert second.remaining == 0
+    assert third.allowed is False
+    assert third.retry_after_ms == 500
+    assert fourth.allowed is True
+
+
+def test_token_bucket_limiter_rejects_invalid_cost() -> None:
+    limiter = TokenBucketLimiter(capacity=2, refill_rate=1.0, backend=InMemoryBackend())
+
+    with pytest.raises(ValueError):
+        limiter.enforce("user", cost=0)
+
+
+def test_sliding_window_limiter_is_exact_across_window_boundary() -> None:
+    backend = InMemoryBackend()
+    current_ms = [1_000]
+    backend.now_ms = lambda: current_ms[0]  # type: ignore[method-assign]
+    limiter = SlidingWindowLimiter(capacity=2, period_ms=1_000, backend=backend, namespace="sw-unit")
+
+    first = limiter.enforce("user")
+    current_ms[0] += 100
+    second = limiter.enforce("user")
+    denied = limiter.enforce("user")
+    current_ms[0] = 2_001
+    allowed_again = limiter.enforce("user")
+
+    assert first.allowed is True
+    assert second.allowed is True
+    assert denied.allowed is False
+    assert denied.retry_after_ms == 900
+    assert allowed_again.allowed is True
+
+
+def test_sliding_window_limiter_supports_weighted_cost() -> None:
+    backend = InMemoryBackend()
+    current_ms = [10_000]
+    backend.now_ms = lambda: current_ms[0]  # type: ignore[method-assign]
+    limiter = SlidingWindowLimiter(capacity=5, period_ms=1_000, backend=backend, namespace="sw-cost")
+
+    first = limiter.enforce("user", cost=3)
+    denied = limiter.enforce("user", cost=3)
+    current_ms[0] += 1_000
+    allowed = limiter.enforce("user", cost=3)
+
+    assert first.allowed is True
+    assert first.remaining == 2
+    assert denied.allowed is False
+    assert denied.retry_after_ms == 1_000
+    assert allowed.allowed is True
+
+
+def test_redis_backend_round_trip_for_both_limiters() -> None:
+    backend = RedisBackend(fakeredis.FakeRedis())
+    token_bucket = TokenBucketLimiter(capacity=2, refill_rate=1.0, backend=backend, namespace="redis-tb")
+    sliding_window = SlidingWindowLimiter(capacity=2, period_ms=500, backend=backend, namespace="redis-sw")
+
+    assert token_bucket.enforce("alpha").allowed is True
+    assert token_bucket.enforce("alpha").allowed is True
+    assert token_bucket.enforce("alpha").allowed is False
+
+    assert sliding_window.enforce("beta").allowed is True
+    assert sliding_window.enforce("beta").allowed is True
+    assert sliding_window.enforce("beta").allowed is False
+    time.sleep(0.55)
+    assert sliding_window.enforce("beta").allowed is True
