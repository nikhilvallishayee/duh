+++ b/ratelimit/limiters/sliding_window.py
@@ -0,0 +1,16 @@
+from ..backends.base import Backend
+from .base import RateLimiter
+from ..types import Decision
+
+class SlidingWindowLimiter(RateLimiter):
+    def __init__(self, backend: Backend, capacity: int, window_size_ms: int):
+        if capacity < 0:
+            raise ValueError("Capacity must be non-negative")
+        if window_size_ms <= 0:
+            raise ValueError("Window size must be positive")
+        self.backend = backend
+        self.capacity = capacity
+        self.window_size_ms = window_size_ms
+
+    def enforce(self, key: str, cost: int = 1) -> Decision:
+        return self.backend.sliding_window(key, self.capacity, self.window_size_ms, cost)
