new file mode 100644
index 0000000..e766ac5
--- /dev/null
+++ b/duh/cli/tdd.py
@@ -0,0 +1,209 @@
+"""``duh tdd`` subcommand — one-shot double-agent TDD run (ADR-076).
+
+Builds a Driver engine and a Navigator engine from the current provider
++ tool set, then drives them through the six-phase red-green-refactor
+flow defined in :mod:`duh.kernel.tdd_mode`.  Designed for CI use: no
+interactive approval, prints a concise phase-by-phase log to stdout,
+exits non-zero if any gate fails.
+
+For the interactive REPL flow, see the ``/tdd`` slash command in
+``duh.cli.slash_commands``.
+"""
+
+from __future__ import annotations
+
+import argparse
+import logging
+import os
+import shlex
+import sys
+from typing import Any
+
+from duh.adapters.approvers import AutoApprover
+from duh.adapters.file_store import FileStore
+from duh.adapters.native_executor import NativeExecutor
+from duh.adapters.simple_compactor import SimpleCompactor
+from duh.agents import AgentDef
+from duh.cli import exit_codes
+from duh.kernel.deps import Deps
+from duh.kernel.engine import Engine, EngineConfig
+from duh.kernel.tdd_mode import DEFAULT_TEST_COMMAND, TddMode, TddState
+from duh.providers.registry import build_model_backend, resolve_provider_name
+from duh.tools.registry import get_all_tools
+
+logger = logging.getLogger("duh")
+
+
+def _resolve_provider_and_model(args: argparse.Namespace) -> tuple[str, str, Any]:
+    """Shared provider-resolution plumbing for the tdd subcommand.
+
+    Returns ``(provider_name, model, call_model)`` on success.  Writes an
+    error to stderr and raises :class:`SystemExit` on failure.
+    """
+
+    def _check_ollama() -> bool:
+        try:
+            import httpx
+            r = httpx.get("http://localhost:11434/api/tags", timeout=2)
+            return r.status_code == 200
+        except Exception:
+            return False
+
+    provider_name = resolve_provider_name(
+        explicit_provider=getattr(args, "provider", None),
+        model=getattr(args, "model", None),
+        check_ollama=_check_ollama,
+    )
+    if not provider_name:
+        sys.stderr.write(
+            "Error: No provider available for `duh tdd`.\n"
+            "  Set ANTHROPIC_API_KEY, OPENAI_API_KEY, or DUH_STUB_PROVIDER=1.\n"
+        )
+        raise SystemExit(exit_codes.PROVIDER_ERROR)
+
+    backend = build_model_backend(provider_name, getattr(args, "model", None))
+    if not backend.ok:
+        sys.stderr.write(f"Error: {backend.error}\n")
+        raise SystemExit(exit_codes.PROVIDER_ERROR)
+    return provider_name, backend.model, backend.call_model
+
+
+def _build_engine(
+    *,
+    agent_type: str,
+    model: str,
+    call_model: Any,
+    tools: list[Any],
+    cwd: str,
+    max_turns: int,
+) -> Engine:
+    """Build a single Engine with the given agent overlay, sharing the
+    caller's tool set + approver.  Driver and Navigator differ only in
+    the system prompt (``agent_type``) and — optionally — the model.
+    """
+    agent_def = AgentDef.from_type(agent_type)
+    executor = NativeExecutor(tools=tools, cwd=cwd)
+    compactor = SimpleCompactor()
+    store = FileStore(cwd=cwd)
+    approver = AutoApprover()  # non-interactive — see ADR-076
+
+    deps = Deps(
+        call_model=call_model,
+        run_tool=executor.run,
+        approve=approver.check,
+        compact=compactor.compact,
+    )
+    config = EngineConfig(
+        model=model,
+        system_prompt=agent_def.system_prompt,
+        tools=tools,
+        max_turns=max_turns,
+        cwd=cwd,
+    )
+    # Same lambda as batch.py — let tools ask which model is running.
+    executor.get_current_model = lambda: config.model
+    return Engine(deps=deps, config=config, session_store=store)
+
+
+def _format_gate(event: dict[str, Any]) -> str:
+    """Render a ``tdd_gate`` event as a single readable line."""
+    phase = event.get("phase", "?")
+    passed = event.get("passed", False)
+    exit_code = event.get("exit_code", "?")
+    marker = "✓" if passed else "✗"
+    return f"  [{phase} gate {marker}] exit={exit_code} gate_passed={passed}"
+
+
+async def run_tdd(args: argparse.Namespace) -> int:
+    """Drive the full six-phase double-agent TDD flow end-to-end.
+
+    Returns 0 on success (``TddState.DONE``), non-zero on any gate
+    failure or phase that didn't advance.
+    """
+    debug = getattr(args, "debug", False)
+    if debug:
+        logging.basicConfig(
+            level=logging.DEBUG, stream=sys.stderr,
+            format="[%(levelname)s] %(name)s: %(message)s",
+        )
+
+    provider_name, model, call_model = _resolve_provider_and_model(args)
+    driver_model = getattr(args, "driver_model", None) or model
+    navigator_model = getattr(args, "navigator_model", None) or model
+
+    cwd = os.getcwd()
+    tools = list(get_all_tools())
+    max_turns = getattr(args, "max_turns", 50) or 50
+
+    # Two Engines, same provider, distinct system prompts (ADR-076).
+    driver = _build_engine(
+        agent_type="coder",
+        model=driver_model,
+        call_model=call_model,
+        tools=tools,
+        cwd=cwd,
+        max_turns=max_turns,
+    )
+    navigator = _build_engine(
+        agent_type="reviewer",
+        model=navigator_model,
+        call_model=call_model,
+        tools=tools,
+        cwd=cwd,
+        max_turns=max_turns,
+    )
+
+    # Parse --test
+    test_cmd_str = getattr(args, "test", None)
+    if test_cmd_str:
+        test_command = shlex.split(test_cmd_str)
+    else:
+        test_command = list(DEFAULT_TEST_COMMAND)
+
+    tdd = TddMode(
+        driver=driver,
+        navigator=navigator,
+        test_command=test_command,
+        cwd=cwd,
+    )
+
+    sys.stdout.write(
+        f"duh tdd — provider={provider_name} "
+        f"driver={driver_model} navigator={navigator_model}\n"
+        f"  test command: {' '.join(test_command)}\n"
+        f"  feature     : {args.feature}\n\n"
+    )
+    sys.stdout.flush()
+
+    async for event in tdd.run_all(args.feature):
+        etype = event.get("type", "")
+        if etype == "tdd_phase":
+            phase = event.get("phase", "?")
+            actor = event.get("actor", "?")
+            sys.stdout.write(f"== {phase} ({actor}) ==\n")
+            sys.stdout.flush()
+        elif etype == "tdd_gate":
+            sys.stdout.write(_format_gate(event) + "\n")
+            if not event.get("passed", False):
+                # Surface stdout/stderr so the user can see why.
+                err_tail = (event.get("stdout", "") + event.get("stderr", ""))[-500:]
+                if err_tail:
+                    sys.stdout.write("    " + err_tail.replace("\n", "\n    ") + "\n")
+            sys.stdout.flush()
+        elif etype == "text_delta" and debug:
+            sys.stderr.write(event.get("text", ""))
+            sys.stderr.flush()
+        elif etype == "error":
+            sys.stderr.write(f"  ! error: {event.get('error', 'unknown')}\n")
+
+    sys.stdout.write("\n" + tdd.format_status() + "\n")
+
+    if tdd.state == TddState.DONE:
+        return exit_codes.SUCCESS
+    # Spec revised but never re-approved, or a gate failed — signal
+    # non-zero but preserve the session state for the user to inspect.
+    sys.stderr.write(
+        f"\nTDD run did not reach DONE (final state: {tdd.state.name}, "
+        f"spec revisions: {tdd.spec_revisions})\n"
+    )
+    return exit_codes.ERROR
diff --git a/duh/kernel/tdd_mode.py b/duh/kernel/tdd_mode.py
new file mode 100644
index 0000000..9a495dd
--- /dev/null
+++ b/duh/kernel/tdd_mode.py
@@ -0,0 +1,673 @@
+"""Double-Agent TDD mode — Driver / Navigator pair-programming harness.
+
+Implements the red-green-refactor flow specified in ADR-076 on top of the
+existing ``Engine`` / ``Deps`` / agent-overlay abstractions.  Two
+``Engine`` instances — the **Driver** (``coder`` overlay) and the
+**Navigator** (``reviewer`` overlay) — are sequenced through six strict
+phases, with a real subprocess test-run acting as the gate between
+phases.
+
+The shape mirrors :class:`duh.kernel.plan_mode.PlanMode`:
+
+    driver = Engine(...)        # coder system prompt
+    navigator = Engine(...)     # reviewer system prompt
+    tdd = TddMode(driver=driver, navigator=navigator)
+
+    # Phase 1 — Navigator drafts the test spec
+    async for event in tdd.spec("cache LRU eviction drops oldest entry"):
+        handle(event)
+
+    # Phase 2 — Driver writes the failing test, runs it, RED-gate fires
+    async for event in tdd.red():
+        handle(event)
+
+    # Phase 3 — Driver writes minimum code, GREEN-gate fires
+    async for event in tdd.green():
+        handle(event)
+
+    # Phases 4–6 — Navigator proposes refactor, Driver applies, Navigator validates
+    async for event in tdd.refactor():
+        handle(event)
+
+A convenience ``run_all()`` coroutine drives every phase end-to-end for
+CLI / CI use.  See ADR-076 for the rationale.
+"""
+
+from __future__ import annotations
+
+import os
+import subprocess
+from dataclasses import dataclass, field
+from enum import Enum, auto
+from typing import Any, AsyncGenerator, Callable
+
+from duh.kernel.engine import Engine
+from duh.kernel.messages import Message
+
+
+# ---------------------------------------------------------------------------
+# State machine
+# ---------------------------------------------------------------------------
+
+
+class TddState(Enum):
+    """Current state of a double-agent TDD session."""
+
+    EMPTY = auto()               # No spec yet
+    SPEC = auto()                # Navigator drafted spec, awaiting approval
+    RED = auto()                 # Driver wrote test, it failed — ready for GREEN
+    GREEN = auto()               # Driver wrote code, test passes — ready for REFACTOR
+    REFACTOR_PLAN = auto()       # Navigator proposed refactor — ready for APPLY
+    REFACTOR_APPLY = auto()      # Driver applied refactor — ready for VALIDATE
+    DONE = auto()                # Navigator validated — full cycle complete
+
+
+# Ordered list of phases for history / renderer consumption.
+PHASE_ORDER = [
+    TddState.SPEC,
+    TddState.RED,
+    TddState.GREEN,
+    TddState.REFACTOR_PLAN,
+    TddState.REFACTOR_APPLY,
+    TddState.DONE,
+]
+
+
+# ---------------------------------------------------------------------------
+# Prompt templates (single source of truth — referenced in unit tests)
+# ---------------------------------------------------------------------------
+
+SPEC_PROMPT = (
+    "You are the NAVIGATOR in a TDD pair. Draft a tight, minimal test "
+    "specification for the feature below. Output ONLY:\n"
+    "  - one sentence describing the behaviour under test\n"
+    "  - a bullet list of the concrete assertions the test must make\n"
+    "  - the file path where the test should live\n"
+    "Do NOT write any code or call any tools yet.\n\n"
+    "Feature: "
+)
+
+RED_PROMPT = (
+    "You are the DRIVER in a TDD pair. The Navigator has approved this "
+    "test specification:\n\n"
+    "---\n{spec}\n---\n\n"
+    "Write the FAILING test now. Use the Write / Edit tool to create the "
+    "test file. Do NOT write any production code — the test MUST fail "
+    "because the behaviour is not yet implemented. A test that passes on "
+    "the first run means the spec was too loose and we will start over."
+)
+
+GREEN_PROMPT = (
+    "You are the DRIVER. The test you just wrote is failing as expected "
+    "(the RED phase passed). Now write the MINIMUM production code "
+    "needed to make the test pass. Constraints:\n"
+    "  - Do NOT refactor existing code — that is the next phase\n"
+    "  - Do NOT add features the test does not exercise\n"
+    "  - Do NOT rename, reorganise, or re-style code outside the diff\n"
+    "When you think the test will pass, stop. The harness re-runs the "
+    "test automatically."
+)
+
+REFACTOR_PROPOSE_PROMPT = (
+    "You are the NAVIGATOR. The Driver's test is now GREEN. Read the "
+    "code the Driver just wrote and propose ONE concrete refactor that "
+    "improves clarity or removes duplication without changing behaviour. "
+    "Output ONLY:\n"
+    "  - the file(s) to modify\n"
+    "  - a bullet list of the exact changes\n"
+    "  - a one-line justification\n"
+    "Do NOT apply the refactor — the Driver will do that in the next phase."
+)
+
+REFACTOR_APPLY_PROMPT = (
+    "You are the DRIVER. Apply the Navigator's refactor VERBATIM — no "
+    "scope creep, no additional 'while I'm here' edits. Here is the "
+    "Navigator's refactor plan:\n\n"
+    "---\n{refactor_plan}\n---\n\n"
+    "Apply every bullet. Do not skip items. When done, stop — the "
+    "harness re-runs the test suite."
+)
+
+VALIDATE_PROMPT = (
+    "You are the NAVIGATOR. The Driver has applied the refactor and the "
+    "test suite passed. Your job is to VALIDATE: confirm that each "
+    "bullet in your refactor plan was applied, and that nothing extra "
+    "was changed. Output a short structured summary:\n"
+    "  - plan item → 'applied' | 'missing' | 'partially applied'\n"
+    "  - any unexpected changes you spotted\n"
+    "  - final verdict: APPROVED or NEEDS REWORK"
+)
+
+
+# Default test command — overridable via TddMode(test_command=...).
+DEFAULT_TEST_COMMAND: list[str] = ["pytest", "-x", "--no-header"]
+
+
+# ---------------------------------------------------------------------------
+# History entries + gate result
+# ---------------------------------------------------------------------------
+
+
+@dataclass
+class GateResult:
+    """Outcome of running the test command at a RED/GREEN/VALIDATE gate."""
+
+    phase: str                   # "RED" | "GREEN" | "VALIDATE"
+    exit_code: int
+    stdout: str
+    stderr: str
+
+    @property
+    def test_passed(self) -> bool:
+        """True if the test command exited with code 0."""
+        return self.exit_code == 0
+
+    @property
+    def gate_passed(self) -> bool:
+        """True if the gate's expected outcome held.
+
+        RED expects the test to FAIL (non-zero exit).
+        GREEN and VALIDATE expect the test to PASS (zero exit).
+        """
+        if self.phase == "RED":
+            return not self.test_passed
+        return self.test_passed
+
+
+@dataclass
+class PhaseResult:
+    """One entry per phase transition, in ``TddMode.history`` order."""
+
+    phase: str                   # e.g. "SPEC", "RED", "GREEN", ...
+    actor: str                   # "navigator" | "driver"
+    text: str                    # the agent's final assistant text
+    gate: GateResult | None = None
+
+
+# ---------------------------------------------------------------------------
+# Test runner — pluggable for tests
+# ---------------------------------------------------------------------------
+
+
+TestRunnerFn = Callable[[list[str], str], GateResult]
+
+
+def _default_test_runner(cmd: list[str], cwd: str) -> GateResult:
+    """Run ``cmd`` in ``cwd`` and capture stdout/stderr/exit code.
+
+    Returns a :class:`GateResult` with ``phase`` left blank — the caller
+    fills it in with the current phase name.
+    """
+    proc = subprocess.run(
+        cmd,
+        cwd=cwd,
+        capture_output=True,
+        text=True,
+        check=False,
+    )
+    return GateResult(
+        phase="",
+        exit_code=proc.returncode,
+        stdout=proc.stdout,
+        stderr=proc.stderr,
+    )
+
+
+# ---------------------------------------------------------------------------
+# TddMode — the orchestrator
+# ---------------------------------------------------------------------------
+
+
+class TddMode:
+    """Double-agent driver/navigator TDD state machine.
+
+    Owns nothing the two Engines already own (messages, tools, model
+    choice).  Owns only the TDD-specific state: which phase we are in,
+    the Navigator's spec, the refactor plan, and the per-phase history.
+
+    Raises ``ValueError`` on every out-of-order transition.  The tests in
+    ``tests/unit/test_tdd_mode.py`` cover each guard explicitly.
+    """
+
+    def __init__(
+        self,
+        *,
+        driver: Engine,
+        navigator: Engine,
+        test_command: list[str] | None = None,
+        test_runner: TestRunnerFn | None = None,
+        cwd: str | None = None,
+    ) -> None:
+        self._driver = driver
+        self._navigator = navigator
+        self._test_command = list(test_command) if test_command else list(DEFAULT_TEST_COMMAND)
+        self._test_runner: TestRunnerFn = test_runner or _default_test_runner
+        self._cwd = cwd or os.getcwd()
+
+        self._state: TddState = TddState.EMPTY
+        self._description: str = ""
+        self._spec: str = ""
+        self._refactor_plan: str = ""
+        self._history: list[PhaseResult] = []
+        self._spec_revisions: int = 0
+
+    # -------------------------------------------------------- read-only props
+
+    @property
+    def state(self) -> TddState:
+        return self._state
+
+    @property
+    def description(self) -> str:
+        return self._description
+
+    @property
+    def spec(self) -> str:
+        return self._spec
+
+    @property
+    def refactor_plan(self) -> str:
+        return self._refactor_plan
+
+    @property
+    def history(self) -> list[PhaseResult]:
+        return list(self._history)
+
+    @property
+    def test_command(self) -> list[str]:
+        return list(self._test_command)
+
+    @property
+    def spec_revisions(self) -> int:
+        """Number of times the Navigator re-drafted the spec because RED
+        unexpectedly passed.  Observable for tests / UX.
+        """
+        return self._spec_revisions
+
+    def clear(self) -> None:
+        """Reset to the initial empty state."""
+        self._state = TddState.EMPTY
+        self._description = ""
+        self._spec = ""
+        self._refactor_plan = ""
+        self._history = []
+        self._spec_revisions = 0
+
+    # --------------------------------------------------------------- helpers
+
+    @staticmethod
+    def _extract_assistant_text(event: dict[str, Any]) -> str:
+        """Pull clean text off an ``assistant`` event, tolerating the
+        several Message-shape variants the kernel emits.
+        """
+        msg = event.get("message")
+        if msg is None:
+            return ""
+        text_attr = getattr(msg, "text", None)
+        if isinstance(text_attr, str):
+            return text_attr
+        content = getattr(msg, "content", None)
+        if isinstance(content, str):
+            return content
+        if isinstance(content, list):
+            parts: list[str] = []
+            for block in content:
+                if isinstance(block, dict) and block.get("type") == "text":
+                    parts.append(block.get("text", "") or "")
+                else:
+                    btext = getattr(block, "text", None)
+                    if isinstance(btext, str):
+                        parts.append(btext)
+            return "".join(parts)
+        return ""
+
+    async def _run_engine(
+        self,
+        engine: Engine,
+        prompt: str,
+        *,
+        tool_choice: str | None,
+    ) -> AsyncGenerator[dict[str, Any], None]:
+        """Run a single phase on the given engine, yielding its events
+        plus capturing the final assistant text into ``self._last_text``.
+
+        ``tool_choice`` is restored on the engine's config even if the
+        caller breaks out early.
+        """
+        config = engine._config  # intentional — same seam PlanMode uses
+        original = config.tool_choice
+        config.tool_choice = tool_choice
+
+        delta_text: list[str] = []
+        assistant_text = ""
+
+        try:
+            async for event in engine.run(prompt):
+                etype = event.get("type", "")
+                if etype == "text_delta":
+                    delta_text.append(event.get("text", ""))
+                elif etype == "assistant":
+                    extracted = self._extract_assistant_text(event)
+                    if extracted:
+                        assistant_text = extracted
+                yield event
+        finally:
+            config.tool_choice = original
+
+        self._last_text = assistant_text or "".join(delta_text)
+
+    def _run_gate(self, phase_name: str) -> GateResult:
+        """Execute the test command and return a :class:`GateResult`
+        tagged with ``phase_name``.
+        """
+        result = self._test_runner(list(self._test_command), self._cwd)
+        return GateResult(
+            phase=phase_name,
+            exit_code=result.exit_code,
+            stdout=result.stdout,
+            stderr=result.stderr,
+        )
+
+    # ----------------------------------------------------------------- phases
+
+    async def draft_spec(
+        self,
+        description: str,
+    ) -> AsyncGenerator[dict[str, Any], None]:
+        """**Phase 1** — Navigator drafts the test spec.
+
+        Runs the Navigator engine with ``tool_choice="none"`` (no writes),
+        captures the assistant text as ``self.spec``, and advances to
+        :attr:`TddState.SPEC`.  Callable only from ``EMPTY``.
+        """
+        if self._state not in (TddState.EMPTY,):
+            raise ValueError(
+                f"Cannot draft spec: state is {self._state.name}, expected EMPTY"
+            )
+        self._description = description
+
+        yield {"type": "tdd_phase", "phase": "SPEC", "actor": "navigator"}
+
+        async for event in self._run_engine(
+            self._navigator,
+            SPEC_PROMPT + description,
+            tool_choice="none",
+        ):
+            yield event
+
+        self._spec = self._last_text.strip()
+        self._history.append(
+            PhaseResult(phase="SPEC", actor="navigator", text=self._spec)
+        )
+        self._state = TddState.SPEC
+
+    async def red(self) -> AsyncGenerator[dict[str, Any], None]:
+        """**Phase 2** — Driver writes the failing test, we run it.
+
+        Must be called from :attr:`TddState.SPEC`.  Runs the test command
+        as a hard gate: if the test unexpectedly passes, the Navigator
+        is invited to revise the spec (``state`` reverts to ``EMPTY`` so
+        the caller can call :meth:`spec` again) and ``spec_revisions``
+        is incremented.  Otherwise advances to :attr:`TddState.RED`.
+        """
+        if self._state != TddState.SPEC:
+            raise ValueError(
+                f"Cannot run RED: state is {self._state.name}, expected SPEC"
+            )
+
+        yield {"type": "tdd_phase", "phase": "RED", "actor": "driver"}
+
+        prompt = RED_PROMPT.format(spec=self._spec)
+        async for event in self._run_engine(
+            self._driver,
+            prompt,
+            tool_choice=None,
+        ):
+            yield event
+        driver_text = self._last_text
+
+        gate = self._run_gate("RED")
+        yield {
+            "type": "tdd_gate",
+            "phase": "RED",
+            "passed": gate.gate_passed,
+            "test_passed": gate.test_passed,
+            "exit_code": gate.exit_code,
+            "stdout": gate.stdout,
+            "stderr": gate.stderr,
+        }
+        self._history.append(
+            PhaseResult(phase="RED", actor="driver", text=driver_text, gate=gate)
+        )
+
+        if gate.gate_passed:
+            self._state = TddState.RED
+        else:
+            # Test passed at RED — spec was too loose. Send the Navigator
+            # back to re-draft. State reverts so the caller can call
+            # .spec() again with a tightened description.
+            self._spec_revisions += 1
+            self._state = TddState.EMPTY
+            self._spec = ""
+
+    async def green(self) -> AsyncGenerator[dict[str, Any], None]:
+        """**Phase 3** — Driver writes the minimum code; we re-run.
+
+        Must be called from :attr:`TddState.RED`.
+        """
+        if self._state != TddState.RED:
+            raise ValueError(
+                f"Cannot run GREEN: state is {self._state.name}, expected RED"
+            )
+
+        yield {"type": "tdd_phase", "phase": "GREEN", "actor": "driver"}
+
+        async for event in self._run_engine(
+            self._driver,
+            GREEN_PROMPT,
+            tool_choice=None,
+        ):
+            yield event
+        driver_text = self._last_text
+
+        gate = self._run_gate("GREEN")
+        yield {
+            "type": "tdd_gate",
+            "phase": "GREEN",
+            "passed": gate.gate_passed,
+            "test_passed": gate.test_passed,
+            "exit_code": gate.exit_code,
+            "stdout": gate.stdout,
+            "stderr": gate.stderr,
+        }
+        self._history.append(
+            PhaseResult(phase="GREEN", actor="driver", text=driver_text, gate=gate)
+        )
+
+        if gate.gate_passed:
+            self._state = TddState.GREEN
+        # On failure we stay in RED — caller can retry green() after
+        # investigating. We do NOT silently advance.
+
+    async def propose_refactor(self) -> AsyncGenerator[dict[str, Any], None]:
+        """**Phase 4** — Navigator proposes a refactor (read-only).
+
+        Must be called from :attr:`TddState.GREEN`.
+        """
+        if self._state != TddState.GREEN:
+            raise ValueError(
+                f"Cannot propose refactor: state is {self._state.name}, expected GREEN"
+            )
+
+        yield {"type": "tdd_phase", "phase": "REFACTOR_PLAN", "actor": "navigator"}
+
+        async for event in self._run_engine(
+            self._navigator,
+            REFACTOR_PROPOSE_PROMPT,
+            tool_choice="none",
+        ):
+            yield event
+
+        self._refactor_plan = self._last_text.strip()
+        self._history.append(
+            PhaseResult(
+                phase="REFACTOR_PLAN",
+                actor="navigator",
+                text=self._refactor_plan,
+            )
+        )
+        self._state = TddState.REFACTOR_PLAN
+
+    async def refactor_apply(self) -> AsyncGenerator[dict[str, Any], None]:
+        """**Phase 5** — Driver applies the Navigator's refactor.
+
+        Must be called from :attr:`TddState.REFACTOR_PLAN`.  The prompt
+        literally includes :attr:`refactor_plan`, and we assert that it
+        is non-empty — a Driver cannot apply a refactor that was never
+        proposed.
+        """
+        if self._state != TddState.REFACTOR_PLAN:
+            raise ValueError(
+                f"Cannot apply refactor: state is {self._state.name}, "
+                f"expected REFACTOR_PLAN"
+            )
+        if not self._refactor_plan:
+            raise ValueError(
+                "Cannot apply refactor: Navigator's refactor_plan is empty"
+            )
+
+        yield {"type": "tdd_phase", "phase": "REFACTOR_APPLY", "actor": "driver"}
+
+        prompt = REFACTOR_APPLY_PROMPT.format(refactor_plan=self._refactor_plan)
+        async for event in self._run_engine(
+            self._driver,
+            prompt,
+            tool_choice=None,
+        ):
+            yield event
+        driver_text = self._last_text
+
+        self._history.append(
+            PhaseResult(
+                phase="REFACTOR_APPLY",
+                actor="driver",
+                text=driver_text,
+            )
+        )
+        self._state = TddState.REFACTOR_APPLY
+
+    async def validate(self) -> AsyncGenerator[dict[str, Any], None]:
+        """**Phase 6** — Navigator validates refactor landed + tests pass.
+
+        Must be called from :attr:`TddState.REFACTOR_APPLY`.  Re-runs
+        the test command; only on a passing test does state advance to
+        :attr:`TddState.DONE`.
+        """
+        if self._state != TddState.REFACTOR_APPLY:
+            raise ValueError(
+                f"Cannot validate: state is {self._state.name}, "
+                f"expected REFACTOR_APPLY"
+            )
+
+        yield {"type": "tdd_phase", "phase": "VALIDATE", "actor": "navigator"}
+
+        async for event in self._run_engine(
+            self._navigator,
+            VALIDATE_PROMPT,
+            tool_choice=None,
+        ):
+            yield event
+        navigator_text = self._last_text
+
+        gate = self._run_gate("VALIDATE")
+        yield {
+            "type": "tdd_gate",
+            "phase": "VALIDATE",
+            "passed": gate.gate_passed,
+            "test_passed": gate.test_passed,
+            "exit_code": gate.exit_code,
+            "stdout": gate.stdout,
+            "stderr": gate.stderr,
+        }
+        self._history.append(
+            PhaseResult(
+                phase="VALIDATE",
+                actor="navigator",
+                text=navigator_text,
+                gate=gate,
+            )
+        )
+
+        if gate.gate_passed:
+            self._state = TddState.DONE
+        # If the refactor broke the tests we stay at REFACTOR_APPLY so
+        # the caller can fix it. Again: no silent advancement.
+
+    # --------------------------------------------------------------- refactor
+
+    async def refactor(self) -> AsyncGenerator[dict[str, Any], None]:
+        """Convenience: run phases 4 → 5 → 6 in sequence from GREEN."""
+        async for event in self.propose_refactor():
+            yield event
+        if self._state != TddState.REFACTOR_PLAN:
+            return
+        async for event in self.refactor_apply():
+            yield event
+        if self._state != TddState.REFACTOR_APPLY:
+            return
+        async for event in self.validate():
+            yield event
+
+    async def run_all(
+        self,
+        description: str,
+    ) -> AsyncGenerator[dict[str, Any], None]:
+        """Drive every phase end-to-end for CLI / CI use.
+
+        Equivalent to ``spec() → red() → green() → refactor()`` but short-
+        circuits on any gate failure (state stops advancing).
+        """
+        async for event in self.draft_spec(description):
+            yield event
+        if self._state != TddState.SPEC:
+            return
+        async for event in self.red():
+            yield event
+        if self._state != TddState.RED:
+            # RED gate failed (test passed) — caller may loop back to spec.
+            return
+        async for event in self.green():
+            yield event
+        if self._state != TddState.GREEN:
+            return
+        async for event in self.refactor():
+            yield event
+
+    # --------------------------------------------------------- pretty-printer
+
+    def format_status(self) -> str:
+        """Human-readable one-screen summary of the session."""
+        lines = [f"TDD state: {self._state.name}"]
+        if self._description:
+            lines.append(f"  feature: {self._description}")
+        if self._spec:
+            lines.append("  spec:")
+            for ln in self._spec.splitlines():
+                lines.append(f"    {ln}")
+        if self._spec_revisions:
+            lines.append(f"  spec revisions: {self._spec_revisions}")
+        if self._refactor_plan:
+            lines.append("  refactor plan:")
+            for ln in self._refactor_plan.splitlines():
+                lines.append(f"    {ln}")
+        if self._history:
+            lines.append("  history:")
+            for entry in self._history:
+                suffix = ""
+                if entry.gate is not None:
+                    suffix = (
+                        f"  [gate: exit={entry.gate.exit_code} "
+                        f"{'PASSED' if entry.gate.gate_passed else 'FAILED'}]"
+                    )
+                lines.append(f"    - {entry.phase} ({entry.actor}){suffix}")
+        return "\n".join(lines)
