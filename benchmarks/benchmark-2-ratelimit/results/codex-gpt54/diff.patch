+import asyncio
+
+import pytest
+
+from ratelimit import InMemoryBackend, RateLimitExceeded, SlidingWindowLimiter, TokenBucketLimiter, rate_limit
+
+
+def test_rate_limit_decorator_for_sync_function() -> None:
+    limiter = TokenBucketLimiter(capacity=1, refill_rate=1.0, backend=InMemoryBackend(), namespace="decorator-sync")
+
+    @rate_limit(limiter, key_fn=lambda user_id: user_id)
+    def greet(user_id: str) -> str:
+        return f"hi {user_id}"
+
+    assert greet("alice") == "hi alice"
+    with pytest.raises(RateLimitExceeded):
+        greet("alice")
+
+
+@pytest.mark.asyncio
+async def test_rate_limit_decorator_for_async_function() -> None:
+    limiter = SlidingWindowLimiter(capacity=1, period_ms=1_000, backend=InMemoryBackend(), namespace="decorator-async")
+
+    @rate_limit(limiter, key_fn=lambda user_id: user_id)
+    async def greet(user_id: str) -> str:
+        await asyncio.sleep(0)
+        return f"hi {user_id}"
+
+    assert await greet("alice") == "hi alice"
+    with pytest.raises(RateLimitExceeded):
+        await greet("alice")
+
+
+def test_rate_limit_decorator_rejects_async_key_fn_for_sync_function() -> None:
+    limiter = TokenBucketLimiter(capacity=1, refill_rate=1.0, backend=InMemoryBackend(), namespace="decorator-key")
+
+    async def async_key(name: str) -> str:
+        return name
+
+    @rate_limit(limiter, key_fn=async_key)
+    def greet(name: str) -> str:
+        return name
+
+    with pytest.raises(TypeError):
+        greet("bob")
