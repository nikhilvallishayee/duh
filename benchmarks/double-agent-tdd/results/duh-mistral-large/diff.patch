+# ---------------------------------------------------------------------------
+# TDD flow phase transitions
+# ---------------------------------------------------------------------------
+
+class TestTDDFlow:
+    @pytest.mark.asyncio
+    async def test_full_tdd_flow(self):
+        """Test the full TDD flow with all phases completing successfully."""
+        engine = _make_engine()
+        tdd = TDDPlanMode(engine)
+        
+        # Mock the test run to fail initially, then pass
+        with patch.object(tdd, '_run_test') as mock_run_test:
+            mock_run_test.side_effect = [
+                "=== FAIL: test_auth.py::TestAuth::test_new_feature\nAssertionError: False is not true",  # RED phase
+                "=== 1 passed in 0.12s",  # GREEN phase
+                "=== 1 passed in 0.12s"   # VALIDATE phase
+            ]
+            
+            events = await _collect_events(tdd.run("Add new feature to auth module"))
+        
+        # Check phase transitions
+        assert tdd.current_phase == TDDPhase.VALIDATE
+        assert len(tdd.steps) == 6  # All phases completed
+        
+        # Check each phase was completed
+        for step in tdd.steps:
+            assert step.done is True
+        
+        # Check task description was set
+        assert tdd.task_description == "Add new feature to auth module"
+        
+        # Check events include TDD-specific types
+        event_types = [e.get("type") for e in events]
+        assert "tdd_phase" in event_types
+        assert "tdd_output" in event_types
+        assert "tdd_complete" in event_types
+
+    @pytest.mark.asyncio
+    async def test_test_passes_unexpectedly(self):
