diff --git a/duh/tdd.py b/duh/tdd.py
new file mode 100644
index 0000000..810a64a
--- /dev/null
+++ b/duh/tdd.py
@@ -0,0 +1,278 @@
+from __future__ import annotations
+
+import argparse
+import asyncio
+import os
+from dataclasses import dataclass, field
+from enum import Enum
+from typing import Awaitable, Callable
+
+from duh.agents import AgentResult, run_agent
+from typing import Any
+
+
+class TDDPhase(str, Enum):
+    NAVIGATOR_SPEC = "navigator_spec"
+    DRIVER_RED = "driver_red"
+    DRIVER_GREEN = "driver_green"
+    NAVIGATOR_REFACTOR = "navigator_refactor"
+    DRIVER_REFACTOR = "driver_refactor"
+    NAVIGATOR_VALIDATE = "navigator_validate"
+
+
+@dataclass
+class PhaseRecord:
+    phase: TDDPhase
+    actor: str
+    summary: str
+    test_exit_code: int | None = None
+    test_output: str = ""
+
+
+@dataclass
+class TDDOutcome:
+    success: bool
+    status: str
+    phases: list[PhaseRecord] = field(default_factory=list)
+
+
+AgentRunner = Callable[..., Awaitable[AgentResult]]
+TestRunner = Callable[[str, str], Awaitable[tuple[int, str]]]
+
+
+def _default_test_runner(command: str, cwd: str) -> Awaitable[tuple[int, str]]:
+    return _run_test_command(command, cwd)
+
+
+async def _run_test_command(command: str, cwd: str) -> tuple[int, str]:
+    proc = await asyncio.create_subprocess_shell(
+        command,
+        cwd=cwd,
+        stdout=asyncio.subprocess.PIPE,
+        stderr=asyncio.subprocess.STDOUT,
+    )
+    stdout, _ = await proc.communicate()
+    return proc.returncode or 0, stdout.decode("utf-8", errors="replace")
+
+
+class DoubleAgentTDDSession:
+    def __init__(
+        self,
+        *,
+        task: str,
+        test_command: str,
+        deps: Any = None,
+        cwd: str = ".",
+        driver_agent_type: str = "coder",
+        navigator_agent_type: str = "reviewer",
+        driver_model: str = "inherit",
+        navigator_model: str = "inherit",
+        parent_model: str = "",
+        agent_runner: AgentRunner = run_agent,
+        test_runner: TestRunner = _default_test_runner,
+    ) -> None:
+        self.task = task
+        self.test_command = test_command
+        self.deps = deps
+        self.cwd = cwd
+        self.driver_agent_type = driver_agent_type
+        self.navigator_agent_type = navigator_agent_type
+        self.driver_model = driver_model
+        self.navigator_model = navigator_model
+        self.parent_model = parent_model
+        self.agent_runner = agent_runner
+        self.test_runner = test_runner
+        self._phases: list[PhaseRecord] = []
+
+    @property
+    def phases(self) -> list[PhaseRecord]:
+        return list(self._phases)
+
+    async def _run_navigator(self, phase: TDDPhase, prompt: str) -> AgentResult:
+        return await self.agent_runner(
+            prompt=prompt,
+            agent_type=self.navigator_agent_type,
+            model=self.navigator_model,
+            parent_model=self.parent_model,
+            deps=self.deps,
+            cwd=self.cwd,
+        )
+
+    async def _run_driver(self, phase: TDDPhase, prompt: str) -> AgentResult:
+        return await self.agent_runner(
+            prompt=prompt,
+            agent_type=self.driver_agent_type,
+            model=self.driver_model,
+            parent_model=self.parent_model,
+            deps=self.deps,
+            cwd=self.cwd,
+        )
+
+    def _record(
+        self,
+        phase: TDDPhase,
+        actor: str,
+        summary: str,
+        *,
+        test_exit_code: int | None = None,
+        test_output: str = "",
+    ) -> None:
+        self._phases.append(
+            PhaseRecord(
+                phase=phase,
+                actor=actor,
+                summary=summary,
+                test_exit_code=test_exit_code,
+                test_output=test_output,
+            )
+        )
+
+    async def run(self) -> TDDOutcome:
+        spec = await self._run_navigator(
+            TDDPhase.NAVIGATOR_SPEC,
+            (
+                "Draft a tight TDD test spec for this task. State the expected behavior, "
+                "the failure target, and what the RED test should prove.\n\n"
+                f"Task: {self.task}\n"
+                f"Test command: {self.test_command}\n"
+            ),
+        )
+        self._record(TDDPhase.NAVIGATOR_SPEC, "navigator", spec.result_text or spec.error)
+        if spec.is_error:
+            return TDDOutcome(False, "navigator_spec_error", self.phases)
+
+        red = await self._run_driver(
+            TDDPhase.DRIVER_RED,
+            (
+                "Write the failing test for this spec. Do only the RED step. "
+                "Do not make production code pass yet.\n\n"
+                f"Task: {self.task}\n"
+                f"Navigator spec:\n{spec.result_text}\n"
+                f"Test command to verify RED: {self.test_command}\n"
+            ),
+        )
+        red_code, red_output = await self.test_runner(self.test_command, self.cwd)
+        self._record(
+            TDDPhase.DRIVER_RED,
+            "driver",
+            red.result_text or red.error,
+            test_exit_code=red_code,
+            test_output=red_output,
+        )
+        if red.is_error:
+            return TDDOutcome(False, "driver_red_error", self.phases)
+        if red_code == 0:
+            revision = await self._run_navigator(
+                TDDPhase.NAVIGATOR_SPEC,
+                (
+                    "The RED test unexpectedly passed. Tighten the spec so the failure is distinct.\n\n"
+                    f"Original task: {self.task}\n"
+                    f"Previous spec:\n{spec.result_text}\n"
+                    f"RED test output:\n{red_output}\n"
+                ),
+            )
+            self._record(TDDPhase.NAVIGATOR_SPEC, "navigator", revision.result_text or revision.error)
+            return TDDOutcome(False, "red_not_failing", self.phases)
+
+        green = await self._run_driver(
+            TDDPhase.DRIVER_GREEN,
+            (
+                "Make the RED test pass with the minimum production change. Do not refactor yet.\n\n"
+                f"Task: {self.task}\n"
+                f"Navigator spec:\n{spec.result_text}\n"
+                f"RED failure output:\n{red_output}\n"
+                f"Test command to verify GREEN: {self.test_command}\n"
+            ),
+        )
+        green_code, green_output = await self.test_runner(self.test_command, self.cwd)
+        self._record(
+            TDDPhase.DRIVER_GREEN,
+            "driver",
+            green.result_text or green.error,
+            test_exit_code=green_code,
+            test_output=green_output,
+        )
+        if green.is_error:
+            return TDDOutcome(False, "driver_green_error", self.phases)
+        if green_code != 0:
+            return TDDOutcome(False, "green_failed", self.phases)
+
+        refactor = await self._run_navigator(
+            TDDPhase.NAVIGATOR_REFACTOR,
+            (
+                "Tests are GREEN. Propose one behavior-preserving refactor to improve the code. "
+                "Be concrete about what the Driver should change.\n\n"
+                f"Task: {self.task}\n"
+                f"Navigator spec:\n{spec.result_text}\n"
+                f"GREEN result:\n{green.result_text}\n"
+            ),
+        )
+        self._record(TDDPhase.NAVIGATOR_REFACTOR, "navigator", refactor.result_text or refactor.error)
+        if refactor.is_error:
+            return TDDOutcome(False, "navigator_refactor_error", self.phases)
+
+        driver_refactor = await self._run_driver(
+            TDDPhase.DRIVER_REFACTOR,
+            (
+                "Apply the Navigator's refactor now. Preserve behavior and keep tests green.\n\n"
+                f"Task: {self.task}\n"
+                f"Refactor proposal:\n{refactor.result_text}\n"
+            ),
+        )
+        self._record(TDDPhase.DRIVER_REFACTOR, "driver", driver_refactor.result_text or driver_refactor.error)
+        if driver_refactor.is_error:
+            return TDDOutcome(False, "driver_refactor_error", self.phases)
+
+        validate_code, validate_output = await self.test_runner(self.test_command, self.cwd)
+        validation = await self._run_navigator(
+            TDDPhase.NAVIGATOR_VALIDATE,
+            (
+                "Validate that the refactor landed cleanly and that tests still pass. "
+                "Call out whether the refactor suggestion appears applied.\n\n"
+                f"Task: {self.task}\n"
+                f"Refactor proposal:\n{refactor.result_text}\n"
+                f"Driver refactor result:\n{driver_refactor.result_text}\n"
+                f"Validation test exit code: {validate_code}\n"
+                f"Validation test output:\n{validate_output}\n"
+            ),
+        )
+        self._record(
+            TDDPhase.NAVIGATOR_VALIDATE,
+            "navigator",
+            validation.result_text or validation.error,
+            test_exit_code=validate_code,
+            test_output=validate_output,
+        )
+        if validation.is_error:
+            return TDDOutcome(False, "navigator_validate_error", self.phases)
+        if validate_code != 0:
+            return TDDOutcome(False, "validation_failed", self.phases)
+        return TDDOutcome(True, "completed", self.phases)
+
+
+def format_tdd_outcome(outcome: TDDOutcome) -> str:
+    lines = [f"Double-agent TDD: {outcome.status}"]
+    for record in outcome.phases:
+        lines.append(f"- {record.phase.value}: {record.actor}")
+        if record.summary:
+            lines.append(f"  {record.summary}")
+        if record.test_exit_code is not None:
+            lines.append(f"  test_exit_code={record.test_exit_code}")
+    return "\n".join(lines)
+
+
+async def run_tdd_command(args: argparse.Namespace) -> int:
+    session = DoubleAgentTDDSession(
+        task=args.task,
+        test_command=args.test_command,
+        deps=None,
+        cwd=os.getcwd(),
+        driver_agent_type=args.driver_agent_type,
+        navigator_agent_type=args.navigator_agent_type,
+        driver_model=args.driver_model,
+        navigator_model=args.navigator_model,
+        parent_model=args.model or "",
+    )
+    outcome = await session.run()
+    print(format_tdd_outcome(outcome))
+    return 0 if outcome.success else 1
