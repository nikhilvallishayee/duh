+        ),
+    )
+    tdd_parser.add_argument("task", type=str, help="Task description for the Driver/Navigator pair.")
+    tdd_parser.add_argument(
+        "--test-command",
+        type=str,
+        required=True,
+        help="Shell command used to validate RED, GREEN, and final validation.",
+    )
+    tdd_parser.add_argument(
+        "--driver-model",
+        type=str,
+        default="inherit",
+        help="Driver child-agent model tier or literal model name (default: inherit).",
+    )
+    tdd_parser.add_argument(
+        "--navigator-model",
+        type=str,
+        default="inherit",
+        help="Navigator child-agent model tier or literal model name (default: inherit).",
+    )
+    tdd_parser.add_argument(
+        "--driver-max-turns",
+        type=int,
+        default=50,
+        help="Maximum turns for each Driver phase (default: 50).",
+    )
+    tdd_parser.add_argument(
+        "--navigator-max-turns",
+        type=int,
+        default=50,
+        help="Maximum turns for each Navigator phase (default: 50).",
+    )
+    tdd_parser.add_argument(
+        "--max-red-revisions",
+        type=int,
+        default=2,
+        help="How many times the Navigator may tighten the spec if RED passes unexpectedly.",
+    )
+    tdd_parser.add_argument(
+        "--shell",
+        type=str,
+        choices=["auto", "bash", "powershell"],
+        default="auto",
+        help="Shell backend used to run the test command (default: auto).",
+    )
+
     bridge_parser = subparsers.add_parser("bridge", help="Start the remote bridge server.")
     bridge_sub = bridge_parser.add_subparsers(dest="bridge_command", required=True)
     start_parser = bridge_sub.add_parser("start", help="Start the WebSocket bridge server.")
